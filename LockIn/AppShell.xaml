<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="LockIn.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:LockIn.Views"
    Title="LockIn"
    Shell.TabBarSelectedColor="{StaticResource ForgeAccent}"
    Shell.TabBarUnselectedColor="{AppThemeBinding Light={StaticResource LightMuted}, Dark={StaticResource ForgeTextSecondary}}"
    Shell.TabBarBackgroundColor="{AppThemeBinding Light={StaticResource LightSurface}, Dark={StaticResource ForgeSurface}}">

    <TabBar>
        <ShellContent Title="Träna"
                      Icon="tab_train.png"
                      Route="TrainPage"
                      ContentTemplate="{DataTemplate views:TrainPage}" />
        <ShellContent Title="Historik"
                      Icon="tab_history.png"
                      Route="HistoryPage"
                      ContentTemplate="{DataTemplate views:HistoryPage}" />
        <ShellContent Title="Bibliotek"
                      Icon="tab_library.png"
                      Route="LibraryPage"
                      ContentTemplate="{DataTemplate views:LibraryPage}" />
        <ShellContent Title="Kropp"
                      Icon="ic_ruler.png"
                      Route="KroppPage"
                      ContentTemplate="{DataTemplate views:KroppPage}" />
    </TabBar>

</Shell>
