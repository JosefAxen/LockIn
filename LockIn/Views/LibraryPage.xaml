<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:LockIn.ViewModels"
             xmlns:models="clr-namespace:LockIn.Models"
             xmlns:data="clr-namespace:LockIn.Data"
             xmlns:views="clr-namespace:LockIn.Views"
             xmlns:controls="clr-namespace:LockIn.Controls"
             xmlns:ios="clr-namespace:Microsoft.Maui.Controls.PlatformConfiguration.iOSSpecific;assembly=Microsoft.Maui.Controls"
             x:Class="LockIn.Views.LibraryPage"
             x:DataType="vm:LibraryViewModel"
             Title="Bibliotek"
             Shell.NavBarIsVisible="False"
             BackgroundColor="Transparent"
             ios:Page.UseSafeArea="False">

    <ContentPage.Resources>
        <vm:MuscleGroupColorConverter x:Key="MuscleGroupColorConverter"/>
        <vm:MuscleGroupLabelConverter x:Key="MuscleGroupLabelConverter"/>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,Auto,Auto,Auto,*" SafeAreaEdges="None">

        <!-- Atmosfärisk bakgrund -->
        <controls:AtmosphericBackgroundView Grid.RowSpan="5" InputTransparent="True"/>

        <!-- Permanent status bar gradient (alltid synlig, fyller Dynamic Island-zonen) -->
        <BoxView Grid.RowSpan="6" VerticalOptions="Start" HeightRequest="90" InputTransparent="True" ZIndex="19">
            <BoxView.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="{AppThemeBinding Light=#28FCFCFC, Dark=#28141418}" Offset="0.0"/>
                    <GradientStop Color="{AppThemeBinding Light=#00FCFCFC, Dark=#00141418}" Offset="1.0"/>
                </LinearGradientBrush>
            </BoxView.Background>
        </BoxView>

        <!-- Sticky header (fades in on scroll) -->
        <Grid x:Name="StickyHeader" Grid.RowSpan="6" VerticalOptions="Start" ZIndex="20" Opacity="0"
              HeightRequest="150" SafeAreaEdges="None">
            <BoxView InputTransparent="True">
                <BoxView.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="{AppThemeBinding Light=#D8FCFCFC, Dark=#D8141418}" Offset="0.0"/>
                        <GradientStop Color="{AppThemeBinding Light=#90FCFCFC, Dark=#90141418}" Offset="0.35"/>
                        <GradientStop Color="{AppThemeBinding Light=#38FCFCFC, Dark=#38141418}" Offset="0.65"/>
                        <GradientStop Color="{AppThemeBinding Light=#00FCFCFC, Dark=#00141418}" Offset="1.0"/>
                    </LinearGradientBrush>
                </BoxView.Background>
            </BoxView>
            <Grid Padding="20,14,16,12" VerticalOptions="Start">
                <Label Text="BIBLIOTEK"
                       HorizontalOptions="Center" HorizontalTextAlignment="Center"
                       Style="{StaticResource DisplayLabel}" FontSize="18"
                       VerticalOptions="Center"/>
                <Button HorizontalOptions="End" VerticalOptions="Center"
                        IsVisible="{Binding ShowActionButton}"
                        Text="+ Lägg till"
                        Style="{StaticResource SecondaryButton}"
                        Padding="12,8" HeightRequest="36"
                        Command="{Binding ActionButtonCommand}"/>
            </Grid>
        </Grid>

        <!-- Page title (crossfades with sticky header) -->
        <Grid x:Name="PageTitleRow" Grid.Row="0" Padding="16,56,16,8" ColumnDefinitions="*,Auto">
            <Label Grid.Column="0" Text="BIBLIOTEK"
                   FontFamily="BebasNeue" FontSize="34" CharacterSpacing="1"
                   TextColor="{AppThemeBinding Light={StaticResource LightText}, Dark={StaticResource ForgeText}}"
                   VerticalOptions="Center"/>
            <Button Grid.Column="1"
                    IsVisible="{Binding ShowActionButton}"
                    Text="+ Lägg till"
                    Style="{StaticResource SecondaryButton}"
                    Padding="12,8" HeightRequest="36"
                    Command="{Binding ActionButtonCommand}"
                    VerticalOptions="Center"/>
        </Grid>

        <!-- Tab segment control — iOS glass pill -->
        <Border Grid.Row="1" Margin="16,8,16,10"
                BackgroundColor="#33787882"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 50"
                Padding="2">
            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="0">

                <Border Grid.Column="0"
                        BackgroundColor="{Binding Tab0Bg}"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 48"
                        Padding="0,9">
                    <Label Text="ÖVNINGAR"
                           TextColor="{Binding Tab0Fg}"
                           FontFamily="BebasNeue" FontSize="13" CharacterSpacing="1"
                           HorizontalOptions="Center" VerticalOptions="Center"/>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding SelectTabCommand}" CommandParameter="{x:Int32 0}"/>
                        <PointerGestureRecognizer PointerPressed="OnPillPressed" PointerReleased="OnPillReleased"/>
                    </Border.GestureRecognizers>
                </Border>

                <Border Grid.Column="1"
                        BackgroundColor="{Binding Tab1Bg}"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 48"
                        Padding="0,9">
                    <Label Text="MALLAR"
                           TextColor="{Binding Tab1Fg}"
                           FontFamily="BebasNeue" FontSize="13" CharacterSpacing="1"
                           HorizontalOptions="Center" VerticalOptions="Center"/>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding SelectTabCommand}" CommandParameter="{x:Int32 1}"/>
                        <PointerGestureRecognizer PointerPressed="OnPillPressed" PointerReleased="OnPillReleased"/>
                    </Border.GestureRecognizers>
                </Border>

                <Border Grid.Column="2"
                        BackgroundColor="{Binding Tab2Bg}"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 48"
                        Padding="0,9">
                    <Label Text="PROGRAM"
                           TextColor="{Binding Tab2Fg}"
                           FontFamily="BebasNeue" FontSize="13" CharacterSpacing="1"
                           HorizontalOptions="Center" VerticalOptions="Center"/>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding SelectTabCommand}" CommandParameter="{x:Int32 2}"/>
                        <PointerGestureRecognizer PointerPressed="OnPillPressed" PointerReleased="OnPillReleased"/>
                    </Border.GestureRecognizers>
                </Border>

            </Grid>
        </Border>

        <!-- Loading indicator -->
        <ActivityIndicator Grid.Row="4"
                           IsRunning="{Binding IsLoading}"
                           IsVisible="{Binding IsLoading}"
                           HorizontalOptions="Center"/>

        <!-- Tab 0: Exercises -->
        <CollectionView Grid.Row="4"
                        IsVisible="{Binding ShowExercises}"
                        ItemsSource="{Binding Groups}"
                        IsGrouped="True"
                        Scrolled="OnExercisesScrolled"
                        HorizontalScrollBarVisibility="Never"
                        VerticalScrollBarVisibility="Never">
            <CollectionView.Header>
                <VerticalStackLayout Spacing="0">
                    <!-- Pill-formad sökruta (scrollar med innehållet) -->
                    <Border BackgroundColor="{AppThemeBinding Light={StaticResource LightSurface}, Dark={StaticResource ForgeSurface2}}"
                            StrokeShape="RoundRectangle 26"
                            StrokeThickness="0"
                            Padding="18,0"
                            HeightRequest="46"
                            Margin="16,0,16,10">
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                            <Label Grid.Column="0"
                                   Text="⌕"
                                   FontSize="20"
                                   TextColor="{AppThemeBinding Light={StaticResource LightMuted}, Dark={StaticResource ForgeMuted}}"
                                   VerticalOptions="Center"/>
                            <Entry Grid.Column="1"
                                   Text="{Binding Source={RelativeSource AncestorType={x:Type vm:LibraryViewModel}}, Path=SearchText}"
                                   Placeholder="Sök övning..."
                                   PlaceholderColor="{AppThemeBinding Light={StaticResource LightMuted}, Dark={StaticResource ForgeMuted}}"
                                   BackgroundColor="Transparent"
                                   TextColor="{AppThemeBinding Light={StaticResource LightText}, Dark={StaticResource ForgeText}}"
                                   FontFamily="DMSansRegular" FontSize="15"
                                   VerticalOptions="Center"/>
                        </Grid>
                    </Border>
                    <!-- Muskelchips (horisontell scroll, BindableLayout) -->
                    <ScrollView Orientation="Horizontal"
                                HorizontalScrollBarVisibility="Never"
                                Margin="16,0,16,8">
                        <HorizontalStackLayout BindableLayout.ItemsSource="{Binding Source={RelativeSource AncestorType={x:Type vm:LibraryViewModel}}, Path=MuscleChips}"
                                               Spacing="6">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="vm:MuscleGroupChip">
                                    <Border BackgroundColor="{Binding Background}"
                                            StrokeShape="RoundRectangle 22" StrokeThickness="0"
                                            Padding="14,0"
                                            HeightRequest="34">
                                        <Label Text="{Binding Label}"
                                               TextColor="{Binding Foreground}"
                                               FontFamily="BebasNeue" FontSize="13" CharacterSpacing="1"
                                               VerticalOptions="Center"/>
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:LibraryViewModel}}, Path=SelectMuscleChipCommand}"
                                                CommandParameter="{Binding .}"/>
                                        </Border.GestureRecognizers>
                                    </Border>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </HorizontalStackLayout>
                    </ScrollView>
                </VerticalStackLayout>
            </CollectionView.Header>
            <CollectionView.GroupHeaderTemplate>
                <DataTemplate x:DataType="vm:ExerciseGroup">
                    <Label Text="{Binding Title}"
                           Style="{StaticResource SectionLabel}"
                           Padding="16,12,16,4"/>
                </DataTemplate>
            </CollectionView.GroupHeaderTemplate>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Exercise">
                    <Border Margin="16,0,16,8"
                            BackgroundColor="{AppThemeBinding Light={StaticResource LightSurface}, Dark={StaticResource ForgeSurface}}"
                            StrokeShape="RoundRectangle 18"
                            StrokeThickness="0"
                            Padding="18,14">
                        <Border.Shadow>
                            <Shadow Brush="Black" Offset="0,2" Radius="10" Opacity="0.18"/>
                        </Border.Shadow>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer
                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:LibraryViewModel}}, Path=OpenExerciseProgressCommand}"
                                CommandParameter="{Binding .}"/>
                        </Border.GestureRecognizers>
                        <Grid ColumnDefinitions="12,*,Auto" ColumnSpacing="12">
                            <Ellipse Grid.Column="0"
                                     WidthRequest="10" HeightRequest="10"
                                     Fill="{Binding MuscleGroup, Converter={StaticResource MuscleGroupColorConverter}}"
                                     VerticalOptions="Center"/>
                            <VerticalStackLayout Grid.Column="1" Spacing="3" VerticalOptions="Center">
                                <Label Text="{Binding Name}"
                                       FontFamily="DMSansMedium" FontSize="15"/>
                                <Label Text="{Binding MuscleGroup, Converter={StaticResource MuscleGroupLabelConverter}}"
                                       FontSize="12"
                                       Opacity="0.85"
                                       TextColor="{Binding MuscleGroup, Converter={StaticResource MuscleGroupColorConverter}}"/>
                            </VerticalStackLayout>
                            <Border Grid.Column="2"
                                    IsVisible="{Binding IsCustom}"
                                    BackgroundColor="{StaticResource ForgeAccentOrangeDim}"
                                    StrokeShape="RoundRectangle 8"
                                    StrokeThickness="0" Padding="8,4"
                                    VerticalOptions="Center">
                                <Label Text="EGNA" TextColor="{StaticResource ForgeAccentOrange}"
                                       FontSize="10" FontFamily="BebasNeue"
                                       CharacterSpacing="1"/>
                            </Border>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Tab 1: Templates -->
        <Grid Grid.Row="4" IsVisible="{Binding ShowTemplates}">
            <CollectionView ItemsSource="{Binding Templates}"
                            Scrolled="OnTemplatesScrolled"
                            HorizontalScrollBarVisibility="Never"
                            VerticalScrollBarVisibility="Never">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:WorkoutTemplate">
                        <Border Margin="16,0,16,10"
                                BackgroundColor="{AppThemeBinding Light={StaticResource LightSurface}, Dark={StaticResource ForgeSurface}}"
                                StrokeShape="RoundRectangle 18"
                                StrokeThickness="0"
                                Padding="18,14,8,14">
                            <Border.Shadow>
                                <Shadow Brush="Black" Offset="0,2" Radius="10" Opacity="0.18"/>
                            </Border.Shadow>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:LibraryViewModel}}, Path=EditTemplateCommand}"
                                    CommandParameter="{Binding .}"/>
                            </Border.GestureRecognizers>
                            <Grid ColumnDefinitions="12,*,44,40" ColumnSpacing="10">
                                <Ellipse Grid.Column="0"
                                         WidthRequest="10" HeightRequest="10"
                                         Fill="{StaticResource ForgeAccentOrange}"
                                         VerticalOptions="Center"/>
                                <StackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                    <Label Text="{Binding Name}"
                                           FontFamily="BebasNeue" FontSize="20" CharacterSpacing="1"/>
                                    <Label Text="TRYCK FÖR ATT REDIGERA"
                                           Style="{StaticResource SectionLabel}" FontSize="9"/>
                                </StackLayout>
                                <Border Grid.Column="2"
                                        WidthRequest="36" HeightRequest="36"
                                        BackgroundColor="{StaticResource ForgeAccentOrange}"
                                        StrokeShape="Ellipse" StrokeThickness="0"
                                        VerticalOptions="Center">
                                    <views:AppIcon Source="ic_play.png"
                                                   WidthRequest="18" HeightRequest="18"
                                                   ForceTint="White"
                                                   HorizontalOptions="Center"
                                                   VerticalOptions="Center"/>
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:LibraryViewModel}}, Path=StartFromTemplateCommand}"
                                            CommandParameter="{Binding .}"/>
                                    </Border.GestureRecognizers>
                                </Border>
                                <Button Grid.Column="3"
                                        Text="✕"
                                        BackgroundColor="Transparent"
                                        TextColor="{StaticResource ForgeMuted}"
                                        FontSize="15" HeightRequest="36"
                                        Padding="0"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:LibraryViewModel}}, Path=DeleteTemplateCommand}"
                                        CommandParameter="{Binding .}"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
                <CollectionView.EmptyView>
                    <StackLayout Padding="24,40" Spacing="8">
                        <Label Text="Inga mallar ännu"
                               FontFamily="DMSansMedium" FontSize="15"
                               HorizontalOptions="Center"/>
                        <Label Text="Tryck '+ Lägg till' för att skapa din första mall."
                               Style="{StaticResource MutedLabel}"
                               HorizontalTextAlignment="Center"/>
                    </StackLayout>
                </CollectionView.EmptyView>
            </CollectionView>
        </Grid>

        <!-- Tab 2: Programs -->
        <ScrollView Grid.Row="4" IsVisible="{Binding ShowPrograms}" VerticalScrollBarVisibility="Never"
                    Scrolled="OnProgramsScrolled">
            <StackLayout BindableLayout.ItemsSource="{Binding Programs}"
                         Padding="16,0,16,40" Spacing="12">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="data:WorkoutProgram">
                        <Border BackgroundColor="{AppThemeBinding Light={StaticResource LightSurface}, Dark={StaticResource ForgeSurface}}"
                                StrokeShape="RoundRectangle 18"
                                StrokeThickness="0"
                                Padding="18,14">
                            <Border.Shadow>
                                <Shadow Brush="Black" Offset="0,2" Radius="10" Opacity="0.18"/>
                            </Border.Shadow>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:LibraryViewModel}}, Path=OpenProgramCommand}"
                                    CommandParameter="{Binding .}"/>
                            </Border.GestureRecognizers>
                            <StackLayout Spacing="8">
                                <Grid ColumnDefinitions="*,Auto">
                                    <Label Grid.Column="0"
                                           Text="{Binding Name}"
                                           FontFamily="BebasNeue" FontSize="20"
                                           CharacterSpacing="1"/>
                                    <Border Grid.Column="1"
                                            BackgroundColor="{StaticResource ForgeAccentAmberDim}"
                                            StrokeShape="RoundRectangle 10"
                                            StrokeThickness="0" Padding="10,5">
                                        <Label Text="{Binding DaysPerWeek, StringFormat='{0} dgr/v'}"
                                               TextColor="{StaticResource ForgeAccentAmber}"
                                               FontFamily="DMSansMedium" FontSize="12"/>
                                    </Border>
                                </Grid>
                                <Label Text="{Binding Description}"
                                       Style="{StaticResource MutedLabel}"
                                       LineBreakMode="WordWrap"/>
                                <Label Text="SE PROGRAM →"
                                       TextColor="{StaticResource ForgeAccentAmber}"
                                       FontFamily="BebasNeue" FontSize="13"
                                       CharacterSpacing="2"/>
                            </StackLayout>
                        </Border>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </StackLayout>
        </ScrollView>

        <!-- Active workout banner — overlay, alltid i botten -->
        <Border x:Name="WorkoutBanner"
                Grid.Row="0" Grid.RowSpan="5"
                IsVisible="False"
                BackgroundColor="{AppThemeBinding Light={StaticResource LightSurface}, Dark={StaticResource ForgeSurface}}"
                Stroke="{StaticResource ForgeAccent}"
                StrokeThickness="1.5"
                StrokeShape="RoundRectangle 18,18,0,0"
                Padding="20,14,20,16"
                Margin="0,0,0,83"
                VerticalOptions="End"
                ZIndex="10">
            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                <Ellipse Grid.Column="0"
                         Fill="{StaticResource ForgeAccent}"
                         WidthRequest="8" HeightRequest="8"
                         VerticalOptions="Center"/>
                <Label Grid.Column="1"
                       Text="PASS PÅGÅR"
                       FontFamily="BebasNeue" FontSize="16" CharacterSpacing="2"
                       TextColor="{AppThemeBinding Light={StaticResource LightText}, Dark={StaticResource ForgeText}}"
                       VerticalOptions="Center"/>
                <Label Grid.Column="2"
                       Text="ÖPPNA ›"
                       FontFamily="BebasNeue" FontSize="14" CharacterSpacing="1"
                       TextColor="{StaticResource ForgeAccent}"
                       VerticalOptions="Center"/>
            </Grid>
            <Border.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnWorkoutBannerTapped"/>
            </Border.GestureRecognizers>
        </Border>
    <!-- Bottom gradient fade behind floating tab bar — matchar topp-gradienten spegelvänt -->
    <BoxView Grid.RowSpan="99" InputTransparent="True" VerticalOptions="End" HeightRequest="150">
        <BoxView.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="{AppThemeBinding Light=#00FCFCFC, Dark=#00141418}" Offset="0.0"/>
                <GradientStop Color="{AppThemeBinding Light=#38FCFCFC, Dark=#38141418}" Offset="0.35"/>
                <GradientStop Color="{AppThemeBinding Light=#90FCFCFC, Dark=#90141418}" Offset="0.65"/>
                <GradientStop Color="{AppThemeBinding Light=#FCFCFC, Dark=#141418}" Offset="1.0"/>
            </LinearGradientBrush>
        </BoxView.Background>
    </BoxView>

    </Grid>
</ContentPage>