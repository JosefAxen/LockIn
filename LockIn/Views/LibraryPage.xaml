<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:LockIn.ViewModels"
             xmlns:models="clr-namespace:LockIn.Models"
             xmlns:data="clr-namespace:LockIn.Data"
             xmlns:views="clr-namespace:LockIn.Views"
             xmlns:ios="clr-namespace:Microsoft.Maui.Controls.PlatformConfiguration.iOSSpecific;assembly=Microsoft.Maui.Controls"
             x:Class="LockIn.Views.LibraryPage"
             x:DataType="vm:LibraryViewModel"
             Title="Bibliotek"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light={StaticResource LightBackground}, Dark={StaticResource ForgeBackground}}"
             ios:Page.UseSafeArea="False">

    <ContentPage.Resources>
        <vm:MuscleGroupColorConverter x:Key="MuscleGroupColorConverter"/>
        <vm:MuscleGroupLabelConverter x:Key="MuscleGroupLabelConverter"/>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,Auto,Auto,Auto,*" SafeAreaEdges="None">

        <!-- Permanent status bar gradient (alltid synlig, fyller Dynamic Island-zonen) -->
        <BoxView Grid.RowSpan="6" VerticalOptions="Start" HeightRequest="90" InputTransparent="True" ZIndex="19">
            <BoxView.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="{AppThemeBinding Light=#28FCFCFC, Dark=#280E0E10}" Offset="0.0"/>
                    <GradientStop Color="{AppThemeBinding Light=#00FCFCFC, Dark=#000E0E10}" Offset="1.0"/>
                </LinearGradientBrush>
            </BoxView.Background>
        </BoxView>

        <!-- Sticky header (fades in on scroll) -->
        <Grid x:Name="StickyHeader" Grid.RowSpan="6" VerticalOptions="Start" ZIndex="20" Opacity="0"
              HeightRequest="150" SafeAreaEdges="None">
            <BoxView InputTransparent="True">
                <BoxView.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="{AppThemeBinding Light=#D8FCFCFC, Dark=#D80E0E10}" Offset="0.0"/>
                        <GradientStop Color="{AppThemeBinding Light=#90FCFCFC, Dark=#900E0E10}" Offset="0.35"/>
                        <GradientStop Color="{AppThemeBinding Light=#38FCFCFC, Dark=#380E0E10}" Offset="0.65"/>
                        <GradientStop Color="{AppThemeBinding Light=#00FCFCFC, Dark=#000E0E10}" Offset="1.0"/>
                    </LinearGradientBrush>
                </BoxView.Background>
            </BoxView>
            <Grid Padding="20,14,16,12" VerticalOptions="Start">
                <Label Text="BIBLIOTEK"
                       HorizontalOptions="Center" HorizontalTextAlignment="Center"
                       Style="{StaticResource DisplayLabel}" FontSize="18"
                       VerticalOptions="Center"/>
                <Button HorizontalOptions="End" VerticalOptions="Center"
                        IsVisible="{Binding ShowActionButton}"
                        Text="+ Lägg till"
                        Style="{StaticResource SecondaryButton}"
                        Padding="12,8" HeightRequest="36"
                        Command="{Binding ActionButtonCommand}"/>
            </Grid>
        </Grid>

        <!-- Page title (crossfades with sticky header) -->
        <Grid x:Name="PageTitleRow" Grid.Row="0" Padding="16,56,16,8" ColumnDefinitions="*,Auto">
            <Label Grid.Column="0" Text="BIBLIOTEK"
                   FontFamily="BebasNeue" FontSize="34" CharacterSpacing="1"
                   TextColor="{AppThemeBinding Light={StaticResource LightText}, Dark={StaticResource ForgeText}}"
                   VerticalOptions="Center"/>
            <Button Grid.Column="1"
                    IsVisible="{Binding ShowActionButton}"
                    Text="+ Lägg till"
                    Style="{StaticResource SecondaryButton}"
                    Padding="12,8" HeightRequest="36"
                    Command="{Binding ActionButtonCommand}"
                    VerticalOptions="Center"/>
        </Grid>

        <!-- Tab segment control -->
        <Grid Grid.Row="1" ColumnDefinitions="*,*,*" Padding="16,8,16,10" ColumnSpacing="6">

            <Border Grid.Column="0"
                    BackgroundColor="{Binding Tab0Bg}"
                    StrokeShape="RoundRectangle 10"
                    StrokeThickness="0"
                    HeightRequest="36">
                <Label Text="ÖVNINGAR"
                       TextColor="{Binding Tab0Fg}"
                       FontFamily="BebasNeue" FontSize="13" CharacterSpacing="1"
                       HorizontalOptions="Center" VerticalOptions="Center"/>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding SelectTabCommand}" CommandParameter="{x:Int32 0}"/>
                </Border.GestureRecognizers>
            </Border>

            <Border Grid.Column="1"
                    BackgroundColor="{Binding Tab1Bg}"
                    StrokeShape="RoundRectangle 10"
                    StrokeThickness="0"
                    HeightRequest="36">
                <Label Text="MALLAR"
                       TextColor="{Binding Tab1Fg}"
                       FontFamily="BebasNeue" FontSize="13" CharacterSpacing="1"
                       HorizontalOptions="Center" VerticalOptions="Center"/>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding SelectTabCommand}" CommandParameter="{x:Int32 1}"/>
                </Border.GestureRecognizers>
            </Border>

            <Border Grid.Column="2"
                    BackgroundColor="{Binding Tab2Bg}"
                    StrokeShape="RoundRectangle 10"
                    StrokeThickness="0"
                    HeightRequest="36">
                <Label Text="PROGRAM"
                       TextColor="{Binding Tab2Fg}"
                       FontFamily="BebasNeue" FontSize="13" CharacterSpacing="1"
                       HorizontalOptions="Center" VerticalOptions="Center"/>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding SelectTabCommand}" CommandParameter="{x:Int32 2}"/>
                </Border.GestureRecognizers>
            </Border>

        </Grid>

        <!-- Search bar (exercises only) -->
        <SearchBar Grid.Row="2"
                   IsVisible="{Binding ShowExercises}"
                   Text="{Binding SearchText}"
                   Placeholder="Sök övning..."
                   Margin="16,0,16,8"/>

        <!-- Muscle chips (exercises only) -->
        <CollectionView Grid.Row="3"
                        IsVisible="{Binding ShowExercises}"
                        ItemsSource="{Binding MuscleChips}"
                        SelectionMode="None"
                        HeightRequest="40"
                        Margin="16,0,16,6"
                        HorizontalScrollBarVisibility="Never"
                        VerticalScrollBarVisibility="Never">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Horizontal" ItemSpacing="6"/>
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="vm:MuscleGroupChip">
                    <Border BackgroundColor="{Binding Background}"
                            StrokeShape="RoundRectangle 10" StrokeThickness="0"
                            Padding="12,0">
                        <Label Text="{Binding Label}"
                               TextColor="{Binding Foreground}"
                               FontFamily="BebasNeue" FontSize="13" CharacterSpacing="1"
                               VerticalOptions="Center"/>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer
                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:LibraryViewModel}}, Path=SelectMuscleChipCommand}"
                                CommandParameter="{Binding .}"/>
                        </Border.GestureRecognizers>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Loading indicator -->
        <ActivityIndicator Grid.Row="4"
                           IsRunning="{Binding IsLoading}"
                           IsVisible="{Binding IsLoading}"
                           HorizontalOptions="Center"/>

        <!-- Tab 0: Exercises -->
        <CollectionView Grid.Row="4"
                        IsVisible="{Binding ShowExercises}"
                        ItemsSource="{Binding Groups}"
                        IsGrouped="True"
                        Scrolled="OnExercisesScrolled"
                        HorizontalScrollBarVisibility="Never"
                        VerticalScrollBarVisibility="Never">
            <CollectionView.GroupHeaderTemplate>
                <DataTemplate x:DataType="vm:ExerciseGroup">
                    <Label Text="{Binding Title}"
                           Style="{StaticResource SectionLabel}"
                           Padding="16,12,16,4"/>
                </DataTemplate>
            </CollectionView.GroupHeaderTemplate>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Exercise">
                    <Border Margin="16,0,16,8"
                            Style="{StaticResource CardFrame}"
                            Padding="0">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer
                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:LibraryViewModel}}, Path=OpenExerciseProgressCommand}"
                                CommandParameter="{Binding .}"/>
                        </Border.GestureRecognizers>
                        <Grid ColumnDefinitions="4,*">
                            <BoxView Grid.Column="0"
                                     BackgroundColor="{Binding MuscleGroup, Converter={StaticResource MuscleGroupColorConverter}}"/>
                            <Grid Grid.Column="1" ColumnDefinitions="*,Auto" Padding="14,12,14,12">
                                <VerticalStackLayout Grid.Column="0" Spacing="3" VerticalOptions="Center">
                                    <Label Text="{Binding Name}"
                                           FontFamily="DMSansMedium" FontSize="15"/>
                                    <Label Text="{Binding MuscleGroup, Converter={StaticResource MuscleGroupLabelConverter}}"
                                           FontSize="12"
                                           TextColor="{Binding MuscleGroup, Converter={StaticResource MuscleGroupColorConverter}}"/>
                                </VerticalStackLayout>
                                <Border Grid.Column="1"
                                        IsVisible="{Binding IsCustom}"
                                        BackgroundColor="{StaticResource ForgeAccentDim}"
                                        StrokeShape="RoundRectangle 6"
                                        StrokeThickness="0" Padding="8,4"
                                        VerticalOptions="Center">
                                    <Label Text="EIGEN" TextColor="{StaticResource ForgeAccent}"
                                           FontSize="10" FontFamily="BebasNeue"
                                           CharacterSpacing="1"/>
                                </Border>
                            </Grid>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Tab 1: Templates -->
        <Grid Grid.Row="4" IsVisible="{Binding ShowTemplates}">
            <CollectionView ItemsSource="{Binding Templates}"
                            HorizontalScrollBarVisibility="Never"
                            VerticalScrollBarVisibility="Never">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:WorkoutTemplate">
                        <Border Margin="16,0,16,10"
                                Style="{StaticResource CardFrame}">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:LibraryViewModel}}, Path=EditTemplateCommand}"
                                    CommandParameter="{Binding .}"/>
                            </Border.GestureRecognizers>
                            <Grid ColumnDefinitions="*,44,40" Padding="16,12,8,12" ColumnSpacing="4">
                                <Label Grid.Column="0"
                                       Text="{Binding Name}"
                                       FontFamily="DMSansMedium" FontSize="15"
                                       VerticalOptions="Center"/>
                                <Border Grid.Column="1"
                                        WidthRequest="36" HeightRequest="36"
                                        BackgroundColor="{StaticResource ForgeAccent}"
                                        StrokeShape="Ellipse" StrokeThickness="0">
                                    <views:AppIcon Source="ic_play.png"
                                                   WidthRequest="18" HeightRequest="18"
                                                   ForceTint="White"
                                                   HorizontalOptions="Center"
                                                   VerticalOptions="Center"/>
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:LibraryViewModel}}, Path=StartFromTemplateCommand}"
                                            CommandParameter="{Binding .}"/>
                                    </Border.GestureRecognizers>
                                </Border>
                                <Button Grid.Column="2"
                                        Text="✕"
                                        BackgroundColor="Transparent"
                                        TextColor="{StaticResource ForgeMuted}"
                                        FontSize="15" HeightRequest="36"
                                        Padding="0"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:LibraryViewModel}}, Path=DeleteTemplateCommand}"
                                        CommandParameter="{Binding .}"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
                <CollectionView.EmptyView>
                    <StackLayout Padding="24,40" Spacing="8">
                        <Label Text="Inga mallar ännu"
                               FontFamily="DMSansMedium" FontSize="15"
                               HorizontalOptions="Center"/>
                        <Label Text="Tryck '+ Lägg till' för att skapa din första mall."
                               Style="{StaticResource MutedLabel}"
                               HorizontalTextAlignment="Center"/>
                    </StackLayout>
                </CollectionView.EmptyView>
            </CollectionView>
        </Grid>

        <!-- Tab 2: Programs -->
        <ScrollView Grid.Row="4" IsVisible="{Binding ShowPrograms}" VerticalScrollBarVisibility="Never"
                    Scrolled="OnProgramsScrolled">
            <StackLayout BindableLayout.ItemsSource="{Binding Programs}"
                         Padding="16,0,16,40" Spacing="12">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="data:WorkoutProgram">
                        <Border Style="{StaticResource CardFrame}">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:LibraryViewModel}}, Path=OpenProgramCommand}"
                                    CommandParameter="{Binding .}"/>
                            </Border.GestureRecognizers>
                            <StackLayout Padding="16,14" Spacing="8">
                                <Grid ColumnDefinitions="*,Auto">
                                    <Label Grid.Column="0"
                                           Text="{Binding Name}"
                                           FontFamily="BebasNeue" FontSize="20"
                                           CharacterSpacing="1"/>
                                    <Border Grid.Column="1"
                                            BackgroundColor="{StaticResource ForgeAccentDim}"
                                            StrokeShape="RoundRectangle 8"
                                            StrokeThickness="0" Padding="10,5">
                                        <Label Text="{Binding DaysPerWeek, StringFormat='{0} dgr/v'}"
                                               TextColor="{StaticResource ForgeAccent}"
                                               FontFamily="DMSansMedium" FontSize="12"/>
                                    </Border>
                                </Grid>
                                <Label Text="{Binding Description}"
                                       Style="{StaticResource MutedLabel}"
                                       LineBreakMode="WordWrap"/>
                                <Label Text="SE PROGRAM →"
                                       TextColor="{StaticResource ForgeAccent}"
                                       FontFamily="BebasNeue" FontSize="13"
                                       CharacterSpacing="2"/>
                            </StackLayout>
                        </Border>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </StackLayout>
        </ScrollView>

        <!-- Active workout banner — overlay, alltid i botten -->
        <Border x:Name="WorkoutBanner"
                Grid.Row="0" Grid.RowSpan="5"
                IsVisible="False"
                BackgroundColor="{AppThemeBinding Light={StaticResource LightSurface}, Dark={StaticResource ForgeSurface}}"
                Stroke="{StaticResource ForgeAccent}"
                StrokeThickness="1.5"
                StrokeShape="RoundRectangle 18,18,0,0"
                Padding="20,14,20,36"
                VerticalOptions="End"
                ZIndex="10">
            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                <Ellipse Grid.Column="0"
                         Fill="{StaticResource ForgeAccent}"
                         WidthRequest="8" HeightRequest="8"
                         VerticalOptions="Center"/>
                <Label Grid.Column="1"
                       Text="PASS PÅGÅR"
                       FontFamily="BebasNeue" FontSize="16" CharacterSpacing="2"
                       TextColor="{AppThemeBinding Light={StaticResource LightText}, Dark={StaticResource ForgeText}}"
                       VerticalOptions="Center"/>
                <Label Grid.Column="2"
                       Text="ÖPPNA ›"
                       FontFamily="BebasNeue" FontSize="14" CharacterSpacing="1"
                       TextColor="{StaticResource ForgeAccent}"
                       VerticalOptions="Center"/>
            </Grid>
            <Border.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnWorkoutBannerTapped"/>
            </Border.GestureRecognizers>
        </Border>
    <!-- Bottom gradient fade behind floating tab bar -->
    <BoxView Grid.RowSpan="99" InputTransparent="True" VerticalOptions="End" HeightRequest="140">
        <BoxView.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="Transparent" Offset="0"/>
                <GradientStop Color="{AppThemeBinding Light=#FCFCFC, Dark=#0E0E10}" Offset="1"/>
            </LinearGradientBrush>
        </BoxView.Background>
    </BoxView>

    </Grid>
</ContentPage>