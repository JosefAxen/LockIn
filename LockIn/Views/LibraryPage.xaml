<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:LockIn.ViewModels"
             xmlns:models="clr-namespace:LockIn.Models"
             xmlns:data="clr-namespace:LockIn.Data"
             xmlns:views="clr-namespace:LockIn.Views"
             xmlns:controls="clr-namespace:LockIn.Controls"
             xmlns:loc="clr-namespace:LockIn.Resources.Strings"
             xmlns:ios="clr-namespace:Microsoft.Maui.Controls.PlatformConfiguration.iOSSpecific;assembly=Microsoft.Maui.Controls"
             x:Class="LockIn.Views.LibraryPage"
             x:DataType="vm:LibraryViewModel"
             Title="{loc:Localize Library_Title}"
             Shell.NavBarIsVisible="False"
             BackgroundColor="Transparent"
             ios:Page.UseSafeArea="False">

    <ContentPage.Resources>
        <vm:MuscleGroupColorConverter x:Key="MuscleGroupColorConverter"/>
        <vm:MuscleGroupLabelConverter x:Key="MuscleGroupLabelConverter"/>
        <views:EquipmentLabelConverter x:Key="EquipmentLabelConverter"/>
        <views:EquipmentNotOtherConverter x:Key="EquipmentNotOtherConverter"/>
    </ContentPage.Resources>

    <Grid SafeAreaEdges="None">

        <!-- Atmosfärisk bakgrund -->
        <controls:AtmosphericBackgroundView InputTransparent="True"/>

        <!-- Permanent status bar gradient (alltid synlig, fyller Dynamic Island-zonen) -->
        <BoxView VerticalOptions="Start" HeightRequest="90" InputTransparent="True" ZIndex="19">
            <BoxView.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="{AppThemeBinding Light=#28FCFCFC, Dark=#28141418}" Offset="0.0"/>
                    <GradientStop Color="{AppThemeBinding Light=#00FCFCFC, Dark=#00141418}" Offset="1.0"/>
                </LinearGradientBrush>
            </BoxView.Background>
        </BoxView>

        <!-- Loading indicator — Forge stålband -->
        <VerticalStackLayout IsVisible="{Binding IsLoading}"
                             HorizontalOptions="Center"
                             VerticalOptions="Center"
                             Spacing="14"
                             ZIndex="5">
            <Grid WidthRequest="140" HeightRequest="2">
                <BoxView Color="{StaticResource ForgeSurface3}"
                         HeightRequest="2" WidthRequest="140"/>
                <Border x:Name="LoaderHighlight"
                        WidthRequest="40" HeightRequest="2"
                        HorizontalOptions="Start"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 1"
                        TranslationX="-40">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                            <GradientStop Color="#00B8B8BC" Offset="0"/>
                            <GradientStop Color="{StaticResource ForgeAccent}" Offset="0.5"/>
                            <GradientStop Color="#00B8B8BC" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>
            </Grid>
            <Label x:Name="LoaderLabel"
                   Text="{loc:Localize Library_LoadingIn}"
                   FontFamily="BebasNeue"
                   FontSize="12"
                   CharacterSpacing="4"
                   TextColor="{StaticResource ForgeMuted}"
                   HorizontalOptions="Center"
                   Opacity="0.6"/>
        </VerticalStackLayout>

        <!-- Tab 0: Exercises -->
        <CollectionView IsVisible="{Binding ShowExercises}"
                        ItemsSource="{Binding Groups}"
                        IsGrouped="True"
                        Scrolled="OnExercisesScrolled"
                        RemainingItemsThreshold="3"
                        RemainingItemsThresholdReachedCommand="{Binding LoadMoreGroupsCommand}"
                        HorizontalScrollBarVisibility="Never"
                        VerticalScrollBarVisibility="Never">
            <CollectionView.Header>
                <VerticalStackLayout Spacing="0">
                    <!-- Sidrubrik — scrollar bort med innehållet -->
                    <Grid ColumnDefinitions="*,Auto" Padding="16,56,16,8">
                        <Label Grid.Column="0" Text="{loc:Localize Library_Title}"
                               FontFamily="BebasNeue" FontSize="34" CharacterSpacing="1"
                               TextColor="{AppThemeBinding Light={StaticResource LightText}, Dark={StaticResource ForgeText}}"
                               VerticalOptions="Center"/>
                        <Button Grid.Column="1"
                                IsVisible="{Binding ShowActionButton}"
                                Text="{loc:Localize Library_AddButton}"
                                Style="{StaticResource SecondaryButton}"
                                Padding="12,8" HeightRequest="36"
                                Command="{Binding ActionButtonCommand}"
                                VerticalOptions="Center"/>
                    </Grid>
                    <!-- Tab-pill — scrollar med innehållet -->
                    <Border x:Name="TabSegmentExercises"
                            BackgroundColor="{StaticResource ForgePillTrack}"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 50"
                            Margin="16,0,16,12"
                            Padding="2">
                        <Grid ColumnDefinitions="*,*,*" HeightRequest="40"
                              SizeChanged="OnTabContainerSizeChanged">
                            <Border x:Name="TabIndicatorExercises" Grid.ColumnSpan="3"
                                    BackgroundColor="{StaticResource ForgePillIndicator}"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 48"
                                    HorizontalOptions="Start"
                                    VerticalOptions="Fill"/>
                            <Border Grid.Column="0" BackgroundColor="Transparent" StrokeThickness="0" Padding="0,9">
                                <Label Text="{loc:Localize Library_Tab_Exercises}" TextColor="{Binding Tab0Fg}"
                                       FontFamily="BebasNeue" FontSize="13" CharacterSpacing="1"
                                       HorizontalOptions="Center" VerticalOptions="Center"/>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding SelectTabCommand}" CommandParameter="{x:Int32 0}" Tapped="OnPillTapped"/>
                                </Border.GestureRecognizers>
                            </Border>
                            <Border Grid.Column="1" BackgroundColor="Transparent" StrokeThickness="0" Padding="0,9">
                                <Label Text="{loc:Localize Library_Tab_Templates}" TextColor="{Binding Tab1Fg}"
                                       FontFamily="BebasNeue" FontSize="13" CharacterSpacing="1"
                                       HorizontalOptions="Center" VerticalOptions="Center"/>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding SelectTabCommand}" CommandParameter="{x:Int32 1}" Tapped="OnPillTapped"/>
                                </Border.GestureRecognizers>
                            </Border>
                            <Border Grid.Column="2" BackgroundColor="Transparent" StrokeThickness="0" Padding="0,9">
                                <Label Text="{loc:Localize Library_Tab_Programs}" TextColor="{Binding Tab2Fg}"
                                       FontFamily="BebasNeue" FontSize="13" CharacterSpacing="1"
                                       HorizontalOptions="Center" VerticalOptions="Center"/>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding SelectTabCommand}" CommandParameter="{x:Int32 2}" Tapped="OnPillTapped"/>
                                </Border.GestureRecognizers>
                            </Border>
                        </Grid>
                    </Border>
                    <!-- Pill-formad sökruta -->
                    <Border BackgroundColor="{AppThemeBinding Light={StaticResource LightSurface}, Dark={StaticResource ForgeSurface2}}"
                            StrokeShape="RoundRectangle 26"
                            StrokeThickness="0"
                            Padding="18,0"
                            HeightRequest="46"
                            Margin="16,0,16,10">
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                            <Label Grid.Column="0"
                                   Text="⌕"
                                   FontSize="20"
                                   TextColor="{AppThemeBinding Light={StaticResource LightMuted}, Dark={StaticResource ForgeMuted}}"
                                   VerticalOptions="Center"/>
                            <Entry Grid.Column="1"
                                   Text="{Binding Source={RelativeSource AncestorType={x:Type vm:LibraryViewModel}}, Path=SearchText}"
                                   Placeholder="{loc:Localize Library_SearchPlaceholder}"
                                   PlaceholderColor="{AppThemeBinding Light={StaticResource LightMuted}, Dark={StaticResource ForgeMuted}}"
                                   BackgroundColor="Transparent"
                                   TextColor="{AppThemeBinding Light={StaticResource LightText}, Dark={StaticResource ForgeText}}"
                                   FontFamily="DMSansRegular" FontSize="15"
                                   VerticalOptions="Center"/>
                        </Grid>
                    </Border>
                    <!-- Muskelchips -->
                    <ScrollView Orientation="Horizontal"
                                HorizontalScrollBarVisibility="Never"
                                Margin="16,0,16,8">
                        <HorizontalStackLayout BindableLayout.ItemsSource="{Binding Source={RelativeSource AncestorType={x:Type vm:LibraryViewModel}}, Path=MuscleChips}"
                                               Spacing="6">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="vm:MuscleGroupChip">
                                    <Border BackgroundColor="{Binding Background}"
                                            StrokeShape="RoundRectangle 22" StrokeThickness="0"
                                            Padding="14,0"
                                            HeightRequest="44">
                                        <Label Text="{Binding Label}"
                                               TextColor="{Binding Foreground}"
                                               FontFamily="BebasNeue" FontSize="13" CharacterSpacing="1"
                                               VerticalOptions="Center"/>
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:LibraryViewModel}}, Path=SelectMuscleChipCommand}"
                                                CommandParameter="{Binding .}"/>
                                        </Border.GestureRecognizers>
                                    </Border>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </HorizontalStackLayout>
                    </ScrollView>
                    <!-- Equipment-chips -->
                    <ScrollView Orientation="Horizontal"
                                HorizontalScrollBarVisibility="Never"
                                Margin="16,0,16,12">
                        <HorizontalStackLayout
                            BindableLayout.ItemsSource="{Binding Source={RelativeSource AncestorType={x:Type vm:LibraryViewModel}}, Path=EquipmentChips}"
                            Spacing="6">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="vm:EquipmentChip">
                                    <Border BackgroundColor="{Binding Background}"
                                            StrokeShape="RoundRectangle 22" StrokeThickness="0"
                                            Padding="14,0" HeightRequest="44">
                                        <Label Text="{Binding Label}"
                                               TextColor="{Binding Foreground}"
                                               FontFamily="BebasNeue" FontSize="13" CharacterSpacing="1"
                                               VerticalOptions="Center"/>
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:LibraryViewModel}}, Path=SelectEquipmentChipCommand}"
                                                CommandParameter="{Binding .}"/>
                                        </Border.GestureRecognizers>
                                    </Border>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </HorizontalStackLayout>
                    </ScrollView>
                </VerticalStackLayout>
            </CollectionView.Header>
            <CollectionView.GroupHeaderTemplate>
                <DataTemplate x:DataType="vm:ExerciseGroup">
                    <Label Text="{Binding Title}"
                           Style="{StaticResource SectionLabel}"
                           Padding="16,12,16,4"/>
                </DataTemplate>
            </CollectionView.GroupHeaderTemplate>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Exercise">
                    <Border Margin="16,0,16,8"
                            BackgroundColor="{AppThemeBinding Light={StaticResource LightSurface}, Dark={StaticResource ForgeSurface}}"
                            StrokeShape="RoundRectangle 18"
                            StrokeThickness="0"
                            Padding="18,14">
                        <Border.Shadow>
                            <Shadow Brush="Black" Offset="0,2" Radius="10" Opacity="0.18"/>
                        </Border.Shadow>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer
                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:LibraryViewModel}}, Path=OpenExerciseProgressCommand}"
                                CommandParameter="{Binding .}"/>
                        </Border.GestureRecognizers>
                        <Grid ColumnDefinitions="12,*,Auto" ColumnSpacing="12">
                            <Ellipse Grid.Column="0"
                                     WidthRequest="10" HeightRequest="10"
                                     Fill="{Binding MuscleGroup, Converter={StaticResource MuscleGroupColorConverter}}"
                                     VerticalOptions="Center"/>
                            <VerticalStackLayout Grid.Column="1" Spacing="3" VerticalOptions="Center">
                                <Label Text="{Binding Name}"
                                       FontFamily="DMSansMedium" FontSize="15"/>
                                <Label Text="{Binding MuscleGroup, Converter={StaticResource MuscleGroupLabelConverter}}"
                                       FontSize="12"
                                       Opacity="0.85"
                                       TextColor="{Binding MuscleGroup, Converter={StaticResource MuscleGroupColorConverter}}"/>
                            </VerticalStackLayout>
                            <StackLayout Grid.Column="2" Orientation="Horizontal" Spacing="4" VerticalOptions="Center">
                                <Border IsVisible="{Binding IsCustom}"
                                        BackgroundColor="{StaticResource ForgeAccentOrangeDim}"
                                        StrokeShape="RoundRectangle 8"
                                        StrokeThickness="0" Padding="8,4">
                                    <Label Text="{loc:Localize Library_Badge_Custom}" TextColor="{StaticResource ForgeAccentOrange}"
                                           FontSize="10" FontFamily="BebasNeue" CharacterSpacing="1"/>
                                </Border>
                                <Border IsVisible="{Binding Equipment, Converter={StaticResource EquipmentNotOtherConverter}}"
                                        BackgroundColor="{AppThemeBinding Light={StaticResource LightSurface2}, Dark={StaticResource ForgeSurface2}}"
                                        StrokeShape="RoundRectangle 8"
                                        StrokeThickness="0" Padding="8,4">
                                    <Label Text="{Binding Equipment, Converter={StaticResource EquipmentLabelConverter}}"
                                           TextColor="{AppThemeBinding Light={StaticResource LightMuted}, Dark={StaticResource ForgeMuted}}"
                                           FontSize="10" FontFamily="BebasNeue" CharacterSpacing="1"/>
                                </Border>
                            </StackLayout>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Tab 1: Templates -->
        <ScrollView IsVisible="{Binding ShowTemplates}" VerticalScrollBarVisibility="Never"
                    Scrolled="OnTemplatesScrolled">
            <VerticalStackLayout Spacing="0">
                <!-- Sidrubrik — scrollar bort med innehållet -->
                <Grid ColumnDefinitions="*,Auto" Padding="16,56,16,8">
                    <Label Grid.Column="0" Text="{loc:Localize Library_Title}"
                           FontFamily="BebasNeue" FontSize="34" CharacterSpacing="1"
                           TextColor="{AppThemeBinding Light={StaticResource LightText}, Dark={StaticResource ForgeText}}"
                           VerticalOptions="Center"/>
                    <Button Grid.Column="1"
                            IsVisible="{Binding ShowActionButton}"
                            Text="{loc:Localize Library_AddButton}"
                            Style="{StaticResource SecondaryButton}"
                            Padding="12,8" HeightRequest="36"
                            Command="{Binding ActionButtonCommand}"
                            VerticalOptions="Center"/>
                </Grid>
                <!-- Tab-pill — scrollar med innehållet -->
                <Border x:Name="TabSegmentTemplates"
                        BackgroundColor="{StaticResource ForgePillTrack}"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 50"
                        Margin="16,0,16,12"
                        Padding="2">
                    <Grid ColumnDefinitions="*,*,*" HeightRequest="40"
                          SizeChanged="OnTabContainerSizeChanged">
                        <Border x:Name="TabIndicatorTemplates" Grid.ColumnSpan="3"
                                BackgroundColor="{StaticResource ForgePillIndicator}"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 48"
                                HorizontalOptions="Start"
                                VerticalOptions="Fill"/>
                        <Border Grid.Column="0" BackgroundColor="Transparent" StrokeThickness="0" Padding="0,9">
                            <Label Text="{loc:Localize Library_Tab_Exercises}" TextColor="{Binding Tab0Fg}"
                                   FontFamily="BebasNeue" FontSize="13" CharacterSpacing="1"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SelectTabCommand}" CommandParameter="{x:Int32 0}" Tapped="OnPillTapped"/>
                            </Border.GestureRecognizers>
                        </Border>
                        <Border Grid.Column="1" BackgroundColor="Transparent" StrokeThickness="0" Padding="0,9">
                            <Label Text="{loc:Localize Library_Tab_Templates}" TextColor="{Binding Tab1Fg}"
                                   FontFamily="BebasNeue" FontSize="13" CharacterSpacing="1"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SelectTabCommand}" CommandParameter="{x:Int32 1}" Tapped="OnPillTapped"/>
                            </Border.GestureRecognizers>
                        </Border>
                        <Border Grid.Column="2" BackgroundColor="Transparent" StrokeThickness="0" Padding="0,9">
                            <Label Text="{loc:Localize Library_Tab_Programs}" TextColor="{Binding Tab2Fg}"
                                   FontFamily="BebasNeue" FontSize="13" CharacterSpacing="1"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SelectTabCommand}" CommandParameter="{x:Int32 2}" Tapped="OnPillTapped"/>
                            </Border.GestureRecognizers>
                        </Border>
                    </Grid>
                </Border>
                <!-- Mallar-lista -->
                <StackLayout BindableLayout.ItemsSource="{Binding Templates}" Spacing="0">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="models:WorkoutTemplate">
                            <Border Margin="16,0,16,10"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource LightSurface}, Dark={StaticResource ForgeSurface}}"
                                    StrokeShape="RoundRectangle 18"
                                    StrokeThickness="0"
                                    Padding="18,14,8,14">
                                <Border.Shadow>
                                    <Shadow Brush="Black" Offset="0,2" Radius="10" Opacity="0.18"/>
                                </Border.Shadow>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:LibraryViewModel}}, Path=EditTemplateCommand}"
                                        CommandParameter="{Binding .}"/>
                                </Border.GestureRecognizers>
                                <Grid ColumnDefinitions="12,*,44,44,44" ColumnSpacing="10">
                                    <Ellipse Grid.Column="0"
                                             WidthRequest="10" HeightRequest="10"
                                             Fill="{StaticResource ForgeAccentCoral}"
                                             VerticalOptions="Center"/>
                                    <Label Grid.Column="1"
                                           Text="{Binding Name}"
                                           FontFamily="BebasNeue" FontSize="20" CharacterSpacing="1"
                                           VerticalOptions="Center"/>
                                    <Border Grid.Column="2"
                                            WidthRequest="44" HeightRequest="44"
                                            BackgroundColor="{StaticResource ForgeAccentCoral}"
                                            StrokeShape="Ellipse" StrokeThickness="0"
                                            VerticalOptions="Center">
                                        <views:AppIcon Source="ic_play.png"
                                                       WidthRequest="18" HeightRequest="18"
                                                       ForceTint="White"
                                                       HorizontalOptions="Center"
                                                       VerticalOptions="Center"/>
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:LibraryViewModel}}, Path=StartFromTemplateCommand}"
                                                CommandParameter="{Binding .}"/>
                                        </Border.GestureRecognizers>
                                    </Border>
                                    <Button Grid.Column="3"
                                            Text="⧉"
                                            BackgroundColor="Transparent"
                                            TextColor="{StaticResource ForgeMuted}"
                                            FontSize="16" HeightRequest="44"
                                            MinimumWidthRequest="44"
                                            Padding="0"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:LibraryViewModel}}, Path=DuplicateTemplateCommand}"
                                            CommandParameter="{Binding .}"/>
                                    <Button Grid.Column="4"
                                            Text="✕"
                                            BackgroundColor="Transparent"
                                            TextColor="{StaticResource ForgeMuted}"
                                            FontSize="15" HeightRequest="44"
                                            MinimumWidthRequest="44"
                                            Padding="0"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:LibraryViewModel}}, Path=DeleteTemplateCommand}"
                                            CommandParameter="{Binding .}"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                    <BindableLayout.EmptyView>
                        <StackLayout Padding="24,40" Spacing="8">
                            <Label Text="{loc:Localize Library_NoTemplates_Title}"
                                   Style="{StaticResource DisplayLabel}"
                                   FontSize="22"
                                   HorizontalOptions="Center"
                                   TextColor="{StaticResource ForgeMuted}"/>
                            <Label Text="{loc:Localize Library_NoTemplates_Body}"
                                   Style="{StaticResource MutedLabel}"
                                   HorizontalTextAlignment="Center"/>
                        </StackLayout>
                    </BindableLayout.EmptyView>
                </StackLayout>
            </VerticalStackLayout>
        </ScrollView>

        <!-- Tab 2: Programs -->
        <ScrollView IsVisible="{Binding ShowPrograms}" VerticalScrollBarVisibility="Never"
                    Scrolled="OnProgramsScrolled">
            <VerticalStackLayout Spacing="0">
                <!-- Sidrubrik — scrollar bort med innehållet -->
                <Grid ColumnDefinitions="*,Auto" Padding="16,56,16,8">
                    <Label Grid.Column="0" Text="{loc:Localize Library_Title}"
                           FontFamily="BebasNeue" FontSize="34" CharacterSpacing="1"
                           TextColor="{AppThemeBinding Light={StaticResource LightText}, Dark={StaticResource ForgeText}}"
                           VerticalOptions="Center"/>
                </Grid>
                <!-- Tab-pill — scrollar med innehållet -->
                <Border x:Name="TabSegmentPrograms"
                        BackgroundColor="{StaticResource ForgePillTrack}"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 50"
                        Margin="16,0,16,12"
                        Padding="2">
                    <Grid ColumnDefinitions="*,*,*" HeightRequest="40"
                          SizeChanged="OnTabContainerSizeChanged">
                        <Border x:Name="TabIndicatorPrograms" Grid.ColumnSpan="3"
                                BackgroundColor="{StaticResource ForgePillIndicator}"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 48"
                                HorizontalOptions="Start"
                                VerticalOptions="Fill"/>
                        <Border Grid.Column="0" BackgroundColor="Transparent" StrokeThickness="0" Padding="0,9">
                            <Label Text="{loc:Localize Library_Tab_Exercises}" TextColor="{Binding Tab0Fg}"
                                   FontFamily="BebasNeue" FontSize="13" CharacterSpacing="1"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SelectTabCommand}" CommandParameter="{x:Int32 0}" Tapped="OnPillTapped"/>
                            </Border.GestureRecognizers>
                        </Border>
                        <Border Grid.Column="1" BackgroundColor="Transparent" StrokeThickness="0" Padding="0,9">
                            <Label Text="{loc:Localize Library_Tab_Templates}" TextColor="{Binding Tab1Fg}"
                                   FontFamily="BebasNeue" FontSize="13" CharacterSpacing="1"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SelectTabCommand}" CommandParameter="{x:Int32 1}" Tapped="OnPillTapped"/>
                            </Border.GestureRecognizers>
                        </Border>
                        <Border Grid.Column="2" BackgroundColor="Transparent" StrokeThickness="0" Padding="0,9">
                            <Label Text="{loc:Localize Library_Tab_Programs}" TextColor="{Binding Tab2Fg}"
                                   FontFamily="BebasNeue" FontSize="13" CharacterSpacing="1"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SelectTabCommand}" CommandParameter="{x:Int32 2}" Tapped="OnPillTapped"/>
                            </Border.GestureRecognizers>
                        </Border>
                    </Grid>
                </Border>
                <!-- Programs content -->
                <StackLayout Margin="16,0,16,40" Spacing="12"
                             BindableLayout.ItemsSource="{Binding Programs}">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="data:WorkoutProgram">
                            <Border BackgroundColor="{AppThemeBinding Light={StaticResource LightSurface}, Dark={StaticResource ForgeSurface}}"
                                    StrokeShape="RoundRectangle 18"
                                    StrokeThickness="0"
                                    Padding="18,14">
                                <Border.Shadow>
                                    <Shadow Brush="Black" Offset="0,2" Radius="10" Opacity="0.18"/>
                                </Border.Shadow>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:LibraryViewModel}}, Path=OpenProgramCommand}"
                                        CommandParameter="{Binding .}"/>
                                </Border.GestureRecognizers>
                                <StackLayout Spacing="8">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <Label Grid.Column="0"
                                               Text="{Binding Name}"
                                               FontFamily="BebasNeue" FontSize="20"
                                               CharacterSpacing="1"/>
                                        <Border Grid.Column="1"
                                                BackgroundColor="{StaticResource ForgeAccentPurpleDim}"
                                                StrokeShape="RoundRectangle 10"
                                                StrokeThickness="0" Padding="10,5">
                                            <Label Text="{Binding DaysPerWeekText}"
                                                   TextColor="{StaticResource ForgeAccentPurple}"
                                                   FontFamily="DMSansMedium" FontSize="12"/>
                                        </Border>
                                    </Grid>
                                    <Label Text="{Binding LocalizedDescription}"
                                           Style="{StaticResource MutedLabel}"
                                           LineBreakMode="WordWrap"/>
                                    <Label Text="{loc:Localize Library_ViewProgram}"
                                           TextColor="{StaticResource ForgeAccentPurple}"
                                           FontFamily="BebasNeue" FontSize="13"
                                           CharacterSpacing="2"/>
                                </StackLayout>
                            </Border>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </StackLayout>
            </VerticalStackLayout>
        </ScrollView>

        <!-- Sticky header (fades in on scroll) -->
        <Grid x:Name="StickyHeader" VerticalOptions="Start" ZIndex="20" Opacity="0"
              HeightRequest="150" SafeAreaEdges="None">
            <BoxView InputTransparent="True">
                <BoxView.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="{AppThemeBinding Light=#D8FCFCFC, Dark=#D8141418}" Offset="0.0"/>
                        <GradientStop Color="{AppThemeBinding Light=#90FCFCFC, Dark=#90141418}" Offset="0.35"/>
                        <GradientStop Color="{AppThemeBinding Light=#38FCFCFC, Dark=#38141418}" Offset="0.65"/>
                        <GradientStop Color="{AppThemeBinding Light=#00FCFCFC, Dark=#00141418}" Offset="1.0"/>
                    </LinearGradientBrush>
                </BoxView.Background>
            </BoxView>
            <Grid Padding="20,14,16,12" VerticalOptions="Start">
                <Label Text="{loc:Localize Library_Title}"
                       HorizontalOptions="Center" HorizontalTextAlignment="Center"
                       Style="{StaticResource DisplayLabel}" FontSize="18"
                       VerticalOptions="Center"/>
                <Button HorizontalOptions="End" VerticalOptions="Center"
                        IsVisible="{Binding ShowActionButton}"
                        Text="{loc:Localize Library_AddButton}"
                        Style="{StaticResource SecondaryButton}"
                        Padding="12,8" HeightRequest="36"
                        Command="{Binding ActionButtonCommand}"/>
            </Grid>
        </Grid>

        <!-- ═══ WORKOUT BANNER — Live Forge Capsule ═══ -->
        <Grid x:Name="WorkoutBanner"
              IsVisible="False"
              VerticalOptions="End"
              HorizontalOptions="Center"
              Margin="0,0,0,96"
              ZIndex="10">
            <Border StrokeThickness="0"
                    StrokeShape="RoundRectangle 36"
                    BackgroundColor="{StaticResource ForgeAccentGlow}"
                    Margin="-18,-14"
                    InputTransparent="True"/>
            <Border StrokeThickness="1"
                    Stroke="{StaticResource ForgeBannerStroke}"
                    StrokeShape="RoundRectangle 22"
                    Padding="16,9,18,10">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="{StaticResource ForgeSurface2}" Offset="0"/>
                        <GradientStop Color="{StaticResource ForgeSurface}" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,6" Radius="22" Opacity="0.55"/>
                </Border.Shadow>
                <HorizontalStackLayout Spacing="11" VerticalOptions="Center">
                    <controls:ForgeLiveDotView x:Name="BannerPulseRing"
                                               VerticalOptions="Center"/>
                    <Label Text="{loc:Localize Hem_WorkoutBanner_Label}"
                           FontFamily="BebasNeue" FontSize="13" CharacterSpacing="3"
                           TextColor="{StaticResource ForgeText}"
                           VerticalOptions="Center"/>
                    <Path Style="{StaticResource ForwardChevron}"
                          Stroke="{StaticResource ForgeAccent}"/>
                </HorizontalStackLayout>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnWorkoutBannerTapped"/>
                </Border.GestureRecognizers>
            </Border>
        </Grid>

        <!-- Bottom gradient fade behind floating tab bar -->
        <BoxView InputTransparent="True" VerticalOptions="End" HeightRequest="150">
            <BoxView.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="{AppThemeBinding Light=#00FCFCFC, Dark=#00141418}" Offset="0.0"/>
                    <GradientStop Color="{AppThemeBinding Light=#38FCFCFC, Dark=#38141418}" Offset="0.35"/>
                    <GradientStop Color="{AppThemeBinding Light=#90FCFCFC, Dark=#90141418}" Offset="0.65"/>
                    <GradientStop Color="{AppThemeBinding Light=#FCFCFC, Dark=#141418}" Offset="1.0"/>
                </LinearGradientBrush>
            </BoxView.Background>
        </BoxView>

    </Grid>
</ContentPage>
