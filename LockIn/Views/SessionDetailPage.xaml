<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:LockIn.ViewModels"
             xmlns:svc="clr-namespace:LockIn.Services"
             xmlns:views="clr-namespace:LockIn.Views"
             xmlns:controls="clr-namespace:LockIn.Controls"
             x:Class="LockIn.Views.SessionDetailPage"
             x:DataType="vm:SessionDetailViewModel"
             xmlns:ios="clr-namespace:Microsoft.Maui.Controls.PlatformConfiguration.iOSSpecific;assembly=Microsoft.Maui.Controls"
             Shell.NavBarIsVisible="False"
             BackgroundColor="Transparent"
             ios:Page.UseSafeArea="False">

    <Grid RowDefinitions="Auto,*" SafeAreaEdges="None">

        <!-- Atmosfärisk bakgrund -->
        <controls:AtmosphericBackgroundView Grid.RowSpan="2" InputTransparent="True"/>

        <!-- Permanent status bar gradient -->
        <BoxView Grid.RowSpan="2" VerticalOptions="Start" HeightRequest="90" InputTransparent="True" ZIndex="19">
            <BoxView.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#280E0E10" Offset="0.0"/>
                    <GradientStop Color="#000E0E10" Offset="1.0"/>
                </LinearGradientBrush>
            </BoxView.Background>
        </BoxView>

        <!-- Sticky header gradient (fades in on scroll) -->
        <Grid x:Name="StickyHeader" Grid.RowSpan="2" VerticalOptions="Start" ZIndex="20" Opacity="0"
              HeightRequest="150" SafeAreaEdges="None" InputTransparent="True">
            <BoxView InputTransparent="True">
                <BoxView.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#D80E0E10" Offset="0.0"/>
                        <GradientStop Color="#900E0E10" Offset="0.35"/>
                        <GradientStop Color="#380E0E10" Offset="0.65"/>
                        <GradientStop Color="#000E0E10" Offset="1.0"/>
                    </LinearGradientBrush>
                </BoxView.Background>
            </BoxView>
        </Grid>

        <!-- Header -->
        <Grid Grid.Row="0" Padding="16,56,20,12" ColumnDefinitions="48,*" ZIndex="21">
            <Border Grid.Column="0"
                    WidthRequest="36" HeightRequest="36"
                    StrokeShape="Ellipse"
                    BackgroundColor="#17FFFFFF"
                    Stroke="#29FFFFFF"
                    StrokeThickness="0.5"
                    VerticalOptions="Center">
                <Label Text="‹" FontSize="22" FontFamily="DMSansMedium"
                       HorizontalOptions="Center" VerticalOptions="Center"
                       TextColor="{StaticResource ForgeText}"/>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding GoBackCommand}"/>
                </Border.GestureRecognizers>
            </Border>
            <Label Grid.Column="1"
                   Text="{Binding TemplateName}"
                   Style="{StaticResource DisplayLabel}"
                   FontSize="24"
                   HorizontalOptions="Center" VerticalOptions="Center"/>
        </Grid>

        <ScrollView Grid.Row="1" VerticalScrollBarVisibility="Never" Scrolled="OnScrolled">
            <StackLayout Padding="16,0,16,32" Spacing="12">

                <!-- Stats card -->
                <Border Style="{StaticResource CardFrame}" Padding="16">
                    <StackLayout Spacing="8">
                        <Label Text="{Binding DateDisplay}"
                               Style="{StaticResource MutedLabel}" FontSize="13"/>
                        <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                            <StackLayout Grid.Column="0" Spacing="2">
                                <Label Text="{Binding VolumeDisplay}"
                                       FontFamily="BebasNeue" FontSize="24"
                                       TextColor="{StaticResource ForgeAccentBlue}"/>
                                <Label Text="VOLYM" Style="{StaticResource SectionLabel}" FontSize="10"/>
                            </StackLayout>
                            <StackLayout Grid.Column="1" Spacing="2">
                                <Label Text="{Binding DurationDisplay}"
                                       FontFamily="BebasNeue" FontSize="24"
                                       TextColor="{StaticResource ForgeAccentAmber}"/>
                                <Label Text="TID" Style="{StaticResource SectionLabel}" FontSize="10"/>
                            </StackLayout>
                            <StackLayout Grid.Column="2" Spacing="2">
                                <Label Text="{Binding PrCountValue}"
                                       FontFamily="BebasNeue" FontSize="24"
                                       TextColor="{StaticResource ForgeAccentAmber}"/>
                                <Label Text="PRs" Style="{StaticResource SectionLabel}" FontSize="10"/>
                            </StackLayout>
                        </Grid>
                    </StackLayout>
                </Border>

                <!-- Notes -->
                <Border Style="{StaticResource CardFrame}" Padding="16,14"
                        IsVisible="{Binding HasNotes}">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="ANTECKNINGAR" Style="{StaticResource SectionLabel}"/>
                        <Label Text="{Binding SessionNotes}"
                               FontFamily="DMSansRegular" FontSize="14"
                               TextColor="{AppThemeBinding Light={StaticResource LightText}, Dark={StaticResource ForgeText}}"
                               LineBreakMode="WordWrap"/>
                    </VerticalStackLayout>
                </Border>

                <!-- Photos -->
                <Grid ColumnDefinitions="*,Auto">
                    <Label Grid.Column="0" Text="FOTON" Style="{StaticResource SectionLabel}"/>
                    <Button Grid.Column="1"
                            Text="+ FOTO"
                            Style="{StaticResource SecondaryButton}"
                            FontFamily="BebasNeue" FontSize="13"
                            Padding="12,4" HeightRequest="32"
                            Command="{Binding AddPhotoCommand}"/>
                </Grid>
                <CollectionView ItemsSource="{Binding Photos}"
                                HeightRequest="120"
                                ItemsLayout="HorizontalList"
                                IsVisible="{Binding Photos.Count, Converter={x:Static vm:GreaterThanZeroConverter.Instance}}"
                                HorizontalScrollBarVisibility="Never"
                                VerticalScrollBarVisibility="Never">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="vm:PhotoRow">
                            <Border Margin="0,0,8,0"
                                    StrokeShape="RoundRectangle 10"
                                    StrokeThickness="0"
                                    WidthRequest="120" HeightRequest="120"
                                    Padding="0">
                                <Grid>
                                    <Image Source="{Binding Source}" Aspect="AspectFill"
                                           WidthRequest="120" HeightRequest="120"/>
                                    <Border BackgroundColor="#CC000000"
                                            StrokeThickness="0"
                                            VerticalOptions="End" Padding="6,4">
                                        <Label Text="✕" TextColor="White" FontSize="14"
                                               HorizontalOptions="End">
                                            <Label.GestureRecognizers>
                                                <TapGestureRecognizer
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:SessionDetailViewModel}}, Path=DeletePhotoCommand}"
                                                    CommandParameter="{Binding .}"/>
                                            </Label.GestureRecognizers>
                                        </Label>
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <!-- Exercise groups -->
                <StackLayout BindableLayout.ItemsSource="{Binding ExerciseGroups}" Spacing="10">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="vm:SessionExerciseGroup">
                            <Border Style="{StaticResource CardFrame}">
                                <StackLayout Spacing="0">
                                    <Label Text="{Binding ExerciseName}"
                                           FontFamily="DMSansMedium" FontSize="15"
                                           Padding="16,12,16,8"/>

                                    <!-- Column headers -->
                                    <Grid ColumnDefinitions="24,*,*,*"
                                          Padding="16,0,16,6" ColumnSpacing="8">
                                        <Label Grid.Column="0" Text="SET"
                                               Style="{StaticResource SectionLabel}" FontSize="10"/>
                                        <Label Grid.Column="1" Text="KG"
                                               Style="{StaticResource SectionLabel}" FontSize="10"
                                               HorizontalTextAlignment="Center"/>
                                        <Label Grid.Column="2" Text="REPS"
                                               Style="{StaticResource SectionLabel}" FontSize="10"
                                               HorizontalTextAlignment="Center"/>
                                        <Label Grid.Column="3" Text="RIR"
                                               Style="{StaticResource SectionLabel}" FontSize="10"
                                               HorizontalTextAlignment="Center"/>
                                    </Grid>

                                    <StackLayout BindableLayout.ItemsSource="{Binding .}" Spacing="0">
                                        <BindableLayout.ItemTemplate>
                                            <DataTemplate x:DataType="svc:DatabaseService+SessionExerciseDetailRow">
                                                <Grid ColumnDefinitions="24,*,*,*"
                                                      Padding="16,6,16,6" ColumnSpacing="8"
                                                      BackgroundColor="Transparent">
                                                    <Label Grid.Column="0"
                                                           Text="{Binding SetNumber}"
                                                           Style="{StaticResource MutedLabel}"
                                                           VerticalOptions="Center"/>
                                                    <Label Grid.Column="1"
                                                           Text="{Binding WeightKg}"
                                                           FontFamily="DMSansMedium" FontSize="14"
                                                           HorizontalTextAlignment="Center"
                                                           VerticalOptions="Center"
                                                           TextColor="{Binding IsPR, Converter={x:Static vm:PRColorConverter.Instance}}"/>
                                                    <Label Grid.Column="2"
                                                           Text="{Binding Reps}"
                                                           FontFamily="DMSansMedium" FontSize="14"
                                                           HorizontalTextAlignment="Center"
                                                           VerticalOptions="Center"/>
                                                    <Label Grid.Column="3"
                                                           Text="{Binding RIR}"
                                                           Style="{StaticResource MutedLabel}"
                                                           HorizontalTextAlignment="Center"
                                                           VerticalOptions="Center"/>
                                                </Grid>
                                            </DataTemplate>
                                        </BindableLayout.ItemTemplate>
                                    </StackLayout>

                                </StackLayout>
                            </Border>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </StackLayout>

            </StackLayout>
        </ScrollView>

        <!-- Bottom gradient fade — matchar topp-gradienten spegelvänt -->
        <BoxView Grid.RowSpan="2" InputTransparent="True" VerticalOptions="End" HeightRequest="150" ZIndex="22">
            <BoxView.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#000E0E10" Offset="0.0"/>
                    <GradientStop Color="#380E0E10" Offset="0.35"/>
                    <GradientStop Color="#900E0E10" Offset="0.65"/>
                    <GradientStop Color="#0E0E10" Offset="1.0"/>
                </LinearGradientBrush>
            </BoxView.Background>
        </BoxView>

    </Grid>
</ContentPage>
