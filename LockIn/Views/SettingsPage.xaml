<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:LockIn.ViewModels"
             xmlns:views="clr-namespace:LockIn.Views"
             xmlns:controls="clr-namespace:LockIn.Controls"
             xmlns:loc="clr-namespace:LockIn.Resources.Strings"
             x:Class="LockIn.Views.SettingsPage"
             x:DataType="vm:SettingsViewModel"
             Title="{loc:Localize Settings_PageTitle}"
             xmlns:ios="clr-namespace:Microsoft.Maui.Controls.PlatformConfiguration.iOSSpecific;assembly=Microsoft.Maui.Controls"
             Shell.NavBarIsVisible="False"
             BackgroundColor="Transparent">

    <ContentPage.Resources>
        <views:WeightUnitConverter x:Key="WeightUnitConverter"/>
    </ContentPage.Resources>

    <Grid SafeAreaEdges="None">

        <!-- Atmosf�risk bakgrund -->
        <controls:AtmosphericBackgroundView InputTransparent="True"/>

        <!-- Permanent status bar gradient -->
        <BoxView VerticalOptions="Start" HeightRequest="90" InputTransparent="True" ZIndex="19">
            <BoxView.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="{AppThemeBinding Light=#28FCFCFC, Dark=#28141418}" Offset="0.0"/>
                    <GradientStop Color="{AppThemeBinding Light=#00FCFCFC, Dark=#00141418}" Offset="1.0"/>
                </LinearGradientBrush>
            </BoxView.Background>
        </BoxView>

        <!-- Sticky header (fades in on scroll) -->
        <Grid x:Name="StickyHeader" VerticalOptions="Start" ZIndex="20" Opacity="0"
              HeightRequest="150" SafeAreaEdges="None">
            <BoxView InputTransparent="True">
                <BoxView.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="{AppThemeBinding Light=#D8FCFCFC, Dark=#D8141418}" Offset="0.0"/>
                        <GradientStop Color="{AppThemeBinding Light=#90FCFCFC, Dark=#90141418}" Offset="0.35"/>
                        <GradientStop Color="{AppThemeBinding Light=#38FCFCFC, Dark=#38141418}" Offset="0.65"/>
                        <GradientStop Color="{AppThemeBinding Light=#00FCFCFC, Dark=#00141418}" Offset="1.0"/>
                    </LinearGradientBrush>
                </BoxView.Background>
            </BoxView>
            <Grid Padding="20,14,16,12" ColumnDefinitions="48,*">
                <Border Grid.Column="0"
                        WidthRequest="36" HeightRequest="36"
                        StrokeShape="Ellipse"
                        BackgroundColor="{AppThemeBinding Light=#1A000000, Dark=#17FFFFFF}"
                        Stroke="{AppThemeBinding Light=#0D000000, Dark=#29FFFFFF}"
                        StrokeThickness="0.5"
                        VerticalOptions="Center">
                    <Path Style="{StaticResource BackChevron}"/>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnBackClicked"/>
                    </Border.GestureRecognizers>
                </Border>
                <Label Grid.Column="1"
                       Text="{loc:Localize Settings_PageTitle}"
                       HorizontalOptions="Center" HorizontalTextAlignment="Center"
                       Style="{StaticResource DisplayLabel}" FontSize="18"
                       VerticalOptions="Center"/>
            </Grid>
        </Grid>

        <ScrollView VerticalScrollBarVisibility="Never" Scrolled="OnScrolled">
            <VerticalStackLayout Spacing="0">

                <!-- Page title row (scrolls away) -->
                <Grid Padding="16,56,16,8" ColumnDefinitions="48,*">
                    <Border Grid.Column="0"
                            WidthRequest="36" HeightRequest="36"
                            StrokeShape="Ellipse"
                            BackgroundColor="{AppThemeBinding Light=#1A000000, Dark=#17FFFFFF}"
                            Stroke="{AppThemeBinding Light=#0D000000, Dark=#29FFFFFF}"
                            StrokeThickness="0.5"
                            VerticalOptions="Center">
                        <Path Style="{StaticResource BackChevron}"/>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnBackClicked"/>
                            <PointerGestureRecognizer PointerPressed="OnBackPointerPressed" PointerReleased="OnBackPointerReleased"/>
                        </Border.GestureRecognizers>
                    </Border>
                    <Label Grid.Column="1"
                           Text="{loc:Localize Settings_PageTitle}"
                           Style="{StaticResource DisplayLabel}" FontSize="28"
                           VerticalOptions="End" Margin="4,0,0,0"/>
                </Grid>

                <StackLayout Padding="16,8,16,48" Spacing="16">

                <!-- Profile -->
                <Label Text="{loc:Localize Settings_Section_Profile}" Style="{StaticResource SectionLabel}" Margin="4,0"/>
                <Border Style="{StaticResource CardFrame}" Padding="16,14">
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                        <Border Grid.Column="0" BackgroundColor="{StaticResource ForgeAccentBlueDim}"
                                StrokeShape="RoundRectangle 10" StrokeThickness="0"
                                WidthRequest="38" HeightRequest="38" VerticalOptions="Center">
                            <views:AppIcon Source="ic_profile.png" WidthRequest="20" HeightRequest="20"
                                         HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <StackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                            <Label Text="{loc:Localize Settings_Profile_Name}" FontFamily="DMSansMedium" FontSize="15"/>
                            <Label Text="{Binding UserName}" Style="{StaticResource MutedLabel}"/>
                        </StackLayout>
                        <Path Grid.Column="2" Style="{StaticResource ForwardChevron}"/>
                    </Grid>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding EditUserNameCommand}"/>
                    </Border.GestureRecognizers>
                </Border>

                <!-- Height -->
                <Border Style="{StaticResource CardFrame}" Padding="16,14">
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                        <Border Grid.Column="0" BackgroundColor="{StaticResource ForgeSurface2}"
                                StrokeShape="RoundRectangle 10" StrokeThickness="0"
                                WidthRequest="38" HeightRequest="38" VerticalOptions="Center">
                            <views:AppIcon Source="ic_ruler.png" WidthRequest="20" HeightRequest="20"
                                         HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <StackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                            <Label Text="{loc:Localize Settings_Height_Title}" FontFamily="DMSansMedium" FontSize="15"/>
                            <Label Text="{Binding HeightDisplay}" Style="{StaticResource MutedLabel}"/>
                        </StackLayout>
                        <Path Grid.Column="2" Style="{StaticResource ForwardChevron}"/>
                    </Grid>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding EditHeightCommand}"/>
                    </Border.GestureRecognizers>
                </Border>

                <!-- Weekly goal -->
                <Label Text="{loc:Localize Settings_Section_Training}" Style="{StaticResource SectionLabel}" Margin="4,0"/>
                <Border Style="{StaticResource CardFrame}" Padding="16,14">
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                        <Border Grid.Column="0" BackgroundColor="{StaticResource ForgeAccentOrangeDim}"
                                StrokeShape="RoundRectangle 10" StrokeThickness="0"
                                WidthRequest="38" HeightRequest="38" VerticalOptions="Center">
                            <views:AppIcon Source="ic_calendar.png" WidthRequest="20" HeightRequest="20"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <StackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                            <Label Text="{loc:Localize Settings_WeeklyGoal_Title}" FontFamily="DMSansMedium" FontSize="15"/>
                            <Label Text="{Binding WeeklyGoalDisplay}"
                                   Style="{StaticResource MutedLabel}"/>
                        </StackLayout>
                        <Path Grid.Column="2" Style="{StaticResource ForwardChevron}"/>
                    </Grid>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding EditWeeklyGoalCommand}"/>
                    </Border.GestureRecognizers>
                </Border>

                <!-- Reminders section -->
                <Label Text="{loc:Localize Settings_Section_Reminders}" Style="{StaticResource SectionLabel}" Margin="4,0"/>
                <Border Style="{StaticResource CardFrame}" Padding="0">
                    <VerticalStackLayout Spacing="0">
                        <!-- Header row -->
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12" Padding="16,14,16,10">
                            <Border Grid.Column="0" BackgroundColor="{StaticResource ForgeSuccessDim}"
                                    StrokeShape="RoundRectangle 10" StrokeThickness="0"
                                    WidthRequest="38" HeightRequest="38" VerticalOptions="Center">
                                <views:AppIcon Source="ic_timer.png" WidthRequest="20" HeightRequest="20"
                                             HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <StackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                <Label Text="{loc:Localize Settings_Reminders_Title}" FontFamily="DMSansMedium" FontSize="15"/>
                                <Label Text="{Binding ReminderDisplay}" Style="{StaticResource MutedLabel}"/>
                            </StackLayout>
                        </Grid>
                        <!-- Day chips -->
                        <HorizontalStackLayout Spacing="6" HorizontalOptions="Center" Padding="0,0,0,12">
                            <VerticalStackLayout Spacing="2" WidthRequest="36">
                                <Border BackgroundColor="{Binding Day0Bg}" StrokeShape="RoundRectangle 8" StrokeThickness="0"
                                        WidthRequest="36" HeightRequest="36">
                                    <Label Text="{loc:Localize Settings_Reminders_Day_0}" FontFamily="DMSansMedium" FontSize="11"
                                           TextColor="{Binding Day0Fg}" HorizontalOptions="Center" VerticalOptions="Center"/>
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding ToggleReminderDayCommand}" CommandParameter="{x:Int32 0}"/>
                                    </Border.GestureRecognizers>
                                </Border>
                                <Label Text="{Binding Day0Label}" FontFamily="DMSansRegular" FontSize="8"
                                       MinimumHeightRequest="10"
                                       TextColor="{StaticResource ForgeAccent}" HorizontalOptions="Center"
                                       LineBreakMode="TailTruncation">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding EditReminderLabelCommand}" CommandParameter="{x:Int32 0}"/>
                                    </Label.GestureRecognizers>
                                </Label>
                            </VerticalStackLayout>
                            <VerticalStackLayout Spacing="2" WidthRequest="36">
                                <Border BackgroundColor="{Binding Day1Bg}" StrokeShape="RoundRectangle 8" StrokeThickness="0"
                                        WidthRequest="36" HeightRequest="36">
                                    <Label Text="{loc:Localize Settings_Reminders_Day_1}" FontFamily="DMSansMedium" FontSize="11"
                                           TextColor="{Binding Day1Fg}" HorizontalOptions="Center" VerticalOptions="Center"/>
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding ToggleReminderDayCommand}" CommandParameter="{x:Int32 1}"/>
                                    </Border.GestureRecognizers>
                                </Border>
                                <Label Text="{Binding Day1Label}" FontFamily="DMSansRegular" FontSize="8"
                                       MinimumHeightRequest="10"
                                       TextColor="{StaticResource ForgeAccent}" HorizontalOptions="Center"
                                       LineBreakMode="TailTruncation">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding EditReminderLabelCommand}" CommandParameter="{x:Int32 1}"/>
                                    </Label.GestureRecognizers>
                                </Label>
                            </VerticalStackLayout>
                            <VerticalStackLayout Spacing="2" WidthRequest="36">
                                <Border BackgroundColor="{Binding Day2Bg}" StrokeShape="RoundRectangle 8" StrokeThickness="0"
                                        WidthRequest="36" HeightRequest="36">
                                    <Label Text="{loc:Localize Settings_Reminders_Day_2}" FontFamily="DMSansMedium" FontSize="11"
                                           TextColor="{Binding Day2Fg}" HorizontalOptions="Center" VerticalOptions="Center"/>
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding ToggleReminderDayCommand}" CommandParameter="{x:Int32 2}"/>
                                    </Border.GestureRecognizers>
                                </Border>
                                <Label Text="{Binding Day2Label}" FontFamily="DMSansRegular" FontSize="8"
                                       MinimumHeightRequest="10"
                                       TextColor="{StaticResource ForgeAccent}" HorizontalOptions="Center"
                                       LineBreakMode="TailTruncation">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding EditReminderLabelCommand}" CommandParameter="{x:Int32 2}"/>
                                    </Label.GestureRecognizers>
                                </Label>
                            </VerticalStackLayout>
                            <VerticalStackLayout Spacing="2" WidthRequest="36">
                                <Border BackgroundColor="{Binding Day3Bg}" StrokeShape="RoundRectangle 8" StrokeThickness="0"
                                        WidthRequest="36" HeightRequest="36">
                                    <Label Text="{loc:Localize Settings_Reminders_Day_3}" FontFamily="DMSansMedium" FontSize="11"
                                           TextColor="{Binding Day3Fg}" HorizontalOptions="Center" VerticalOptions="Center"/>
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding ToggleReminderDayCommand}" CommandParameter="{x:Int32 3}"/>
                                    </Border.GestureRecognizers>
                                </Border>
                                <Label Text="{Binding Day3Label}" FontFamily="DMSansRegular" FontSize="8"
                                       MinimumHeightRequest="10"
                                       TextColor="{StaticResource ForgeAccent}" HorizontalOptions="Center"
                                       LineBreakMode="TailTruncation">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding EditReminderLabelCommand}" CommandParameter="{x:Int32 3}"/>
                                    </Label.GestureRecognizers>
                                </Label>
                            </VerticalStackLayout>
                            <VerticalStackLayout Spacing="2" WidthRequest="36">
                                <Border BackgroundColor="{Binding Day4Bg}" StrokeShape="RoundRectangle 8" StrokeThickness="0"
                                        WidthRequest="36" HeightRequest="36">
                                    <Label Text="{loc:Localize Settings_Reminders_Day_4}" FontFamily="DMSansMedium" FontSize="11"
                                           TextColor="{Binding Day4Fg}" HorizontalOptions="Center" VerticalOptions="Center"/>
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding ToggleReminderDayCommand}" CommandParameter="{x:Int32 4}"/>
                                    </Border.GestureRecognizers>
                                </Border>
                                <Label Text="{Binding Day4Label}" FontFamily="DMSansRegular" FontSize="8"
                                       MinimumHeightRequest="10"
                                       TextColor="{StaticResource ForgeAccent}" HorizontalOptions="Center"
                                       LineBreakMode="TailTruncation">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding EditReminderLabelCommand}" CommandParameter="{x:Int32 4}"/>
                                    </Label.GestureRecognizers>
                                </Label>
                            </VerticalStackLayout>
                            <VerticalStackLayout Spacing="2" WidthRequest="36">
                                <Border BackgroundColor="{Binding Day5Bg}" StrokeShape="RoundRectangle 8" StrokeThickness="0"
                                        WidthRequest="36" HeightRequest="36">
                                    <Label Text="{loc:Localize Settings_Reminders_Day_5}" FontFamily="DMSansMedium" FontSize="11"
                                           TextColor="{Binding Day5Fg}" HorizontalOptions="Center" VerticalOptions="Center"/>
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding ToggleReminderDayCommand}" CommandParameter="{x:Int32 5}"/>
                                    </Border.GestureRecognizers>
                                </Border>
                                <Label Text="{Binding Day5Label}" FontFamily="DMSansRegular" FontSize="8"
                                       MinimumHeightRequest="10"
                                       TextColor="{StaticResource ForgeAccent}" HorizontalOptions="Center"
                                       LineBreakMode="TailTruncation">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding EditReminderLabelCommand}" CommandParameter="{x:Int32 5}"/>
                                    </Label.GestureRecognizers>
                                </Label>
                            </VerticalStackLayout>
                            <VerticalStackLayout Spacing="2" WidthRequest="36">
                                <Border BackgroundColor="{Binding Day6Bg}" StrokeShape="RoundRectangle 8" StrokeThickness="0"
                                        WidthRequest="36" HeightRequest="36">
                                    <Label Text="{loc:Localize Settings_Reminders_Day_6}" FontFamily="DMSansMedium" FontSize="11"
                                           TextColor="{Binding Day6Fg}" HorizontalOptions="Center" VerticalOptions="Center"/>
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding ToggleReminderDayCommand}" CommandParameter="{x:Int32 6}"/>
                                    </Border.GestureRecognizers>
                                </Border>
                                <Label Text="{Binding Day6Label}" FontFamily="DMSansRegular" FontSize="8"
                                       MinimumHeightRequest="10"
                                       TextColor="{StaticResource ForgeAccent}" HorizontalOptions="Center"
                                       LineBreakMode="TailTruncation">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding EditReminderLabelCommand}" CommandParameter="{x:Int32 6}"/>
                                    </Label.GestureRecognizers>
                                </Label>
                            </VerticalStackLayout>
                        </HorizontalStackLayout>
                        <!-- Divider -->
                        <BoxView HeightRequest="1" BackgroundColor="{StaticResource ForgeSurface2}"/>
                        <!-- Time row -->
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8" Padding="16,12">
                            <Label Grid.Column="0" Text="{loc:Localize Settings_Reminders_Time_Label}"
                                   FontFamily="DMSansMedium" FontSize="14" VerticalOptions="Center"/>
                            <Label Grid.Column="1" Text="{Binding ReminderTimeDisplay}"
                                   Style="{StaticResource MutedLabel}" VerticalOptions="Center"/>
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding EditReminderTimeCommand}"/>
                            </Grid.GestureRecognizers>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- Weight unit -->
                <Label Text="{loc:Localize Settings_Section_Units}" Style="{StaticResource SectionLabel}" Margin="4,0"/>
                <Border Style="{StaticResource CardFrame}" Padding="16,14">
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                        <Border Grid.Column="0" BackgroundColor="{StaticResource ForgeAccentPurpleDim}"
                                StrokeShape="RoundRectangle 10" StrokeThickness="0"
                                WidthRequest="38" HeightRequest="38" VerticalOptions="Center">
                            <views:AppIcon Source="ic_ruler.png" WidthRequest="20" HeightRequest="20"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <StackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                            <Label Text="{loc:Localize Settings_WeightUnit_Title}" FontFamily="DMSansMedium" FontSize="15"/>
                            <Label Text="{Binding UseKg, Converter={StaticResource WeightUnitConverter}}"
                                   Style="{StaticResource MutedLabel}"/>
                        </StackLayout>
                        <Switch Grid.Column="2" IsToggled="{Binding UseKg}" VerticalOptions="Center"/>
                    </Grid>
                </Border>

                <!-- Haptic + Sound -->
                <Label Text="{loc:Localize Settings_Section_RestTimer}" Style="{StaticResource SectionLabel}" Margin="4,0"/>
                <Border Style="{StaticResource CardFrame}" Padding="16,14">
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                        <Border Grid.Column="0" BackgroundColor="{StaticResource ForgeAccentAmberDim}"
                                StrokeShape="RoundRectangle 10" StrokeThickness="0"
                                WidthRequest="38" HeightRequest="38" VerticalOptions="Center">
                            <views:AppIcon Source="ic_vibration.png" WidthRequest="20" HeightRequest="20"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <StackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                            <Label Text="{loc:Localize Settings_Vibration_Title}" FontFamily="DMSansMedium" FontSize="15"/>
                            <Label Text="{loc:Localize Settings_Vibration_Description}"
                                   Style="{StaticResource MutedLabel}"/>
                        </StackLayout>
                        <Switch Grid.Column="2" IsToggled="{Binding HapticEnabled}" VerticalOptions="Center"/>
                    </Grid>
                </Border>
                <Border Style="{StaticResource CardFrame}" Padding="16,14">
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                        <Border Grid.Column="0" BackgroundColor="{StaticResource ForgeAccentAmberDim}"
                                StrokeShape="RoundRectangle 10" StrokeThickness="0"
                                WidthRequest="38" HeightRequest="38" VerticalOptions="Center">
                            <views:AppIcon Source="ic_volume.png" WidthRequest="20" HeightRequest="20"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <StackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                            <Label Text="{loc:Localize Settings_Sound_Title}" FontFamily="DMSansMedium" FontSize="15"/>
                            <Label Text="{loc:Localize Settings_Sound_Description}"
                                   Style="{StaticResource MutedLabel}"/>
                        </StackLayout>
                        <Switch Grid.Column="2" IsToggled="{Binding SoundEnabled}" VerticalOptions="Center"/>
                    </Grid>
                </Border>

                <!-- Health -->
                <Label Text="{loc:Localize Settings_Section_Health}" Style="{StaticResource SectionLabel}" Margin="4,0"/>
                <Border Style="{StaticResource CardFrame}" Padding="16,14">
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                        <Border Grid.Column="0" BackgroundColor="{StaticResource ForgeAccentCoralDim}"
                                StrokeShape="RoundRectangle 10" StrokeThickness="0"
                                WidthRequest="38" HeightRequest="38" VerticalOptions="Center">
                            <views:AppIcon Source="ic_weight.png" WidthRequest="20" HeightRequest="20"
                                             HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <StackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                            <Label Text="{loc:Localize Settings_HealthSync_Title}" FontFamily="DMSansMedium" FontSize="15"/>
                            <Label Text="{loc:Localize Settings_HealthSync_Description}"
                                   Style="{StaticResource MutedLabel}"/>
                        </StackLayout>
                        <Switch Grid.Column="2" IsToggled="{Binding HealthKitSyncEnabled}" VerticalOptions="Center"/>
                    </Grid>
                </Border>

                <!-- Body weight -->
                <Border Style="{StaticResource CardFrame}" Padding="16,14">
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                        <Border Grid.Column="0" BackgroundColor="{StaticResource ForgeAccentBlueDim}"
                                StrokeShape="RoundRectangle 10" StrokeThickness="0"
                                WidthRequest="38" HeightRequest="38" VerticalOptions="Center">
                            <views:AppIcon Source="ic_weight.png" WidthRequest="20" HeightRequest="20"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <StackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                            <Label Text="{loc:Localize Settings_BodyWeight_Title}" FontFamily="DMSansMedium" FontSize="15"/>
                            <Label Text="{loc:Localize Settings_BodyWeight_Description}"
                                   Style="{StaticResource MutedLabel}"/>
                        </StackLayout>
                        <Path Grid.Column="2" Style="{StaticResource ForwardChevron}"/>
                    </Grid>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding OpenBodyWeightCommand}"/>
                    </Border.GestureRecognizers>
                </Border>

                <!-- Progress photos -->
                <Border Style="{StaticResource CardFrame}" Padding="16,14">
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                        <Border Grid.Column="0" BackgroundColor="{StaticResource ForgeAccentDim}"
                                StrokeShape="RoundRectangle 10" StrokeThickness="0"
                                WidthRequest="38" HeightRequest="38" VerticalOptions="Center">
                            <views:AppIcon Source="ic_scale.png" WidthRequest="20" HeightRequest="20"
                                         HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <StackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                            <Label Text="{loc:Localize Settings_ProgressPhotos_Title}" FontFamily="DMSansMedium" FontSize="15"/>
                            <Label Text="{loc:Localize Settings_ProgressPhotos_Description}"
                                   Style="{StaticResource MutedLabel}"/>
                        </StackLayout>
                        <Path Grid.Column="2" Style="{StaticResource ForwardChevron}"/>
                    </Grid>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding OpenProgressPhotosCommand}"/>
                    </Border.GestureRecognizers>
                </Border>

                <!-- Export data -->
                <Border Style="{StaticResource CardFrame}" Padding="16,14">
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                        <Border Grid.Column="0" BackgroundColor="{StaticResource ForgeAccentBlueDim}"
                                StrokeShape="RoundRectangle 10" StrokeThickness="0"
                                WidthRequest="38" HeightRequest="38" VerticalOptions="Center">
                            <views:AppIcon Source="ic_layers.png" WidthRequest="20" HeightRequest="20"
                                         HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <StackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                            <Label Text="{loc:Localize Settings_ExportData_Title}"
                                   FontFamily="DMSansMedium" FontSize="15"/>
                            <Label Text="{loc:Localize Settings_ExportData_Subtitle}"
                                   Style="{StaticResource MutedLabel}"/>
                        </StackLayout>
                        <Path Grid.Column="2" Style="{StaticResource ForwardChevron}"/>
                    </Grid>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding ExportDataCommand}"/>
                    </Border.GestureRecognizers>
                </Border>

                <!-- Volyminställningar (MEV / MRV per muskelgrupp) -->
                <Border Style="{StaticResource CardFrame}" Padding="16,14">
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                        <Border Grid.Column="0" BackgroundColor="{StaticResource ForgeAccentDim}"
                                StrokeShape="RoundRectangle 10" StrokeThickness="0"
                                WidthRequest="38" HeightRequest="38" VerticalOptions="Center">
                            <views:AppIcon Source="ic_barbell.png" WidthRequest="20" HeightRequest="20"
                                         HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <StackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                            <Label Text="{loc:Localize Settings_MuscleVolume_Label}"
                                   FontFamily="DMSansMedium" FontSize="15"/>
                            <Label Text="{loc:Localize Settings_MuscleVolume_Sub}"
                                   Style="{StaticResource MutedLabel}"/>
                        </StackLayout>
                        <Path Grid.Column="2" Style="{StaticResource ForwardChevron}"/>
                    </Grid>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnMuscleVolumeTapped"/>
                    </Border.GestureRecognizers>
                </Border>

                <!-- Danger zone -->
                <Label Text="{loc:Localize Settings_Section_Data}" Style="{StaticResource SectionLabel}" Margin="4,8,4,0"/>
                <Border Style="{StaticResource CardFrame}" Padding="16,14">
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                        <Border Grid.Column="0" BackgroundColor="{StaticResource ForgeDestructive}"
                                StrokeShape="RoundRectangle 10" StrokeThickness="0"
                                WidthRequest="38" HeightRequest="38" VerticalOptions="Center">
                            <views:AppIcon Source="ic_trash.png" WidthRequest="20" HeightRequest="20"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <Button Grid.Column="1" Text="{loc:Localize Settings_ClearData_Button}"
                                Style="{StaticResource DestructiveButton}"
                                HorizontalOptions="Start"
                                Command="{Binding ClearAllDataCommand}"/>
                    </Grid>
                </Border>

                <!-- About / version -->
                <VerticalStackLayout HorizontalOptions="Center" Spacing="6" Margin="0,24,0,0">
                    <Image Source="logo.svg"
                           WidthRequest="40" HeightRequest="40"
                           HorizontalOptions="Center"/>
                    <Label Text="Vana Strength"
                           FontFamily="BebasNeue" FontSize="16" CharacterSpacing="2"
                           TextColor="{StaticResource ForgeAccent}"
                           HorizontalOptions="Center"/>
                    <Label Text="{Binding AppVersion, StringFormat='v{0}'}"
                           Style="{StaticResource MutedLabel}"
                           HorizontalOptions="Center"/>
                </VerticalStackLayout>

                </StackLayout>
            </VerticalStackLayout>
        </ScrollView>

        <!-- = WORKOUT BANNER � Live Forge Capsule = -->
        <Grid x:Name="WorkoutBanner"
              IsVisible="False"
              VerticalOptions="End"
              HorizontalOptions="Center"
              Margin="0,0,0,96"
              ZIndex="10">
            <Border StrokeThickness="0"
                    StrokeShape="RoundRectangle 36"
                    BackgroundColor="{StaticResource ForgeAccentGlow}"
                    Margin="-18,-14"
                    InputTransparent="True"/>
            <Border StrokeThickness="1"
                    Stroke="#55B8B8BC"
                    StrokeShape="RoundRectangle 22"
                    Padding="16,9,18,10">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#26262E" Offset="0"/>
                        <GradientStop Color="#18181C" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,6" Radius="22" Opacity="0.55"/>
                </Border.Shadow>
                <HorizontalStackLayout Spacing="11" VerticalOptions="Center">
                    <controls:ForgeLiveDotView x:Name="BannerPulseRing"
                                               VerticalOptions="Center"/>
                    <Label Text="{loc:Localize Hem_WorkoutBanner_Label}"
                           FontFamily="BebasNeue" FontSize="13" CharacterSpacing="3"
                           TextColor="{StaticResource ForgeText}"
                           VerticalOptions="Center"/>
                    <Path Style="{StaticResource ForwardChevron}"
                          Stroke="{StaticResource ForgeAccent}"/>
                </HorizontalStackLayout>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnWorkoutBannerTapped"/>
                </Border.GestureRecognizers>
            </Border>
        </Grid>

    </Grid>

</ContentPage>
