<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:LockIn.ViewModels"
             xmlns:views="clr-namespace:LockIn.Views"
             x:Class="LockIn.Views.SettingsPage"
             x:DataType="vm:SettingsViewModel"
             Title="Inställningar">

    <ContentPage.Resources>
        <views:WeightUnitConverter x:Key="WeightUnitConverter"/>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*">

        <Grid Grid.Row="0" Padding="20,16,20,8">
            <Label Text="INSTÄLLNINGAR" Style="{StaticResource DisplayLabel}" FontSize="28"/>
        </Grid>

        <ScrollView Grid.Row="1">
            <StackLayout Padding="16,8,16,48" Spacing="16">

                <!-- Weight unit -->
                <Label Text="ENHETER" Style="{StaticResource SectionLabel}" Margin="4,0"/>
                <Border Style="{StaticResource CardFrame}" Padding="16,14">
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                        <Border Grid.Column="0" BackgroundColor="{StaticResource ForgeAccentDim}"
                                StrokeShape="RoundRectangle 10" StrokeThickness="0"
                                WidthRequest="38" HeightRequest="38" VerticalOptions="Center">
                            <Image Source="ic_ruler.png" WidthRequest="20" HeightRequest="20"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <StackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                            <Label Text="Viktenhet" FontFamily="DMSansMedium" FontSize="15"/>
                            <Label Text="{Binding UseKg, Converter={StaticResource WeightUnitConverter}}"
                                   Style="{StaticResource MutedLabel}"/>
                        </StackLayout>
                        <Switch Grid.Column="2" IsToggled="{Binding UseKg}" VerticalOptions="Center"/>
                    </Grid>
                </Border>

                <!-- Haptic + Sound -->
                <Label Text="VILOTIMER" Style="{StaticResource SectionLabel}" Margin="4,0"/>
                <Border Style="{StaticResource CardFrame}" Padding="16,14">
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                        <Border Grid.Column="0" BackgroundColor="{StaticResource ForgeAccent}"
                                StrokeShape="RoundRectangle 10" StrokeThickness="0"
                                WidthRequest="38" HeightRequest="38" VerticalOptions="Center">
                            <Image Source="ic_vibration.png" WidthRequest="20" HeightRequest="20"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <StackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                            <Label Text="Vibration" FontFamily="DMSansMedium" FontSize="15"/>
                            <Label Text="Vibrera när vilotimern är klar"
                                   Style="{StaticResource MutedLabel}"/>
                        </StackLayout>
                        <Switch Grid.Column="2" IsToggled="{Binding HapticEnabled}" VerticalOptions="Center"/>
                    </Grid>
                </Border>
                <Border Style="{StaticResource CardFrame}" Padding="16,14">
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                        <Border Grid.Column="0" BackgroundColor="{StaticResource ForgeAccent}"
                                StrokeShape="RoundRectangle 10" StrokeThickness="0"
                                WidthRequest="38" HeightRequest="38" VerticalOptions="Center">
                            <Image Source="ic_volume.png" WidthRequest="20" HeightRequest="20"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <StackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                            <Label Text="Ljud" FontFamily="DMSansMedium" FontSize="15"/>
                            <Label Text="Spela ett ljud när vilotimern är klar"
                                   Style="{StaticResource MutedLabel}"/>
                        </StackLayout>
                        <Switch Grid.Column="2" IsToggled="{Binding SoundEnabled}" VerticalOptions="Center"/>
                    </Grid>
                </Border>

                <!-- Body weight -->
                <Label Text="HÄLSA" Style="{StaticResource SectionLabel}" Margin="4,0"/>
                <Border Style="{StaticResource CardFrame}" Padding="16,14">
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                        <Border Grid.Column="0" BackgroundColor="{StaticResource ForgeAccentDim}"
                                StrokeShape="RoundRectangle 10" StrokeThickness="0"
                                WidthRequest="38" HeightRequest="38" VerticalOptions="Center">
                            <Image Source="ic_weight.png" WidthRequest="20" HeightRequest="20"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <StackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                            <Label Text="Kroppsvikt" FontFamily="DMSansMedium" FontSize="15"/>
                            <Label Text="Logga och följ din kroppsvikt över tid"
                                   Style="{StaticResource MutedLabel}"/>
                        </StackLayout>
                        <Label Grid.Column="2" Text="›" FontSize="22"
                               TextColor="{StaticResource ForgeMuted}" VerticalOptions="Center"/>
                    </Grid>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding OpenBodyWeightCommand}"/>
                    </Border.GestureRecognizers>
                </Border>

                <!-- Progress photos -->
                <Border Style="{StaticResource CardFrame}" Padding="16,14">
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                        <Border Grid.Column="0" BackgroundColor="{StaticResource ForgeAccentDim}"
                                StrokeShape="RoundRectangle 10" StrokeThickness="0"
                                WidthRequest="38" HeightRequest="38" VerticalOptions="Center">
                            <Label Text="📸" FontSize="18"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <StackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                            <Label Text="Progressfoton" FontFamily="DMSansMedium" FontSize="15"/>
                            <Label Text="Se alla sparade träningsfoton"
                                   Style="{StaticResource MutedLabel}"/>
                        </StackLayout>
                        <Label Grid.Column="2" Text="›" FontSize="22"
                               TextColor="{StaticResource ForgeMuted}" VerticalOptions="Center"/>
                    </Grid>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding OpenProgressPhotosCommand}"/>
                    </Border.GestureRecognizers>
                </Border>

                <!-- Danger zone -->
                <Label Text="DATAHANTERING" Style="{StaticResource SectionLabel}" Margin="4,8,4,0"/>
                <Border Style="{StaticResource CardFrame}" Padding="16,14">
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                        <Border Grid.Column="0" BackgroundColor="{StaticResource ForgeDestructive}"
                                StrokeShape="RoundRectangle 10" StrokeThickness="0"
                                WidthRequest="38" HeightRequest="38" VerticalOptions="Center">
                            <Image Source="ic_trash.png" WidthRequest="20" HeightRequest="20"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <Button Grid.Column="1" Text="Rensa all data"
                                Style="{StaticResource DestructiveButton}"
                                HorizontalOptions="Start"
                                Command="{Binding ClearAllDataCommand}"/>
                    </Grid>
                </Border>

                <!-- Version -->
                <Label Text="{Binding AppVersion, StringFormat='LockIn v{0}'}"
                       Style="{StaticResource MutedLabel}"
                       HorizontalOptions="Center"
                       Margin="0,16,0,0"/>

            </StackLayout>
        </ScrollView>

        <!-- Active workout banner — overlay, alltid i botten -->
        <Border x:Name="WorkoutBanner"
                Grid.Row="0" Grid.RowSpan="2"
                IsVisible="False"
                BackgroundColor="{StaticResource ForgeAccent}"
                StrokeShape="RoundRectangle 0" StrokeThickness="0"
                Padding="20,12,20,28"
                VerticalOptions="End"
                ZIndex="10">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <Ellipse Grid.Column="0" Fill="White" Opacity="0.9"
                         WidthRequest="8" HeightRequest="8"
                         VerticalOptions="Center" Margin="0,0,10,0"/>
                <Label Grid.Column="1" Text="PASS PÅGÅR"
                       FontFamily="BebasNeue" FontSize="16" CharacterSpacing="2"
                       TextColor="White" VerticalOptions="Center"/>
                <Label Grid.Column="2" Text="ÖPPNA ›"
                       FontFamily="BebasNeue" FontSize="14" CharacterSpacing="1"
                       TextColor="White" Opacity="0.8" VerticalOptions="Center"/>
            </Grid>
            <Border.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnWorkoutBannerTapped"/>
            </Border.GestureRecognizers>
        </Border>

    </Grid>

</ContentPage>
