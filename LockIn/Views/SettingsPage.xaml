<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:LockIn.ViewModels"
             xmlns:views="clr-namespace:LockIn.Views"
             x:Class="LockIn.Views.SettingsPage"
             x:DataType="vm:SettingsViewModel"
             Title="Inställningar"
             xmlns:ios="clr-namespace:Microsoft.Maui.Controls.PlatformConfiguration.iOSSpecific;assembly=Microsoft.Maui.Controls"
             Shell.NavBarIsVisible="False"
             ios:Page.UseSafeArea="False">

    <ContentPage.Resources>
        <views:WeightUnitConverter x:Key="WeightUnitConverter"/>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*">

        <Grid Grid.Row="0" Padding="16,56,16,8" ColumnDefinitions="48,*">
            <Border Grid.Column="0"
                    WidthRequest="40" HeightRequest="40"
                    StrokeShape="RoundRectangle 13"
                    BackgroundColor="{AppThemeBinding Light=#1A000000, Dark=#26FFFFFF}"
                    Stroke="{AppThemeBinding Light=#0D000000, Dark=#33FFFFFF}"
                    StrokeThickness="0.5"
                    VerticalOptions="Center">
                <Label Text="‹" FontSize="24" FontFamily="DMSansMedium"
                       HorizontalOptions="Center" VerticalOptions="Center"
                       TextColor="{AppThemeBinding Light={StaticResource LightText}, Dark={StaticResource ForgeText}}"/>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnBackClicked"/>
                    <PointerGestureRecognizer PointerPressed="OnBackPointerPressed" PointerReleased="OnBackPointerReleased"/>
                </Border.GestureRecognizers>
            </Border>
            <Label Grid.Column="1"
                   Text="INSTÄLLNINGAR"
                   Style="{StaticResource DisplayLabel}" FontSize="28"
                   VerticalOptions="End" Margin="4,0,0,0"/>
        </Grid>

        <ScrollView Grid.Row="1" VerticalScrollBarVisibility="Never">
            <StackLayout Padding="16,8,16,48" Spacing="16">

                <!-- Profile -->
                <Label Text="PROFIL" Style="{StaticResource SectionLabel}" Margin="4,0"/>
                <Border Style="{StaticResource CardFrame}" Padding="16,14">
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                        <Border Grid.Column="0" BackgroundColor="{StaticResource ForgeAccentDim}"
                                StrokeShape="RoundRectangle 10" StrokeThickness="0"
                                WidthRequest="38" HeightRequest="38" VerticalOptions="Center">
                            <Label Text="👤" FontSize="18"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <StackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                            <Label Text="Namn" FontFamily="DMSansMedium" FontSize="15"/>
                            <Label Text="{Binding UserName}" Style="{StaticResource MutedLabel}"/>
                        </StackLayout>
                        <Label Grid.Column="2" Text="›" FontSize="22"
                               TextColor="{StaticResource ForgeMuted}" VerticalOptions="Center"/>
                    </Grid>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding EditUserNameCommand}"/>
                    </Border.GestureRecognizers>
                </Border>

                <!-- Weekly goal -->
                <Label Text="TRÄNING" Style="{StaticResource SectionLabel}" Margin="4,0"/>
                <Border Style="{StaticResource CardFrame}" Padding="16,14">
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                        <Border Grid.Column="0" BackgroundColor="{StaticResource ForgeAccentDim}"
                                StrokeShape="RoundRectangle 10" StrokeThickness="0"
                                WidthRequest="38" HeightRequest="38" VerticalOptions="Center">
                            <views:AppIcon Source="ic_calendar.png" WidthRequest="20" HeightRequest="20"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <StackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                            <Label Text="Veckans mål" FontFamily="DMSansMedium" FontSize="15"/>
                            <Label Text="{Binding WeeklyGoal, StringFormat='{0} pass / vecka'}"
                                   Style="{StaticResource MutedLabel}"/>
                        </StackLayout>
                        <Label Grid.Column="2" Text="›" FontSize="22"
                               TextColor="{StaticResource ForgeMuted}" VerticalOptions="Center"/>
                    </Grid>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding EditWeeklyGoalCommand}"/>
                    </Border.GestureRecognizers>
                </Border>

                <!-- Weight unit -->
                <Label Text="ENHETER" Style="{StaticResource SectionLabel}" Margin="4,0"/>
                <Border Style="{StaticResource CardFrame}" Padding="16,14">
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                        <Border Grid.Column="0" BackgroundColor="{StaticResource ForgeAccentDim}"
                                StrokeShape="RoundRectangle 10" StrokeThickness="0"
                                WidthRequest="38" HeightRequest="38" VerticalOptions="Center">
                            <views:AppIcon Source="ic_ruler.png" WidthRequest="20" HeightRequest="20"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <StackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                            <Label Text="Viktenhet" FontFamily="DMSansMedium" FontSize="15"/>
                            <Label Text="{Binding UseKg, Converter={StaticResource WeightUnitConverter}}"
                                   Style="{StaticResource MutedLabel}"/>
                        </StackLayout>
                        <Switch Grid.Column="2" IsToggled="{Binding UseKg}" VerticalOptions="Center"/>
                    </Grid>
                </Border>

                <!-- Haptic + Sound -->
                <Label Text="VILOTIMER" Style="{StaticResource SectionLabel}" Margin="4,0"/>
                <Border Style="{StaticResource CardFrame}" Padding="16,14">
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                        <Border Grid.Column="0" BackgroundColor="{StaticResource ForgeAccent}"
                                StrokeShape="RoundRectangle 10" StrokeThickness="0"
                                WidthRequest="38" HeightRequest="38" VerticalOptions="Center">
                            <views:AppIcon Source="ic_vibration.png" WidthRequest="20" HeightRequest="20"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <StackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                            <Label Text="Vibration" FontFamily="DMSansMedium" FontSize="15"/>
                            <Label Text="Vibrera när vilotimern är klar"
                                   Style="{StaticResource MutedLabel}"/>
                        </StackLayout>
                        <Switch Grid.Column="2" IsToggled="{Binding HapticEnabled}" VerticalOptions="Center"/>
                    </Grid>
                </Border>
                <Border Style="{StaticResource CardFrame}" Padding="16,14">
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                        <Border Grid.Column="0" BackgroundColor="{StaticResource ForgeAccent}"
                                StrokeShape="RoundRectangle 10" StrokeThickness="0"
                                WidthRequest="38" HeightRequest="38" VerticalOptions="Center">
                            <views:AppIcon Source="ic_volume.png" WidthRequest="20" HeightRequest="20"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <StackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                            <Label Text="Ljud" FontFamily="DMSansMedium" FontSize="15"/>
                            <Label Text="Spela ett ljud när vilotimern är klar"
                                   Style="{StaticResource MutedLabel}"/>
                        </StackLayout>
                        <Switch Grid.Column="2" IsToggled="{Binding SoundEnabled}" VerticalOptions="Center"/>
                    </Grid>
                </Border>

                <!-- Health -->
                <Label Text="HÄLSA" Style="{StaticResource SectionLabel}" Margin="4,0"/>
                <Border Style="{StaticResource CardFrame}" Padding="16,14">
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                        <Border Grid.Column="0" BackgroundColor="{StaticResource ForgeAccentCoralDim}"
                                StrokeShape="RoundRectangle 10" StrokeThickness="0"
                                WidthRequest="38" HeightRequest="38" VerticalOptions="Center">
                            <Label Text="♥" FontSize="18" TextColor="{StaticResource ForgeAccentCoral}"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <StackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                            <Label Text="Apple Hälsa" FontFamily="DMSansMedium" FontSize="15"/>
                            <Label Text="Öppna Inställningar för att ge åtkomst"
                                   Style="{StaticResource MutedLabel}"/>
                        </StackLayout>
                        <Label Grid.Column="2" Text="›" FontSize="22"
                               TextColor="{StaticResource ForgeMuted}" VerticalOptions="Center"/>
                    </Grid>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding OpenHealthSettingsCommand}"/>
                    </Border.GestureRecognizers>
                </Border>

                <!-- Body weight -->
                <Border Style="{StaticResource CardFrame}" Padding="16,14">
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                        <Border Grid.Column="0" BackgroundColor="{StaticResource ForgeAccentDim}"
                                StrokeShape="RoundRectangle 10" StrokeThickness="0"
                                WidthRequest="38" HeightRequest="38" VerticalOptions="Center">
                            <views:AppIcon Source="ic_weight.png" WidthRequest="20" HeightRequest="20"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <StackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                            <Label Text="Kroppsvikt" FontFamily="DMSansMedium" FontSize="15"/>
                            <Label Text="Logga och följ din kroppsvikt över tid"
                                   Style="{StaticResource MutedLabel}"/>
                        </StackLayout>
                        <Label Grid.Column="2" Text="›" FontSize="22"
                               TextColor="{StaticResource ForgeMuted}" VerticalOptions="Center"/>
                    </Grid>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding OpenBodyWeightCommand}"/>
                    </Border.GestureRecognizers>
                </Border>

                <!-- Progress photos -->
                <Border Style="{StaticResource CardFrame}" Padding="16,14">
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                        <Border Grid.Column="0" BackgroundColor="{StaticResource ForgeAccentDim}"
                                StrokeShape="RoundRectangle 10" StrokeThickness="0"
                                WidthRequest="38" HeightRequest="38" VerticalOptions="Center">
                            <Label Text="📸" FontSize="18"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <StackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                            <Label Text="Progressfoton" FontFamily="DMSansMedium" FontSize="15"/>
                            <Label Text="Se alla sparade träningsfoton"
                                   Style="{StaticResource MutedLabel}"/>
                        </StackLayout>
                        <Label Grid.Column="2" Text="›" FontSize="22"
                               TextColor="{StaticResource ForgeMuted}" VerticalOptions="Center"/>
                    </Grid>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding OpenProgressPhotosCommand}"/>
                    </Border.GestureRecognizers>
                </Border>

                <!-- Danger zone -->
                <Label Text="DATAHANTERING" Style="{StaticResource SectionLabel}" Margin="4,8,4,0"/>
                <Border Style="{StaticResource CardFrame}" Padding="16,14">
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                        <Border Grid.Column="0" BackgroundColor="{StaticResource ForgeDestructive}"
                                StrokeShape="RoundRectangle 10" StrokeThickness="0"
                                WidthRequest="38" HeightRequest="38" VerticalOptions="Center">
                            <views:AppIcon Source="ic_trash.png" WidthRequest="20" HeightRequest="20"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <Button Grid.Column="1" Text="Rensa all data"
                                Style="{StaticResource DestructiveButton}"
                                HorizontalOptions="Start"
                                Command="{Binding ClearAllDataCommand}"/>
                    </Grid>
                </Border>

                <!-- Version -->
                <Label Text="{Binding AppVersion, StringFormat='LockIn v{0}'}"
                       Style="{StaticResource MutedLabel}"
                       HorizontalOptions="Center"
                       Margin="0,16,0,0"/>

            </StackLayout>
        </ScrollView>

        <!-- Active workout banner — overlay, alltid i botten -->
        <Border x:Name="WorkoutBanner"
                Grid.Row="0" Grid.RowSpan="2"
                IsVisible="False"
                BackgroundColor="{AppThemeBinding Light={StaticResource LightSurface}, Dark={StaticResource ForgeSurface}}"
                Stroke="{StaticResource ForgeAccent}"
                StrokeThickness="1.5"
                StrokeShape="RoundRectangle 18,18,0,0"
                Padding="20,14,20,36"
                VerticalOptions="End"
                ZIndex="10">
            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                <Ellipse Grid.Column="0"
                         Fill="{StaticResource ForgeAccent}"
                         WidthRequest="8" HeightRequest="8"
                         VerticalOptions="Center"/>
                <Label Grid.Column="1"
                       Text="PASS PÅGÅR"
                       FontFamily="BebasNeue" FontSize="16" CharacterSpacing="2"
                       TextColor="{AppThemeBinding Light={StaticResource LightText}, Dark={StaticResource ForgeText}}"
                       VerticalOptions="Center"/>
                <Label Grid.Column="2"
                       Text="ÖPPNA ›"
                       FontFamily="BebasNeue" FontSize="14" CharacterSpacing="1"
                       TextColor="{StaticResource ForgeAccent}"
                       VerticalOptions="Center"/>
            </Grid>
            <Border.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnWorkoutBannerTapped"/>
            </Border.GestureRecognizers>
        </Border>

    </Grid>

</ContentPage>
