<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:LockIn.ViewModels"
             xmlns:controls="clr-namespace:LockIn.Controls"
             xmlns:loc="clr-namespace:LockIn.Resources.Strings"
             x:Class="LockIn.Views.CreateExercisePage"
             x:DataType="vm:CreateExerciseViewModel"
             Title="{loc:Localize CreateExercise_PageTitle}"
             xmlns:ios="clr-namespace:Microsoft.Maui.Controls.PlatformConfiguration.iOSSpecific;assembly=Microsoft.Maui.Controls"
             Shell.NavBarIsVisible="False"
             BackgroundColor="Transparent"
             ios:Page.UseSafeArea="False">

    <Grid SafeAreaEdges="None">

        <!-- Atmosfärisk bakgrund -->
        <controls:AtmosphericBackgroundView InputTransparent="True"/>

        <ScrollView>
            <VerticalStackLayout Padding="16,0,16,8" Spacing="12">

                <!-- Header -->
                <Grid Padding="0,56,0,4" ColumnDefinitions="48,*,Auto">
                    <Border Grid.Column="0"
                            WidthRequest="36" HeightRequest="36"
                            StrokeShape="Ellipse"
                            BackgroundColor="#17FFFFFF"
                            Stroke="#29FFFFFF"
                            StrokeThickness="0.5"
                            VerticalOptions="Center">
                        <Path Style="{StaticResource BackChevron}"/>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding CancelCommand}"/>
                        </Border.GestureRecognizers>
                    </Border>
                    <Label Grid.Column="1" Text="{loc:Localize CreateExercise_Title}"
                           Style="{StaticResource DisplayLabel}"
                           FontSize="22" HorizontalOptions="Center" VerticalOptions="Center"/>
                    <Button Grid.Column="2"
                            Text="{loc:Localize Common_Save}"
                            Style="{StaticResource SecondaryButton}"
                            Padding="12,8" HeightRequest="36"
                            IsEnabled="{Binding IsNameValid}"
                            Command="{Binding SaveCommand}"
                            VerticalOptions="Center"/>
                </Grid>

                <!-- Name -->
                <Border Style="{StaticResource CardFrame}" Padding="16,14">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="{loc:Localize CreateExercise_NameLabel}" Style="{StaticResource SectionLabel}"/>
                        <Entry Text="{Binding Name}"
                               Placeholder="{loc:Localize CreateExercise_NamePlaceholder}"
                               PlaceholderColor="{AppThemeBinding Light={StaticResource LightMuted}, Dark={StaticResource ForgeMuted}}"
                               TextColor="{AppThemeBinding Light={StaticResource LightText}, Dark={StaticResource ForgeText}}"
                               BackgroundColor="Transparent"
                               FontFamily="DMSansRegular" FontSize="16"/>
                    </VerticalStackLayout>
                </Border>

                <!-- Muscle group -->
                <Border Style="{StaticResource CardFrame}" Padding="16,14">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="{loc:Localize CreateExercise_MuscleGroupLabel}" Style="{StaticResource SectionLabel}"/>
                        <CollectionView ItemsSource="{Binding MuscleGroups}"
                                        SelectionMode="None"
                                        HeightRequest="112">
                            <CollectionView.ItemsLayout>
                                <GridItemsLayout Orientation="Vertical" Span="4"
                                                 HorizontalItemSpacing="8" VerticalItemSpacing="8"/>
                            </CollectionView.ItemsLayout>
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="vm:MuscleGroupOption">
                                    <Border BackgroundColor="{Binding BackgroundColor}"
                                            Stroke="{Binding BorderColor}"
                                            StrokeShape="RoundRectangle 12"
                                            StrokeThickness="1.5"
                                            Padding="4,10">
                                        <VerticalStackLayout Spacing="5" HorizontalOptions="Center">
                                            <Ellipse WidthRequest="8" HeightRequest="8"
                                                     Fill="{Binding AccentColor}"
                                                     HorizontalOptions="Center"/>
                                            <Label Text="{Binding Label}"
                                                   FontFamily="BebasNeue" FontSize="9" CharacterSpacing="0.5"
                                                   TextColor="{Binding AccentColor}"
                                                   HorizontalOptions="Center"/>
                                        </VerticalStackLayout>
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:CreateExerciseViewModel}}, Path=SelectMuscleCommand}"
                                                CommandParameter="{Binding .}"/>
                                        </Border.GestureRecognizers>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </Border>

                <!-- Equipment -->
                <Border Style="{StaticResource CardFrame}" Padding="16,14">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="{loc:Localize CreateExercise_EquipmentLabel}" Style="{StaticResource SectionLabel}"/>
                        <CollectionView ItemsSource="{Binding EquipmentOptions}"
                                        SelectionMode="None"
                                        HeightRequest="40">
                            <CollectionView.ItemsLayout>
                                <LinearItemsLayout Orientation="Horizontal" ItemSpacing="8"/>
                            </CollectionView.ItemsLayout>
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="vm:EquipmentOption">
                                    <Border BackgroundColor="Transparent"
                                            Stroke="{Binding BorderColor}"
                                            StrokeShape="RoundRectangle 10"
                                            StrokeThickness="1.5"
                                            Padding="12,8">
                                        <Label Text="{Binding Label}"
                                               TextColor="{Binding TextColor}"
                                               FontFamily="BebasNeue" FontSize="11"
                                               CharacterSpacing="0.5"
                                               VerticalOptions="Center"/>
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:CreateExerciseViewModel}}, Path=SelectEquipmentCommand}"
                                                CommandParameter="{Binding .}"/>
                                        </Border.GestureRecognizers>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </Border>

                <!-- Rest time -->
                <Border Style="{StaticResource CardFrame}" Padding="16,14">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="{loc:Localize CreateExercise_RestLabel}" Style="{StaticResource SectionLabel}"/>
                        <Grid ColumnDefinitions="52,*,52" ColumnSpacing="0">
                            <Button Grid.Column="0" Text="−"
                                    Style="{StaticResource SecondaryButton}"
                                    FontSize="20" HeightRequest="52" WidthRequest="52"
                                    Command="{Binding DecreaseRestCommand}"/>
                            <VerticalStackLayout Grid.Column="1" Spacing="0"
                                                 HorizontalOptions="Center" VerticalOptions="Center">
                                <Label Text="{Binding RestSeconds}"
                                       FontFamily="BebasNeue" FontSize="38" CharacterSpacing="1"
                                       TextColor="{AppThemeBinding Light={StaticResource LightText}, Dark={StaticResource ForgeText}}"
                                       HorizontalOptions="Center"/>
                                <Label Text="{loc:Localize CreateExercise_RestUnit}"
                                       Style="{StaticResource SectionLabel}"
                                       HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                            <Button Grid.Column="2" Text="+"
                                    Style="{StaticResource SecondaryButton}"
                                    FontSize="20" HeightRequest="52" WidthRequest="52"
                                    Command="{Binding IncreaseRestCommand}"/>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- Notes -->
                <Border Style="{StaticResource CardFrame}" Padding="16,14">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="{loc:Localize CreateExercise_NotesLabel}" Style="{StaticResource SectionLabel}"/>
                        <Editor Text="{Binding Notes}"
                                Placeholder="{loc:Localize CreateExercise_NotesPlaceholder}"
                                PlaceholderColor="{AppThemeBinding Light={StaticResource LightMuted}, Dark={StaticResource ForgeMuted}}"
                                TextColor="{AppThemeBinding Light={StaticResource LightText}, Dark={StaticResource ForgeText}}"
                                BackgroundColor="Transparent"
                                FontFamily="DMSansRegular" FontSize="14"
                                AutoSize="TextChanges"
                                MinimumHeightRequest="72"/>
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>

</ContentPage>
