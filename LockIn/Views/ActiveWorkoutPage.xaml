<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:LockIn.ViewModels"
             xmlns:views="clr-namespace:LockIn.Views"
             x:Class="LockIn.Views.ActiveWorkoutPage"
             x:DataType="vm:ActiveWorkoutViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource ForgeBackground}">

    <ContentPage.Resources>
        <views:BoolToColorConverter x:Key="BoolToColorConverter"/>
        <!-- Page is always dark — override AppThemeBinding label colors -->
        <Style TargetType="Label">
            <Setter Property="TextColor" Value="{StaticResource ForgeText}" />
            <Setter Property="FontFamily" Value="DMSansRegular" />
            <Setter Property="FontSize" Value="14" />
        </Style>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*">

        <!-- Top bar -->
        <Grid Grid.Row="0" Padding="16,16,20,8" ColumnDefinitions="Auto,*,Auto,Auto">
            <Button Grid.Column="0" Text="‹"
                    Style="{StaticResource SecondaryButton}"
                    BackgroundColor="{StaticResource ForgeSurface2}"
                    TextColor="{StaticResource ForgeText}"
                    WidthRequest="44" HeightRequest="44" Padding="0"
                    Clicked="OnBackClicked">
                <Button.Behaviors>
                    <views:AnimatedButtonBehavior/>
                </Button.Behaviors>
            </Button>
            <Label Grid.Column="1" Text="{Binding TemplateName}"
                   Style="{StaticResource DisplayLabel}"
                   TextColor="{StaticResource ForgeText}"
                   FontSize="22"
                   HorizontalOptions="Center" VerticalOptions="Center"/>
            <!-- Plate calculator button -->
            <Border Grid.Column="2"
                    WidthRequest="40" HeightRequest="40"
                    BackgroundColor="{AppThemeBinding Light={StaticResource LightSurface2}, Dark={StaticResource ForgeSurface2}}"
                    StrokeShape="Ellipse" StrokeThickness="0"
                    Margin="0,0,6,0">
                <views:AppIcon Source="ic_scale.png"
                               WidthRequest="20" HeightRequest="20"
                               HorizontalOptions="Center" VerticalOptions="Center"/>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding OpenPlateCalculatorCommand}"/>
                </Border.GestureRecognizers>
            </Border>
            <Label Grid.Column="3" Text="{Binding ElapsedTime}"
                   TextColor="{StaticResource ForgeAccent}"
                   FontFamily="BebasNeue" FontSize="22"
                   VerticalOptions="Center"/>
        </Grid>

        <!-- Scrollable content -->
        <ScrollView Grid.Row="1">
            <StackLayout Padding="16,0,16,120" Spacing="12">

                <!-- PR Banner -->
                <Border IsVisible="{Binding HasPR}"
                        BackgroundColor="{StaticResource ForgeSuccessDim}"
                        StrokeShape="RoundRectangle 12"
                        StrokeThickness="0" Padding="14,12">
                    <Grid ColumnDefinitions="Auto,*">
                        <Label Grid.Column="0" Text="🏆" FontSize="20"
                               VerticalOptions="Center" Margin="0,0,10,0"/>
                        <Label Grid.Column="1" Text="{Binding PrMessage}"
                               TextColor="{StaticResource ForgeSuccess}"
                               FontFamily="DMSansMedium" FontSize="13"
                               LineBreakMode="WordWrap"/>
                    </Grid>
                </Border>

                <!-- Auto-progression Banner -->
                <Border IsVisible="{Binding HasAutoProgress}"
                        BackgroundColor="{StaticResource ForgeAccentDim}"
                        StrokeShape="RoundRectangle 12"
                        StrokeThickness="0" Padding="14,12">
                    <Grid ColumnDefinitions="Auto,*">
                        <Label Grid.Column="0" Text="📈" FontSize="20"
                               VerticalOptions="Center" Margin="0,0,10,0"/>
                        <Label Grid.Column="1" Text="{Binding AutoProgressMessage}"
                               TextColor="{StaticResource ForgeAccent}"
                               FontFamily="DMSansMedium" FontSize="13"
                               LineBreakMode="WordWrap"/>
                    </Grid>
                </Border>

                <!-- Exercise sections — one card per exercise -->
                <StackLayout BindableLayout.ItemsSource="{Binding Exercises}" Spacing="14">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="vm:WorkoutExerciseSection">
                            <Border Style="{StaticResource DarkCardFrame}">
                                <StackLayout Spacing="0">

                                    <!-- Exercise header: name + info + rest time badge -->
                                    <Grid ColumnDefinitions="*,Auto,Auto"
                                          Padding="16,12,12,10">
                                        <Label Grid.Column="0"
                                               Text="{Binding ExerciseName}"
                                               FontFamily="DMSansMedium" FontSize="16"
                                               VerticalOptions="Center"/>

                                        <!-- Info button — only visible when description exists -->
                                        <Border Grid.Column="1"
                                                IsVisible="{Binding HasDescription}"
                                                BackgroundColor="Transparent"
                                                StrokeThickness="0"
                                                Padding="4,6,8,6">
                                            <Label Text="ⓘ"
                                                   TextColor="{StaticResource ForgeMuted}"
                                                   FontSize="16"
                                                   VerticalOptions="Center"/>
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ActiveWorkoutViewModel}}, Path=ShowExerciseInfoCommand}"
                                                    CommandParameter="{Binding .}"/>
                                            </Border.GestureRecognizers>
                                        </Border>

                                        <!-- Rest time badge — tap to change -->
                                        <Border Grid.Column="2"
                                                BackgroundColor="{StaticResource ForgeAccentDim}"
                                                StrokeShape="RoundRectangle 8"
                                                StrokeThickness="0"
                                                Padding="10,6">
                                            <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="4">
                                                <views:AppIcon Grid.Column="0" Source="ic_timer.png"
                                                              WidthRequest="13" HeightRequest="13"
                                                              VerticalOptions="Center"/>
                                                <Label Grid.Column="1"
                                                       Text="{Binding RestDisplay}"
                                                       TextColor="{StaticResource ForgeAccent}"
                                                       FontFamily="DMSansMedium" FontSize="13"
                                                       VerticalOptions="Center"/>
                                            </Grid>
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ActiveWorkoutViewModel}}, Path=ChangeRestTimeCommand}"
                                                    CommandParameter="{Binding .}"/>
                                                <PointerGestureRecognizer
                                                    PointerPressed="OnElemPointerPressed"
                                                    PointerReleased="OnElemPointerReleased"/>
                                            </Border.GestureRecognizers>
                                        </Border>
                                    </Grid>

                                    <!-- Column headers -->
                                    <Grid ColumnDefinitions="32,*,14,*,42,36"
                                          Padding="16,0,16,6" ColumnSpacing="6">
                                        <Label Grid.Column="0" Text="SET"
                                               Style="{StaticResource SectionLabel}" FontSize="10"/>
                                        <Label Grid.Column="1" Text="KG"
                                               Style="{StaticResource SectionLabel}" FontSize="10"
                                               HorizontalTextAlignment="Center"/>
                                        <Label Grid.Column="3" Text="REPS"
                                               Style="{StaticResource SectionLabel}" FontSize="10"
                                               HorizontalTextAlignment="Center"/>
                                        <Label Grid.Column="4" Text="RIR"
                                               Style="{StaticResource SectionLabel}" FontSize="10"
                                               HorizontalTextAlignment="Center"/>
                                    </Grid>

                                    <!-- Set rows -->
                                    <StackLayout BindableLayout.ItemsSource="{Binding Sets}" Spacing="0">
                                        <BindableLayout.ItemTemplate>
                                            <DataTemplate x:DataType="vm:LoggedSetRow">
                                                <Grid ColumnDefinitions="32,*,14,*,42,36"
                                                      Padding="16,5,16,5" ColumnSpacing="6">

                                                    <!-- Set number / type label — tap to change type -->
                                                    <Border Grid.Column="0"
                                                            BackgroundColor="Transparent"
                                                            StrokeThickness="0"
                                                            Padding="0"
                                                            HeightRequest="36">
                                                        <Label Text="{Binding SetLabel}"
                                                               TextColor="{Binding SetLabelColor}"
                                                               FontFamily="DMSansMedium" FontSize="13"
                                                               HorizontalOptions="Center"
                                                               VerticalOptions="Center"/>
                                                        <Border.GestureRecognizers>
                                                            <TapGestureRecognizer
                                                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ActiveWorkoutViewModel}}, Path=ChangeSetTypeCommand}"
                                                                CommandParameter="{Binding .}"/>
                                                            <PointerGestureRecognizer
                                                                PointerPressed="OnElemPointerPressed"
                                                                PointerReleased="OnElemPointerReleased"/>
                                                        </Border.GestureRecognizers>
                                                    </Border>

                                                    <!-- Weight -->
                                                    <Border Grid.Column="1"
                                                            BackgroundColor="{StaticResource ForgeSurface2}"
                                                            StrokeShape="RoundRectangle 8"
                                                            StrokeThickness="0" Padding="4,2">
                                                        <Entry Text="{Binding WeightText}"
                                                               Keyboard="Numeric"
                                                               Placeholder="{Binding PrevWeightHint}"
                                                               PlaceholderColor="{StaticResource ForgeTextSecondary}"
                                                               HorizontalTextAlignment="Center"
                                                               FontFamily="DMSansMedium" FontSize="15"
                                                               BackgroundColor="Transparent"
                                                               TextColor="{StaticResource ForgeText}"
                                                               HeightRequest="36" Margin="0"/>
                                                    </Border>

                                                    <!-- Separator (× or ⏱) -->
                                                    <Label Grid.Column="2"
                                                           Text="{Binding SeparatorLabel}"
                                                           Style="{StaticResource MutedLabel}"
                                                           HorizontalOptions="Center"
                                                           VerticalOptions="Center"/>

                                                    <!-- Reps / Duration -->
                                                    <Border Grid.Column="3"
                                                            BackgroundColor="{StaticResource ForgeSurface2}"
                                                            StrokeShape="RoundRectangle 8"
                                                            StrokeThickness="0" Padding="4,2">
                                                        <Entry Text="{Binding RepsText}"
                                                               Keyboard="Numeric"
                                                               Placeholder="{Binding RepsPlaceholder}"
                                                               PlaceholderColor="{StaticResource ForgeTextSecondary}"
                                                               HorizontalTextAlignment="Center"
                                                               FontFamily="DMSansMedium" FontSize="15"
                                                               BackgroundColor="Transparent"
                                                               TextColor="{StaticResource ForgeText}"
                                                               HeightRequest="36" Margin="0"/>
                                                    </Border>

                                                    <!-- RIR — tap to cycle 0-5 -->
                                                    <Border Grid.Column="4"
                                                            BackgroundColor="{StaticResource ForgeSurface2}"
                                                            StrokeShape="RoundRectangle 8"
                                                            StrokeThickness="0">
                                                        <Label Text="{Binding RirDisplay}"
                                                               HorizontalOptions="Center"
                                                               VerticalOptions="Center"
                                                               FontFamily="DMSansMedium" FontSize="13"
                                                               TextColor="{Binding RirColor}"/>
                                                        <Border.GestureRecognizers>
                                                            <TapGestureRecognizer Tapped="OnRirTapped"/>
                                                            <PointerGestureRecognizer
                                                                PointerPressed="OnElemPointerPressed"
                                                                PointerReleased="OnElemPointerReleased"/>
                                                        </Border.GestureRecognizers>
                                                    </Border>

                                                    <!-- Done -->
                                                    <Border Grid.Column="5"
                                                            StrokeShape="RoundRectangle 8"
                                                            StrokeThickness="0"
                                                            BackgroundColor="{Binding IsCompleted, Converter={StaticResource BoolToColorConverter}}">
                                                        <Label Text="✓"
                                                               HorizontalOptions="Center"
                                                               VerticalOptions="Center"
                                                               FontSize="16"
                                                               TextColor="White"/>
                                                        <Border.GestureRecognizers>
                                                            <TapGestureRecognizer
                                                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ActiveWorkoutViewModel}}, Path=CompleteSetCommand}"
                                                                CommandParameter="{Binding .}"/>
                                                            <PointerGestureRecognizer
                                                                PointerPressed="OnDonePointerPressed"
                                                                PointerReleased="OnDonePointerReleased"/>
                                                        </Border.GestureRecognizers>
                                                    </Border>

                                                </Grid>
                                            </DataTemplate>
                                        </BindableLayout.ItemTemplate>
                                    </StackLayout>

                                    <!-- + SET / − SET row -->
                                    <Grid ColumnDefinitions="*,*"
                                          Padding="12,6,12,10" ColumnSpacing="8">
                                        <Button Grid.Column="0"
                                                Text="+ SET"
                                                Style="{StaticResource SecondaryButton}"
                                                BackgroundColor="{StaticResource ForgeSurface2}"
                                                TextColor="{StaticResource ForgeMuted}"
                                                FontFamily="BebasNeue" FontSize="14"
                                                CharacterSpacing="1"
                                                HeightRequest="36"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ActiveWorkoutViewModel}}, Path=AddSetCommand}"
                                                CommandParameter="{Binding .}">
                                            <Button.Behaviors>
                                                <views:AnimatedButtonBehavior/>
                                            </Button.Behaviors>
                                        </Button>
                                        <Button Grid.Column="1"
                                                Text="− SET"
                                                Style="{StaticResource SecondaryButton}"
                                                BackgroundColor="{StaticResource ForgeSurface2}"
                                                TextColor="{StaticResource ForgeMuted}"
                                                FontFamily="BebasNeue" FontSize="14"
                                                CharacterSpacing="1"
                                                HeightRequest="36"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ActiveWorkoutViewModel}}, Path=RemoveSetCommand}"
                                                CommandParameter="{Binding .}">
                                            <Button.Behaviors>
                                                <views:AnimatedButtonBehavior/>
                                            </Button.Behaviors>
                                        </Button>
                                    </Grid>

                                    <!-- Rest timer progress bar (active only) -->
                                    <Grid IsVisible="{Binding IsTimerActive}"
                                          ColumnDefinitions="Auto,*,Auto"
                                          BackgroundColor="{StaticResource ForgeSurface2}"
                                          Padding="16,10,16,10" ColumnSpacing="10">
                                        <views:AppIcon Grid.Column="0" Source="ic_timer.png"
                                                      WidthRequest="16" HeightRequest="16"
                                                      VerticalOptions="Center"/>
                                        <ProgressBar Grid.Column="1"
                                                     Progress="{Binding TimerProgress}"
                                                     ProgressColor="{StaticResource ForgeAccent}"
                                                     VerticalOptions="Center"/>
                                        <Label Grid.Column="2"
                                               Text="{Binding TimerDisplay}"
                                               FontFamily="BebasNeue" FontSize="18"
                                               TextColor="{StaticResource ForgeAccent}"
                                               VerticalOptions="Center"/>
                                    </Grid>

                                </StackLayout>
                            </Border>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </StackLayout>

                <!-- Add exercise button (inside scroll, after exercises) -->
                <Button Text="+ LÄGG TILL ÖVNING"
                        Style="{StaticResource SecondaryButton}"
                        BorderColor="{StaticResource ForgeBorderLight}"
                        BorderWidth="1"
                        FontFamily="BebasNeue" FontSize="16"
                        CharacterSpacing="1"
                        HeightRequest="48"
                        Command="{Binding AddExerciseCommand}">
                    <Button.Behaviors>
                        <views:AnimatedButtonBehavior/>
                    </Button.Behaviors>
                </Button>

            </StackLayout>
        </ScrollView>

        <!-- Floating FAB: avsluta pass -->
        <Button Grid.Row="1"
                Text="AVSLUTA PASS"
                Style="{StaticResource PrimaryButton}"
                HorizontalOptions="End"
                VerticalOptions="End"
                Margin="0,0,20,44"
                HeightRequest="48"
                WidthRequest="172"
                CornerRadius="24"
                Command="{Binding FinishWorkoutCommand}">
            <Button.Behaviors>
                <views:AnimatedButtonBehavior/>
            </Button.Behaviors>
        </Button>

    </Grid>

</ContentPage>
