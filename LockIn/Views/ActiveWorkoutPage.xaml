<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:LockIn.ViewModels"
             xmlns:views="clr-namespace:LockIn.Views"
             xmlns:controls="clr-namespace:LockIn.Controls"
             x:Class="LockIn.Views.ActiveWorkoutPage"
             x:DataType="vm:ActiveWorkoutViewModel"
             xmlns:ios="clr-namespace:Microsoft.Maui.Controls.PlatformConfiguration.iOSSpecific;assembly=Microsoft.Maui.Controls"
             Shell.NavBarIsVisible="False"
             Shell.TabBarIsVisible="False"
             BackgroundColor="Transparent"
             ios:Page.UseSafeArea="False">

    <ContentPage.Resources>
        <views:BoolToColorConverter x:Key="BoolToColorConverter"/>
        <vm:CompletedOpacityConverter x:Key="CompletedOpacityConverter"/>
        <!-- Page is always dark — override AppThemeBinding label colors -->
        <Style TargetType="Label">
            <Setter Property="TextColor" Value="{StaticResource ForgeText}" />
            <Setter Property="FontFamily" Value="DMSansRegular" />
            <Setter Property="FontSize" Value="14" />
        </Style>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*" SafeAreaEdges="None">

        <!-- Atmosfärisk bakgrund -->
        <controls:AtmosphericBackgroundView Grid.RowSpan="2" InputTransparent="True"/>

        <!-- Permanent status bar gradient (alltid synlig, fyller Dynamic Island-zonen) -->
        <BoxView Grid.RowSpan="2" VerticalOptions="Start" HeightRequest="90" InputTransparent="True" ZIndex="19">
            <BoxView.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#28141418" Offset="0.0"/>
                    <GradientStop Color="#00141418" Offset="1.0"/>
                </LinearGradientBrush>
            </BoxView.Background>
        </BoxView>

        <!-- Sticky header gradient + compact mini-toolbar (fades in on scroll) -->
        <Grid x:Name="StickyHeader" Grid.RowSpan="2" VerticalOptions="Start" ZIndex="20" Opacity="0"
              HeightRequest="150" SafeAreaEdges="None">
            <BoxView InputTransparent="True">
                <BoxView.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#D8141418" Offset="0.0"/>
                        <GradientStop Color="#90141418" Offset="0.35"/>
                        <GradientStop Color="#38141418" Offset="0.65"/>
                        <GradientStop Color="#00141418" Offset="1.0"/>
                    </LinearGradientBrush>
                </BoxView.Background>
            </BoxView>
            <!-- Compact mini-toolbar: back + plate-calc + tid (inget namn) -->
            <Grid Padding="16,56,20,8" ColumnDefinitions="Auto,*,Auto,Auto" VerticalOptions="Start">
                <Border Grid.Column="0"
                        WidthRequest="36" HeightRequest="36"
                        StrokeShape="Ellipse"
                        BackgroundColor="#17FFFFFF"
                        Stroke="#29FFFFFF"
                        StrokeThickness="0.5"
                        VerticalOptions="Center">
                    <Path Style="{StaticResource BackChevron}"/>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnBackClicked"/>
                    </Border.GestureRecognizers>
                </Border>
                <Border Grid.Column="2"
                        WidthRequest="40" HeightRequest="40"
                        BackgroundColor="{AppThemeBinding Light={StaticResource LightSurface2}, Dark={StaticResource ForgeSurface2}}"
                        StrokeShape="Ellipse" StrokeThickness="0"
                        Margin="0,0,6,0">
                    <views:AppIcon Source="ic_scale.png"
                                   WidthRequest="20" HeightRequest="20"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding OpenPlateCalculatorCommand}"/>
                    </Border.GestureRecognizers>
                </Border>
                <Label Grid.Column="3" Text="{Binding ElapsedTime}"
                       TextColor="{StaticResource ForgeAccent}"
                       FontFamily="BebasNeue" FontSize="22"
                       VerticalOptions="Center"/>
            </Grid>
        </Grid>

        <!-- Scrollable content (TopBar ligger som första element och scrollar bort) -->
        <ScrollView x:Name="MainScrollView" Grid.Row="0" Grid.RowSpan="2" VerticalScrollBarVisibility="Never" Scrolled="OnScrolled">
            <StackLayout Padding="16,0,16,120" Spacing="12">

                <!-- Top bar — scrollar med innehållet -->
                <Grid x:Name="TopBar" Padding="0,56,4,8" ColumnDefinitions="Auto,*,Auto,Auto">
                    <Border Grid.Column="0"
                            WidthRequest="36" HeightRequest="36"
                            StrokeShape="Ellipse"
                            BackgroundColor="#17FFFFFF"
                            Stroke="#29FFFFFF"
                            StrokeThickness="0.5"
                            VerticalOptions="Center">
                        <Path Style="{StaticResource BackChevron}"/>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnBackClicked"/>
                        </Border.GestureRecognizers>
                    </Border>
                    <Label Grid.Column="1" Text="{Binding TemplateName}"
                           Style="{StaticResource DisplayLabel}"
                           TextColor="{StaticResource ForgeText}"
                           FontSize="22"
                           HorizontalOptions="Center" VerticalOptions="Center"/>
                    <Border Grid.Column="2"
                            WidthRequest="40" HeightRequest="40"
                            BackgroundColor="{AppThemeBinding Light={StaticResource LightSurface2}, Dark={StaticResource ForgeSurface2}}"
                            StrokeShape="Ellipse" StrokeThickness="0"
                            Margin="0,0,6,0">
                        <views:AppIcon Source="ic_scale.png"
                                       WidthRequest="20" HeightRequest="20"
                                       HorizontalOptions="Center" VerticalOptions="Center"/>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding OpenPlateCalculatorCommand}"/>
                        </Border.GestureRecognizers>
                    </Border>
                    <Label Grid.Column="3" Text="{Binding ElapsedTime}"
                           TextColor="{StaticResource ForgeAccent}"
                           FontFamily="BebasNeue" FontSize="22"
                           VerticalOptions="Center"/>
                </Grid>


                <!-- PR Banner -->
                <Border IsVisible="{Binding HasPR}"
                        BackgroundColor="{StaticResource ForgeAccentAmberDim}"
                        Stroke="{StaticResource ForgeAccentAmber}"
                        StrokeShape="RoundRectangle 12"
                        StrokeThickness="0.5" Padding="14,12">
                    <Grid ColumnDefinitions="Auto,*">
                        <Label Grid.Column="0" Text="🏆" FontSize="20"
                               VerticalOptions="Center" Margin="0,0,10,0"/>
                        <Label Grid.Column="1" Text="{Binding PrMessage}"
                               TextColor="{StaticResource ForgeAccentAmber}"
                               FontFamily="DMSansMedium" FontSize="13"
                               LineBreakMode="WordWrap"/>
                    </Grid>
                </Border>

                <!-- Auto-progression Banner -->
                <Border IsVisible="{Binding HasAutoProgress}"
                        BackgroundColor="{StaticResource ForgeAccentDim}"
                        StrokeShape="RoundRectangle 12"
                        StrokeThickness="0" Padding="14,12">
                    <Grid ColumnDefinitions="Auto,*">
                        <Label Grid.Column="0" Text="📈" FontSize="20"
                               VerticalOptions="Center" Margin="0,0,10,0"/>
                        <Label Grid.Column="1" Text="{Binding AutoProgressMessage}"
                               TextColor="{StaticResource ForgeAccent}"
                               FontFamily="DMSansMedium" FontSize="13"
                               LineBreakMode="WordWrap"/>
                    </Grid>
                </Border>

                <!-- Exercise sections — one card per exercise -->
                <StackLayout x:Name="ExercisesLayout" BindableLayout.ItemsSource="{Binding Exercises}" Spacing="14">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="vm:WorkoutExerciseSection">
                            <Border BackgroundColor="{StaticResource ForgeSurface}"
                                    StrokeShape="RoundRectangle 18"
                                    StrokeThickness="0"
                                    Padding="0">
                                <Border.Shadow>
                                    <Shadow Brush="{Binding AccentBrush}" Offset="0,0" Radius="22" Opacity="0.18"/>
                                </Border.Shadow>
                                <StackLayout Spacing="0">

                                    <!-- Superset badge (visible when IsInSuperset) -->
                                    <Grid IsVisible="{Binding IsInSuperset}"
                                          Padding="16,8,16,0">
                                        <Border BackgroundColor="{StaticResource ForgeAccentDim}"
                                                StrokeShape="RoundRectangle 4"
                                                StrokeThickness="0"
                                                Padding="8,3"
                                                HorizontalOptions="Start">
                                            <Label Text="SUPERSET"
                                                   TextColor="{StaticResource ForgeAccent}"
                                                   FontFamily="BebasNeue" FontSize="11"
                                                   CharacterSpacing="1"/>
                                        </Border>
                                    </Grid>

                                    <!-- Exercise header: punkt + name + info + rest time badge + remove -->
                                    <Grid ColumnDefinitions="12,*,Auto,Auto,Auto" ColumnSpacing="10"
                                          Padding="18,12,12,10">
                                        <Ellipse Grid.Column="0"
                                                 WidthRequest="10" HeightRequest="10"
                                                 Fill="{Binding AccentColor}"
                                                 VerticalOptions="Center"/>
                                        <Label Grid.Column="1"
                                               Text="{Binding ExerciseName}"
                                               FontFamily="DMSansMedium" FontSize="16"
                                               VerticalOptions="Center"/>

                                        <!-- Info button — only visible when description exists -->
                                        <Border Grid.Column="2"
                                                IsVisible="{Binding HasDescription}"
                                                BackgroundColor="Transparent"
                                                StrokeThickness="0"
                                                Padding="4,6,8,6">
                                            <Label Text="ⓘ"
                                                   TextColor="{StaticResource ForgeMuted}"
                                                   FontSize="16"
                                                   VerticalOptions="Center"/>
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ActiveWorkoutViewModel}}, Path=ShowExerciseInfoCommand}"
                                                    CommandParameter="{Binding .}"/>
                                            </Border.GestureRecognizers>
                                        </Border>

                                        <!-- Rest time badge — tap to change -->
                                        <Border Grid.Column="3"
                                                BackgroundColor="{StaticResource ForgeAccentDim}"
                                                StrokeShape="RoundRectangle 8"
                                                StrokeThickness="0"
                                                Padding="10,6">
                                            <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="4">
                                                <views:AppIcon Grid.Column="0" Source="ic_timer.png"
                                                              WidthRequest="13" HeightRequest="13"
                                                              VerticalOptions="Center"/>
                                                <Label Grid.Column="1"
                                                       Text="{Binding RestDisplay}"
                                                       TextColor="{StaticResource ForgeAccent}"
                                                       FontFamily="DMSansMedium" FontSize="13"
                                                       VerticalOptions="Center"/>
                                            </Grid>
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ActiveWorkoutViewModel}}, Path=ChangeRestTimeCommand}"
                                                    CommandParameter="{Binding .}"/>
                                                <PointerGestureRecognizer
                                                    PointerPressed="OnElemPointerPressed"
                                                    PointerReleased="OnElemPointerReleased"/>
                                            </Border.GestureRecognizers>
                                        </Border>

                                        <!-- Remove exercise button -->
                                        <Border Grid.Column="4"
                                                BackgroundColor="Transparent"
                                                StrokeThickness="0"
                                                Padding="8,6,4,6">
                                            <Label Text="✕"
                                                   TextColor="{StaticResource ForgeMuted}"
                                                   FontSize="14"
                                                   VerticalOptions="Center"/>
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ActiveWorkoutViewModel}}, Path=RemoveExerciseCommand}"
                                                    CommandParameter="{Binding .}"/>
                                            </Border.GestureRecognizers>
                                        </Border>
                                    </Grid>

                                    <!-- Column headers -->
                                    <Grid ColumnDefinitions="32,*,14,*,42,36"
                                          Padding="16,0,16,6" ColumnSpacing="6">
                                        <Label Grid.Column="0" Text="SET"
                                               Style="{StaticResource SectionLabel}" FontSize="10"/>
                                        <Label Grid.Column="1" Text="KG"
                                               Style="{StaticResource SectionLabel}" FontSize="10"
                                               HorizontalTextAlignment="Center"/>
                                        <Label Grid.Column="3" Text="REPS"
                                               Style="{StaticResource SectionLabel}" FontSize="10"
                                               HorizontalTextAlignment="Center"/>
                                        <Label Grid.Column="4" Text="RIR"
                                               Style="{StaticResource SectionLabel}" FontSize="10"
                                               HorizontalTextAlignment="Center"/>
                                    </Grid>

                                    <!-- Set rows -->
                                    <StackLayout BindableLayout.ItemsSource="{Binding Sets}" Spacing="0">
                                        <BindableLayout.ItemTemplate>
                                            <DataTemplate x:DataType="vm:LoggedSetRow">
                                                <Grid ColumnDefinitions="32,*,14,*,42,36"
                                                      Padding="16,5,16,5" ColumnSpacing="6"
                                                      HeightRequest="46"
                                                      Opacity="{Binding IsCompleted, Converter={StaticResource CompletedOpacityConverter}}"
                                                      Loaded="OnSetRowLoaded">

                                                    <!-- Set number / type label — tap to change type -->
                                                    <Border Grid.Column="0"
                                                            BackgroundColor="Transparent"
                                                            StrokeThickness="0"
                                                            Padding="0"
                                                            HeightRequest="36">
                                                        <Grid>
                                                            <Label Text="{Binding SetLabel}"
                                                                   TextColor="{Binding SetLabelColor}"
                                                                   FontFamily="DMSansMedium" FontSize="13"
                                                                   HorizontalOptions="Center"
                                                                   VerticalOptions="Center"/>
                                                            <!-- PR star badge -->
                                                            <Label Text="★"
                                                                   FontSize="8"
                                                                   TextColor="#FBBF24"
                                                                   HorizontalOptions="End"
                                                                   VerticalOptions="Start"
                                                                   Margin="0,2,0,0"
                                                                   IsVisible="{Binding IsPR}"/>
                                                        </Grid>
                                                        <Border.GestureRecognizers>
                                                            <TapGestureRecognizer
                                                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ActiveWorkoutViewModel}}, Path=ChangeSetTypeCommand}"
                                                                CommandParameter="{Binding .}"/>
                                                            <PointerGestureRecognizer
                                                                PointerPressed="OnElemPointerPressed"
                                                                PointerReleased="OnElemPointerReleased"/>
                                                        </Border.GestureRecognizers>
                                                    </Border>

                                                    <!-- Weight -->
                                                    <Border Grid.Column="1"
                                                            BackgroundColor="{StaticResource ForgeSurface2}"
                                                            StrokeShape="RoundRectangle 8"
                                                            StrokeThickness="0" Padding="4,2">
                                                        <Entry Text="{Binding WeightText}"
                                                               Keyboard="Numeric"
                                                               Placeholder="{Binding PrevWeightHint}"
                                                               PlaceholderColor="{StaticResource ForgeTextSecondary}"
                                                               HorizontalTextAlignment="Center"
                                                               FontFamily="DMSansMedium" FontSize="15"
                                                               BackgroundColor="Transparent"
                                                               TextColor="{StaticResource ForgeText}"
                                                               HeightRequest="36" Margin="0"/>
                                                    </Border>

                                                    <!-- Separator (× or ⏱) -->
                                                    <Label Grid.Column="2"
                                                           Text="{Binding SeparatorLabel}"
                                                           Style="{StaticResource MutedLabel}"
                                                           HorizontalOptions="Center"
                                                           VerticalOptions="Center"/>

                                                    <!-- Reps / Duration -->
                                                    <Border Grid.Column="3"
                                                            BackgroundColor="{StaticResource ForgeSurface2}"
                                                            StrokeShape="RoundRectangle 8"
                                                            StrokeThickness="0" Padding="4,2">
                                                        <Entry Text="{Binding RepsText}"
                                                               Keyboard="Numeric"
                                                               Placeholder="{Binding RepsPlaceholder}"
                                                               PlaceholderColor="{StaticResource ForgeTextSecondary}"
                                                               HorizontalTextAlignment="Center"
                                                               FontFamily="DMSansMedium" FontSize="15"
                                                               BackgroundColor="Transparent"
                                                               TextColor="{StaticResource ForgeText}"
                                                               HeightRequest="36" Margin="0"/>
                                                    </Border>

                                                    <!-- RIR — tap to cycle 0-5 -->
                                                    <Border Grid.Column="4"
                                                            BackgroundColor="{StaticResource ForgeSurface2}"
                                                            StrokeShape="RoundRectangle 8"
                                                            StrokeThickness="0">
                                                        <Label Text="{Binding RirDisplay}"
                                                               HorizontalOptions="Center"
                                                               VerticalOptions="Center"
                                                               FontFamily="DMSansMedium" FontSize="13"
                                                               TextColor="{Binding RirColor}"/>
                                                        <Border.GestureRecognizers>
                                                            <TapGestureRecognizer Tapped="OnRirTapped"/>
                                                            <PointerGestureRecognizer
                                                                PointerPressed="OnElemPointerPressed"
                                                                PointerReleased="OnElemPointerReleased"/>
                                                        </Border.GestureRecognizers>
                                                    </Border>

                                                    <!-- Done -->
                                                    <Border Grid.Column="5"
                                                            StrokeShape="RoundRectangle 8"
                                                            StrokeThickness="0"
                                                            BackgroundColor="{Binding IsCompleted, Converter={StaticResource BoolToColorConverter}}">
                                                        <Label Text="✓"
                                                               HorizontalOptions="Center"
                                                               VerticalOptions="Center"
                                                               FontSize="16"
                                                               TextColor="White"/>
                                                        <Border.GestureRecognizers>
                                                            <TapGestureRecognizer
                                                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ActiveWorkoutViewModel}}, Path=CompleteSetCommand}"
                                                                CommandParameter="{Binding .}"/>
                                                            <PointerGestureRecognizer
                                                                PointerPressed="OnDonePointerPressed"
                                                                PointerReleased="OnDonePointerReleased"/>
                                                        </Border.GestureRecognizers>
                                                    </Border>

                                                </Grid>
                                            </DataTemplate>
                                        </BindableLayout.ItemTemplate>
                                    </StackLayout>

                                    <!-- + SET / − SET row -->
                                    <Grid ColumnDefinitions="*,*"
                                          Padding="12,6,12,10" ColumnSpacing="8">
                                        <Button Grid.Column="0"
                                                Text="+ SET"
                                                Style="{StaticResource SecondaryButton}"
                                                BackgroundColor="{StaticResource ForgeSurface2}"
                                                TextColor="{StaticResource ForgeMuted}"
                                                FontFamily="BebasNeue" FontSize="14"
                                                CharacterSpacing="1"
                                                HeightRequest="36"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ActiveWorkoutViewModel}}, Path=AddSetCommand}"
                                                CommandParameter="{Binding .}">
                                            <Button.Behaviors>
                                                <views:AnimatedButtonBehavior/>
                                            </Button.Behaviors>
                                        </Button>
                                        <Button Grid.Column="1"
                                                Text="− SET"
                                                Style="{StaticResource SecondaryButton}"
                                                BackgroundColor="{StaticResource ForgeSurface2}"
                                                TextColor="{StaticResource ForgeMuted}"
                                                FontFamily="BebasNeue" FontSize="14"
                                                CharacterSpacing="1"
                                                HeightRequest="36"
                                                Clicked="OnRemoveSetClicked">
                                            <Button.Behaviors>
                                                <views:AnimatedButtonBehavior/>
                                            </Button.Behaviors>
                                        </Button>
                                    </Grid>

                                    <!-- Rest timer progress bar (active only) -->
                                    <Grid IsVisible="{Binding IsTimerActive}"
                                          ColumnDefinitions="Auto,*,Auto"
                                          BackgroundColor="{StaticResource ForgeSurface2}"
                                          Padding="16,10,16,10" ColumnSpacing="10">
                                        <views:AppIcon Grid.Column="0" Source="ic_timer.png"
                                                      WidthRequest="16" HeightRequest="16"
                                                      VerticalOptions="Center"/>
                                        <ProgressBar Grid.Column="1"
                                                     Progress="{Binding TimerProgress}"
                                                     ProgressColor="{StaticResource ForgeAccent}"
                                                     VerticalOptions="Center"/>
                                        <Label Grid.Column="2"
                                               Text="{Binding TimerDisplay}"
                                               FontFamily="BebasNeue" FontSize="18"
                                               TextColor="{StaticResource ForgeAccent}"
                                               VerticalOptions="Center"/>
                                    </Grid>

                                </StackLayout>
                            </Border>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </StackLayout>

                <!-- Add exercise button (inside scroll, after exercises) -->
                <Border HeightRequest="48"
                        BackgroundColor="Transparent"
                        StrokeShape="RoundRectangle 12"
                        Stroke="{StaticResource ForgeBorderLight}"
                        StrokeThickness="1">
                    <Label Text="+ LÄGG TILL ÖVNING"
                           FontFamily="BebasNeue" FontSize="16" CharacterSpacing="1"
                           TextColor="{StaticResource ForgeText}"
                           HorizontalOptions="Center" VerticalOptions="Center"/>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding AddExerciseCommand}" Tapped="OnAddExerciseTapped"/>
                    </Border.GestureRecognizers>
                </Border>

            </StackLayout>
        </ScrollView>

        <!-- Confetti overlay — full screen, triggered on PR -->
        <controls:ConfettiView x:Name="Confetti"
                               Grid.Row="0" Grid.RowSpan="2"
                               InputTransparent="True"
                               ZIndex="50"
                               HorizontalOptions="Fill"
                               VerticalOptions="Fill"/>

        <!-- Bottom gradient fade — matchar topp-gradienten spegelvänt -->
        <BoxView Grid.RowSpan="2" InputTransparent="True" VerticalOptions="End" HeightRequest="150" ZIndex="22">
            <BoxView.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#00141418" Offset="0.0"/>
                    <GradientStop Color="#38141418" Offset="0.35"/>
                    <GradientStop Color="#90141418" Offset="0.65"/>
                    <GradientStop Color="#141418" Offset="1.0"/>
                </LinearGradientBrush>
            </BoxView.Background>
        </BoxView>

        <!-- Floating FAB: avsluta pass — silver pill (samma stil som FRITT PASS) -->
        <Border Grid.Row="1"
                StrokeShape="RoundRectangle 28" StrokeThickness="0"
                HorizontalOptions="End" VerticalOptions="End"
                Margin="0,0,18,44"
                HeightRequest="56" WidthRequest="192"
                Padding="20,0"
                ZIndex="30">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#FAFAFA" Offset="0.0"/>
                    <GradientStop Color="#E5E5E8" Offset="0.25"/>
                    <GradientStop Color="#B8B8BC" Offset="0.60"/>
                    <GradientStop Color="#7A7A80" Offset="1.0"/>
                </LinearGradientBrush>
            </Border.Background>
            <Border.Shadow>
                <Shadow Brush="#B8B8BC" Offset="0,6" Radius="28" Opacity="0.45"/>
            </Border.Shadow>
            <HorizontalStackLayout Spacing="10" HorizontalOptions="Center" VerticalOptions="Center">
                <views:AppIcon Source="ic_check.png"
                               WidthRequest="18" HeightRequest="18"
                               ForceTint="#0E0E10"
                               VerticalOptions="Center"/>
                <Label Text="AVSLUTA PASS"
                       FontFamily="BebasNeue" FontSize="17" CharacterSpacing="2"
                       TextColor="#0E0E10" VerticalOptions="Center"/>
            </HorizontalStackLayout>
            <Border.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding FinishWorkoutCommand}"/>
                <PointerGestureRecognizer PointerPressed="OnDonePointerPressed" PointerReleased="OnDonePointerReleased"/>
            </Border.GestureRecognizers>
        </Border>

    </Grid>

</ContentPage>
