<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:LockIn.ViewModels"
             xmlns:models="clr-namespace:LockIn.Models"
             xmlns:views="clr-namespace:LockIn.Views"
             xmlns:controls="clr-namespace:LockIn.Controls"
             xmlns:ios="clr-namespace:Microsoft.Maui.Controls.PlatformConfiguration.iOSSpecific;assembly=Microsoft.Maui.Controls"
             x:Class="LockIn.Views.KroppPage"
             x:DataType="vm:KroppViewModel"
             Title="Kropp"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light={StaticResource LightBackground}, Dark={StaticResource ForgeBackground}}"
             ios:Page.UseSafeArea="False">

    <Grid SafeAreaEdges="None">

        <!-- Permanent status bar gradient (alltid synlig, fyller Dynamic Island-zonen) -->
        <BoxView VerticalOptions="Start" HeightRequest="90" InputTransparent="True" ZIndex="19">
            <BoxView.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="{AppThemeBinding Light=#28FCFCFC, Dark=#280E0E10}" Offset="0.0"/>
                    <GradientStop Color="{AppThemeBinding Light=#00FCFCFC, Dark=#000E0E10}" Offset="1.0"/>
                </LinearGradientBrush>
            </BoxView.Background>
        </BoxView>

        <!-- Sticky header (fades in on scroll) -->
        <Grid x:Name="StickyHeader" VerticalOptions="Start" ZIndex="20" Opacity="0"
              HeightRequest="150">
            <BoxView InputTransparent="True">
                <BoxView.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="{AppThemeBinding Light=#D8FCFCFC, Dark=#D80E0E10}" Offset="0.0"/>
                        <GradientStop Color="{AppThemeBinding Light=#90FCFCFC, Dark=#900E0E10}" Offset="0.35"/>
                        <GradientStop Color="{AppThemeBinding Light=#38FCFCFC, Dark=#380E0E10}" Offset="0.65"/>
                        <GradientStop Color="{AppThemeBinding Light=#00FCFCFC, Dark=#000E0E10}" Offset="1.0"/>
                    </LinearGradientBrush>
                </BoxView.Background>
            </BoxView>
            <Grid Padding="20,48,16,12" VerticalOptions="Start">
                <Label Text="KROPP"
                       HorizontalOptions="Center" HorizontalTextAlignment="Center"
                       Style="{StaticResource DisplayLabel}" FontSize="18"
                       VerticalOptions="Center"/>
                <Border HorizontalOptions="End" VerticalOptions="Center"
                        BackgroundColor="{AppThemeBinding Light={StaticResource LightSurface2}, Dark={StaticResource ForgeSurface2}}"
                        StrokeShape="RoundRectangle 12" StrokeThickness="0"
                        WidthRequest="44" HeightRequest="44">
                    <views:AppIcon Source="tab_settings.png"
                                  WidthRequest="20" HeightRequest="20"
                                  HorizontalOptions="Center" VerticalOptions="Center"/>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding OpenSettingsCommand}"/>
                    </Border.GestureRecognizers>
                </Border>
            </Grid>
        </Grid>

        <ActivityIndicator IsRunning="{Binding IsLoading}"
                           IsVisible="{Binding IsLoading}"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"/>

        <ScrollView IsVisible="{Binding IsLoading, Converter={x:Static vm:InverseBoolConverter.Instance}}"
                    VerticalScrollBarVisibility="Never"
                    Scrolled="OnScrolled">
                <VerticalStackLayout Padding="16,56,16,100" Spacing="14">

                    <!-- Page title -->
                    <Grid ColumnDefinitions="*,Auto" Margin="4,0,0,4">
                        <Label Grid.Column="0" Text="KROPP"
                               FontFamily="BebasNeue" FontSize="34" CharacterSpacing="1"
                               TextColor="{AppThemeBinding Light={StaticResource LightText}, Dark={StaticResource ForgeText}}"
                               VerticalOptions="Center"/>
                        <Border Grid.Column="1"
                                BackgroundColor="{AppThemeBinding Light={StaticResource LightSurface2}, Dark={StaticResource ForgeSurface2}}"
                                StrokeShape="RoundRectangle 12" StrokeThickness="0"
                                WidthRequest="44" HeightRequest="44"
                                VerticalOptions="Center">
                            <views:AppIcon Source="tab_settings.png"
                                          WidthRequest="20" HeightRequest="20"
                                          HorizontalOptions="Center" VerticalOptions="Center"/>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding OpenSettingsCommand}"/>
                            </Border.GestureRecognizers>
                        </Border>
                    </Grid>

                    <!-- Segment tabs -->
                    <Grid ColumnDefinitions="*,*,*" ColumnSpacing="0"
                          BackgroundColor="{AppThemeBinding Light={StaticResource LightSurface2}, Dark={StaticResource ForgeSurface2}}" HeightRequest="44">
                        <Border Grid.Column="0" BackgroundColor="{Binding Tab0Bg}"
                                StrokeShape="RoundRectangle 0" StrokeThickness="0">
                            <Label Text="VIKT"
                                   FontFamily="BebasNeue" FontSize="15" CharacterSpacing="1"
                                   TextColor="{Binding Tab0Fg}"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SelectTabCommand}" CommandParameter="{x:Int32 0}"/>
                            </Border.GestureRecognizers>
                        </Border>
                        <Border Grid.Column="1" BackgroundColor="{Binding Tab1Bg}"
                                StrokeShape="RoundRectangle 0" StrokeThickness="0">
                            <Label Text="KROPP"
                                   FontFamily="BebasNeue" FontSize="15" CharacterSpacing="1"
                                   TextColor="{Binding Tab1Fg}"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SelectTabCommand}" CommandParameter="{x:Int32 1}"/>
                            </Border.GestureRecognizers>
                        </Border>
                        <Border Grid.Column="2" BackgroundColor="{Binding Tab2Bg}"
                                StrokeShape="RoundRectangle 0" StrokeThickness="0">
                            <Label Text="HEATMAP"
                                   FontFamily="BebasNeue" FontSize="15" CharacterSpacing="1"
                                   TextColor="{Binding Tab2Fg}"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SelectTabCommand}" CommandParameter="{x:Int32 2}"/>
                            </Border.GestureRecognizers>
                        </Border>
                    </Grid>

                    <!-- ═══ VIKT TAB ═══ -->
                    <VerticalStackLayout IsVisible="{Binding IsViktTab}" Spacing="14">

                        <!-- Latest weight hero -->
                        <Border Style="{StaticResource CardFrame}" Padding="24,20">
                            <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                                <Label Text="{Binding LatestWeight}"
                                       FontFamily="BebasNeue" FontSize="52"
                                       CharacterSpacing="1"
                                       TextColor="{AppThemeBinding Light={StaticResource LightAccent}, Dark={StaticResource ForgeAccent}}"
                                       HorizontalOptions="Center"/>
                                <Label Text="{Binding LatestWeightDate}"
                                       Style="{StaticResource MutedLabel}"
                                       HorizontalOptions="Center"/>
                                <Label Text="Ingen data ännu – logga din vikt nedan"
                                       Style="{StaticResource MutedLabel}"
                                       HorizontalOptions="Center"
                                       HorizontalTextAlignment="Center"
                                       IsVisible="{Binding HasWeightData, Converter={x:Static vm:InverseBoolConverter.Instance}}"/>
                            </VerticalStackLayout>
                        </Border>

                        <!-- Chart -->
                        <Border Style="{StaticResource CardFrame}" Padding="12,14,12,10"
                                IsVisible="{Binding HasWeightData}">
                            <VerticalStackLayout Spacing="6">
                                <Label Text="VIKTUTVECKLING"
                                       Style="{StaticResource SectionLabel}"
                                       Margin="4,0,0,0"/>
                                <controls:LineChartView Points="{Binding WeightChartPoints}" StrokeColor="#6EA8DC" HeightRequest="180" BackgroundColor="Transparent"/>
                            </VerticalStackLayout>
                        </Border>

                        <!-- Recent entries -->
                        <Label Text="SENASTE LOGGNINGAR"
                               Style="{StaticResource SectionLabel}"
                               IsVisible="{Binding HasWeightData}"/>
                        <Border Style="{StaticResource CardFrame}" Padding="0,4"
                                IsVisible="{Binding HasWeightData}">
                            <StackLayout BindableLayout.ItemsSource="{Binding WeightEntries}" Spacing="0">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate x:DataType="models:BodyWeightEntry">
                                        <Grid ColumnDefinitions="*,Auto,Auto" Padding="16,10,12,10">
                                            <Label Grid.Column="0"
                                                   Text="{Binding LoggedAt, StringFormat='{0:d MMM yyyy  HH:mm}'}"
                                                   Style="{StaticResource MutedLabel}"
                                                   VerticalOptions="Center"/>
                                            <Label Grid.Column="1"
                                                   Text="{Binding WeightKg, StringFormat='{0:F1} kg'}"
                                                   FontFamily="DMSansMedium" FontSize="15"
                                                   TextColor="{AppThemeBinding Light={StaticResource LightAccent}, Dark={StaticResource ForgeAccent}}"
                                                   VerticalOptions="Center"
                                                   Margin="0,0,12,0"/>
                                            <Border Grid.Column="2"
                                                    WidthRequest="36" HeightRequest="36"
                                                    BackgroundColor="{AppThemeBinding Light={StaticResource LightSurface2}, Dark={StaticResource ForgeSurface2}}"
                                                    StrokeShape="Ellipse" StrokeThickness="0">
                                                <views:AppIcon Source="ic_trash.png"
                                                               WidthRequest="16" HeightRequest="16"
                                                               HorizontalOptions="Center" VerticalOptions="Center"/>
                                                <Border.GestureRecognizers>
                                                    <TapGestureRecognizer
                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:KroppViewModel}}, Path=DeleteWeightEntryCommand}"
                                                        CommandParameter="{Binding .}"/>
                                                </Border.GestureRecognizers>
                                            </Border>
                                        </Grid>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </StackLayout>
                        </Border>

                        <Border BackgroundColor="{StaticResource ForgeAccent}"
                                StrokeShape="RoundRectangle 26" StrokeThickness="0"
                                HeightRequest="56" HorizontalOptions="Fill">
                            <HorizontalStackLayout Spacing="10"
                                                   HorizontalOptions="Center" VerticalOptions="Center">
                                <views:AppIcon Source="ic_plus.png"
                                               WidthRequest="18" HeightRequest="18"
                                               ForceTint="White" VerticalOptions="Center"/>
                                <Label Text="LOGGA VIKT"
                                       FontFamily="BebasNeue" FontSize="20" CharacterSpacing="3"
                                       TextColor="White" VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding LogWeightCommand}"/>
                            </Border.GestureRecognizers>
                        </Border>

                    </VerticalStackLayout>

                    <!-- ═══ KROPP TAB ═══ -->
                    <VerticalStackLayout IsVisible="{Binding IsKroppTab}" Spacing="14">

                        <!-- Latest measurements -->
                        <Border Style="{StaticResource CardFrame}" Padding="16,14">
                            <VerticalStackLayout Spacing="12">
                                <Label Text="SENASTE MÄTNING" Style="{StaticResource SectionLabel}"/>
                                <Grid ColumnDefinitions="*,*,*,*,*" ColumnSpacing="8">
                                    <VerticalStackLayout Grid.Column="0" Spacing="3" HorizontalOptions="Center">
                                        <Label Text="{Binding LatestWaist}"
                                               FontFamily="BebasNeue" FontSize="22"
                                               TextColor="{StaticResource ForgeAccent}"
                                               HorizontalOptions="Center"/>
                                        <Label Text="MIDJA" Style="{StaticResource SectionLabel}" FontSize="9" HorizontalOptions="Center"/>
                                    </VerticalStackLayout>
                                    <VerticalStackLayout Grid.Column="1" Spacing="3" HorizontalOptions="Center">
                                        <Label Text="{Binding LatestChest}"
                                               FontFamily="BebasNeue" FontSize="22"
                                               TextColor="{StaticResource ForgeAccent}"
                                               HorizontalOptions="Center"/>
                                        <Label Text="BRÖST" Style="{StaticResource SectionLabel}" FontSize="9" HorizontalOptions="Center"/>
                                    </VerticalStackLayout>
                                    <VerticalStackLayout Grid.Column="2" Spacing="3" HorizontalOptions="Center">
                                        <Label Text="{Binding LatestHip}"
                                               FontFamily="BebasNeue" FontSize="22"
                                               TextColor="{StaticResource ForgeAccent}"
                                               HorizontalOptions="Center"/>
                                        <Label Text="HÖFT" Style="{StaticResource SectionLabel}" FontSize="9" HorizontalOptions="Center"/>
                                    </VerticalStackLayout>
                                    <VerticalStackLayout Grid.Column="3" Spacing="3" HorizontalOptions="Center">
                                        <Label Text="{Binding LatestArm}"
                                               FontFamily="BebasNeue" FontSize="22"
                                               TextColor="{StaticResource ForgeAccent}"
                                               HorizontalOptions="Center"/>
                                        <Label Text="ARMAR" Style="{StaticResource SectionLabel}" FontSize="9" HorizontalOptions="Center"/>
                                    </VerticalStackLayout>
                                    <VerticalStackLayout Grid.Column="4" Spacing="3" HorizontalOptions="Center">
                                        <Label Text="{Binding LatestThigh}"
                                               FontFamily="BebasNeue" FontSize="22"
                                               TextColor="{StaticResource ForgeAccent}"
                                               HorizontalOptions="Center"/>
                                        <Label Text="LÅR" Style="{StaticResource SectionLabel}" FontSize="9" HorizontalOptions="Center"/>
                                    </VerticalStackLayout>
                                </Grid>
                                <Label Text="Ingen data ännu – logga dina mått nedan"
                                       Style="{StaticResource MutedLabel}"
                                       HorizontalOptions="Center"
                                       HorizontalTextAlignment="Center"
                                       IsVisible="{Binding HasCompositionData, Converter={x:Static vm:InverseBoolConverter.Instance}}"/>
                            </VerticalStackLayout>
                        </Border>

                        <!-- History list -->
                        <Label Text="HISTORIK" Style="{StaticResource SectionLabel}"
                               IsVisible="{Binding HasCompositionData}"/>
                        <Border Style="{StaticResource CardFrame}" Padding="0,4"
                                IsVisible="{Binding HasCompositionData}">
                            <StackLayout BindableLayout.ItemsSource="{Binding CompositionEntries}" Spacing="0">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate x:DataType="models:BodyCompositionEntry">
                                        <Grid ColumnDefinitions="*,Auto" Padding="16,10,12,10">
                                            <VerticalStackLayout Grid.Column="0" Spacing="2">
                                                <Label Text="{Binding LoggedAt, StringFormat='{0:d MMM yyyy}'}"
                                                       FontFamily="DMSansMedium" FontSize="14"
                                                       TextColor="{StaticResource ForgeText}"/>
                                                <Label Text="{Binding Summary}"
                                                       Style="{StaticResource MutedLabel}" FontSize="12"/>
                                            </VerticalStackLayout>
                                            <Border Grid.Column="1"
                                                    WidthRequest="36" HeightRequest="36"
                                                    BackgroundColor="{AppThemeBinding Light={StaticResource LightSurface2}, Dark={StaticResource ForgeSurface2}}"
                                                    StrokeShape="Ellipse" StrokeThickness="0">
                                                <views:AppIcon Source="ic_trash.png"
                                                               WidthRequest="16" HeightRequest="16"
                                                               HorizontalOptions="Center" VerticalOptions="Center"/>
                                                <Border.GestureRecognizers>
                                                    <TapGestureRecognizer
                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:KroppViewModel}}, Path=DeleteCompositionEntryCommand}"
                                                        CommandParameter="{Binding .}"/>
                                                </Border.GestureRecognizers>
                                            </Border>
                                        </Grid>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </StackLayout>
                        </Border>

                        <Border BackgroundColor="{StaticResource ForgeAccent}"
                                StrokeShape="RoundRectangle 26" StrokeThickness="0"
                                HeightRequest="56" HorizontalOptions="Fill">
                            <HorizontalStackLayout Spacing="10"
                                                   HorizontalOptions="Center" VerticalOptions="Center">
                                <views:AppIcon Source="ic_plus.png"
                                               WidthRequest="18" HeightRequest="18"
                                               ForceTint="White" VerticalOptions="Center"/>
                                <Label Text="LOGGA MÅTT"
                                       FontFamily="BebasNeue" FontSize="20" CharacterSpacing="3"
                                       TextColor="White" VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding LogCompositionCommand}"/>
                            </Border.GestureRecognizers>
                        </Border>

                    </VerticalStackLayout>

                    <!-- ═══ HEATMAP TAB ═══ -->
                    <VerticalStackLayout IsVisible="{Binding IsHeatmapTab}" Spacing="14">

                        <Label Text="MUSKELGRUPPER · 7 DAGAR"
                               Style="{StaticResource SectionLabel}"/>

                        <!-- Heatmap grid (byggs i code-behind) -->
                        <Grid x:Name="HeatmapGrid"
                              ColumnDefinitions="*,*,*,*"
                              ColumnSpacing="8" RowSpacing="8"/>

                    </VerticalStackLayout>

                </VerticalStackLayout>
            </ScrollView>

            <!-- Workout banner -->
            <Border x:Name="WorkoutBanner"
                    IsVisible="False"
                    BackgroundColor="{AppThemeBinding Light={StaticResource LightSurface}, Dark={StaticResource ForgeSurface}}"
                    Stroke="{StaticResource ForgeAccent}"
                    StrokeThickness="1.5"
                    StrokeShape="RoundRectangle 18,18,0,0"
                    Padding="20,14,20,36"
                    VerticalOptions="End"
                    ZIndex="10">
                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                    <Ellipse Grid.Column="0"
                             Fill="{StaticResource ForgeAccent}"
                             WidthRequest="8" HeightRequest="8"
                             VerticalOptions="Center"/>
                    <Label Grid.Column="1"
                           Text="PASS PÅGÅR"
                           FontFamily="BebasNeue" FontSize="16" CharacterSpacing="2"
                           TextColor="{AppThemeBinding Light={StaticResource LightText}, Dark={StaticResource ForgeText}}"
                           VerticalOptions="Center"/>
                    <Label Grid.Column="2"
                           Text="ÖPPNA ›"
                           FontFamily="BebasNeue" FontSize="14" CharacterSpacing="1"
                           TextColor="{StaticResource ForgeAccent}"
                           VerticalOptions="Center"/>
                </Grid>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnWorkoutBannerTapped"/>
                </Border.GestureRecognizers>
            </Border>

    <!-- Bottom gradient fade behind floating tab bar -->
    <BoxView Grid.RowSpan="99" InputTransparent="True" VerticalOptions="End" HeightRequest="140">
        <BoxView.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="Transparent" Offset="0"/>
                <GradientStop Color="{AppThemeBinding Light=#FCFCFC, Dark=#0E0E10}" Offset="1"/>
            </LinearGradientBrush>
        </BoxView.Background>
    </BoxView>

    </Grid>
</ContentPage>