<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:LockIn.ViewModels"
             xmlns:models="clr-namespace:LockIn.Models"
             xmlns:views="clr-namespace:LockIn.Views"
             xmlns:controls="clr-namespace:LockIn.Controls"
             xmlns:ios="clr-namespace:Microsoft.Maui.Controls.PlatformConfiguration.iOSSpecific;assembly=Microsoft.Maui.Controls"
             xmlns:loc="clr-namespace:LockIn.Resources.Strings"
             x:Class="LockIn.Views.KroppPage"
             x:DataType="vm:KroppViewModel"
             Title="{loc:Localize Tab_Body}"
             Shell.NavBarIsVisible="False"
             BackgroundColor="Transparent">

    <Grid SafeAreaEdges="None">

        <!-- Atmosf�risk bakgrund -->
        <controls:AtmosphericBackgroundView InputTransparent="True"/>

        <!-- Permanent status bar gradient (alltid synlig, fyller Dynamic Island-zonen) -->
        <BoxView VerticalOptions="Start" HeightRequest="90" InputTransparent="True" ZIndex="19">
            <BoxView.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="{AppThemeBinding Light=#28FCFCFC, Dark=#28141418}" Offset="0.0"/>
                    <GradientStop Color="{AppThemeBinding Light=#00FCFCFC, Dark=#00141418}" Offset="1.0"/>
                </LinearGradientBrush>
            </BoxView.Background>
        </BoxView>

        <!-- Sticky header (fades in on scroll) -->
        <Grid x:Name="StickyHeader" VerticalOptions="Start" ZIndex="20" Opacity="0"
              HeightRequest="150" SafeAreaEdges="None">
            <BoxView InputTransparent="True">
                <BoxView.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="{AppThemeBinding Light=#D8FCFCFC, Dark=#D8141418}" Offset="0.0"/>
                        <GradientStop Color="{AppThemeBinding Light=#90FCFCFC, Dark=#90141418}" Offset="0.35"/>
                        <GradientStop Color="{AppThemeBinding Light=#38FCFCFC, Dark=#38141418}" Offset="0.65"/>
                        <GradientStop Color="{AppThemeBinding Light=#00FCFCFC, Dark=#00141418}" Offset="1.0"/>
                    </LinearGradientBrush>
                </BoxView.Background>
            </BoxView>
            <Grid Padding="20,14,16,12" VerticalOptions="Start">
                <Label Text="{loc:Localize Kropp_Title}"
                       HorizontalOptions="Center" HorizontalTextAlignment="Center"
                       Style="{StaticResource DisplayLabel}" FontSize="18"
                       VerticalOptions="Center"/>
                <Border HorizontalOptions="End" VerticalOptions="Center"
                        BackgroundColor="{AppThemeBinding Light={StaticResource LightSurface2}, Dark={StaticResource ForgeSurface2}}"
                        StrokeShape="RoundRectangle 12" StrokeThickness="0"
                        WidthRequest="44" HeightRequest="44">
                    <views:AppIcon Source="tab_settings.png"
                                  WidthRequest="20" HeightRequest="20"
                                  HorizontalOptions="Center" VerticalOptions="Center"/>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding OpenSettingsCommand}"/>
                    </Border.GestureRecognizers>
                </Border>
            </Grid>
        </Grid>

        <ActivityIndicator IsRunning="{Binding IsLoading}"
                           IsVisible="{Binding IsLoading}"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"/>

        <ScrollView IsVisible="{Binding IsLoading, Converter={x:Static vm:InverseBoolConverter.Instance}}"
                    VerticalScrollBarVisibility="Never"
                    Scrolled="OnScrolled">
                <VerticalStackLayout Padding="16,56,16,100" Spacing="14">

                    <!-- Page title -->
                    <Grid ColumnDefinitions="*,Auto" Margin="4,0,0,4">
                        <Label Grid.Column="0" Text="{loc:Localize Kropp_Title}"
                               FontFamily="BebasNeue" FontSize="34" CharacterSpacing="1"
                               TextColor="{AppThemeBinding Light={StaticResource LightText}, Dark={StaticResource ForgeText}}"
                               VerticalOptions="Center"/>
                        <Border Grid.Column="1"
                                BackgroundColor="{AppThemeBinding Light={StaticResource LightSurface2}, Dark={StaticResource ForgeSurface2}}"
                                StrokeShape="RoundRectangle 12" StrokeThickness="0"
                                WidthRequest="44" HeightRequest="44"
                                VerticalOptions="Center">
                            <views:AppIcon Source="tab_settings.png"
                                          WidthRequest="20" HeightRequest="20"
                                          HorizontalOptions="Center" VerticalOptions="Center"/>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding OpenSettingsCommand}"/>
                            </Border.GestureRecognizers>
                        </Border>
                    </Grid>

                    <!-- Segment tabs � iOS glass pill -->
                    <Border BackgroundColor="{StaticResource ForgePillTrack}"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 50"
                            Padding="2">
                        <Grid x:Name="TabPills" ColumnDefinitions="*,*,*" HeightRequest="40"
                              SizeChanged="OnTabContainerSizeChanged">
                            <Border x:Name="TabIndicator" Grid.ColumnSpan="3"
                                    BackgroundColor="{StaticResource ForgePillIndicator}"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 48"
                                    HorizontalOptions="Start" VerticalOptions="Fill"/>
                            <Border Grid.Column="0" BackgroundColor="Transparent"
                                    StrokeThickness="0" Padding="0,9">
                                <Label Text="{loc:Localize Kropp_Tab_Weight}"
                                       FontFamily="BebasNeue" FontSize="13" CharacterSpacing="1.5"
                                       TextColor="{Binding Tab0Fg}"
                                       HorizontalOptions="Center" VerticalOptions="Center"/>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding SelectTabCommand}" CommandParameter="{x:Int32 0}" Tapped="OnLogMatsTapped"/>
                                </Border.GestureRecognizers>
                            </Border>
                            <Border Grid.Column="1" BackgroundColor="Transparent"
                                    StrokeThickness="0" Padding="0,9">
                                <Label Text="{loc:Localize Kropp_Tab_Body}"
                                       FontFamily="BebasNeue" FontSize="13" CharacterSpacing="1.5"
                                       TextColor="{Binding Tab1Fg}"
                                       HorizontalOptions="Center" VerticalOptions="Center"/>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding SelectTabCommand}" CommandParameter="{x:Int32 1}" Tapped="OnLogMatsTapped"/>
                                </Border.GestureRecognizers>
                            </Border>
                            <Border Grid.Column="2" BackgroundColor="Transparent"
                                    StrokeThickness="0" Padding="0,9">
                                <Label Text="{loc:Localize Kropp_Tab_Heatmap}"
                                       FontFamily="BebasNeue" FontSize="13" CharacterSpacing="1.5"
                                       TextColor="{Binding Tab2Fg}"
                                       HorizontalOptions="Center" VerticalOptions="Center"/>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding SelectTabCommand}" CommandParameter="{x:Int32 2}" Tapped="OnLogMatsTapped"/>
                                </Border.GestureRecognizers>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- = VIKT TAB = -->
                    <VerticalStackLayout IsVisible="{Binding IsViktTab}" Spacing="14">

                        <!-- Latest weight hero -->
                        <Border Style="{StaticResource CardFrame}" Padding="24,20">
                            <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                                <Label Text="{Binding LatestWeight}"
                                       FontFamily="BebasNeue" FontSize="60"
                                       CharacterSpacing="-1"
                                       TextColor="{AppThemeBinding Light={StaticResource LightAccentBlue}, Dark={StaticResource ForgeAccentBlue}}"
                                       HorizontalOptions="Center"/>
                                <Label Text="{Binding LatestWeightDate}"
                                       Style="{StaticResource MutedLabel}"
                                       HorizontalOptions="Center"/>
                                <Label Text="{loc:Localize Kropp_NoWeightData}"
                                       Style="{StaticResource MutedLabel}"
                                       HorizontalOptions="Center"
                                       HorizontalTextAlignment="Center"
                                       IsVisible="{Binding HasWeightData, Converter={x:Static vm:InverseBoolConverter.Instance}}"/>
                            </VerticalStackLayout>
                        </Border>

                        <!-- Chart -->
                        <Border Style="{StaticResource CardFrame}" Padding="12,14,12,10"
                                IsVisible="{Binding HasWeightData}">
                            <VerticalStackLayout Spacing="6">
                                <Label Text="{loc:Localize Kropp_WeightProgress}"
                                       Style="{StaticResource SectionLabel}"
                                       Margin="4,0,0,0"/>
                                <controls:LineChartView Points="{Binding WeightChartPoints}" StrokeColor="{StaticResource ForgeAccentBlue}" HeightRequest="180" BackgroundColor="Transparent"/>
                            </VerticalStackLayout>
                        </Border>

                        <!-- Recent entries -->
                        <Label Text="{loc:Localize Kropp_RecentLogs}"
                               Style="{StaticResource SectionLabel}"
                               IsVisible="{Binding HasWeightData}"/>
                        <Border Style="{StaticResource CardFrame}" Padding="0,4"
                                IsVisible="{Binding HasWeightData}">
                            <StackLayout BindableLayout.ItemsSource="{Binding WeightEntries}" Spacing="0">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate x:DataType="models:BodyWeightEntry">
                                        <Grid ColumnDefinitions="*,Auto,Auto" Padding="16,10,12,10">
                                            <Label Grid.Column="0"
                                                   Text="{Binding LoggedAt, StringFormat='{0:d MMM yyyy  HH:mm}'}"
                                                   Style="{StaticResource MutedLabel}"
                                                   VerticalOptions="Center"/>
                                            <Label Grid.Column="1"
                                                   Text="{Binding WeightKg, StringFormat='{0:F1} kg'}"
                                                   FontFamily="DMSansMedium" FontSize="15"
                                                   TextColor="{AppThemeBinding Light={StaticResource LightAccentBlue}, Dark={StaticResource ForgeAccentBlue}}"
                                                   VerticalOptions="Center"
                                                   Margin="0,0,12,0"/>
                                            <Border Grid.Column="2"
                                                    WidthRequest="44" HeightRequest="44"
                                                    BackgroundColor="{AppThemeBinding Light={StaticResource LightSurface2}, Dark={StaticResource ForgeSurface2}}"
                                                    StrokeShape="Ellipse" StrokeThickness="0">
                                                <views:AppIcon Source="ic_trash.png"
                                                               WidthRequest="16" HeightRequest="16"
                                                               HorizontalOptions="Center" VerticalOptions="Center"/>
                                                <Border.GestureRecognizers>
                                                    <TapGestureRecognizer
                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:KroppViewModel}}, Path=DeleteWeightEntryCommand}"
                                                        CommandParameter="{Binding .}"/>
                                                </Border.GestureRecognizers>
                                            </Border>
                                        </Grid>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </StackLayout>
                        </Border>

                        <Border BackgroundColor="{StaticResource ForgeAccentBlueDim}"
                                Stroke="{StaticResource ForgeAccentBlue}" StrokeThickness="0.5"
                                StrokeShape="RoundRectangle 26"
                                HeightRequest="56" HorizontalOptions="Fill">
                            <HorizontalStackLayout Spacing="10"
                                                   HorizontalOptions="Center" VerticalOptions="Center">
                                <views:AppIcon Source="ic_plus.png"
                                               WidthRequest="18" HeightRequest="18"
                                               ForceTint="#38BDF8" VerticalOptions="Center"/>
                                <Label Text="{loc:Localize Kropp_LogWeight}"
                                       FontFamily="BebasNeue" FontSize="20" CharacterSpacing="3"
                                       TextColor="{StaticResource ForgeAccentBlue}" VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding LogWeightCommand}" Tapped="OnLogMatsTapped"/>
                            </Border.GestureRecognizers>
                        </Border>

                    </VerticalStackLayout>

                    <!-- = KROPP TAB = -->
                    <VerticalStackLayout IsVisible="{Binding IsKroppTab}" Spacing="14">

                        <!-- Latest measurements -->
                        <Border Style="{StaticResource CardFrame}" Padding="16,14">
                            <VerticalStackLayout Spacing="12">
                                <Label Text="{loc:Localize Kropp_LatestMeasurement}" Style="{StaticResource SectionLabel}"/>
                                <Grid ColumnDefinitions="*,*,*,*,*" ColumnSpacing="8">
                                    <VerticalStackLayout Grid.Column="0" Spacing="3" HorizontalOptions="Center">
                                        <Label Text="{Binding LatestWaist}"
                                               FontFamily="BebasNeue" FontSize="22"
                                               TextColor="{StaticResource ForgeAccentPurple}"
                                               HorizontalOptions="Center"/>
                                        <Label Text="{loc:Localize Kropp_Measurement_Waist}" Style="{StaticResource SectionLabel}" FontSize="11" HorizontalOptions="Center"/>
                                    </VerticalStackLayout>
                                    <VerticalStackLayout Grid.Column="1" Spacing="3" HorizontalOptions="Center">
                                        <Label Text="{Binding LatestChest}"
                                               FontFamily="BebasNeue" FontSize="22"
                                               TextColor="{StaticResource ForgeAccentPurple}"
                                               HorizontalOptions="Center"/>
                                        <Label Text="{loc:Localize Kropp_Measurement_Chest}" Style="{StaticResource SectionLabel}" FontSize="11" HorizontalOptions="Center"/>
                                    </VerticalStackLayout>
                                    <VerticalStackLayout Grid.Column="2" Spacing="3" HorizontalOptions="Center">
                                        <Label Text="{Binding LatestHip}"
                                               FontFamily="BebasNeue" FontSize="22"
                                               TextColor="{StaticResource ForgeAccentPurple}"
                                               HorizontalOptions="Center"/>
                                        <Label Text="{loc:Localize Kropp_Measurement_Hips}" Style="{StaticResource SectionLabel}" FontSize="11" HorizontalOptions="Center"/>
                                    </VerticalStackLayout>
                                    <VerticalStackLayout Grid.Column="3" Spacing="3" HorizontalOptions="Center">
                                        <Label Text="{Binding LatestArm}"
                                               FontFamily="BebasNeue" FontSize="22"
                                               TextColor="{StaticResource ForgeAccentPurple}"
                                               HorizontalOptions="Center"/>
                                        <Label Text="{loc:Localize Kropp_Measurement_Arms}" Style="{StaticResource SectionLabel}" FontSize="11" HorizontalOptions="Center"/>
                                    </VerticalStackLayout>
                                    <VerticalStackLayout Grid.Column="4" Spacing="3" HorizontalOptions="Center">
                                        <Label Text="{Binding LatestThigh}"
                                               FontFamily="BebasNeue" FontSize="22"
                                               TextColor="{StaticResource ForgeAccentPurple}"
                                               HorizontalOptions="Center"/>
                                        <Label Text="{loc:Localize Kropp_Measurement_Thighs}" Style="{StaticResource SectionLabel}" FontSize="11" HorizontalOptions="Center"/>
                                    </VerticalStackLayout>
                                </Grid>
                                <Label Text="{loc:Localize Kropp_NoMeasurementData}"
                                       Style="{StaticResource MutedLabel}"
                                       HorizontalOptions="Center"
                                       HorizontalTextAlignment="Center"
                                       IsVisible="{Binding HasCompositionData, Converter={x:Static vm:InverseBoolConverter.Instance}}"/>
                            </VerticalStackLayout>
                        </Border>

                        <!-- History list -->
                        <Label Text="{loc:Localize Kropp_MeasurementHistory}" Style="{StaticResource SectionLabel}"
                               IsVisible="{Binding HasCompositionData}"/>
                        <Border Style="{StaticResource CardFrame}" Padding="0,4"
                                IsVisible="{Binding HasCompositionData}">
                            <StackLayout BindableLayout.ItemsSource="{Binding CompositionEntries}" Spacing="0">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate x:DataType="models:BodyCompositionEntry">
                                        <Grid ColumnDefinitions="*,Auto" Padding="16,10,12,10">
                                            <VerticalStackLayout Grid.Column="0" Spacing="2">
                                                <Label Text="{Binding LoggedAt, StringFormat='{0:d MMM yyyy}'}"
                                                       FontFamily="DMSansMedium" FontSize="14"
                                                       TextColor="{StaticResource ForgeText}"/>
                                                <Label Text="{Binding Summary}"
                                                       Style="{StaticResource MutedLabel}" FontSize="12"/>
                                            </VerticalStackLayout>
                                            <Border Grid.Column="1"
                                                    WidthRequest="44" HeightRequest="44"
                                                    BackgroundColor="{AppThemeBinding Light={StaticResource LightSurface2}, Dark={StaticResource ForgeSurface2}}"
                                                    StrokeShape="Ellipse" StrokeThickness="0">
                                                <views:AppIcon Source="ic_trash.png"
                                                               WidthRequest="16" HeightRequest="16"
                                                               HorizontalOptions="Center" VerticalOptions="Center"/>
                                                <Border.GestureRecognizers>
                                                    <TapGestureRecognizer
                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:KroppViewModel}}, Path=DeleteCompositionEntryCommand}"
                                                        CommandParameter="{Binding .}"/>
                                                </Border.GestureRecognizers>
                                            </Border>
                                        </Grid>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </StackLayout>
                        </Border>

                        <Border BackgroundColor="{StaticResource ForgeAccentPurpleDim}"
                                Stroke="{StaticResource ForgeAccentPurple}" StrokeThickness="0.5"
                                StrokeShape="RoundRectangle 26"
                                HeightRequest="56" HorizontalOptions="Fill">
                            <HorizontalStackLayout Spacing="10"
                                                   HorizontalOptions="Center" VerticalOptions="Center">
                                <views:AppIcon Source="ic_plus.png"
                                               WidthRequest="18" HeightRequest="18"
                                               ForceTint="#A78BFA" VerticalOptions="Center"/>
                                <Label Text="{loc:Localize Kropp_LogMeasurement}"
                                       FontFamily="BebasNeue" FontSize="20" CharacterSpacing="3"
                                       TextColor="{StaticResource ForgeAccentPurple}" VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding LogCompositionCommand}" Tapped="OnLogMatsTapped"/>
                            </Border.GestureRecognizers>
                        </Border>

                    </VerticalStackLayout>

                    <!-- = HEATMAP TAB = -->
                    <VerticalStackLayout IsVisible="{Binding IsHeatmapTab}" Spacing="14">

                        <Label Text="{loc:Localize Kropp_MuscleGroups_Title}"
                               Style="{StaticResource SectionLabel}"/>

                        <!-- Heatmap grid (byggs i code-behind) -->
                        <Grid x:Name="HeatmapGrid"
                              ColumnDefinitions="*,*,*,*"
                              ColumnSpacing="8" RowSpacing="8"/>

                    </VerticalStackLayout>

                </VerticalStackLayout>
            </ScrollView>

            <!-- = WORKOUT BANNER � Live Forge Capsule = -->
            <Grid x:Name="WorkoutBanner"
                  IsVisible="False"
                  VerticalOptions="End"
                  HorizontalOptions="Center"
                  Margin="0,0,0,96"
                  ZIndex="10">
                <Border StrokeThickness="0"
                        StrokeShape="RoundRectangle 36"
                        BackgroundColor="{StaticResource ForgeAccentGlow}"
                        Margin="-18,-14"
                        InputTransparent="True"/>
                <Border StrokeThickness="1"
                        Stroke="{StaticResource ForgeBannerStroke}"
                        StrokeShape="RoundRectangle 22"
                        Padding="16,9,18,10">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="{StaticResource ForgeSurface2}" Offset="0"/>
                            <GradientStop Color="{StaticResource ForgeSurface}" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,6" Radius="22" Opacity="0.55"/>
                    </Border.Shadow>
                    <HorizontalStackLayout Spacing="11" VerticalOptions="Center">
                        <controls:ForgeLiveDotView x:Name="BannerPulseRing"
                                                   VerticalOptions="Center"/>
                        <Label Text="{loc:Localize Hem_WorkoutBanner_Label}"
                               FontFamily="BebasNeue" FontSize="13" CharacterSpacing="3"
                               TextColor="{StaticResource ForgeText}"
                               VerticalOptions="Center"/>
                        <Path Style="{StaticResource ForwardChevron}"
                              Stroke="{StaticResource ForgeAccent}"/>
                    </HorizontalStackLayout>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnWorkoutBannerTapped"/>
                    </Border.GestureRecognizers>
                </Border>
            </Grid>

    <!-- Bottom gradient fade behind floating tab bar � matchar topp-gradienten spegelv�nt -->
    <BoxView Grid.RowSpan="99" InputTransparent="True" VerticalOptions="End" HeightRequest="150">
        <BoxView.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="{AppThemeBinding Light=#00FCFCFC, Dark=#00141418}" Offset="0.0"/>
                <GradientStop Color="{AppThemeBinding Light=#38FCFCFC, Dark=#38141418}" Offset="0.35"/>
                <GradientStop Color="{AppThemeBinding Light=#90FCFCFC, Dark=#90141418}" Offset="0.65"/>
                <GradientStop Color="{AppThemeBinding Light=#FCFCFC, Dark=#141418}" Offset="1.0"/>
            </LinearGradientBrush>
        </BoxView.Background>
    </BoxView>

    </Grid>
</ContentPage>