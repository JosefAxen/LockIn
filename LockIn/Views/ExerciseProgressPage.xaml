<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:LockIn.ViewModels"
             xmlns:views="clr-namespace:LockIn.Views"
             xmlns:controls="clr-namespace:LockIn.Controls"
             xmlns:loc="clr-namespace:LockIn.Resources.Strings"
             x:Class="LockIn.Views.ExerciseProgressPage"
             x:DataType="vm:ExerciseProgressViewModel"
             xmlns:ios="clr-namespace:Microsoft.Maui.Controls.PlatformConfiguration.iOSSpecific;assembly=Microsoft.Maui.Controls"
             Shell.NavBarIsVisible="False"
             BackgroundColor="Transparent">

    <ContentPage.Resources>
        <views:InvertedBoolConverter x:Key="InvertedBoolConverter"/>
        <views:StringNotEmptyConverter x:Key="StringNotEmptyConverter"/>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*" SafeAreaEdges="None">

        <!-- Atmosf�risk bakgrund -->
        <controls:AtmosphericBackgroundView Grid.RowSpan="2" InputTransparent="True"/>

        <!-- Header -->
        <Grid Grid.Row="0" Padding="16,56,16,8" ColumnDefinitions="48,*,48">
            <Border Grid.Column="0"
                    WidthRequest="36" HeightRequest="36"
                    StrokeShape="Ellipse"
                    BackgroundColor="#17FFFFFF"
                    Stroke="#29FFFFFF"
                    StrokeThickness="0.5"
                    VerticalOptions="Center">
                <Path Style="{StaticResource BackChevron}"/>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnBackClicked"/>
                </Border.GestureRecognizers>
            </Border>
            <StackLayout Grid.Column="1" Spacing="1" VerticalOptions="Center" Margin="4,0,0,0">
                <Label Text="{Binding ExerciseName}"
                       FontFamily="BebasNeue" FontSize="26"
                       CharacterSpacing="1"/>
                <Label Text="{Binding MuscleGroupName}"
                       Style="{StaticResource MutedLabel}"/>
            </StackLayout>
            <Border Grid.Column="2"
                    WidthRequest="36" HeightRequest="36"
                    StrokeShape="Ellipse"
                    BackgroundColor="#17FFFFFF"
                    Stroke="#29FFFFFF"
                    StrokeThickness="0.5"
                    VerticalOptions="Center"
                    HorizontalOptions="End"
                    IsEnabled="{Binding IsSharing, Converter={StaticResource InvertedBoolConverter}}">
                <Label Text="↗"
                       TextColor="{AppThemeBinding Light={StaticResource LightText}, Dark={StaticResource ForgeText}}"
                       FontSize="16"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"/>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding ShareProgressCommand}"/>
                </Border.GestureRecognizers>
            </Border>
        </Grid>

        <ScrollView Grid.Row="1" VerticalScrollBarVisibility="Never">
            <VerticalStackLayout Padding="16,4,16,40" Spacing="12">

                <!-- Chart card -->
                <Border Style="{StaticResource CardFrame}" Padding="12,14,12,10">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="{loc:Localize ExerciseProgress_Chart_1RM}"
                               Style="{StaticResource SectionLabel}"
                               Margin="4,0,0,0"/>
                        <controls:LineChartView Points="{Binding ChartPoints}" StrokeColor="#B8B8BC" HeightRequest="200" BackgroundColor="Transparent"/>
                    </VerticalStackLayout>
                </Border>

                <!-- Stats row -->
                <Grid ColumnDefinitions="*,*" ColumnSpacing="12">

                    <Border Grid.Column="0" Style="{StaticResource CardFrame}" Padding="16,14">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="{loc:Localize ExerciseProgress_BestLift}"
                                   Style="{StaticResource SectionLabel}"/>
                            <Label Text="{Binding BestSet}"
                                   FontFamily="DMSansMedium" FontSize="15"/>
                            <Label Text="{Binding EstimatedOneRmFormatted}"
                                   Style="{StaticResource MutedLabel}"
                                   TextColor="{StaticResource ForgeAccentBlue}"/>
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource CardFrame}" Padding="16,14">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="{loc:Localize ExerciseProgress_TotalVolume}"
                                   Style="{StaticResource SectionLabel}"/>
                            <Label Text="{Binding TotalSessions}"
                                   FontSize="32" FontAttributes="Bold"
                                   CharacterSpacing="-1"
                                   TextColor="{StaticResource ForgeAccentAmber}"/>
                            <Label Text="{loc:Localize ExerciseProgress_LoggedSessions}"
                                   Style="{StaticResource MutedLabel}"/>
                        </VerticalStackLayout>
                    </Border>

                </Grid>

                <!-- Empty state -->
                <Border IsVisible="{Binding HasData, Converter={x:StaticResource InvertedBoolConverter}}"
                        Style="{StaticResource CardFrame}" Padding="24,20">
                    <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                        <Label Text="{loc:Localize ExerciseProgress_Empty_Title}"
                               FontFamily="DMSansMedium" FontSize="15"
                               HorizontalOptions="Center"/>
                        <Label Text="{loc:Localize ExerciseProgress_Empty_Body}"
                               Style="{StaticResource MutedLabel}"
                               HorizontalTextAlignment="Center"
                               LineBreakMode="WordWrap"/>
                    </VerticalStackLayout>
                </Border>

                <!-- Metadata (utrustning, niv�, typ) -->
                <Border Style="{StaticResource CardFrame}" Padding="16,14"
                        IsVisible="{Binding HasMetadata}">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="{loc:Localize ExerciseProgress_ExerciseInfo}" Style="{StaticResource SectionLabel}"/>
                        <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="12" RowSpacing="8">

                            <VerticalStackLayout Grid.Row="0" Grid.Column="0" Spacing="2"
                                                 IsVisible="{Binding EquipmentName, Converter={StaticResource StringNotEmptyConverter}}">
                                <Label Text="{loc:Localize ExerciseProgress_Equipment}" Style="{StaticResource SectionLabel}" FontSize="10"/>
                                <Label Text="{Binding EquipmentName}"
                                       FontFamily="DMSansMedium" FontSize="13"
                                       TextColor="{AppThemeBinding Light={StaticResource LightText}, Dark={StaticResource ForgeText}}"/>
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Row="0" Grid.Column="1" Spacing="2"
                                                 IsVisible="{Binding LevelName, Converter={StaticResource StringNotEmptyConverter}}">
                                <Label Text="{loc:Localize ExerciseProgress_Level}" Style="{StaticResource SectionLabel}" FontSize="10"/>
                                <Label Text="{Binding LevelName}"
                                       FontFamily="DMSansMedium" FontSize="13"
                                       TextColor="{AppThemeBinding Light={StaticResource LightText}, Dark={StaticResource ForgeText}}"/>
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Row="1" Grid.Column="0" Spacing="2"
                                                 IsVisible="{Binding MechanicName, Converter={StaticResource StringNotEmptyConverter}}">
                                <Label Text="{loc:Localize ExerciseProgress_Type}" Style="{StaticResource SectionLabel}" FontSize="10"/>
                                <Label Text="{Binding MechanicName}"
                                       FontFamily="DMSansMedium" FontSize="13"
                                       TextColor="{AppThemeBinding Light={StaticResource LightText}, Dark={StaticResource ForgeText}}"/>
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Row="1" Grid.Column="1" Spacing="2"
                                                 IsVisible="{Binding ForceName, Converter={StaticResource StringNotEmptyConverter}}">
                                <Label Text="{loc:Localize ExerciseProgress_Force}" Style="{StaticResource SectionLabel}" FontSize="10"/>
                                <Label Text="{Binding ForceName}"
                                       FontFamily="DMSansMedium" FontSize="13"
                                       TextColor="{AppThemeBinding Light={StaticResource LightText}, Dark={StaticResource ForgeText}}"/>
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Spacing="2"
                                                 IsVisible="{Binding SecondaryMusclesText, Converter={StaticResource StringNotEmptyConverter}}">
                                <Label Text="{loc:Localize ExerciseProgress_SecondaryMuscles}" Style="{StaticResource SectionLabel}" FontSize="10"/>
                                <Label Text="{Binding SecondaryMusclesText}"
                                       FontFamily="DMSansRegular" FontSize="13"
                                       TextColor="{AppThemeBinding Light={StaticResource LightText}, Dark={StaticResource ForgeText}}"
                                       LineBreakMode="WordWrap"/>
                            </VerticalStackLayout>

                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- Description (instruktioner) -->
                <Border Style="{StaticResource CardFrame}" Padding="16,14"
                        IsVisible="{Binding HasDescription}">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="{loc:Localize ExerciseProgress_Instructions}" Style="{StaticResource SectionLabel}"/>
                        <Label Text="{Binding ExerciseDescription}"
                               FontFamily="DMSansRegular" FontSize="14"
                               TextColor="{AppThemeBinding Light={StaticResource LightText}, Dark={StaticResource ForgeText}}"
                               LineBreakMode="WordWrap"
                               LineHeight="1.5"/>
                    </VerticalStackLayout>
                </Border>

                <!-- Notes -->
                <Border Style="{StaticResource CardFrame}" Padding="16,14">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="{loc:Localize ExerciseProgress_Notes}" Style="{StaticResource SectionLabel}"/>
                        <Border BackgroundColor="{AppThemeBinding Light={StaticResource LightSurface2}, Dark={StaticResource ForgeSurface2}}" Stroke="{AppThemeBinding Light={StaticResource LightBorder}, Dark={StaticResource ForgeBorder}}" StrokeThickness="1"
                                StrokeShape="RoundRectangle 8">
                            <Editor Text="{Binding ExerciseNotes}"
                                    Placeholder="{loc:Localize ExerciseProgress_Notes_Placeholder}"
                                    PlaceholderColor="{StaticResource ForgeMuted}"
                                    BackgroundColor="Transparent"
                                    TextColor="{AppThemeBinding Light={StaticResource LightText}, Dark={StaticResource ForgeText}}"
                                    FontFamily="DMSansRegular" FontSize="14"
                                    AutoSize="TextChanges"
                                    MinimumHeightRequest="80"
                                    Margin="12,8"/>
                        </Border>
                        <Button Text="{loc:Localize Common_Save}"
                                Style="{StaticResource SecondaryButton}"
                                Command="{Binding SaveNotesCommand}"
                                HorizontalOptions="End"
                                Padding="20,0"/>
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</ContentPage>
