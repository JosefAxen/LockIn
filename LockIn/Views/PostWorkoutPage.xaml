<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:LockIn.ViewModels"
             xmlns:views="clr-namespace:LockIn.Views"
             xmlns:controls="clr-namespace:LockIn.Controls"
             xmlns:loc="clr-namespace:LockIn.Resources.Strings"
             x:Class="LockIn.Views.PostWorkoutPage"
             x:DataType="vm:PostWorkoutViewModel"
             xmlns:ios="clr-namespace:Microsoft.Maui.Controls.PlatformConfiguration.iOSSpecific;assembly=Microsoft.Maui.Controls"
             Shell.NavBarIsVisible="False"
             Shell.TabBarIsVisible="False"
             BackgroundColor="Transparent">

    <ContentPage.Resources>
        <vm:GreaterThanZeroConverter x:Key="GtzConverter"/>
    </ContentPage.Resources>

    <Grid SafeAreaEdges="None">

        <!-- Atmosf�risk bakgrund -->
        <controls:AtmosphericBackgroundView InputTransparent="True"/>

        <!-- Celebration gradient � edge-to-edge inkl. Dynamic Island -->
        <BoxView VerticalOptions="Start" HeightRequest="200" InputTransparent="True" ZIndex="1">
            <BoxView.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#1AB8B8BC" Offset="0.0"/>
                    <GradientStop Color="Transparent" Offset="1.0"/>
                </LinearGradientBrush>
            </BoxView.Background>
        </BoxView>

        <!-- Permanent status bar gradient -->
        <BoxView VerticalOptions="Start" HeightRequest="90" InputTransparent="True" ZIndex="19">
            <BoxView.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#28141418" Offset="0.0"/>
                    <GradientStop Color="#00141418" Offset="1.0"/>
                </LinearGradientBrush>
            </BoxView.Background>
        </BoxView>

        <!-- Sticky header gradient + compact namn (fades in on scroll) -->
        <Grid x:Name="StickyHeader" VerticalOptions="Start" ZIndex="20" Opacity="0"
              HeightRequest="150" SafeAreaEdges="None">
            <BoxView InputTransparent="True">
                <BoxView.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#D8141418" Offset="0.0"/>
                        <GradientStop Color="#90141418" Offset="0.35"/>
                        <GradientStop Color="#38141418" Offset="0.65"/>
                        <GradientStop Color="#00141418" Offset="1.0"/>
                    </LinearGradientBrush>
                </BoxView.Background>
            </BoxView>
            <VerticalStackLayout Padding="22,56,22,12" Spacing="2" VerticalOptions="Start">
                <Label Text="{loc:Localize PostWorkout_GreatJob}"
                       Style="{StaticResource SectionLabel}"
                       TextColor="{StaticResource ForgeAccent}"/>
                <Label Text="{Binding TemplateName}"
                       FontFamily="BebasNeue" FontSize="18" CharacterSpacing="1"
                       TextColor="{StaticResource ForgeText}"/>
            </VerticalStackLayout>
        </Grid>

    <Grid ZIndex="2" SafeAreaEdges="None">

        <ScrollView VerticalScrollBarVisibility="Never" Scrolled="OnScrolled">
            <StackLayout Padding="16,0,16,120" Spacing="16">

                <!-- Header � scrollar med inneh�llet -->
                <VerticalStackLayout Padding="4,56,4,4" Spacing="4">
                    <Label Text="{loc:Localize PostWorkout_GreatJob}"
                           Style="{StaticResource SectionLabel}"
                           TextColor="{StaticResource ForgeAccent}"/>
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0"
                               Text="{Binding TemplateName}"
                               Style="{StaticResource DisplayLabel}"
                               FontSize="32"
                               VerticalOptions="Center"/>
                        <Label Grid.Column="1"
                               Text="{Binding Duration}"
                               Style="{StaticResource MutedLabel}"
                               FontSize="13"
                               VerticalOptions="End" Margin="0,0,0,4"/>
                    </Grid>
                </VerticalStackLayout>


                <!-- Stats row -->
                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                    <Border Grid.Column="0" Style="{StaticResource CardFrame}" Padding="14,16">
                        <StackLayout Spacing="4">
                            <Label Text="{Binding TotalVolume}"
                                   FontSize="40" FontAttributes="Bold" LineHeight="1" CharacterSpacing="-1"
                                   TextColor="{StaticResource ForgeAccentBlue}"/>
                            <Label Text="{loc:Localize PostWorkout_Stats_Volume}" Style="{StaticResource SectionLabel}"/>
                        </StackLayout>
                    </Border>
                    <Border Grid.Column="1" Style="{StaticResource CardFrame}" Padding="14,16">
                        <StackLayout Spacing="4">
                            <Label Text="{Binding TotalSets}"
                                   FontSize="40" FontAttributes="Bold" LineHeight="1" CharacterSpacing="-1"
                                   TextColor="{StaticResource ForgeAccentPurple}"/>
                            <Label Text="{loc:Localize PostWorkout_Stats_Sets}" Style="{StaticResource SectionLabel}"/>
                        </StackLayout>
                    </Border>
                    <Border Grid.Column="2" Style="{StaticResource CardFrame}" Padding="14,16">
                        <StackLayout Spacing="4">
                            <Label Text="{Binding PrCount}"
                                   FontSize="40" FontAttributes="Bold" LineHeight="1" CharacterSpacing="-1"
                                   TextColor="{StaticResource ForgeAccentAmber}"/>
                            <Label Text="{loc:Localize PostWorkout_Stats_PR}" Style="{StaticResource SectionLabel}"/>
                        </StackLayout>
                    </Border>
                </Grid>

                <!-- Muscle groups -->
                <Label Text="{loc:Localize PostWorkout_MuscleGroups}" Style="{StaticResource SectionLabel}"/>
                <Border Style="{StaticResource CardFrame}" Padding="16,12">
                    <StackLayout BindableLayout.ItemsSource="{Binding MuscleGroups}" Spacing="10">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="vm:MuscleGroupRow">
                                <Grid ColumnDefinitions="70,*,80" ColumnSpacing="10">
                                    <Label Grid.Column="0" Text="{Binding Name}"
                                           Style="{StaticResource MutedLabel}"
                                           VerticalOptions="Center"/>
                                    <Grid Grid.Column="1" HeightRequest="4" VerticalOptions="Center">
                                        <BoxView BackgroundColor="{AppThemeBinding Light={StaticResource LightSurface2}, Dark={StaticResource ForgeSurface3}}"
                                                 CornerRadius="2" HorizontalOptions="Fill" VerticalOptions="Fill"/>
                                        <BoxView BackgroundColor="{StaticResource ForgeAccent}"
                                                 CornerRadius="2" HorizontalOptions="Fill" VerticalOptions="Fill"
                                                 AnchorX="0" ScaleX="{Binding ProgressFraction}"/>
                                    </Grid>
                                    <StackLayout Grid.Column="2" Spacing="0">
                                        <Label Text="{Binding VolumeDisplay}"
                                               FontFamily="DMSansMedium" FontSize="12"
                                               TextColor="{AppThemeBinding Light={StaticResource LightText}, Dark={StaticResource ForgeText}}"
                                               HorizontalTextAlignment="End"/>
                                        <Label Text="{Binding SetsDisplay}"
                                               Style="{StaticResource MutedLabel}"
                                               HorizontalTextAlignment="End"/>
                                    </StackLayout>
                                </Grid>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </StackLayout>
                </Border>

                <!-- Session notes -->
                <Label Text="{loc:Localize PostWorkout_Notes}" Style="{StaticResource SectionLabel}"/>
                <Border Style="{StaticResource CardFrame}" Padding="4,2">
                    <Editor Text="{Binding Notes}"
                            Placeholder="{loc:Localize PostWorkout_Notes_Placeholder}"
                            PlaceholderColor="{StaticResource ForgeMuted}"
                            BackgroundColor="Transparent"
                            TextColor="{AppThemeBinding Light={StaticResource LightText}, Dark={StaticResource ForgeText}}"
                            FontFamily="DMSansRegular" FontSize="14"
                            AutoSize="TextChanges"
                            MinimumHeightRequest="72"
                            Margin="12,6"/>
                </Border>

                <!-- New achievements -->
                <Label Text="{loc:Localize PostWorkout_NewAchievements}" Style="{StaticResource SectionLabel}"
                       IsVisible="{Binding NewAchievements.Count, Converter={StaticResource GtzConverter}}"/>
                <StackLayout BindableLayout.ItemsSource="{Binding NewAchievements}" Spacing="8"
                             IsVisible="{Binding NewAchievements.Count, Converter={StaticResource GtzConverter}}">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="vm:NewAchievementRow">
                            <Border BackgroundColor="{StaticResource ForgeAccentAmberDim}"
                                    StrokeThickness="1"
                                    Stroke="{StaticResource ForgeAccentAmber}"
                                    StrokeShape="RoundRectangle 12"
                                    Padding="16,12">
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                                    <Label Grid.Column="0" Text="{Binding Emoji}"
                                           FontSize="26" VerticalOptions="Center"/>
                                    <StackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                        <Label Text="{loc:Localize PostWorkout_Achievement_Unlocked}"
                                               Style="{StaticResource SectionLabel}"
                                               TextColor="{StaticResource ForgeAccentAmber}"
                                               FontSize="10"/>
                                        <Label Text="{Binding Title}"
                                               FontFamily="BebasNeue" FontSize="18"
                                               TextColor="{StaticResource ForgeAccentAmber}"
                                               CharacterSpacing="0.5"/>
                                    </StackLayout>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </StackLayout>

                <!-- Photos -->
                <Grid ColumnDefinitions="*,Auto" Margin="0,4,0,0">
                    <Label Grid.Column="0" Text="{loc:Localize PostWorkout_Photos}" Style="{StaticResource SectionLabel}"/>
                    <Button Grid.Column="1"
                            Text="{loc:Localize PostWorkout_AddPhoto}"
                            Style="{StaticResource SecondaryButton}"
                            FontFamily="BebasNeue" FontSize="13"
                            Padding="12,4"
                            HeightRequest="32"
                            Command="{Binding AddPhotoCommand}"/>
                </Grid>
                <CollectionView ItemsSource="{Binding Photos}"
                                HeightRequest="120"
                                ItemsLayout="HorizontalList"
                                IsVisible="{Binding Photos.Count, Converter={StaticResource GtzConverter}}"
                                HorizontalScrollBarVisibility="Never"
                                VerticalScrollBarVisibility="Never">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="vm:PhotoRow">
                            <Border Margin="0,0,8,0"
                                    StrokeShape="RoundRectangle 10"
                                    StrokeThickness="0"
                                    WidthRequest="120" HeightRequest="120"
                                    Padding="0">
                                <Grid>
                                    <Image Source="{Binding Source}"
                                           Aspect="AspectFill"
                                           WidthRequest="120" HeightRequest="120"/>
                                    <Border BackgroundColor="#CC000000"
                                            StrokeThickness="0"
                                            VerticalOptions="End"
                                            Padding="6,4">
                                        <Label Text="?"
                                               TextColor="White" FontSize="14"
                                               HorizontalOptions="End">
                                            <Label.GestureRecognizers>
                                                <TapGestureRecognizer
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:PostWorkoutViewModel}}, Path=DeletePhotoCommand}"
                                                    CommandParameter="{Binding .}"/>
                                            </Label.GestureRecognizers>
                                        </Label>
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <!-- PRs -->
                <Label Text="{loc:Localize PostWorkout_PersonalRecords}" Style="{StaticResource SectionLabel}"
                       IsVisible="{Binding PRs.Count, Converter={StaticResource GtzConverter}}"/>
                <Border Style="{StaticResource CardFrame}" Padding="16,12"
                        IsVisible="{Binding PRs.Count, Converter={StaticResource GtzConverter}}">
                    <StackLayout BindableLayout.ItemsSource="{Binding PRs}" Spacing="0">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="vm:PRRow">
                                <Grid ColumnDefinitions="Auto,*,Auto" Padding="0,8,0,8"
                                      ColumnSpacing="12">
                                    <views:AppIcon Grid.Column="0" Source="ic_flame.png"
                                           WidthRequest="18" HeightRequest="18" VerticalOptions="Center"/>
                                    <StackLayout Grid.Column="1" Spacing="2">
                                        <Label Text="{Binding ExerciseName}"
                                               FontFamily="DMSansMedium" FontSize="13"/>
                                        <Label Text="{Binding Epley1RM}"
                                               Style="{StaticResource MutedLabel}"/>
                                    </StackLayout>
                                    <Label Grid.Column="2"
                                           Text="{Binding Display}"
                                           TextColor="{StaticResource ForgeSuccess}"
                                           FontFamily="DMSansMedium" FontSize="13"
                                           VerticalOptions="Center"/>
                                </Grid>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </StackLayout>
                </Border>

            </StackLayout>
        </ScrollView>

    </Grid>

    <!-- Floating KLAR-knapp � fast l�ngst ner, ingen container/gradient -->
    <Border BackgroundColor="{StaticResource ForgePrimary}"
            StrokeShape="RoundRectangle 26"
            StrokeThickness="0"
            HeightRequest="56"
            HorizontalOptions="Fill"
            VerticalOptions="End"
            Margin="16,0,16,40"
            ZIndex="23">
        <Label Text="{loc:Localize Common_Done}"
               TextColor="{StaticResource ForgePrimaryForeground}"
               FontFamily="BebasNeue"
               FontSize="20"
               CharacterSpacing="3"
               HorizontalOptions="Center"
               VerticalOptions="Center"/>
        <Border.GestureRecognizers>
            <TapGestureRecognizer Command="{Binding DoneCommand}" Tapped="OnKlarTapped"/>
        </Border.GestureRecognizers>
    </Border>

    <controls:ConfettiView x:Name="ConfettiOverlay"/>

    </Grid>

</ContentPage>
