<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:LockIn.ViewModels"
             xmlns:views="clr-namespace:LockIn.Views"
             xmlns:controls="clr-namespace:LockIn.Controls"
             xmlns:ios="clr-namespace:Microsoft.Maui.Controls.PlatformConfiguration.iOSSpecific;assembly=Microsoft.Maui.Controls"
             x:Class="LockIn.Views.HemPage"
             x:DataType="vm:HemViewModel"
             Title="Hem"
             Shell.NavBarIsVisible="False"
             BackgroundColor="Transparent"
             ios:Page.UseSafeArea="False">

    <Grid SafeAreaEdges="None">

        <!-- Atmosfärisk bakgrund — renderas under allt annat -->
        <controls:AtmosphericBackgroundView InputTransparent="True"/>

        <!-- Permanent status bar gradient (alltid synlig, fyller Dynamic Island-zonen) -->
        <BoxView VerticalOptions="Start" HeightRequest="90" InputTransparent="True" ZIndex="19">
            <BoxView.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="{AppThemeBinding Light=#28FCFCFC, Dark=#280E0E10}" Offset="0.0"/>
                    <GradientStop Color="{AppThemeBinding Light=#00FCFCFC, Dark=#000E0E10}" Offset="1.0"/>
                </LinearGradientBrush>
            </BoxView.Background>
        </BoxView>

        <!-- Sticky header (fades in on scroll) -->
        <Grid x:Name="StickyHeader" VerticalOptions="Start" ZIndex="20" Opacity="0"
              HeightRequest="150" SafeAreaEdges="None">
            <BoxView InputTransparent="True">
                <BoxView.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="{AppThemeBinding Light=#D8FCFCFC, Dark=#D80E0E10}" Offset="0.0"/>
                        <GradientStop Color="{AppThemeBinding Light=#90FCFCFC, Dark=#900E0E10}" Offset="0.35"/>
                        <GradientStop Color="{AppThemeBinding Light=#38FCFCFC, Dark=#380E0E10}" Offset="0.65"/>
                        <GradientStop Color="{AppThemeBinding Light=#00FCFCFC, Dark=#000E0E10}" Offset="1.0"/>
                    </LinearGradientBrush>
                </BoxView.Background>
            </BoxView>
            <Grid Padding="22,14,48,12" VerticalOptions="Start">
                <Label Text="{Binding UserName}"
                       HorizontalOptions="Center" HorizontalTextAlignment="Center"
                       FontFamily="BebasNeue" FontSize="18" CharacterSpacing="1"
                       VerticalOptions="Center"
                       TextColor="{AppThemeBinding Light={StaticResource LightText}, Dark={StaticResource ForgeText}}"/>
            </Grid>
        </Grid>

        <ScrollView VerticalScrollBarVisibility="Never" Scrolled="OnScrolled">
            <VerticalStackLayout Spacing="0" Padding="0,0,0,120">

                <!-- ═══ HEADER ═══ -->
                <Grid Padding="22,56,22,4" ColumnDefinitions="*,48">
                    <VerticalStackLayout Grid.Column="0" Spacing="0" VerticalOptions="End">
                        <Label Text="{Binding Greeting}"
                               FontFamily="BebasNeue" FontSize="12" CharacterSpacing="4"
                               TextColor="{AppThemeBinding Light={StaticResource LightMuted}, Dark={StaticResource ForgeMuted}}"/>
                        <Label Text="{Binding UserName}"
                               FontFamily="BebasNeue" FontSize="52" CharacterSpacing="1" LineHeight="1"
                               TextColor="{AppThemeBinding Light={StaticResource LightText}, Dark={StaticResource ForgeText}}"/>
                    </VerticalStackLayout>
                    <Border Grid.Column="1"
                            WidthRequest="44" HeightRequest="44"
                            StrokeShape="Ellipse"
                            BackgroundColor="{AppThemeBinding Light={StaticResource LightAccent}, Dark={StaticResource ForgeAccentDim}}"
                            Stroke="{AppThemeBinding Light={StaticResource LightAccent}, Dark={StaticResource ForgeAccent}}"
                            StrokeThickness="1.5"
                            VerticalOptions="End">
                        <Label Text="{Binding UserInitial}"
                               FontFamily="BebasNeue" FontSize="22"
                               TextColor="{AppThemeBinding Light={StaticResource LightText}, Dark={StaticResource ForgeAccent}}"
                               HorizontalOptions="Center" VerticalOptions="Center"/>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnAvatarTapped"/>
                        </Border.GestureRecognizers>
                    </Border>
                </Grid>

                <!-- ═══ SCORE CARD (HERO GAUGE) ═══ -->
                <Border Margin="16,14,16,0"
                        StrokeShape="RoundRectangle 22"
                        BackgroundColor="{AppThemeBinding Light={StaticResource LightSurface}, Dark={StaticResource ForgeSurface}}"
                        Stroke="{AppThemeBinding Light={StaticResource LightBorder}, Dark={StaticResource ForgeBorderLight}}"
                        StrokeThickness="1">
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,2" Radius="20" Opacity="0.10"/>
                    </Border.Shadow>
                    <VerticalStackLayout Padding="24,20,24,16" Spacing="0">
                        <Label Text="TRÄNINGSSCORE · IDAG"
                               Style="{StaticResource SectionLabel}" Margin="0,0,0,8"/>
                        <Label Text="{Binding MotivationText}"
                               Style="{StaticResource MutedLabel}"
                               HorizontalTextAlignment="Center" Margin="0,8,0,10"/>
                        <controls:WeeklyGoalGauge x:Name="Gauge"
                                                  Progress="{Binding GaugeProgress}"
                                                  HeightRequest="260"
                                                  WidthRequest="260"
                                                  HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </Border>

                <!-- ═══ IDAG-REKOMMENDATION ═══ -->
                <Border Margin="16,16,16,4"
                        BackgroundColor="{AppThemeBinding Light={StaticResource LightSurface}, Dark={StaticResource ForgeSurface}}"
                        StrokeShape="RoundRectangle 18"
                        StrokeThickness="0"
                        Padding="20,16">
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,2" Radius="10" Opacity="0.18"/>
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="6">
                        <Label Text="IDAG"
                               Style="{StaticResource SectionLabel}"
                               TextColor="{StaticResource ForgeAccent}"/>
                        <Label Text="{Binding TodayRecommendation}"
                               FontFamily="BebasNeue" FontSize="32"
                               CharacterSpacing="1"
                               LineHeight="1"
                               TextColor="{AppThemeBinding Light={StaticResource LightText}, Dark={StaticResource ForgeText}}"/>
                        <Label Text="{Binding TodayRecommendationDetail}"
                               Style="{StaticResource MutedLabel}"
                               LineBreakMode="WordWrap"/>
                    </VerticalStackLayout>
                </Border>

                <!-- ═══ STRAIN / RECOVERY / SÖMN-RINGAR ═══ -->
                <Label Text="STRAIN · RECOVERY · SÖMN" Style="{StaticResource SectionLabel}" Margin="22,18,0,10"/>
                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8" Margin="16,0,16,4">
                    <StackLayout Grid.Column="0" Spacing="6" HorizontalOptions="Center">
                        <controls:MetricRingView Progress="{Binding StrainProgress}"
                                                 TargetProgress="{Binding StrainTarget}"
                                                 RingColor="{StaticResource ForgeAccentAmber}"
                                                 CenterText="{Binding StrainText}"
                                                 WidthRequest="90" HeightRequest="90"
                                                 HorizontalOptions="Center"/>
                        <Label Text="STRAIN" Style="{StaticResource SectionLabel}" HorizontalTextAlignment="Center"/>
                        <Label Text="{Binding StrainTargetText}"
                               FontFamily="BebasNeue" FontSize="10" CharacterSpacing="1.5"
                               TextColor="{StaticResource ForgeAccentAmber}"
                               Opacity="0.7"
                               HorizontalTextAlignment="Center"/>
                    </StackLayout>
                    <StackLayout Grid.Column="1" Spacing="8" HorizontalOptions="Center">
                        <controls:MetricRingView Progress="{Binding RecoveryProgress}"
                                                 RingColor="{StaticResource ForgeAccent}"
                                                 CenterText="{Binding RecoveryText}"
                                                 WidthRequest="90" HeightRequest="90"
                                                 HorizontalOptions="Center"/>
                        <Label Text="RECOVERY" Style="{StaticResource SectionLabel}" HorizontalTextAlignment="Center"/>
                    </StackLayout>
                    <StackLayout Grid.Column="2" Spacing="8" HorizontalOptions="Center">
                        <controls:MetricRingView Progress="{Binding SleepProgress}"
                                                 RingColor="{StaticResource ForgeAccentBlue}"
                                                 CenterText="{Binding SleepText}"
                                                 WidthRequest="90" HeightRequest="90"
                                                 HorizontalOptions="Center"/>
                        <Label Text="SÖMN" Style="{StaticResource SectionLabel}" HorizontalTextAlignment="Center"/>
                    </StackLayout>
                </Grid>

                <Label Text="{Binding RecoveryComponentsText}"
                       Style="{StaticResource MutedLabel}"
                       FontSize="10"
                       HorizontalTextAlignment="Center"
                       Margin="16,6,16,0"/>

                <!-- ═══ SÖMN-DETALJER ═══ -->
                <Label Text="SÖMN" Style="{StaticResource SectionLabel}" Margin="22,18,0,10"/>
                <Border Margin="16,0,16,0"
                        BackgroundColor="{AppThemeBinding Light={StaticResource LightSurface}, Dark={StaticResource ForgeSurface}}"
                        StrokeShape="RoundRectangle 18"
                        StrokeThickness="0"
                        Padding="20,16">
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,2" Radius="10" Opacity="0.18"/>
                    </Border.Shadow>
                    <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="10">
                        <VerticalStackLayout Grid.Column="0" Spacing="2">
                            <Label Text="{Binding SleepStages.CoreMinutes, StringFormat='{0:F0}m'}"
                                   FontSize="22" FontAttributes="Bold"
                                   TextColor="{StaticResource ForgeAccentBlue}"/>
                            <Label Text="CORE" Style="{StaticResource SectionLabel}" FontSize="9"/>
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="1" Spacing="2">
                            <Label Text="{Binding SleepStages.DeepMinutes, StringFormat='{0:F0}m'}"
                                   FontSize="22" FontAttributes="Bold"
                                   TextColor="{StaticResource ForgeAccentPurple}"/>
                            <Label Text="DEEP" Style="{StaticResource SectionLabel}" FontSize="9"/>
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="2" Spacing="2">
                            <Label Text="{Binding SleepStages.RemMinutes, StringFormat='{0:F0}m'}"
                                   FontSize="22" FontAttributes="Bold"
                                   TextColor="{StaticResource ForgeAccent}"/>
                            <Label Text="REM" Style="{StaticResource SectionLabel}" FontSize="9"/>
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="3" Spacing="2">
                            <Label Text="{Binding SleepStages.AwakeMinutes, StringFormat='{0:F0}m'}"
                                   FontSize="22" FontAttributes="Bold"
                                   TextColor="{StaticResource ForgeAccentAmber}"/>
                            <Label Text="AWAKE" Style="{StaticResource SectionLabel}" FontSize="9"/>
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <!-- ═══ STREAK HEADER ═══ -->
                <Grid Padding="22,22,22,10" ColumnDefinitions="*,Auto">
                    <VerticalStackLayout Grid.Column="0" Spacing="2">
                        <Label Text="STREAK" Style="{StaticResource SectionLabel}"/>
                        <Label Text="{Binding StreakLabel}"
                               FontFamily="DMSansMedium" FontSize="13"
                               TextColor="{AppThemeBinding Light={StaticResource LightAccent}, Dark={StaticResource ForgeAccentAmber}}"/>
                    </VerticalStackLayout>
                    <Label Grid.Column="1"
                           Text="SE ALLA ›"
                           Style="{StaticResource SectionLabel}"
                           VerticalOptions="End"
                           TextColor="{AppThemeBinding Light={StaticResource LightMuted}, Dark={StaticResource ForgeMuted}}">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnSeAllaHistorik"/>
                        </Label.GestureRecognizers>
                    </Label>
                </Grid>

                <!-- ═══ DAY STREAK TRACKER ═══ -->
                <CollectionView x:Name="StreakCollectionView"
                                ItemsSource="{Binding Days}"
                                Margin="12,0" HeightRequest="76"
                                HorizontalScrollBarVisibility="Never"
                                VerticalScrollBarVisibility="Never">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Horizontal" ItemSpacing="6"/>
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="vm:DayStreakItem">
                            <VerticalStackLayout Spacing="5" HorizontalOptions="Center" Margin="2,0">
                                <Border WidthRequest="46" HeightRequest="46"
                                        StrokeShape="Ellipse"
                                        BackgroundColor="{Binding CircleFill}"
                                        Stroke="{Binding CircleStroke}"
                                        StrokeThickness="1.5">
                                    <Label Text="{Binding DayNum}"
                                           FontFamily="BebasNeue" FontSize="20" CharacterSpacing="0"
                                           TextColor="{Binding DayNumColor}"
                                           HorizontalOptions="Center" VerticalOptions="Center"/>
                                </Border>
                                <Label Text="{Binding DayAbbr}"
                                       FontFamily="BebasNeue" FontSize="9" CharacterSpacing="1.5"
                                       TextColor="{Binding DayAbbrColor}"
                                       HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <!-- ═══ STATS HEADER ═══ -->
                <Label Text="IDAG" Style="{StaticResource SectionLabel}" Margin="22,18,0,10"/>

                <!-- ═══ DATA CARDS 2×2 ═══ -->
                <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto"
                      ColumnSpacing="8" RowSpacing="8" Margin="16,0">

                    <Border Grid.Column="0" Grid.Row="0"
                            StrokeShape="RoundRectangle 18"
                            BackgroundColor="{AppThemeBinding Light={StaticResource LightSurface}, Dark={StaticResource ForgeSurface}}"
                            Stroke="{AppThemeBinding Light={StaticResource LightBorder}, Dark={StaticResource ForgeBorder}}"
                            StrokeThickness="1" Padding="16,14,16,12">
                        <VerticalStackLayout Spacing="0">
                            <Label Text="STEG" Style="{StaticResource SectionLabel}" Margin="0,0,0,4"/>
                            <Label Text="{Binding StepsText}"
                                   FontSize="36" CharacterSpacing="0" LineHeight="1"
                                   TextColor="{AppThemeBinding Light={StaticResource LightAccent}, Dark={StaticResource ForgeAccent}}"/>
                            <Label Text="steg idag" Style="{StaticResource MutedLabel}" Margin="0,2,0,6"/>
                            <controls:SparklineView Values="{Binding StepsValues}" StrokeColor="#B8B8BC" HeightRequest="38" BackgroundColor="Transparent"/>
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Column="1" Grid.Row="0"
                            StrokeShape="RoundRectangle 18"
                            BackgroundColor="{AppThemeBinding Light={StaticResource LightSurface}, Dark={StaticResource ForgeSurface}}"
                            Stroke="{AppThemeBinding Light={StaticResource LightBorder}, Dark={StaticResource ForgeBorder}}"
                            StrokeThickness="1" Padding="16,14,16,12">
                        <VerticalStackLayout Spacing="0">
                            <Label Text="KALORIER" Style="{StaticResource SectionLabel}" Margin="0,0,0,4"/>
                            <Label Text="{Binding CaloriesText}"
                                   FontSize="36" CharacterSpacing="0" LineHeight="1"
                                   TextColor="{AppThemeBinding Light={StaticResource LightAccentCoral}, Dark={StaticResource ForgeAccentCoral}}"/>
                            <Label Text="kcal" Style="{StaticResource MutedLabel}" Margin="0,2,0,6"/>
                            <controls:SparklineView Values="{Binding CaloriesValues}" StrokeColor="#FB7185" HeightRequest="38" BackgroundColor="Transparent"/>
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Column="0" Grid.Row="1"
                            StrokeShape="RoundRectangle 18"
                            BackgroundColor="{AppThemeBinding Light={StaticResource LightSurface}, Dark={StaticResource ForgeSurface}}"
                            Stroke="{AppThemeBinding Light={StaticResource LightBorder}, Dark={StaticResource ForgeBorder}}"
                            StrokeThickness="1" Padding="16,14,16,12">
                        <VerticalStackLayout Spacing="0">
                            <Label Text="AKTIV TID" Style="{StaticResource SectionLabel}" Margin="0,0,0,4"/>
                            <Label Text="{Binding ActiveText}"
                                   FontSize="36" CharacterSpacing="0" LineHeight="1"
                                   TextColor="{AppThemeBinding Light={StaticResource LightAccentBlue}, Dark={StaticResource ForgeAccentBlue}}"/>
                            <Label Text="minuter" Style="{StaticResource MutedLabel}" Margin="0,2,0,6"/>
                            <controls:SparklineView Values="{Binding ActiveValues}" StrokeColor="#38BDF8" HeightRequest="38" BackgroundColor="Transparent"/>
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Column="1" Grid.Row="1"
                            StrokeShape="RoundRectangle 18"
                            BackgroundColor="{AppThemeBinding Light={StaticResource LightSurface}, Dark={StaticResource ForgeSurface}}"
                            Stroke="{AppThemeBinding Light={StaticResource LightBorder}, Dark={StaticResource ForgeBorder}}"
                            StrokeThickness="1" Padding="16,14,16,12">
                        <VerticalStackLayout Spacing="0">
                            <Label Text="MAXPULS" Style="{StaticResource SectionLabel}" Margin="0,0,0,4"/>
                            <Label Text="{Binding HeartRateText}"
                                   FontSize="36" CharacterSpacing="0" LineHeight="1"
                                   TextColor="{AppThemeBinding Light={StaticResource LightAccentPurple}, Dark={StaticResource ForgeAccentPurple}}"/>
                            <Label Text="slag/min" Style="{StaticResource MutedLabel}" Margin="0,2,0,6"/>
                            <controls:SparklineView Values="{Binding HeartRateValues}" StrokeColor="#A78BFA" HeightRequest="38" BackgroundColor="Transparent"/>
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <!-- ═══ MUSKELHEATMAP ═══ -->
                <Border Margin="16,16,16,0"
                        StrokeShape="RoundRectangle 22"
                        BackgroundColor="{AppThemeBinding Light={StaticResource LightSurface}, Dark={StaticResource ForgeSurface}}"
                        Stroke="{AppThemeBinding Light={StaticResource LightBorder}, Dark={StaticResource ForgeBorder}}"
                        StrokeThickness="1"
                        Padding="20,18">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="MUSKLER · 7 DAGAR" Style="{StaticResource SectionLabel}"/>
                        <CollectionView ItemsSource="{Binding HeatmapItems}"
                                        HeightRequest="120"
                                        HorizontalScrollBarVisibility="Never"
                                        VerticalScrollBarVisibility="Never">
                            <CollectionView.ItemsLayout>
                                <GridItemsLayout Orientation="Vertical" Span="4"
                                                 HorizontalItemSpacing="8" VerticalItemSpacing="8"/>
                            </CollectionView.ItemsLayout>
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="vm:HeatmapTile">
                                    <Border BackgroundColor="{Binding TileColor}"
                                            StrokeShape="RoundRectangle 12"
                                            StrokeThickness="0"
                                            Padding="4,10,4,4">
                                        <VerticalStackLayout Spacing="3" HorizontalOptions="Center">
                                            <Label Text="{Binding Name}"
                                                   FontFamily="BebasNeue" FontSize="8" CharacterSpacing="0.5"
                                                   TextColor="{Binding TextColor}" Opacity="0.85"
                                                   HorizontalOptions="Center"/>
                                            <Label Text="{Binding ScoreText}"
                                                   FontFamily="BebasNeue" FontSize="18"
                                                   TextColor="{Binding TextColor}"
                                                   HorizontalOptions="Center"/>
                                        </VerticalStackLayout>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

        <!-- ═══ WORKOUT BANNER ═══ -->
        <Border x:Name="WorkoutBanner"
                IsVisible="False"
                BackgroundColor="{AppThemeBinding Light={StaticResource LightSurface}, Dark={StaticResource ForgeSurface}}"
                Stroke="{StaticResource ForgeAccent}"
                StrokeThickness="1.5"
                StrokeShape="RoundRectangle 18,18,0,0"
                Padding="20,14,20,16"
                Margin="0,0,0,83"
                VerticalOptions="End"
                ZIndex="10">
            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                <Ellipse Grid.Column="0"
                         Fill="{StaticResource ForgeAccent}"
                         WidthRequest="8" HeightRequest="8"
                         VerticalOptions="Center"/>
                <Label Grid.Column="1"
                       Text="PASS PÅGÅR"
                       FontFamily="BebasNeue" FontSize="16" CharacterSpacing="2"
                       TextColor="{AppThemeBinding Light={StaticResource LightText}, Dark={StaticResource ForgeText}}"
                       VerticalOptions="Center"/>
                <Label Grid.Column="2"
                       Text="ÖPPNA ›"
                       FontFamily="BebasNeue" FontSize="14" CharacterSpacing="1"
                       TextColor="{StaticResource ForgeAccent}"
                       VerticalOptions="Center"/>
            </Grid>
            <Border.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnWorkoutBannerTapped"/>
                <PointerGestureRecognizer
                    PointerPressed="OnBannerPointerPressed"
                    PointerReleased="OnBannerPointerReleased"/>
            </Border.GestureRecognizers>
        </Border>
    <!-- Bottom gradient fade behind floating tab bar — matchar topp-gradienten spegelvänt -->
    <BoxView Grid.RowSpan="99" InputTransparent="True" VerticalOptions="End" HeightRequest="150">
        <BoxView.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="{AppThemeBinding Light=#00FCFCFC, Dark=#000E0E10}" Offset="0.0"/>
                <GradientStop Color="{AppThemeBinding Light=#38FCFCFC, Dark=#380E0E10}" Offset="0.35"/>
                <GradientStop Color="{AppThemeBinding Light=#90FCFCFC, Dark=#900E0E10}" Offset="0.65"/>
                <GradientStop Color="{AppThemeBinding Light=#FCFCFC, Dark=#0E0E10}" Offset="1.0"/>
            </LinearGradientBrush>
        </BoxView.Background>
    </BoxView>

    </Grid>
</ContentPage>