<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:LockIn.ViewModels"
             x:Class="LockIn.Views.HemPage"
             x:DataType="vm:HemViewModel"
             Title="Hem"
             Shell.NavBarIsVisible="False">

    <RefreshView IsEnabled="False">
        <ScrollView>
            <VerticalStackLayout Spacing="0" Padding="0,0,0,120">

                <!-- ═══ HEADER ═══ -->
                <Grid Padding="22,56,22,4" ColumnDefinitions="*,48">

                    <VerticalStackLayout Grid.Column="0" Spacing="0" VerticalOptions="End">
                        <Label Text="{Binding Greeting}"
                               FontFamily="BebasNeue"
                               FontSize="12"
                               CharacterSpacing="4"
                               TextColor="{AppThemeBinding Light={StaticResource LightMuted}, Dark={StaticResource ForgeMuted}}"/>
                        <Label Text="{Binding UserName}"
                               FontFamily="BebasNeue"
                               FontSize="52"
                               CharacterSpacing="1"
                               LineHeight="1"
                               TextColor="{AppThemeBinding Light={StaticResource LightText}, Dark={StaticResource ForgeText}}"/>
                    </VerticalStackLayout>

                    <!-- Profile avatar -->
                    <Border Grid.Column="1"
                            WidthRequest="44" HeightRequest="44"
                            StrokeShape="Ellipse"
                            BackgroundColor="{AppThemeBinding Light={StaticResource LightSurface2}, Dark={StaticResource ForgeSurface2}}"
                            Stroke="{AppThemeBinding Light={StaticResource LightBorder}, Dark={StaticResource ForgeBorder}}"
                            StrokeThickness="1"
                            VerticalOptions="End">
                        <Image Source="user-circle.png"
                               WidthRequest="22" HeightRequest="22"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>
                    </Border>
                </Grid>

                <!-- ═══ SCORE CARD (HERO GAUGE) ═══ -->
                <Border Margin="16,14,16,0"
                        StrokeShape="RoundRectangle 22"
                        BackgroundColor="{AppThemeBinding Light={StaticResource LightSurface}, Dark={StaticResource ForgeSurface}}"
                        Stroke="{AppThemeBinding Light={StaticResource LightBorder}, Dark={StaticResource ForgeBorderLight}}"
                        StrokeThickness="1">
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,2" Radius="20" Opacity="0.10"/>
                    </Border.Shadow>
                    <VerticalStackLayout Padding="24,22,24,20" Spacing="0">

                        <Label Text="TRÄNINGSSCORE · IDAG"
                               Style="{StaticResource SectionLabel}"
                               Margin="0,0,0,4"/>

                        <!-- Gauge overlay grid -->
                        <Grid HeightRequest="186">
                            <GraphicsView x:Name="GaugeView"
                                          Drawable="{Binding GaugeDrawable}"/>

                            <!-- Score label centered at gauge midpoint -->
                            <VerticalStackLayout HorizontalOptions="Center"
                                                 VerticalOptions="End"
                                                 Spacing="0"
                                                 Margin="0,0,0,12">
                                <Label Text="{Binding TrainingScoreText}"
                                       FontFamily="BebasNeue"
                                       FontSize="86"
                                       CharacterSpacing="0"
                                       LineHeight="1"
                                       HorizontalOptions="Center"
                                       TextColor="{AppThemeBinding Light={StaticResource LightText}, Dark={StaticResource ForgeText}}"/>
                                <Label Text="/ 100"
                                       FontFamily="BebasNeue"
                                       FontSize="18"
                                       CharacterSpacing="1"
                                       HorizontalOptions="Center"
                                       TextColor="{AppThemeBinding Light={StaticResource LightMuted}, Dark={StaticResource ForgeMuted}}"/>
                            </VerticalStackLayout>
                        </Grid>

                        <!-- Motivation text -->
                        <Label Text="{Binding MotivationText}"
                               Style="{StaticResource MutedLabel}"
                               HorizontalTextAlignment="Center"
                               Margin="0,10,0,0"/>
                    </VerticalStackLayout>
                </Border>

                <!-- ═══ STREAK HEADER ═══ -->
                <Grid Padding="22,22,22,10" ColumnDefinitions="*,Auto">
                    <VerticalStackLayout Grid.Column="0" Spacing="2">
                        <Label Text="STREAK"
                               Style="{StaticResource SectionLabel}"/>
                        <Label Text="{Binding StreakLabel}"
                               FontFamily="DMSansMedium"
                               FontSize="13"
                               TextColor="{StaticResource ForgeAccent}"/>
                    </VerticalStackLayout>
                    <Label Grid.Column="1"
                           Text="SE ALLA ›"
                           Style="{StaticResource SectionLabel}"
                           VerticalOptions="End"
                           TextColor="{AppThemeBinding Light={StaticResource LightMuted}, Dark={StaticResource ForgeMuted}}"/>
                </Grid>

                <!-- ═══ DAY STREAK TRACKER ═══ -->
                <CollectionView ItemsSource="{Binding Days}"
                                Margin="12,0"
                                HeightRequest="76">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Horizontal" ItemSpacing="6"/>
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="vm:DayStreakItem">
                            <VerticalStackLayout Spacing="5" HorizontalOptions="Center" Margin="2,0">
                                <Border WidthRequest="46" HeightRequest="46"
                                        StrokeShape="Ellipse"
                                        BackgroundColor="{Binding CircleFill}"
                                        Stroke="{Binding CircleStroke}"
                                        StrokeThickness="1.5">
                                    <Label Text="{Binding DayNum}"
                                           FontFamily="BebasNeue"
                                           FontSize="20"
                                           CharacterSpacing="0"
                                           TextColor="{Binding DayNumColor}"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center"/>
                                </Border>
                                <Label Text="{Binding DayAbbr}"
                                       FontFamily="BebasNeue"
                                       FontSize="9"
                                       CharacterSpacing="1.5"
                                       TextColor="{Binding DayAbbrColor}"
                                       HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <!-- ═══ STATS HEADER ═══ -->
                <Label Text="IDAG"
                       Style="{StaticResource SectionLabel}"
                       Margin="22,18,0,10"/>

                <!-- ═══ DATA CARDS 2×2 ═══ -->
                <Grid ColumnDefinitions="*,*"
                      RowDefinitions="Auto,Auto"
                      ColumnSpacing="8"
                      RowSpacing="8"
                      Margin="16,0">

                    <!-- STEG -->
                    <Border Grid.Column="0" Grid.Row="0"
                            StrokeShape="RoundRectangle 18"
                            BackgroundColor="{AppThemeBinding Light={StaticResource LightSurface}, Dark={StaticResource ForgeSurface}}"
                            Stroke="{AppThemeBinding Light={StaticResource LightBorder}, Dark={StaticResource ForgeBorder}}"
                            StrokeThickness="1"
                            Padding="16,14,16,12">
                        <VerticalStackLayout Spacing="0">
                            <Label Text="STEG"
                                   Style="{StaticResource SectionLabel}"
                                   Margin="0,0,0,4"/>
                            <Label Text="{Binding StepsText}"
                                   FontFamily="BebasNeue"
                                   FontSize="36"
                                   CharacterSpacing="0"
                                   LineHeight="1"
                                   TextColor="{StaticResource ForgeAccent}"/>
                            <Label Text="steg idag"
                                   Style="{StaticResource MutedLabel}"
                                   Margin="0,2,0,6"/>
                            <GraphicsView Drawable="{Binding StepsSparkline}"
                                          HeightRequest="38"/>
                        </VerticalStackLayout>
                    </Border>

                    <!-- KALORIER -->
                    <Border Grid.Column="1" Grid.Row="0"
                            StrokeShape="RoundRectangle 18"
                            BackgroundColor="{AppThemeBinding Light={StaticResource LightSurface}, Dark={StaticResource ForgeSurface}}"
                            Stroke="{AppThemeBinding Light={StaticResource LightBorder}, Dark={StaticResource ForgeBorder}}"
                            StrokeThickness="1"
                            Padding="16,14,16,12">
                        <VerticalStackLayout Spacing="0">
                            <Label Text="KALORIER"
                                   Style="{StaticResource SectionLabel}"
                                   Margin="0,0,0,4"/>
                            <Label Text="{Binding CaloriesText}"
                                   FontFamily="BebasNeue"
                                   FontSize="36"
                                   CharacterSpacing="0"
                                   LineHeight="1"
                                   TextColor="{StaticResource ForgeAccent}"/>
                            <Label Text="kcal"
                                   Style="{StaticResource MutedLabel}"
                                   Margin="0,2,0,6"/>
                            <GraphicsView Drawable="{Binding CaloriesSparkline}"
                                          HeightRequest="38"/>
                        </VerticalStackLayout>
                    </Border>

                    <!-- AKTIV TID -->
                    <Border Grid.Column="0" Grid.Row="1"
                            StrokeShape="RoundRectangle 18"
                            BackgroundColor="{AppThemeBinding Light={StaticResource LightSurface}, Dark={StaticResource ForgeSurface}}"
                            Stroke="{AppThemeBinding Light={StaticResource LightBorder}, Dark={StaticResource ForgeBorder}}"
                            StrokeThickness="1"
                            Padding="16,14,16,12">
                        <VerticalStackLayout Spacing="0">
                            <Label Text="AKTIV TID"
                                   Style="{StaticResource SectionLabel}"
                                   Margin="0,0,0,4"/>
                            <Label Text="{Binding ActiveText}"
                                   FontFamily="BebasNeue"
                                   FontSize="36"
                                   CharacterSpacing="0"
                                   LineHeight="1"
                                   TextColor="{StaticResource ForgeAccent}"/>
                            <Label Text="minuter"
                                   Style="{StaticResource MutedLabel}"
                                   Margin="0,2,0,6"/>
                            <GraphicsView Drawable="{Binding ActiveSparkline}"
                                          HeightRequest="38"/>
                        </VerticalStackLayout>
                    </Border>

                    <!-- MAXPULS -->
                    <Border Grid.Column="1" Grid.Row="1"
                            StrokeShape="RoundRectangle 18"
                            BackgroundColor="{AppThemeBinding Light={StaticResource LightSurface}, Dark={StaticResource ForgeSurface}}"
                            Stroke="{AppThemeBinding Light={StaticResource LightBorder}, Dark={StaticResource ForgeBorder}}"
                            StrokeThickness="1"
                            Padding="16,14,16,12">
                        <VerticalStackLayout Spacing="0">
                            <Label Text="MAXPULS"
                                   Style="{StaticResource SectionLabel}"
                                   Margin="0,0,0,4"/>
                            <Label Text="{Binding HeartRateText}"
                                   FontFamily="BebasNeue"
                                   FontSize="36"
                                   CharacterSpacing="0"
                                   LineHeight="1"
                                   TextColor="{AppThemeBinding Light={StaticResource LightText}, Dark={StaticResource ForgeText}}"/>
                            <Label Text="slag/min"
                                   Style="{StaticResource MutedLabel}"
                                   Margin="0,2,0,6"/>
                            <GraphicsView Drawable="{Binding HeartRateSparkline}"
                                          HeightRequest="38"/>
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <!-- ═══ AI COACH ═══ -->
                <Border Margin="16,16,16,0"
                        StrokeShape="RoundRectangle 22"
                        BackgroundColor="{AppThemeBinding Light={StaticResource LightSurface}, Dark={StaticResource ForgeSurface}}"
                        Stroke="{AppThemeBinding Light={StaticResource LightAccent}, Dark={StaticResource ForgeAccent}}"
                        StrokeThickness="1"
                        Padding="20,18">
                    <Border.Shadow>
                        <Shadow Brush="#4ADE80" Offset="0,2" Radius="20" Opacity="0.12"/>
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="14">

                        <!-- Header row -->
                        <Grid ColumnDefinitions="28,*">
                            <Label Grid.Column="0"
                                   Text="✦"
                                   FontSize="16"
                                   TextColor="{StaticResource ForgeAccent}"
                                   VerticalOptions="Start"
                                   Margin="0,2,0,0"/>
                            <VerticalStackLayout Grid.Column="1" Spacing="2">
                                <Label Text="AI COACH"
                                       Style="{StaticResource SectionLabel}"/>
                                <Label Text="Hur kan jag hjälpa dig idag?"
                                       FontFamily="DMSansMedium"
                                       FontSize="15"
                                       TextColor="{AppThemeBinding Light={StaticResource LightText}, Dark={StaticResource ForgeText}}"/>
                            </VerticalStackLayout>
                        </Grid>

                        <!-- Prompt chips -->
                        <StackLayout Spacing="8">
                            <Border StrokeShape="RoundRectangle 20"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource LightSurface2}, Dark={StaticResource ForgeSurface2}}"
                                    Stroke="{AppThemeBinding Light={StaticResource LightBorder}, Dark={StaticResource ForgeBorder}}"
                                    StrokeThickness="1"
                                    Padding="14,9">
                                <Label Text="↗  Visa min veckosammanfattning"
                                       FontFamily="DMSansRegular"
                                       FontSize="13"
                                       TextColor="{AppThemeBinding Light={StaticResource LightText}, Dark={StaticResource ForgeText}}"/>
                            </Border>
                            <Border StrokeShape="RoundRectangle 20"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource LightSurface2}, Dark={StaticResource ForgeSurface2}}"
                                    Stroke="{AppThemeBinding Light={StaticResource LightBorder}, Dark={StaticResource ForgeBorder}}"
                                    StrokeThickness="1"
                                    Padding="14,9">
                                <Label Text="↗  Tips för bättre återhämtning"
                                       FontFamily="DMSansRegular"
                                       FontSize="13"
                                       TextColor="{AppThemeBinding Light={StaticResource LightText}, Dark={StaticResource ForgeText}}"/>
                            </Border>
                            <Border StrokeShape="RoundRectangle 20"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource LightSurface2}, Dark={StaticResource ForgeSurface2}}"
                                    Stroke="{AppThemeBinding Light={StaticResource LightBorder}, Dark={StaticResource ForgeBorder}}"
                                    StrokeThickness="1"
                                    Padding="14,9">
                                <Label Text="↗  Föreslå mitt nästa pass"
                                       FontFamily="DMSansRegular"
                                       FontSize="13"
                                       TextColor="{AppThemeBinding Light={StaticResource LightText}, Dark={StaticResource ForgeText}}"/>
                            </Border>
                        </StackLayout>

                        <!-- Input stub -->
                        <Border StrokeShape="RoundRectangle 24"
                                BackgroundColor="{AppThemeBinding Light={StaticResource LightSurface2}, Dark={StaticResource ForgeSurface2}}"
                                Stroke="{AppThemeBinding Light={StaticResource LightBorder}, Dark={StaticResource ForgeBorder}}"
                                StrokeThickness="1"
                                Padding="16,12,12,12">
                            <Grid ColumnDefinitions="*,40">
                                <Label Grid.Column="0"
                                       Text="Fråga mig något..."
                                       FontFamily="DMSansRegular"
                                       FontSize="14"
                                       TextColor="{AppThemeBinding Light={StaticResource LightMuted}, Dark={StaticResource ForgeMuted}}"
                                       VerticalOptions="Center"/>
                                <Border Grid.Column="1"
                                        WidthRequest="34" HeightRequest="34"
                                        StrokeShape="Ellipse"
                                        BackgroundColor="{StaticResource ForgePrimary}"
                                        StrokeThickness="0"
                                        HorizontalOptions="End"
                                        VerticalOptions="Center">
                                    <Label Text="↑"
                                           FontFamily="BebasNeue"
                                           FontSize="18"
                                           TextColor="{StaticResource ForgePrimaryForeground}"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center"/>
                                </Border>
                            </Grid>
                        </Border>

                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>
    </RefreshView>

</ContentPage>
