<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:LockIn.ViewModels"
             xmlns:views="clr-namespace:LockIn.Views"
             xmlns:controls="clr-namespace:LockIn.Controls"
             xmlns:loc="clr-namespace:LockIn.Resources.Strings"
             xmlns:ios="clr-namespace:Microsoft.Maui.Controls.PlatformConfiguration.iOSSpecific;assembly=Microsoft.Maui.Controls"
             xmlns:models="clr-namespace:LockIn.Models"
             x:Class="LockIn.Views.HemPage"
             x:DataType="vm:HemViewModel"
             Title="{loc:Localize Tab_Home}"
             Shell.NavBarIsVisible="False"
             BackgroundColor="Transparent"
             ios:Page.UseSafeArea="False">

    <Grid SafeAreaEdges="None">

        <!-- Atmosfärisk bakgrund — renderas under allt annat -->
        <controls:AtmosphericBackgroundView InputTransparent="True"/>

        <!-- Permanent status bar gradient (alltid synlig, fyller Dynamic Island-zonen) -->
        <BoxView VerticalOptions="Start" HeightRequest="90" InputTransparent="True" ZIndex="19">
            <BoxView.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="{AppThemeBinding Light=#28FCFCFC, Dark=#28141418}" Offset="0.0"/>
                    <GradientStop Color="{AppThemeBinding Light=#00FCFCFC, Dark=#00141418}" Offset="1.0"/>
                </LinearGradientBrush>
            </BoxView.Background>
        </BoxView>

        <!-- Sticky header (fades in on scroll) -->
        <Grid x:Name="StickyHeader" VerticalOptions="Start" ZIndex="20" Opacity="0"
              HeightRequest="150" SafeAreaEdges="None">
            <BoxView InputTransparent="True">
                <BoxView.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="{AppThemeBinding Light=#D8FCFCFC, Dark=#D8141418}" Offset="0.0"/>
                        <GradientStop Color="{AppThemeBinding Light=#90FCFCFC, Dark=#90141418}" Offset="0.35"/>
                        <GradientStop Color="{AppThemeBinding Light=#38FCFCFC, Dark=#38141418}" Offset="0.65"/>
                        <GradientStop Color="{AppThemeBinding Light=#00FCFCFC, Dark=#00141418}" Offset="1.0"/>
                    </LinearGradientBrush>
                </BoxView.Background>
            </BoxView>
            <Grid Padding="22,14,22,12" VerticalOptions="Start">
                <Label Text="{Binding UserName}"
                       HorizontalOptions="Center" HorizontalTextAlignment="Center"
                       FontFamily="BebasNeue" FontSize="18" CharacterSpacing="1"
                       VerticalOptions="Center"
                       TextColor="{AppThemeBinding Light={StaticResource LightText}, Dark={StaticResource ForgeText}}"/>
            </Grid>
        </Grid>

        <ScrollView VerticalScrollBarVisibility="Never" Scrolled="OnScrolled">
            <VerticalStackLayout Spacing="0" Padding="0,0,0,120">

                <!-- ═══ HEADER ═══ -->
                <Grid Padding="22,56,22,4" ColumnDefinitions="*,48">
                    <VerticalStackLayout Grid.Column="0" Spacing="0" VerticalOptions="End">
                        <Label Text="{Binding Greeting}"
                               FontFamily="BebasNeue" FontSize="12" CharacterSpacing="4"
                               TextColor="{AppThemeBinding Light={StaticResource LightMuted}, Dark={StaticResource ForgeMuted}}"/>
                        <Label Text="{Binding UserName}"
                               FontFamily="BebasNeue" FontSize="52" CharacterSpacing="1" LineHeight="1"
                               TextColor="{AppThemeBinding Light={StaticResource LightText}, Dark={StaticResource ForgeText}}"/>
                    </VerticalStackLayout>
                    <Border Grid.Column="1"
                            WidthRequest="44" HeightRequest="44"
                            StrokeShape="Ellipse"
                            BackgroundColor="{AppThemeBinding Light={StaticResource LightAccent}, Dark={StaticResource ForgeAccentDim}}"
                            Stroke="{AppThemeBinding Light={StaticResource LightAccent}, Dark={StaticResource ForgeAccent}}"
                            StrokeThickness="1.5"
                            VerticalOptions="End">
                        <Label Text="{Binding UserInitial}"
                               FontFamily="BebasNeue" FontSize="22"
                               TextColor="{AppThemeBinding Light={StaticResource LightText}, Dark={StaticResource ForgeAccent}}"
                               HorizontalOptions="Center" VerticalOptions="Center"/>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnAvatarTapped"/>
                        </Border.GestureRecognizers>
                    </Border>
                </Grid>

                <!-- ═══ SCORE CARD (HERO GAUGE) ═══ -->
                <Border Margin="16,14,16,0"
                        StrokeShape="RoundRectangle 22"
                        BackgroundColor="{AppThemeBinding Light={StaticResource LightSurface}, Dark={StaticResource ForgeSurface}}"
                        Stroke="{AppThemeBinding Light={StaticResource LightBorder}, Dark={StaticResource ForgeBorderLight}}"
                        StrokeThickness="1">
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,2" Radius="20" Opacity="0.10"/>
                    </Border.Shadow>
                    <VerticalStackLayout Padding="24,20,24,16" Spacing="0">
                        <Label Text="{loc:Localize Hem_ScoreCard_Title}"
                               Style="{StaticResource SectionLabel}" Margin="0,0,0,8"/>
                        <Label Text="{Binding MotivationText}"
                               Style="{StaticResource MutedLabel}"
                               HorizontalTextAlignment="Center" Margin="0,8,0,10"/>
                        <controls:WeeklyGoalGauge x:Name="Gauge"
                                                  Progress="{Binding GaugeProgress}"
                                                  HeightRequest="260"
                                                  WidthRequest="260"
                                                  HorizontalOptions="Center"
                                                  SemanticProperties.Description="{Binding GaugeAccessibilityLabel}"/>
                    </VerticalStackLayout>
                </Border>

                <!-- ═══ IDAG-REKOMMENDATION ═══ -->
                <Border Margin="16,16,16,4"
                        BackgroundColor="{AppThemeBinding Light={StaticResource LightSurface}, Dark={StaticResource ForgeSurface}}"
                        StrokeShape="RoundRectangle 18"
                        StrokeThickness="0"
                        Padding="20,16">
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,2" Radius="10" Opacity="0.18"/>
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="6">
                        <Label Text="{loc:Localize Hem_Recommendation_Label}"
                               Style="{StaticResource SectionLabel}"
                               TextColor="{StaticResource ForgeAccent}"/>
                        <Label Text="{Binding TodayRecommendation}"
                               FontFamily="BebasNeue" FontSize="32"
                               CharacterSpacing="1"
                               LineHeight="1"
                               TextColor="{AppThemeBinding Light={StaticResource LightText}, Dark={StaticResource ForgeText}}"/>
                        <Label Text="{Binding TodayRecommendationDetail}"
                               Style="{StaticResource MutedLabel}"
                               LineBreakMode="WordWrap"/>
                    </VerticalStackLayout>
                </Border>

                <!-- ═══ DATA-CHIPS ═══ -->
                <CollectionView ItemsSource="{Binding CoachChips}"
                                IsVisible="{Binding HasCoachChips}"
                                Margin="16,10,0,0"
                                HeightRequest="40"
                                HorizontalScrollBarVisibility="Never"
                                VerticalScrollBarVisibility="Never">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Horizontal" ItemSpacing="8"/>
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:CoachChip">
                            <Border StrokeShape="RoundRectangle 10"
                                    Padding="14,0"
                                    HeightRequest="36"
                                    VerticalOptions="Center"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource LightSurface2}, Dark={StaticResource ForgeSurface2}}"
                                    Stroke="{AppThemeBinding Light={StaticResource LightBorder}, Dark={StaticResource ForgeBorderLight}}"
                                    StrokeThickness="1">
                                <Label Text="{Binding ChipText}"
                                       FontFamily="DMSansMedium" FontSize="13"
                                       TextColor="{AppThemeBinding Light={StaticResource LightText}, Dark={StaticResource ForgeText}}"
                                       VerticalOptions="Center"/>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnChipTapped"/>
                                </Border.GestureRecognizers>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <!-- ═══ STRAIN / RECOVERY / SÖMN-RINGAR ═══ -->
                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8" Margin="16,18,16,4">
                    <StackLayout Grid.Column="0" Spacing="8" HorizontalOptions="Center">
                        <controls:MetricRingView Progress="{Binding StrainProgress}"
                                                 TargetProgress="{Binding StrainTarget}"
                                                 RingColor="{StaticResource ForgeAccentAmber}"
                                                 CenterText="{Binding StrainText}"
                                                 WidthRequest="90" HeightRequest="90"
                                                 HorizontalOptions="Center"
                                                 SemanticProperties.Description="{Binding StrainAccessibilityLabel}"/>
                        <Label Text="{loc:Localize Hem_Strain_Label}" Style="{StaticResource SectionLabel}" HorizontalTextAlignment="Center"/>
                        <Label Text="{Binding StrainTargetText}"
                               FontFamily="BebasNeue" FontSize="10" CharacterSpacing="1.5"
                               TextColor="{StaticResource ForgeAccentAmber}"
                               Opacity="0.7"
                               HorizontalTextAlignment="Center"/>
                    </StackLayout>
                    <StackLayout Grid.Column="1" Spacing="8" HorizontalOptions="Center">
                        <controls:MetricRingView Progress="{Binding RecoveryProgress}"
                                                 RingColor="{StaticResource ForgeAccent}"
                                                 CenterText="{Binding RecoveryText}"
                                                 WidthRequest="90" HeightRequest="90"
                                                 HorizontalOptions="Center"
                                                 SemanticProperties.Description="{Binding RecoveryAccessibilityLabel}"/>
                        <Label Text="{loc:Localize Hem_Recovery_Label}" Style="{StaticResource SectionLabel}" HorizontalTextAlignment="Center"/>
                        <Label Text="{Binding RecoveryStatusText}"
                               FontFamily="BebasNeue" FontSize="9" CharacterSpacing="1.5"
                               TextColor="{StaticResource ForgeAccent}"
                               Opacity="0.7"
                               HorizontalTextAlignment="Center"/>
                    </StackLayout>
                    <StackLayout Grid.Column="2" Spacing="8" HorizontalOptions="Center">
                        <controls:MetricRingView Progress="{Binding SleepProgress}"
                                                 RingColor="{StaticResource ForgeAccentBlue}"
                                                 CenterText="{Binding SleepText}"
                                                 WidthRequest="90" HeightRequest="90"
                                                 HorizontalOptions="Center"
                                                 SemanticProperties.Description="{Binding SleepAccessibilityLabel}"/>
                        <Label Text="{loc:Localize Hem_Sleep_Label}" Style="{StaticResource SectionLabel}" HorizontalTextAlignment="Center"/>
                        <Label Text="{Binding SleepStatusText}"
                               FontFamily="BebasNeue" FontSize="9" CharacterSpacing="1.5"
                               TextColor="{StaticResource ForgeAccentBlue}"
                               Opacity="0.7"
                               HorizontalTextAlignment="Center"/>
                    </StackLayout>
                </Grid>

                <Label Text="{Binding RecoveryComponentsText}"
                       Style="{StaticResource MutedLabel}"
                       FontSize="10"
                       HorizontalTextAlignment="Center"
                       Margin="16,6,16,0"/>

                <!-- ═══ SÖMN-DETALJER ═══ -->
                <Label Text="{loc:Localize Hem_Sleep_Label}" Style="{StaticResource SectionLabel}" Margin="22,18,0,10"/>
                <Border Margin="16,0,16,0"
                        BackgroundColor="{AppThemeBinding Light={StaticResource LightSurface}, Dark={StaticResource ForgeSurface}}"
                        StrokeShape="RoundRectangle 18"
                        StrokeThickness="0"
                        Padding="20,16">
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,2" Radius="10" Opacity="0.18"/>
                    </Border.Shadow>
                    <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="10">
                        <VerticalStackLayout Grid.Column="0" Spacing="2" HorizontalOptions="Center">
                            <Label Text="{Binding CoreSleepText}"
                                   FontSize="22" FontAttributes="Bold"
                                   HorizontalTextAlignment="Center"
                                   TextColor="{StaticResource ForgeAccentBlue}"/>
                            <Label Text="{loc:Localize Hem_Sleep_Core}" Style="{StaticResource SectionLabel}" FontSize="9" HorizontalTextAlignment="Center"/>
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="1" Spacing="2" HorizontalOptions="Center">
                            <Label Text="{Binding DeepSleepText}"
                                   FontSize="22" FontAttributes="Bold"
                                   HorizontalTextAlignment="Center"
                                   TextColor="{StaticResource ForgeAccentPurple}"/>
                            <Label Text="{loc:Localize Hem_Sleep_Deep}" Style="{StaticResource SectionLabel}" FontSize="9" HorizontalTextAlignment="Center"/>
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="2" Spacing="2" HorizontalOptions="Center">
                            <Label Text="{Binding RemSleepText}"
                                   FontSize="22" FontAttributes="Bold"
                                   HorizontalTextAlignment="Center"
                                   TextColor="{StaticResource ForgeAccent}"/>
                            <Label Text="{loc:Localize Hem_Sleep_Rem}" Style="{StaticResource SectionLabel}" FontSize="9" HorizontalTextAlignment="Center"/>
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="3" Spacing="2" HorizontalOptions="Center">
                            <Label Text="{Binding AwakeSleepText}"
                                   FontSize="22" FontAttributes="Bold"
                                   HorizontalTextAlignment="Center"
                                   TextColor="{StaticResource ForgeAccentAmber}"/>
                            <Label Text="{loc:Localize Hem_SleepStage_Awake}" Style="{StaticResource SectionLabel}" FontSize="9" HorizontalTextAlignment="Center"/>
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <!-- ═══ STREAK HEADER ═══ -->
                <Grid Padding="22,22,22,10" ColumnDefinitions="*,Auto">
                    <VerticalStackLayout Grid.Column="0" Spacing="2">
                        <Label Text="{loc:Localize Hem_Streak_Label}" Style="{StaticResource SectionLabel}"/>
                        <Label Text="{Binding StreakLabel}"
                               FontFamily="DMSansMedium" FontSize="13"
                               TextColor="{AppThemeBinding Light={StaticResource LightAccent}, Dark={StaticResource ForgeAccentAmber}}"/>
                    </VerticalStackLayout>
                    <Label Grid.Column="1"
                           Text="{loc:Localize Hem_SeeAll}"
                           Style="{StaticResource SectionLabel}"
                           VerticalOptions="End"
                           TextColor="{AppThemeBinding Light={StaticResource LightMuted}, Dark={StaticResource ForgeMuted}}">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnSeAllaHistorik"/>
                        </Label.GestureRecognizers>
                    </Label>
                </Grid>

                <!-- ═══ DAY STREAK TRACKER ═══ -->
                <CollectionView x:Name="StreakCollectionView"
                                ItemsSource="{Binding Days}"
                                Margin="12,0" HeightRequest="76"
                                HorizontalScrollBarVisibility="Never"
                                VerticalScrollBarVisibility="Never">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Horizontal" ItemSpacing="6"/>
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="vm:DayStreakItem">
                            <VerticalStackLayout Spacing="5" HorizontalOptions="Center" Margin="2,0">
                                <Border WidthRequest="46" HeightRequest="46"
                                        StrokeShape="Ellipse"
                                        BackgroundColor="{Binding CircleFill}"
                                        Stroke="{Binding CircleStroke}"
                                        StrokeThickness="1.5">
                                    <Label Text="{Binding DayNum}"
                                           FontFamily="BebasNeue" FontSize="20" CharacterSpacing="0"
                                           TextColor="{Binding DayNumColor}"
                                           HorizontalOptions="Center" VerticalOptions="Center"/>
                                </Border>
                                <Label Text="{Binding DayAbbr}"
                                       FontFamily="BebasNeue" FontSize="9" CharacterSpacing="1.5"
                                       TextColor="{Binding DayAbbrColor}"
                                       HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <!-- ═══ STATS HEADER ═══ -->
                <Label Text="{loc:Localize Hem_Activity_Label}" Style="{StaticResource SectionLabel}" Margin="22,18,0,10"/>

                <!-- ═══ DATA CARDS 2×2 ═══ -->
                <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto"
                      ColumnSpacing="8" RowSpacing="8" Margin="16,0">

                    <Border Grid.Column="0" Grid.Row="0"
                            StrokeShape="RoundRectangle 18"
                            BackgroundColor="{AppThemeBinding Light={StaticResource LightSurface}, Dark={StaticResource ForgeSurface}}"
                            Stroke="{AppThemeBinding Light={StaticResource LightBorder}, Dark={StaticResource ForgeBorder}}"
                            StrokeThickness="1" Padding="16,14,16,12">
                        <VerticalStackLayout Spacing="0">
                            <Label Text="{loc:Localize Hem_Steps_Label}" Style="{StaticResource SectionLabel}" Margin="0,0,0,4"/>
                            <Label Text="{Binding StepsText}"
                                   FontSize="36" CharacterSpacing="0" LineHeight="1"
                                   TextColor="{AppThemeBinding Light={StaticResource LightAccent}, Dark={StaticResource ForgeAccent}}"/>
                            <Label Text="{loc:Localize Hem_Steps_Sub}" Style="{StaticResource MutedLabel}" Margin="0,2,0,6"/>
                            <controls:SparklineView Values="{Binding StepsValues}" StrokeColor="{StaticResource ForgeAccent}" HeightRequest="38" BackgroundColor="Transparent"
                                                   SemanticProperties.Description="{loc:Localize Hem_Sparkline_Steps}"/>
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Column="1" Grid.Row="0"
                            StrokeShape="RoundRectangle 18"
                            BackgroundColor="{AppThemeBinding Light={StaticResource LightSurface}, Dark={StaticResource ForgeSurface}}"
                            Stroke="{AppThemeBinding Light={StaticResource LightBorder}, Dark={StaticResource ForgeBorder}}"
                            StrokeThickness="1" Padding="16,14,16,12">
                        <VerticalStackLayout Spacing="0">
                            <Label Text="{loc:Localize Hem_Calories_Label}" Style="{StaticResource SectionLabel}" Margin="0,0,0,4"/>
                            <Label Text="{Binding CaloriesText}"
                                   FontSize="36" CharacterSpacing="0" LineHeight="1"
                                   TextColor="{AppThemeBinding Light={StaticResource LightAccentCoral}, Dark={StaticResource ForgeAccentCoral}}"/>
                            <Label Text="{loc:Localize Hem_Calories_Sub}" Style="{StaticResource MutedLabel}" Margin="0,2,0,6"/>
                            <controls:SparklineView Values="{Binding CaloriesValues}" StrokeColor="{StaticResource ForgeAccentCoral}" HeightRequest="38" BackgroundColor="Transparent"
                                                   SemanticProperties.Description="{loc:Localize Hem_Sparkline_Calories}"/>
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Column="0" Grid.Row="1"
                            StrokeShape="RoundRectangle 18"
                            BackgroundColor="{AppThemeBinding Light={StaticResource LightSurface}, Dark={StaticResource ForgeSurface}}"
                            Stroke="{AppThemeBinding Light={StaticResource LightBorder}, Dark={StaticResource ForgeBorder}}"
                            StrokeThickness="1" Padding="16,14,16,12">
                        <VerticalStackLayout Spacing="0">
                            <Label Text="{loc:Localize Hem_ActiveTime_Label}" Style="{StaticResource SectionLabel}" Margin="0,0,0,4"/>
                            <Label Text="{Binding ActiveText}"
                                   FontSize="36" CharacterSpacing="0" LineHeight="1"
                                   TextColor="{AppThemeBinding Light={StaticResource LightAccentBlue}, Dark={StaticResource ForgeAccentBlue}}"/>
                            <Label Text="{loc:Localize Hem_ActiveTime_Sub}" Style="{StaticResource MutedLabel}" Margin="0,2,0,6"/>
                            <controls:SparklineView Values="{Binding ActiveValues}" StrokeColor="{StaticResource ForgeAccentBlue}" HeightRequest="38" BackgroundColor="Transparent"
                                                   SemanticProperties.Description="{loc:Localize Hem_Sparkline_ActiveTime}"/>
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Column="1" Grid.Row="1"
                            StrokeShape="RoundRectangle 18"
                            BackgroundColor="{AppThemeBinding Light={StaticResource LightSurface}, Dark={StaticResource ForgeSurface}}"
                            Stroke="{AppThemeBinding Light={StaticResource LightBorder}, Dark={StaticResource ForgeBorder}}"
                            StrokeThickness="1" Padding="16,14,16,12">
                        <VerticalStackLayout Spacing="0">
                            <Label Text="{loc:Localize Hem_HeartRate_Label}" Style="{StaticResource SectionLabel}" Margin="0,0,0,4"/>
                            <Label Text="{Binding HeartRateText}"
                                   FontSize="36" CharacterSpacing="0" LineHeight="1"
                                   TextColor="{AppThemeBinding Light={StaticResource LightAccentPurple}, Dark={StaticResource ForgeAccentPurple}}"/>
                            <Label Text="{loc:Localize Hem_HeartRate_Sub}" Style="{StaticResource MutedLabel}" Margin="0,2,0,6"/>
                            <controls:SparklineView Values="{Binding HeartRateValues}" StrokeColor="{StaticResource ForgeAccentPurple}" HeightRequest="38" BackgroundColor="Transparent"
                                                   SemanticProperties.Description="{loc:Localize Hem_Sparkline_HeartRate}"/>
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <!-- ═══ MUSKELHEATMAP ═══ -->
                <Label Text="{loc:Localize Hem_Muscles_Title}" Style="{StaticResource SectionLabel}" Margin="22,18,0,10"/>
                <Grid x:Name="HemHeatmapGrid"
                      ColumnDefinitions="*,*,*,*"
                      ColumnSpacing="8" RowSpacing="8"
                      Margin="16,0"/>

                <!-- ═══ VOLYMTREND ═══ -->
                <Label Text="{loc:Localize Hem_MuscleTrend_Title}"
                       Style="{StaticResource SectionLabel}"
                       Margin="22,18,0,8"
                       IsVisible="{Binding MuscleTrends.Count, Converter={x:Static vm:GreaterThanZeroConverter.Instance}}"/>
                <ScrollView Orientation="Horizontal"
                            HorizontalScrollBarVisibility="Never"
                            IsVisible="{Binding MuscleTrends.Count, Converter={x:Static vm:GreaterThanZeroConverter.Instance}}"
                            Margin="0,0,0,32">
                    <HorizontalStackLayout BindableLayout.ItemsSource="{Binding MuscleTrends}"
                                           Spacing="8" Padding="16,0,16,0">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="vm:MuscleTrendItem">
                                <Border BackgroundColor="{StaticResource ForgeSurface}"
                                        Stroke="{StaticResource ForgeBorder}"
                                        StrokeThickness="1"
                                        StrokeShape="RoundRectangle 14"
                                        Padding="12,10,12,8"
                                        WidthRequest="84">
                                    <VerticalStackLayout Spacing="6">
                                        <Label Text="{Binding Name}"
                                               FontSize="8"
                                               FontFamily="BebasNeue"
                                               TextColor="{StaticResource ForgeTextSecondary}"
                                               CharacterSpacing="0.8"
                                               HorizontalOptions="Center"/>
                                        <controls:SparklineView Values="{Binding Values}"
                                                               StrokeColor="{Binding Color}"
                                                               HeightRequest="44"
                                                               BackgroundColor="Transparent"/>
                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </HorizontalStackLayout>
                </ScrollView>

            </VerticalStackLayout>
        </ScrollView>

        <!-- ═══ WORKOUT BANNER — Live Forge Capsule ═══ -->
        <Grid x:Name="WorkoutBanner"
              IsVisible="False"
              VerticalOptions="End"
              HorizontalOptions="Center"
              Margin="0,0,0,96"
              ZIndex="10">

            <!-- Soft silver halo bakom kapseln — "upplyst inifrån" -->
            <Border StrokeThickness="0"
                    StrokeShape="RoundRectangle 36"
                    BackgroundColor="{StaticResource ForgeAccentGlow}"
                    Margin="-18,-14"
                    InputTransparent="True"/>

            <!-- Kapselkropp -->
            <Border x:Name="WorkoutBannerCapsule"
                    StrokeThickness="1"
                    Stroke="#55B8B8BC"
                    StrokeShape="RoundRectangle 22"
                    Padding="16,9,18,10">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="{StaticResource ForgeSurface2}" Offset="0"/>
                        <GradientStop Color="{StaticResource ForgeSurface}" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,6" Radius="22" Opacity="0.55"/>
                </Border.Shadow>

                <HorizontalStackLayout Spacing="11" VerticalOptions="Center">

                    <controls:ForgeLiveDotView x:Name="BannerPulseRing"
                                               VerticalOptions="Center"/>

                    <Label Text="{loc:Localize Hem_WorkoutBanner_Label}"
                           FontFamily="BebasNeue"
                           FontSize="13"
                           CharacterSpacing="3"
                           TextColor="{StaticResource ForgeText}"
                           VerticalOptions="Center"/>

                    <Path Style="{StaticResource ForwardChevron}"
                          Stroke="{StaticResource ForgeAccent}"/>
                </HorizontalStackLayout>

                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnWorkoutBannerTapped"/>
                    <PointerGestureRecognizer
                        PointerPressed="OnBannerPointerPressed"
                        PointerReleased="OnBannerPointerReleased"/>
                </Border.GestureRecognizers>
            </Border>
        </Grid>
    <!-- Bottom gradient fade behind floating tab bar — matchar topp-gradienten spegelvänt -->
    <BoxView Grid.RowSpan="99" InputTransparent="True" VerticalOptions="End" HeightRequest="150">
        <BoxView.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="{AppThemeBinding Light=#00FCFCFC, Dark=#00141418}" Offset="0.0"/>
                <GradientStop Color="{AppThemeBinding Light=#38FCFCFC, Dark=#38141418}" Offset="0.35"/>
                <GradientStop Color="{AppThemeBinding Light=#90FCFCFC, Dark=#90141418}" Offset="0.65"/>
                <GradientStop Color="{AppThemeBinding Light=#FCFCFC, Dark=#141418}" Offset="1.0"/>
            </LinearGradientBrush>
        </BoxView.Background>
    </BoxView>

    </Grid>
</ContentPage>