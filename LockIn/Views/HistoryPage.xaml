<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:LockIn.ViewModels"
             xmlns:svc="clr-namespace:LockIn.Services"
             xmlns:ios="clr-namespace:Microsoft.Maui.Controls.PlatformConfiguration.iOSSpecific;assembly=Microsoft.Maui.Controls"
             x:Class="LockIn.Views.HistoryPage"
             x:DataType="vm:HistoryViewModel"
             Title="Historik"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light={StaticResource LightBackground}, Dark={StaticResource ForgeBackground}}"
             ios:Page.UseSafeArea="False">

    <Grid SafeAreaEdges="None">

        <!-- Permanent status bar gradient (alltid synlig, fyller Dynamic Island-zonen) -->
        <BoxView VerticalOptions="Start" HeightRequest="90" InputTransparent="True" ZIndex="19">
            <BoxView.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="{AppThemeBinding Light=#28FCFCFC, Dark=#280E0E10}" Offset="0.0"/>
                    <GradientStop Color="{AppThemeBinding Light=#00FCFCFC, Dark=#000E0E10}" Offset="1.0"/>
                </LinearGradientBrush>
            </BoxView.Background>
        </BoxView>

        <!-- Sticky header (fades in on scroll) -->
        <Grid x:Name="StickyHeader" VerticalOptions="Start" ZIndex="20" Opacity="0"
              HeightRequest="150">
            <BoxView InputTransparent="True">
                <BoxView.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="{AppThemeBinding Light=#BCFCFCFC, Dark=#BC0E0E10}" Offset="0.0"/>
                        <GradientStop Color="{AppThemeBinding Light=#70FCFCFC, Dark=#700E0E10}" Offset="0.38"/>
                        <GradientStop Color="{AppThemeBinding Light=#28FCFCFC, Dark=#280E0E10}" Offset="0.68"/>
                        <GradientStop Color="{AppThemeBinding Light=#00FCFCFC, Dark=#000E0E10}" Offset="1.0"/>
                    </LinearGradientBrush>
                </BoxView.Background>
            </BoxView>
            <Grid Padding="20,56,16,12">
                <Label Text="HISTORIK"
                       HorizontalOptions="Center" HorizontalTextAlignment="Center"
                       Style="{StaticResource DisplayLabel}" FontSize="18"
                       VerticalOptions="Center"/>
                <Border HorizontalOptions="End" VerticalOptions="Center"
                        BackgroundColor="{StaticResource ForgeAccentDim}"
                        StrokeShape="RoundRectangle 10" StrokeThickness="0"
                        Padding="12,8">
                    <Label Text="🏆" FontSize="18" VerticalOptions="Center"/>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding OpenAchievementsCommand}"/>
                    </Border.GestureRecognizers>
                </Border>
            </Grid>
        </Grid>

        <Grid>

            <ActivityIndicator IsRunning="{Binding IsLoading}"
                               IsVisible="{Binding IsLoading}"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>

            <ScrollView IsVisible="{Binding IsLoading, Converter={x:Static vm:InverseBoolConverter.Instance}}"
                        VerticalScrollBarVisibility="Never"
                   Scrolled="OnScrolled">
                <VerticalStackLayout Padding="16,56,16,100" Spacing="12">

                    <!-- Page title -->
                    <Grid ColumnDefinitions="*,Auto" Margin="4,0,0,4">
                        <Label Grid.Column="0" Text="HISTORIK"
                               FontFamily="BebasNeue" FontSize="34" CharacterSpacing="1"
                               TextColor="{AppThemeBinding Light={StaticResource LightText}, Dark={StaticResource ForgeText}}"
                               VerticalOptions="Center"/>
                        <Border Grid.Column="1"
                                BackgroundColor="{StaticResource ForgeAccentDim}"
                                StrokeShape="RoundRectangle 10" StrokeThickness="0"
                                Padding="12,8" VerticalOptions="Center">
                            <Label Text="🏆" FontSize="18" VerticalOptions="Center"/>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding OpenAchievementsCommand}"/>
                            </Border.GestureRecognizers>
                        </Border>
                    </Grid>

                    <!-- Kalender -->
                    <Border Style="{StaticResource CardFrame}" Padding="14,12">
                        <VerticalStackLayout Spacing="10">

                            <!-- Månadsnavigering -->
                            <Grid ColumnDefinitions="Auto,*,Auto">
                                <Label Grid.Column="0" Text="‹"
                                       FontSize="26" TextColor="{StaticResource ForgeMuted}"
                                       VerticalOptions="Center" Padding="4,0,12,0">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding PrevMonthCommand}"/>
                                    </Label.GestureRecognizers>
                                </Label>
                                <Label Grid.Column="1"
                                       Text="{Binding CalendarTitle}"
                                       FontFamily="BebasNeue" FontSize="18" CharacterSpacing="1"
                                       TextColor="{StaticResource ForgeText}"
                                       HorizontalOptions="Center" VerticalOptions="Center"/>
                                <Label Grid.Column="2" Text="›"
                                       FontSize="26" TextColor="{StaticResource ForgeMuted}"
                                       VerticalOptions="Center" Padding="12,0,4,0">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding NextMonthCommand}"/>
                                    </Label.GestureRecognizers>
                                </Label>
                            </Grid>

                            <!-- Veckodagsrubriker -->
                            <Grid ColumnDefinitions="*,*,*,*,*,*,*" Padding="0,2,0,0">
                                <Label Text="M" Grid.Column="0" Style="{StaticResource SectionLabel}" FontSize="11" HorizontalOptions="Center"/>
                                <Label Text="T" Grid.Column="1" Style="{StaticResource SectionLabel}" FontSize="11" HorizontalOptions="Center"/>
                                <Label Text="O" Grid.Column="2" Style="{StaticResource SectionLabel}" FontSize="11" HorizontalOptions="Center"/>
                                <Label Text="T" Grid.Column="3" Style="{StaticResource SectionLabel}" FontSize="11" HorizontalOptions="Center"/>
                                <Label Text="F" Grid.Column="4" Style="{StaticResource SectionLabel}" FontSize="11" HorizontalOptions="Center"/>
                                <Label Text="L" Grid.Column="5" Style="{StaticResource SectionLabel}" FontSize="11" HorizontalOptions="Center"/>
                                <Label Text="S" Grid.Column="6" Style="{StaticResource SectionLabel}" FontSize="11" HorizontalOptions="Center"/>
                            </Grid>

                            <!-- Kalenderceller (byggs i code-behind) -->
                            <Grid x:Name="CalendarGrid"
                                  ColumnDefinitions="*,*,*,*,*,*,*"
                                  ColumnSpacing="2" RowSpacing="2"/>

                        </VerticalStackLayout>
                    </Border>

                    <!-- Filter + Sort -->
                    <StackLayout Spacing="8">
                        <Grid ColumnDefinitions="*,*,*" ColumnSpacing="6">
                            <Border Grid.Column="0" BackgroundColor="{Binding Period0Bg}"
                                    StrokeThickness="0" StrokeShape="RoundRectangle 10" Padding="0,8">
                                <Label Text="ALLT" HorizontalOptions="Center"
                                       FontFamily="BebasNeue" FontSize="14" CharacterSpacing="1"
                                       TextColor="{Binding Period0Fg}"/>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding SelectPeriodCommand}" CommandParameter="{x:Int32 0}"/>
                                </Border.GestureRecognizers>
                            </Border>
                            <Border Grid.Column="1" BackgroundColor="{Binding Period1Bg}"
                                    StrokeThickness="0" StrokeShape="RoundRectangle 10" Padding="0,8">
                                <Label Text="VECKA" HorizontalOptions="Center"
                                       FontFamily="BebasNeue" FontSize="14" CharacterSpacing="1"
                                       TextColor="{Binding Period1Fg}"/>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding SelectPeriodCommand}" CommandParameter="{x:Int32 1}"/>
                                </Border.GestureRecognizers>
                            </Border>
                            <Border Grid.Column="2" BackgroundColor="{Binding Period2Bg}"
                                    StrokeThickness="0" StrokeShape="RoundRectangle 10" Padding="0,8">
                                <Label Text="MÅNAD" HorizontalOptions="Center"
                                       FontFamily="BebasNeue" FontSize="14" CharacterSpacing="1"
                                       TextColor="{Binding Period2Fg}"/>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding SelectPeriodCommand}" CommandParameter="{x:Int32 2}"/>
                                </Border.GestureRecognizers>
                            </Border>
                        </Grid>
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="6">
                            <Border Grid.Column="0" BackgroundColor="{Binding Sort0Bg}"
                                    StrokeThickness="0" StrokeShape="RoundRectangle 10" Padding="0,7">
                                <Label Text="DATUM" HorizontalOptions="Center"
                                       FontFamily="BebasNeue" FontSize="13" CharacterSpacing="1"
                                       TextColor="{Binding Sort0Fg}"/>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding SelectSortCommand}" CommandParameter="{x:Int32 0}"/>
                                </Border.GestureRecognizers>
                            </Border>
                            <Border Grid.Column="1" BackgroundColor="{Binding Sort1Bg}"
                                    StrokeThickness="0" StrokeShape="RoundRectangle 10" Padding="0,7">
                                <Label Text="VOLYM" HorizontalOptions="Center"
                                       FontFamily="BebasNeue" FontSize="13" CharacterSpacing="1"
                                       TextColor="{Binding Sort1Fg}"/>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding SelectSortCommand}" CommandParameter="{x:Int32 1}"/>
                                </Border.GestureRecognizers>
                            </Border>
                        </Grid>
                    </StackLayout>

                    <!-- Empty state -->
                    <StackLayout IsVisible="{Binding HasNoSessions}"
                                 HorizontalOptions="Center" Spacing="8" Margin="0,40,0,0">
                        <Label Text="INGA PASS"
                               Style="{StaticResource DisplayLabel}"
                               FontSize="22"
                               HorizontalOptions="Center"
                               TextColor="{StaticResource ForgeMuted}"/>
                        <Label Text="Starta ditt första pass i Träna-fliken"
                               Style="{StaticResource MutedLabel}"
                               HorizontalOptions="Center"
                               HorizontalTextAlignment="Center"/>
                    </StackLayout>

                    <!-- Session list -->
                    <StackLayout BindableLayout.ItemsSource="{Binding Sessions}" Spacing="0">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="svc:DatabaseService+SessionSummaryRow">
                                <Border Style="{StaticResource CardFrame}" Margin="0,0,0,10">
                                    <Grid ColumnDefinitions="4,*">
                                        <BoxView Grid.Column="0"
                                                 BackgroundColor="{StaticResource ForgeAccent}"
                                                 CornerRadius="16,0,0,16"/>
                                        <StackLayout Grid.Column="1" Padding="14,14,14,14" Spacing="10">
                                            <Grid ColumnDefinitions="*,Auto">
                                                <Label Grid.Column="0"
                                                       Text="{Binding TemplateName}"
                                                       FontFamily="BebasNeue" FontSize="24"
                                                       CharacterSpacing="1"
                                                       TextColor="{AppThemeBinding Light={StaticResource LightText}, Dark={StaticResource ForgeText}}"/>
                                                <Label Grid.Column="1"
                                                       Text="{Binding StartedAt, StringFormat='{0:d MMM}'}"
                                                       Style="{StaticResource MutedLabel}"
                                                       FontSize="12"
                                                       VerticalOptions="Center"/>
                                            </Grid>
                                            <Grid ColumnDefinitions="*,*,*,Auto">
                                                <StackLayout Grid.Column="0" Spacing="1">
                                                    <Label Text="{Binding TotalVolume, StringFormat='{0:F0}'}"
                                                           Style="{StaticResource AccentHeroNumber}"
                                                           FontSize="28"/>
                                                    <Label Text="KG VOLYM" Style="{StaticResource SectionLabel}"/>
                                                </StackLayout>
                                                <StackLayout Grid.Column="1" Spacing="1">
                                                    <Label Text="{Binding TotalSets}"
                                                           Style="{StaticResource HeroNumber}"
                                                           FontSize="28"/>
                                                    <Label Text="SETS" Style="{StaticResource SectionLabel}"/>
                                                </StackLayout>
                                                <StackLayout Grid.Column="2" Spacing="1"
                                                             IsVisible="{Binding PRCount, Converter={x:Static vm:GreaterThanZeroConverter.Instance}}">
                                                    <Label Text="{Binding PRCount}"
                                                           FontFamily="BebasNeue" FontSize="28"
                                                           TextColor="{StaticResource ForgeSuccess}"/>
                                                    <Label Text="PRs" Style="{StaticResource SectionLabel}"/>
                                                </StackLayout>
                                                <Label Grid.Column="3" Text="›"
                                                       FontSize="22"
                                                       TextColor="{StaticResource ForgeMuted}"
                                                       VerticalOptions="Center"/>
                                            </Grid>
                                        </StackLayout>
                                    </Grid>
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Tapped="OnSessionTapped"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:HistoryViewModel}}, Path=OpenSessionCommand}"
                                            CommandParameter="{Binding .}"/>
                                    </Border.GestureRecognizers>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </StackLayout>

                </VerticalStackLayout>
            </ScrollView>

            <!-- Active workout banner -->
            <Border x:Name="WorkoutBanner"
                    IsVisible="False"
                    BackgroundColor="{AppThemeBinding Light={StaticResource LightSurface}, Dark={StaticResource ForgeSurface}}"
                    Stroke="{StaticResource ForgeAccent}"
                    StrokeThickness="1.5"
                    StrokeShape="RoundRectangle 18,18,0,0"
                    Padding="20,14,20,36"
                    VerticalOptions="End"
                    ZIndex="10">
                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                    <Ellipse Grid.Column="0"
                             Fill="{StaticResource ForgeAccent}"
                             WidthRequest="8" HeightRequest="8"
                             VerticalOptions="Center"/>
                    <Label Grid.Column="1"
                           Text="PASS PÅGÅR"
                           FontFamily="BebasNeue" FontSize="16" CharacterSpacing="2"
                           TextColor="{AppThemeBinding Light={StaticResource LightText}, Dark={StaticResource ForgeText}}"
                           VerticalOptions="Center"/>
                    <Label Grid.Column="2"
                           Text="ÖPPNA ›"
                           FontFamily="BebasNeue" FontSize="14" CharacterSpacing="1"
                           TextColor="{StaticResource ForgeAccent}"
                           VerticalOptions="Center"/>
                </Grid>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnWorkoutBannerTapped"/>
                </Border.GestureRecognizers>
            </Border>

        </Grid>
    <!-- Bottom gradient fade behind floating tab bar -->
    <BoxView Grid.RowSpan="99" InputTransparent="True" VerticalOptions="End" HeightRequest="140">
        <BoxView.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="Transparent" Offset="0"/>
                <GradientStop Color="{AppThemeBinding Light=#FCFCFC, Dark=#0E0E10}" Offset="1"/>
            </LinearGradientBrush>
        </BoxView.Background>
    </BoxView>

    </Grid>
</ContentPage>