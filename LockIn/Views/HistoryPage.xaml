<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:LockIn.ViewModels"
             xmlns:views="clr-namespace:LockIn.Views"
             xmlns:models="clr-namespace:LockIn.Models"
             xmlns:svc="clr-namespace:LockIn.Services"
             xmlns:controls="clr-namespace:LockIn.Controls"
             xmlns:loc="clr-namespace:LockIn.Resources.Strings"
             xmlns:ios="clr-namespace:Microsoft.Maui.Controls.PlatformConfiguration.iOSSpecific;assembly=Microsoft.Maui.Controls"
             x:Class="LockIn.Views.HistoryPage"
             x:DataType="vm:HistoryViewModel"
             Title="{loc:Localize Tab_History}"
             Shell.NavBarIsVisible="False"
             BackgroundColor="Transparent">

    <Grid SafeAreaEdges="None">

        <!-- Atmosf�risk bakgrund -->
        <controls:AtmosphericBackgroundView InputTransparent="True"/>

        <!-- Permanent status bar gradient (alltid synlig, fyller Dynamic Island-zonen) -->
        <BoxView VerticalOptions="Start" HeightRequest="90" InputTransparent="True" ZIndex="19">
            <BoxView.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="{AppThemeBinding Light=#28FCFCFC, Dark=#28141418}" Offset="0.0"/>
                    <GradientStop Color="{AppThemeBinding Light=#00FCFCFC, Dark=#00141418}" Offset="1.0"/>
                </LinearGradientBrush>
            </BoxView.Background>
        </BoxView>

        <!-- Sticky header (fades in on scroll) -->
        <Grid x:Name="StickyHeader" VerticalOptions="Start" ZIndex="20" Opacity="0"
              HeightRequest="150" SafeAreaEdges="None">
            <BoxView InputTransparent="True">
                <BoxView.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="{AppThemeBinding Light=#D8FCFCFC, Dark=#D8141418}" Offset="0.0"/>
                        <GradientStop Color="{AppThemeBinding Light=#90FCFCFC, Dark=#90141418}" Offset="0.35"/>
                        <GradientStop Color="{AppThemeBinding Light=#38FCFCFC, Dark=#38141418}" Offset="0.65"/>
                        <GradientStop Color="{AppThemeBinding Light=#00FCFCFC, Dark=#00141418}" Offset="1.0"/>
                    </LinearGradientBrush>
                </BoxView.Background>
            </BoxView>
            <Grid Padding="20,14,16,12">
                <Label Text="{loc:Localize History_Title}"
                       HorizontalOptions="Center" HorizontalTextAlignment="Center"
                       Style="{StaticResource DisplayLabel}" FontSize="18"
                       VerticalOptions="Center"/>
                <Border HorizontalOptions="End" VerticalOptions="Center"
                        BackgroundColor="{StaticResource ForgeAccentAmberDim}"
                        StrokeShape="RoundRectangle 10" StrokeThickness="0"
                        Padding="12,8">
                    <Label Text="{loc:Localize History_Achievements}" FontFamily="BebasNeue" FontSize="12" CharacterSpacing="1"
                           TextColor="{StaticResource ForgeAccentAmber}" VerticalOptions="Center"/>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding OpenAchievementsCommand}" Tapped="OnAchievementTapped"/>
                    </Border.GestureRecognizers>
                </Border>
            </Grid>
        </Grid>

        <ActivityIndicator IsRunning="{Binding IsLoading}"
                           IsVisible="{Binding IsLoading}"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"/>

        <ScrollView IsVisible="{Binding IsLoading, Converter={x:Static vm:InverseBoolConverter.Instance}}"
                    VerticalScrollBarVisibility="Never"
                    Scrolled="OnScrolled">
                <VerticalStackLayout Padding="16,56,16,100" Spacing="12">

                    <!-- Page title -->
                    <Grid ColumnDefinitions="*,Auto" Margin="4,0,0,4">
                        <Label Grid.Column="0" Text="{loc:Localize History_Title}"
                               FontFamily="BebasNeue" FontSize="34" CharacterSpacing="1"
                               TextColor="{AppThemeBinding Light={StaticResource LightText}, Dark={StaticResource ForgeText}}"
                               VerticalOptions="Center"/>
                        <Border Grid.Column="1"
                                BackgroundColor="{StaticResource ForgeAccentAmberDim}"
                                StrokeShape="RoundRectangle 10" StrokeThickness="0"
                                Padding="12,8" VerticalOptions="Center">
                            <Label Text="{loc:Localize History_Achievements}" FontFamily="BebasNeue" FontSize="12" CharacterSpacing="1"
                                   TextColor="{StaticResource ForgeAccentAmber}" VerticalOptions="Center"/>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding OpenAchievementsCommand}" Tapped="OnAchievementTapped"/>
                            </Border.GestureRecognizers>
                        </Border>
                    </Grid>

                    <!-- Kalender -->
                    <Border Style="{StaticResource CardFrame}" Padding="14,12">
                        <VerticalStackLayout Spacing="10">

                            <!-- M�nadsnavigering -->
                            <Grid ColumnDefinitions="Auto,*,Auto">
                                <Border Grid.Column="0" BackgroundColor="Transparent" StrokeThickness="0"
                                        MinimumWidthRequest="44" MinimumHeightRequest="44"
                                        HorizontalOptions="Start" VerticalOptions="Center">
                                    <Label Text="�" FontSize="26" TextColor="{StaticResource ForgeMuted}"
                                           HorizontalOptions="Center" VerticalOptions="Center"/>
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnCalNavTapped" Command="{Binding PrevMonthCommand}"/>
                                    </Border.GestureRecognizers>
                                </Border>
                                <Label Grid.Column="1"
                                       Text="{Binding CalendarTitle}"
                                       FontFamily="BebasNeue" FontSize="18" CharacterSpacing="1"
                                       TextColor="{StaticResource ForgeText}"
                                       HorizontalOptions="Center" VerticalOptions="Center"/>
                                <Border Grid.Column="2" BackgroundColor="Transparent" StrokeThickness="0"
                                        MinimumWidthRequest="44" MinimumHeightRequest="44"
                                        HorizontalOptions="End" VerticalOptions="Center">
                                    <Label Text="�" FontSize="26" TextColor="{StaticResource ForgeMuted}"
                                           HorizontalOptions="Center" VerticalOptions="Center"/>
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnCalNavTapped" Command="{Binding NextMonthCommand}"/>
                                    </Border.GestureRecognizers>
                                </Border>
                            </Grid>

                            <!-- Veckodagsrubriker -->
                            <Grid ColumnDefinitions="*,*,*,*,*,*,*" Padding="0,2,0,0">
                                <Label Text="{loc:Localize History_Cal_Mon}" Grid.Column="0" Style="{StaticResource SectionLabel}" FontSize="11" HorizontalOptions="Center"/>
                                <Label Text="{loc:Localize History_Cal_Tue}" Grid.Column="1" Style="{StaticResource SectionLabel}" FontSize="11" HorizontalOptions="Center"/>
                                <Label Text="{loc:Localize History_Cal_Wed}" Grid.Column="2" Style="{StaticResource SectionLabel}" FontSize="11" HorizontalOptions="Center"/>
                                <Label Text="{loc:Localize History_Cal_Thu}" Grid.Column="3" Style="{StaticResource SectionLabel}" FontSize="11" HorizontalOptions="Center"/>
                                <Label Text="{loc:Localize History_Cal_Fri}" Grid.Column="4" Style="{StaticResource SectionLabel}" FontSize="11" HorizontalOptions="Center"/>
                                <Label Text="{loc:Localize History_Cal_Sat}" Grid.Column="5" Style="{StaticResource SectionLabel}" FontSize="11" HorizontalOptions="Center"/>
                                <Label Text="{loc:Localize History_Cal_Sun}" Grid.Column="6" Style="{StaticResource SectionLabel}" FontSize="11" HorizontalOptions="Center"/>
                            </Grid>

                            <!-- Kalenderceller (byggs i code-behind) -->
                            <Grid x:Name="CalendarGrid"
                                  ColumnDefinitions="*,*,*,*,*,*,*"
                                  ColumnSpacing="2" RowSpacing="2"/>

                        </VerticalStackLayout>
                    </Border>

                    <!-- Filter + Sort -->
                    <StackLayout Spacing="8">
                        <Border BackgroundColor="{StaticResource ForgePillTrack}" StrokeThickness="0" StrokeShape="RoundRectangle 50" Padding="2">
                            <Grid x:Name="PeriodPills" ColumnDefinitions="*,*,*" HeightRequest="40"
                                  SizeChanged="OnPeriodContainerSizeChanged">
                                <Border x:Name="PeriodIndicator" Grid.ColumnSpan="3"
                                        BackgroundColor="{StaticResource ForgePillIndicator}"
                                        StrokeThickness="0"
                                        StrokeShape="RoundRectangle 48"
                                        HorizontalOptions="Start" VerticalOptions="Fill"/>
                                <Border Grid.Column="0" BackgroundColor="Transparent"
                                        StrokeThickness="0" Padding="0,9">
                                    <Label Text="{loc:Localize History_Period_All}" HorizontalOptions="Center"
                                           FontFamily="BebasNeue" FontSize="13" CharacterSpacing="1.5"
                                           TextColor="{Binding Period0Fg}" VerticalOptions="Center"/>
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding SelectPeriodCommand}" CommandParameter="{x:Int32 0}" Tapped="OnPillTapped"/>
                                    </Border.GestureRecognizers>
                                </Border>
                                <Border Grid.Column="1" BackgroundColor="Transparent"
                                        StrokeThickness="0" Padding="0,9">
                                    <Label Text="{loc:Localize History_Period_Week}" HorizontalOptions="Center"
                                           FontFamily="BebasNeue" FontSize="13" CharacterSpacing="1.5"
                                           TextColor="{Binding Period1Fg}" VerticalOptions="Center"/>
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding SelectPeriodCommand}" CommandParameter="{x:Int32 1}" Tapped="OnPillTapped"/>
                                    </Border.GestureRecognizers>
                                </Border>
                                <Border Grid.Column="2" BackgroundColor="Transparent"
                                        StrokeThickness="0" Padding="0,9">
                                    <Label Text="{loc:Localize History_Period_Month}" HorizontalOptions="Center"
                                           FontFamily="BebasNeue" FontSize="13" CharacterSpacing="1.5"
                                           TextColor="{Binding Period2Fg}" VerticalOptions="Center"/>
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding SelectPeriodCommand}" CommandParameter="{x:Int32 2}" Tapped="OnPillTapped"/>
                                    </Border.GestureRecognizers>
                                </Border>
                            </Grid>
                        </Border>
                        <Border BackgroundColor="{StaticResource ForgePillTrack}" StrokeThickness="0" StrokeShape="RoundRectangle 50" Padding="2">
                            <Grid x:Name="SortPills" ColumnDefinitions="*,*" HeightRequest="38"
                                  SizeChanged="OnSortContainerSizeChanged">
                                <Border x:Name="SortIndicator" Grid.ColumnSpan="2"
                                        BackgroundColor="{StaticResource ForgePillIndicator}"
                                        StrokeThickness="0"
                                        StrokeShape="RoundRectangle 48"
                                        HorizontalOptions="Start" VerticalOptions="Fill"/>
                                <Border Grid.Column="0" BackgroundColor="Transparent"
                                        StrokeThickness="0" Padding="0,8">
                                    <Label Text="{loc:Localize History_Sort_Date}" HorizontalOptions="Center"
                                           FontFamily="BebasNeue" FontSize="13" CharacterSpacing="1.5"
                                           TextColor="{Binding Sort0Fg}" VerticalOptions="Center"/>
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding SelectSortCommand}" CommandParameter="{x:Int32 0}" Tapped="OnPillTapped"/>
                                    </Border.GestureRecognizers>
                                </Border>
                                <Border Grid.Column="1" BackgroundColor="Transparent"
                                        StrokeThickness="0" Padding="0,8">
                                    <Label Text="{loc:Localize History_Sort_Volume}" HorizontalOptions="Center"
                                           FontFamily="BebasNeue" FontSize="13" CharacterSpacing="1.5"
                                           TextColor="{Binding Sort1Fg}" VerticalOptions="Center"/>
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding SelectSortCommand}" CommandParameter="{x:Int32 1}" Tapped="OnPillTapped"/>
                                    </Border.GestureRecognizers>
                                </Border>
                            </Grid>
                        </Border>
                    </StackLayout>

                    <!-- Empty state -->
                    <StackLayout IsVisible="{Binding HasNoSessions}"
                                 HorizontalOptions="Center" Spacing="8" Margin="0,40,0,0">
                        <Label Text="{Binding EmptyStateTitle}"
                               Style="{StaticResource DisplayLabel}"
                               FontSize="22"
                               HorizontalOptions="Center"
                               TextColor="{StaticResource ForgeMuted}"/>
                        <Label Text="{Binding EmptyStateSubtitle}"
                               Style="{StaticResource MutedLabel}"
                               HorizontalOptions="Center"
                               HorizontalTextAlignment="Center"/>
                    </StackLayout>

                    <!-- Session list -->
                    <StackLayout BindableLayout.ItemsSource="{Binding Sessions}" Spacing="0">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="svc:DatabaseService+SessionSummaryRow">
                                <Border BackgroundColor="{AppThemeBinding Light={StaticResource LightSurface}, Dark={StaticResource ForgeSurface}}"
                                        StrokeShape="RoundRectangle 18"
                                        StrokeThickness="0"
                                        Margin="0,0,0,10"
                                        Padding="18,14">
                                    <Border.Shadow>
                                        <Shadow Brush="Black" Offset="0,2" Radius="10" Opacity="0.18"/>
                                    </Border.Shadow>
                                    <StackLayout Spacing="10">
                                        <Grid ColumnDefinitions="12,*,Auto" ColumnSpacing="12">
                                            <Ellipse Grid.Column="0"
                                                     WidthRequest="10" HeightRequest="10"
                                                     Fill="{StaticResource ForgeAccentBlue}"
                                                     VerticalOptions="Center"/>
                                            <Label Grid.Column="1"
                                                   Text="{Binding TemplateName}"
                                                   FontFamily="BebasNeue" FontSize="24"
                                                   CharacterSpacing="1"
                                                   TextColor="{AppThemeBinding Light={StaticResource LightText}, Dark={StaticResource ForgeText}}"/>
                                            <Label Grid.Column="2"
                                                   Text="{Binding StartedAt, StringFormat='{0:d MMM}'}"
                                                   Style="{StaticResource MutedLabel}"
                                                   FontSize="12"
                                                   VerticalOptions="Center"/>
                                        </Grid>
                                            <Grid ColumnDefinitions="*,*,Auto,Auto">
                                                <StackLayout Grid.Column="0" Spacing="1">
                                                    <Label Text="{Binding TotalVolume, StringFormat='{0:F0}'}"
                                                           Style="{StaticResource HeroNumber}"
                                                           FontSize="28"
                                                           TextColor="{StaticResource ForgeAccentBlue}"/>
                                                    <Label Text="{loc:Localize History_Card_KgVolume}" Style="{StaticResource SectionLabel}"/>
                                                </StackLayout>
                                                <StackLayout Grid.Column="1" Spacing="1">
                                                    <Label Text="{Binding TotalSets}"
                                                           Style="{StaticResource HeroNumber}"
                                                           FontSize="28"/>
                                                    <Label Text="{loc:Localize History_Card_Sets}" Style="{StaticResource SectionLabel}"/>
                                                </StackLayout>
                                                <StackLayout Grid.Column="2" Spacing="1"
                                                             IsVisible="{Binding PRCount, Converter={x:Static vm:GreaterThanZeroConverter.Instance}}">
                                                    <Label Text="{Binding PRCount}"
                                                           FontSize="28" FontAttributes="Bold"
                                                           TextColor="{StaticResource ForgeAccentAmber}"/>
                                                    <Label Text="{loc:Localize History_Card_PRs}" Style="{StaticResource SectionLabel}"/>
                                                </StackLayout>
                                                <Path Grid.Column="3" Style="{StaticResource ForwardChevron}"/>
                                            </Grid>
                                    </StackLayout>
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Tapped="OnSessionTapped"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:HistoryViewModel}}, Path=OpenSessionCommand}"
                                            CommandParameter="{Binding .}"/>
                                    </Border.GestureRecognizers>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </StackLayout>

                    <!-- Cardio-sessioner -->
                    <Label Text="{loc:Localize History_Cardio_Section}"
                           Style="{StaticResource SectionLabel}"
                           Margin="4,16,0,8"
                           IsVisible="{Binding CardioSessions.Count, Converter={x:Static vm:GreaterThanZeroConverter.Instance}}"/>
                    <StackLayout BindableLayout.ItemsSource="{Binding CardioSessions}"
                                 Spacing="0"
                                 IsVisible="{Binding CardioSessions.Count, Converter={x:Static vm:GreaterThanZeroConverter.Instance}}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="models:CardioSession">
                                <Border BackgroundColor="{AppThemeBinding Light={StaticResource LightSurface}, Dark={StaticResource ForgeSurface}}"
                                        StrokeShape="RoundRectangle 18"
                                        StrokeThickness="0"
                                        Margin="0,0,0,10"
                                        Padding="18,14">
                                    <Grid ColumnDefinitions="12,*,Auto" ColumnSpacing="12">
                                        <Ellipse Grid.Column="0"
                                                 WidthRequest="10" HeightRequest="10"
                                                 Fill="{StaticResource ForgeAccentCoral}"
                                                 VerticalOptions="Center"/>
                                        <VerticalStackLayout Grid.Column="1" Spacing="4">
                                            <Label Text="{Binding ActivityType, Converter={x:Static views:CardioActivityLabelConverter.Instance}}"
                                                   FontFamily="BebasNeue" FontSize="22" CharacterSpacing="1"
                                                   TextColor="{AppThemeBinding Light={StaticResource LightText}, Dark={StaticResource ForgeText}}"/>
                                            <HorizontalStackLayout Spacing="8">
                                                <Label Text="{Binding DurationMinutes, StringFormat='{0} min'}"
                                                       Style="{StaticResource MutedLabel}" FontSize="12"
                                                       IsVisible="{Binding DurationMinutes, Converter={x:Static vm:GreaterThanZeroConverter.Instance}}"/>
                                                <Label Text="{Binding DistanceKm, StringFormat='{0:F1} km'}"
                                                       Style="{StaticResource MutedLabel}" FontSize="12"
                                                       IsVisible="{Binding DistanceKm, Converter={x:Static vm:GreaterThanZeroConverter.Instance}}"/>
                                            </HorizontalStackLayout>
                                        </VerticalStackLayout>
                                        <Label Grid.Column="2"
                                               Text="{Binding StartedAt, StringFormat='{0:d MMM}'}"
                                               Style="{StaticResource MutedLabel}"
                                               FontSize="12" VerticalOptions="Center"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </StackLayout>

                </VerticalStackLayout>
            </ScrollView>

            <!-- --- WORKOUT BANNER � Live Forge Capsule --- -->
            <Grid x:Name="WorkoutBanner"
                  IsVisible="False"
                  VerticalOptions="End"
                  HorizontalOptions="Center"
                  Margin="0,0,0,96"
                  ZIndex="10">
                <Border StrokeThickness="0"
                        StrokeShape="RoundRectangle 36"
                        BackgroundColor="{StaticResource ForgeAccentGlow}"
                        Margin="-18,-14"
                        InputTransparent="True"/>
                <Border StrokeThickness="1"
                        Stroke="{StaticResource ForgeBannerStroke}"
                        StrokeShape="RoundRectangle 22"
                        Padding="16,9,18,10">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="{StaticResource ForgeSurface2}" Offset="0"/>
                            <GradientStop Color="{StaticResource ForgeSurface}" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,6" Radius="22" Opacity="0.55"/>
                    </Border.Shadow>
                    <HorizontalStackLayout Spacing="11" VerticalOptions="Center">
                        <controls:ForgeLiveDotView x:Name="BannerPulseRing"
                                                   VerticalOptions="Center"/>
                        <Label Text="{loc:Localize Hem_WorkoutBanner_Label}"
                               FontFamily="BebasNeue" FontSize="13" CharacterSpacing="3"
                               TextColor="{StaticResource ForgeText}"
                               VerticalOptions="Center"/>
                        <Path Style="{StaticResource ForwardChevron}"
                              Stroke="{StaticResource ForgeAccent}"/>
                    </HorizontalStackLayout>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnWorkoutBannerTapped"/>
                    </Border.GestureRecognizers>
                </Border>
            </Grid>

    <!-- Bottom gradient fade behind floating tab bar � matchar topp-gradienten spegelv�nt -->
    <BoxView Grid.RowSpan="99" InputTransparent="True" VerticalOptions="End" HeightRequest="150">
        <BoxView.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="{AppThemeBinding Light=#00FCFCFC, Dark=#00141418}" Offset="0.0"/>
                <GradientStop Color="{AppThemeBinding Light=#38FCFCFC, Dark=#38141418}" Offset="0.35"/>
                <GradientStop Color="{AppThemeBinding Light=#90FCFCFC, Dark=#90141418}" Offset="0.65"/>
                <GradientStop Color="{AppThemeBinding Light=#FCFCFC, Dark=#141418}" Offset="1.0"/>
            </LinearGradientBrush>
        </BoxView.Background>
    </BoxView>

    </Grid>
</ContentPage>