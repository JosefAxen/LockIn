<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:LockIn.ViewModels"
             xmlns:models="clr-namespace:LockIn.Models"
             x:Class="LockIn.Views.HistoryPage"
             x:DataType="vm:HistoryViewModel"
             Title="Historik">

    <Grid RowDefinitions="Auto,Auto,*">

        <Grid Grid.Row="0" Padding="20,16,20,8">
            <Label Text="HISTORIK" Style="{StaticResource DisplayLabel}" FontSize="32"/>
        </Grid>

        <SearchBar Grid.Row="1"
                   Text="{Binding SearchText}"
                   Placeholder="Sök övning..."
                   Margin="16,0,16,8"/>

        <ScrollView Grid.Row="2">
            <StackLayout Padding="16,0,16,32" Spacing="0">

                <!-- Exercise list (visible when no exercise selected) -->
                <StackLayout IsVisible="{Binding IsExerciseNotSelected}"
                             Spacing="6">
                    <CollectionView ItemsSource="{Binding FilteredExercises}"
                                    SelectionMode="Single"
                                    SelectedItem="{Binding SelectedExercise}"
                                    HeightRequest="600">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:Exercise">
                                <Border Margin="0,0,0,6"
                                        Style="{StaticResource CardFrame}"
                                        Padding="16,14">
                                    <Label Text="{Binding Name}"
                                           FontFamily="DMSansMedium" FontSize="15"/>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </StackLayout>

                <!-- History detail (visible when exercise selected) -->
                <StackLayout IsVisible="{Binding IsExerciseSelected}"
                             Spacing="10">

                    <!-- Back button + exercise name -->
                    <Grid ColumnDefinitions="Auto,*" Margin="0,0,0,8">
                        <Button Grid.Column="0" Text="‹ Tillbaka"
                                Style="{StaticResource SecondaryButton}"
                                Padding="12,8"
                                Command="{Binding ClearSelectionCommand}"/>
                        <Label Grid.Column="1"
                               Text="{Binding SelectedExercise.Name}"
                               FontFamily="DMSansMedium" FontSize="16"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>
                    </Grid>

                    <CollectionView ItemsSource="{Binding HistoryRows}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="vm:ExerciseHistoryRow">
                                <Border Margin="0,0,0,8"
                                        Style="{StaticResource CardFrame}"
                                        Padding="16,12">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <StackLayout Grid.Column="0" Spacing="2">
                                            <Label Text="{Binding SetDisplay}"
                                                   FontFamily="DMSansMedium" FontSize="15"/>
                                            <Label Text="{Binding Epley1RM}"
                                                   Style="{StaticResource AccentLabel}"
                                                   FontSize="12"/>
                                            <Label Text="{Binding Date}"
                                                   Style="{StaticResource MutedLabel}"
                                                   FontSize="11"/>
                                        </StackLayout>
                                        <Label Grid.Column="1" Text="🏆"
                                               FontSize="20"
                                               VerticalOptions="Center"
                                               IsVisible="{Binding IsPR}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                </StackLayout>

            </StackLayout>
        </ScrollView>

    </Grid>
</ContentPage>
