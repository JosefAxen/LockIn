<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:LockIn.ViewModels"
             xmlns:controls="clr-namespace:LockIn.Controls"
             x:Class="LockIn.Views.TemplateEditPage"
             x:DataType="vm:TemplateEditViewModel"
             Title="Mall"
             xmlns:ios="clr-namespace:Microsoft.Maui.Controls.PlatformConfiguration.iOSSpecific;assembly=Microsoft.Maui.Controls"
             Shell.NavBarIsVisible="False"
             BackgroundColor="Transparent"
             ios:Page.UseSafeArea="False">

    <Grid RowDefinitions="Auto,*" Padding="0" SafeAreaEdges="None">

        <!-- Atmosfärisk bakgrund -->
        <controls:AtmosphericBackgroundView Grid.RowSpan="2" InputTransparent="True"/>

        <!-- Header -->
        <Grid Grid.Row="0" Padding="16,56,16,8" ColumnDefinitions="48,*,Auto">
            <Border Grid.Column="0"
                    WidthRequest="36" HeightRequest="36"
                    StrokeShape="Ellipse"
                    BackgroundColor="#17FFFFFF"
                    Stroke="#29FFFFFF"
                    StrokeThickness="0.5"
                    VerticalOptions="Center">
                <Label Text="‹" FontSize="22" FontFamily="DMSansMedium"
                       HorizontalOptions="Center" VerticalOptions="Center"
                       TextColor="{StaticResource ForgeText}"/>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnBackClicked"/>
                </Border.GestureRecognizers>
            </Border>
            <Label Grid.Column="1" Text="MALL"
                   Style="{StaticResource DisplayLabel}"
                   FontSize="24" HorizontalOptions="Center" VerticalOptions="Center"/>
            <Button Grid.Column="2" Text="SPARA"
                    Style="{StaticResource PrimaryButton}"
                    HeightRequest="40" Padding="16,0"
                    Command="{Binding SaveCommand}"/>
        </Grid>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="16,8,16,40" Spacing="12">

                <!-- Template name -->
                <Border Style="{StaticResource CardFrame}" Padding="16">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="MALLNAMN" Style="{StaticResource SectionLabel}"/>
                        <Entry Text="{Binding TemplateName}"
                               Style="{StaticResource InputField}"
                               Placeholder="T.ex. Push A"
                               ReturnType="Done"/>
                    </VerticalStackLayout>
                </Border>

                <Label Text="ÖVNINGAR" Style="{StaticResource SectionLabel}" Margin="4,4,0,0"/>

                <!-- Exercise cards -->
                <StackLayout BindableLayout.ItemsSource="{Binding Exercises}" Spacing="10">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="vm:TemplateExerciseRow">
                            <Border Style="{StaticResource CardFrame}">
                                <VerticalStackLayout Spacing="0">

                                    <!-- Exercise name + remove -->
                                    <Grid ColumnDefinitions="*,44" Padding="16,14,6,12">
                                        <Label Grid.Column="0"
                                               Text="{Binding ExerciseName}"
                                               FontFamily="DMSansMedium"
                                               FontSize="15"
                                               VerticalOptions="Center"/>
                                        <Button Grid.Column="1"
                                                Text="✕"
                                                BackgroundColor="Transparent"
                                                TextColor="{StaticResource ForgeMuted}"
                                                FontSize="15"
                                                WidthRequest="44" HeightRequest="44"
                                                Padding="0"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:TemplateEditViewModel}}, Path=RemoveExerciseCommand}"
                                                CommandParameter="{Binding .}"/>
                                    </Grid>

                                    <!-- Divider -->
                                    <BoxView BackgroundColor="{StaticResource ForgeBorder}"
                                             HeightRequest="1" Margin="0"/>

                                    <!-- Progression toggle row -->
                                    <Grid ColumnDefinitions="*,Auto"
                                          Padding="16,10,16,10">
                                        <Label Grid.Column="0"
                                               Text="AUTO-PROGRESSION"
                                               Style="{StaticResource SectionLabel}"
                                               VerticalOptions="Center"/>
                                        <Switch Grid.Column="1"
                                                IsToggled="{Binding ProgressionEnabled, Mode=TwoWay}"
                                                OnColor="{StaticResource ForgeAccent}"
                                                VerticalOptions="Center"/>
                                    </Grid>

                                    <!-- Progression fields (only when enabled) -->
                                    <Grid IsVisible="{Binding ProgressionEnabled}"
                                          ColumnDefinitions="*,*,*"
                                          Padding="12,0,12,10"
                                          ColumnSpacing="8">

                                        <!-- MIN REPS -->
                                        <VerticalStackLayout Grid.Column="0" Spacing="4">
                                            <Label Text="MIN REPS"
                                                   Style="{StaticResource SectionLabel}"
                                                   TextColor="{StaticResource ForgeAccent}"
                                                   HorizontalOptions="Center"/>
                                            <Border BackgroundColor="{AppThemeBinding Light={StaticResource LightSurface2}, Dark={StaticResource ForgeSurface2}}"
                                                    StrokeShape="RoundRectangle 8"
                                                    Stroke="{StaticResource ForgeAccentDim}"
                                                    StrokeThickness="1"
                                                    Padding="0" HeightRequest="46">
                                                <Entry Text="{Binding TargetRepsMinText, Mode=TwoWay}"
                                                       Keyboard="Numeric"
                                                       Placeholder="6"
                                                       PlaceholderColor="{StaticResource ForgeMuted}"
                                                       HorizontalTextAlignment="Center"
                                                       FontFamily="BebasNeue" FontSize="22"
                                                       TextColor="{AppThemeBinding Light={StaticResource LightText}, Dark={StaticResource ForgeText}}"
                                                       BackgroundColor="Transparent"
                                                       VerticalOptions="Center"/>
                                            </Border>
                                        </VerticalStackLayout>

                                        <!-- MAX REPS -->
                                        <VerticalStackLayout Grid.Column="1" Spacing="4">
                                            <Label Text="MAX REPS"
                                                   Style="{StaticResource SectionLabel}"
                                                   TextColor="{StaticResource ForgeAccent}"
                                                   HorizontalOptions="Center"/>
                                            <Border BackgroundColor="{AppThemeBinding Light={StaticResource LightSurface2}, Dark={StaticResource ForgeSurface2}}"
                                                    StrokeShape="RoundRectangle 8"
                                                    Stroke="{StaticResource ForgeAccentDim}"
                                                    StrokeThickness="1"
                                                    Padding="0" HeightRequest="46">
                                                <Entry Text="{Binding TargetRepsMaxText, Mode=TwoWay}"
                                                       Keyboard="Numeric"
                                                       Placeholder="10"
                                                       PlaceholderColor="{StaticResource ForgeMuted}"
                                                       HorizontalTextAlignment="Center"
                                                       FontFamily="BebasNeue" FontSize="22"
                                                       TextColor="{AppThemeBinding Light={StaticResource LightText}, Dark={StaticResource ForgeText}}"
                                                       BackgroundColor="Transparent"
                                                       VerticalOptions="Center"/>
                                            </Border>
                                        </VerticalStackLayout>

                                        <!-- +KG PER STEG -->
                                        <VerticalStackLayout Grid.Column="2" Spacing="4">
                                            <Label Text="+KG"
                                                   Style="{StaticResource SectionLabel}"
                                                   TextColor="{StaticResource ForgeAccent}"
                                                   HorizontalOptions="Center"/>
                                            <Border BackgroundColor="{AppThemeBinding Light={StaticResource LightSurface2}, Dark={StaticResource ForgeSurface2}}"
                                                    StrokeShape="RoundRectangle 8"
                                                    Stroke="{StaticResource ForgeAccentDim}"
                                                    StrokeThickness="1"
                                                    Padding="0" HeightRequest="46">
                                                <Entry Text="{Binding WeightIncrementText, Mode=TwoWay}"
                                                       Keyboard="Numeric"
                                                       Placeholder="2.5"
                                                       PlaceholderColor="{StaticResource ForgeMuted}"
                                                       HorizontalTextAlignment="Center"
                                                       FontFamily="BebasNeue" FontSize="22"
                                                       TextColor="{AppThemeBinding Light={StaticResource LightText}, Dark={StaticResource ForgeText}}"
                                                       BackgroundColor="Transparent"
                                                       VerticalOptions="Center"/>
                                            </Border>
                                        </VerticalStackLayout>

                                    </Grid>

                                    <!-- Superset toggle row -->
                                    <Grid ColumnDefinitions="*,Auto"
                                          Padding="16,8,16,8">
                                        <Border Grid.Column="0"
                                                BackgroundColor="{StaticResource ForgeAccentDim}"
                                                StrokeShape="RoundRectangle 4"
                                                StrokeThickness="0"
                                                Padding="8,3"
                                                IsVisible="{Binding IsInSuperset}"
                                                HorizontalOptions="Start"
                                                VerticalOptions="Center">
                                            <Label Text="SUPERSET"
                                                   TextColor="{StaticResource ForgeAccent}"
                                                   FontFamily="BebasNeue" FontSize="11"
                                                   CharacterSpacing="1"/>
                                        </Border>
                                        <Button Grid.Column="1"
                                                Text="{Binding SupersetButtonText}"
                                                BackgroundColor="{StaticResource ForgeSurface2}"
                                                TextColor="{StaticResource ForgeMuted}"
                                                FontFamily="BebasNeue" FontSize="12"
                                                CharacterSpacing="1"
                                                HeightRequest="30" Padding="10,0"
                                                CornerRadius="6"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:TemplateEditViewModel}}, Path=ToggleSupersetCommand}"
                                                CommandParameter="{Binding .}"/>
                                    </Grid>

                                    <!-- Divider before main fields -->
                                    <BoxView BackgroundColor="{StaticResource ForgeBorder}"
                                             HeightRequest="1" Margin="0"/>

                                    <!-- Editable fields row -->
                                    <Grid ColumnDefinitions="*,*,*,*"
                                          Padding="12,10,12,12"
                                          ColumnSpacing="8">

                                        <!-- SET -->
                                        <VerticalStackLayout Grid.Column="0" Spacing="4">
                                            <Label Text="SET"
                                                   Style="{StaticResource SectionLabel}"
                                                   HorizontalOptions="Center"/>
                                            <Border BackgroundColor="{AppThemeBinding Light={StaticResource LightSurface2}, Dark={StaticResource ForgeSurface2}}"
                                                    StrokeShape="RoundRectangle 8"
                                                    Stroke="{AppThemeBinding Light={StaticResource LightBorder}, Dark={StaticResource ForgeBorderLight}}"
                                                    StrokeThickness="1"
                                                    Padding="0"
                                                    HeightRequest="46">
                                                <Entry Text="{Binding SetsText, Mode=TwoWay}"
                                                       Keyboard="Numeric"
                                                       HorizontalTextAlignment="Center"
                                                       FontFamily="BebasNeue"
                                                       FontSize="22"
                                                       TextColor="{AppThemeBinding Light={StaticResource LightText}, Dark={StaticResource ForgeText}}"
                                                       BackgroundColor="Transparent"
                                                       VerticalOptions="Center"/>
                                            </Border>
                                        </VerticalStackLayout>

                                        <!-- REPS -->
                                        <VerticalStackLayout Grid.Column="1" Spacing="4">
                                            <Label Text="REPS"
                                                   Style="{StaticResource SectionLabel}"
                                                   HorizontalOptions="Center"/>
                                            <Border BackgroundColor="{AppThemeBinding Light={StaticResource LightSurface2}, Dark={StaticResource ForgeSurface2}}"
                                                    StrokeShape="RoundRectangle 8"
                                                    Stroke="{AppThemeBinding Light={StaticResource LightBorder}, Dark={StaticResource ForgeBorderLight}}"
                                                    StrokeThickness="1"
                                                    Padding="0"
                                                    HeightRequest="46">
                                                <Entry Text="{Binding RepsText, Mode=TwoWay}"
                                                       Keyboard="Numeric"
                                                       HorizontalTextAlignment="Center"
                                                       FontFamily="BebasNeue"
                                                       FontSize="22"
                                                       TextColor="{AppThemeBinding Light={StaticResource LightText}, Dark={StaticResource ForgeText}}"
                                                       BackgroundColor="Transparent"
                                                       VerticalOptions="Center"/>
                                            </Border>
                                        </VerticalStackLayout>

                                        <!-- KG -->
                                        <VerticalStackLayout Grid.Column="2" Spacing="4">
                                            <Label Text="KG"
                                                   Style="{StaticResource SectionLabel}"
                                                   HorizontalOptions="Center"/>
                                            <Border BackgroundColor="{AppThemeBinding Light={StaticResource LightSurface2}, Dark={StaticResource ForgeSurface2}}"
                                                    StrokeShape="RoundRectangle 8"
                                                    Stroke="{AppThemeBinding Light={StaticResource LightBorder}, Dark={StaticResource ForgeBorderLight}}"
                                                    StrokeThickness="1"
                                                    Padding="0"
                                                    HeightRequest="46">
                                                <Entry Text="{Binding WeightText, Mode=TwoWay}"
                                                       Keyboard="Numeric"
                                                       Placeholder="—"
                                                       PlaceholderColor="{StaticResource ForgeMuted}"
                                                       HorizontalTextAlignment="Center"
                                                       FontFamily="BebasNeue"
                                                       FontSize="22"
                                                       TextColor="{AppThemeBinding Light={StaticResource LightText}, Dark={StaticResource ForgeText}}"
                                                       BackgroundColor="Transparent"
                                                       VerticalOptions="Center"/>
                                            </Border>
                                        </VerticalStackLayout>

                                        <!-- VILA (tappable, shows dialog) -->
                                        <VerticalStackLayout Grid.Column="3" Spacing="4">
                                            <Label Text="VILA"
                                                   Style="{StaticResource SectionLabel}"
                                                   TextColor="{StaticResource ForgeAccentAmber}"
                                                   HorizontalOptions="Center"/>
                                            <Border BackgroundColor="{AppThemeBinding Light={StaticResource LightSurface2}, Dark={StaticResource ForgeSurface2}}"
                                                    StrokeShape="RoundRectangle 8"
                                                    Stroke="{StaticResource ForgeAccentAmberDim}"
                                                    StrokeThickness="1"
                                                    HeightRequest="46">
                                                <Border.GestureRecognizers>
                                                    <TapGestureRecognizer
                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:TemplateEditViewModel}}, Path=ChangeRestCommand}"
                                                        CommandParameter="{Binding .}"/>
                                                </Border.GestureRecognizers>
                                                <Label Text="{Binding RestDisplay}"
                                                       FontFamily="BebasNeue"
                                                       FontSize="20"
                                                       TextColor="{AppThemeBinding Light={StaticResource LightText}, Dark={StaticResource ForgeText}}"
                                                       HorizontalOptions="Center"
                                                       VerticalOptions="Center"/>
                                            </Border>
                                        </VerticalStackLayout>

                                    </Grid>
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </StackLayout>

                <!-- Add exercise -->
                <Button Text="+ LÄGG TILL ÖVNING"
                        Style="{StaticResource SecondaryButton}"
                        Margin="0,4,0,0"
                        Command="{Binding AddExerciseCommand}"/>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</ContentPage>
