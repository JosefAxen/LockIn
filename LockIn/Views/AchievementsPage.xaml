<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:LockIn.ViewModels"
             x:Class="LockIn.Views.AchievementsPage"
             x:DataType="vm:AchievementsViewModel"
             xmlns:ios="clr-namespace:Microsoft.Maui.Controls.PlatformConfiguration.iOSSpecific;assembly=Microsoft.Maui.Controls"
             Shell.NavBarIsVisible="False"
             ios:Page.UseSafeArea="False">

    <Grid RowDefinitions="Auto,*" SafeAreaEdges="None">

        <!-- Header -->
        <Grid Grid.Row="0" Padding="16,56,20,12" ColumnDefinitions="Auto,*,Auto">
            <Button Grid.Column="0" Text="‹"
                    Style="{StaticResource SecondaryButton}"
                    WidthRequest="44" HeightRequest="44" Padding="0"
                    Command="{Binding GoBackCommand}"/>
            <Label Grid.Column="1"
                   Text="ACHIEVEMENTS"
                   Style="{StaticResource DisplayLabel}"
                   FontSize="28"
                   HorizontalOptions="Center" VerticalOptions="Center"/>
            <Label Grid.Column="2"
                   Text="{Binding UnlockedCount}"
                   Style="{StaticResource MutedLabel}"
                   FontSize="11"
                   VerticalOptions="Center"/>
        </Grid>

        <ActivityIndicator Grid.Row="1"
                           IsRunning="{Binding IsLoading}"
                           IsVisible="{Binding IsLoading}"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"/>

        <CollectionView Grid.Row="1"
                        ItemsSource="{Binding Achievements}"
                        IsVisible="{Binding IsLoading, Converter={x:Static vm:InverseBoolConverter.Instance}}"
                        Margin="12,4,12,48">
            <CollectionView.ItemsLayout>
                <GridItemsLayout Orientation="Vertical" Span="2"/>
            </CollectionView.ItemsLayout>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="vm:AchievementRow">
                    <Border Margin="4,4"
                            Opacity="{Binding CardOpacity}"
                            StrokeShape="RoundRectangle 14"
                            StrokeThickness="0"
                            BackgroundColor="{AppThemeBinding Light={StaticResource LightSurface}, Dark={StaticResource ForgeSurface}}"
                            Padding="0">
                        <Grid RowDefinitions="Auto,*" Padding="14,14,14,14" RowSpacing="6">

                            <Label Grid.Row="0"
                                   Text="{Binding DisplayEmoji}"
                                   FontSize="32"
                                   HorizontalOptions="Start"/>

                            <VerticalStackLayout Grid.Row="1" Spacing="3">
                                <Label Text="{Binding Title}"
                                       FontFamily="BebasNeue" FontSize="16"
                                       CharacterSpacing="0.5"
                                       TextColor="{AppThemeBinding Light={StaticResource LightText}, Dark={StaticResource ForgeText}}"
                                       LineBreakMode="WordWrap"/>
                                <Label Text="{Binding Description}"
                                       Style="{StaticResource MutedLabel}"
                                       FontSize="11"
                                       LineBreakMode="WordWrap"/>
                                <Label Text="{Binding UnlockedAt}"
                                       IsVisible="{Binding IsUnlocked}"
                                       TextColor="{StaticResource ForgeAccent}"
                                       FontFamily="DMSansRegular"
                                       FontSize="10"
                                       Margin="0,2,0,0"/>
                            </VerticalStackLayout>

                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>
</ContentPage>
