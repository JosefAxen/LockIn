<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:LockIn.ViewModels"
             xmlns:controls="clr-namespace:LockIn.Controls"
             xmlns:loc="clr-namespace:LockIn.Resources.Strings"
             x:Class="LockIn.Views.AchievementsPage"
             x:DataType="vm:AchievementsViewModel"
             xmlns:ios="clr-namespace:Microsoft.Maui.Controls.PlatformConfiguration.iOSSpecific;assembly=Microsoft.Maui.Controls"
             Shell.NavBarIsVisible="False"
             BackgroundColor="Transparent">

    <Grid RowDefinitions="Auto,*" SafeAreaEdges="None">

        <!-- Atmosf�risk bakgrund -->
        <controls:AtmosphericBackgroundView Grid.RowSpan="2" InputTransparent="True"/>

        <!-- Permanent status bar gradient -->
        <BoxView Grid.RowSpan="2" VerticalOptions="Start" HeightRequest="90" InputTransparent="True" ZIndex="19">
            <BoxView.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#28141418" Offset="0.0"/>
                    <GradientStop Color="#00141418" Offset="1.0"/>
                </LinearGradientBrush>
            </BoxView.Background>
        </BoxView>

        <!-- Sticky header gradient (fades in on scroll) -->
        <Grid x:Name="StickyHeader" Grid.RowSpan="2" VerticalOptions="Start" ZIndex="20" Opacity="0"
              HeightRequest="150" SafeAreaEdges="None" InputTransparent="True">
            <BoxView InputTransparent="True">
                <BoxView.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#D8141418" Offset="0.0"/>
                        <GradientStop Color="#90141418" Offset="0.35"/>
                        <GradientStop Color="#38141418" Offset="0.65"/>
                        <GradientStop Color="#00141418" Offset="1.0"/>
                    </LinearGradientBrush>
                </BoxView.Background>
            </BoxView>
        </Grid>

        <!-- Header -->
        <Grid Grid.Row="0" Padding="16,56,20,12" ColumnDefinitions="48,*,Auto" ZIndex="21">
            <Border Grid.Column="0"
                    WidthRequest="36" HeightRequest="36"
                    StrokeShape="Ellipse"
                    BackgroundColor="#17FFFFFF"
                    Stroke="#29FFFFFF"
                    StrokeThickness="0.5"
                    VerticalOptions="Center">
                <Path Style="{StaticResource BackChevron}"/>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding GoBackCommand}"/>
                </Border.GestureRecognizers>
            </Border>
            <Label Grid.Column="1"
                   Text="{loc:Localize Achievements_Title}"
                   Style="{StaticResource DisplayLabel}"
                   FontSize="28"
                   HorizontalOptions="Center" VerticalOptions="Center"/>
            <Label Grid.Column="2"
                   Text="{Binding UnlockedCount}"
                   Style="{StaticResource MutedLabel}"
                   FontSize="11"
                   VerticalOptions="Center"/>
        </Grid>

        <ActivityIndicator Grid.Row="1"
                           IsRunning="{Binding IsLoading}"
                           IsVisible="{Binding IsLoading}"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"/>

        <CollectionView Grid.Row="1"
                        ItemsSource="{Binding Achievements}"
                        IsVisible="{Binding IsLoading, Converter={x:Static vm:InverseBoolConverter.Instance}}"
                        Margin="12,4,12,48"
                        Scrolled="OnScrolled">
            <CollectionView.ItemsLayout>
                <GridItemsLayout Orientation="Vertical" Span="2"/>
            </CollectionView.ItemsLayout>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="vm:AchievementRow">
                    <Border Margin="4,4"
                            Opacity="{Binding CardOpacity}"
                            StrokeShape="RoundRectangle 14"
                            StrokeThickness="1"
                            BackgroundColor="{Binding CardBackground}"
                            Stroke="{Binding CardStroke}"
                            Padding="0">
                        <Grid RowDefinitions="Auto,*" Padding="14,14,14,14" RowSpacing="6">

                            <Label Grid.Row="0"
                                   Text="{Binding DisplayEmoji}"
                                   FontSize="32"
                                   HorizontalOptions="Start"/>

                            <VerticalStackLayout Grid.Row="1" Spacing="3">
                                <Label Text="{Binding Title}"
                                       FontFamily="BebasNeue" FontSize="16"
                                       CharacterSpacing="0.5"
                                       TextColor="{AppThemeBinding Light={StaticResource LightText}, Dark={StaticResource ForgeText}}"
                                       LineBreakMode="WordWrap"/>
                                <Label Text="{Binding Description}"
                                       Style="{StaticResource MutedLabel}"
                                       FontSize="11"
                                       LineBreakMode="WordWrap"/>
                                <Label Text="{Binding UnlockedAt}"
                                       IsVisible="{Binding IsUnlocked}"
                                       TextColor="{StaticResource ForgeAccentAmber}"
                                       FontFamily="DMSansRegular"
                                       FontSize="10"
                                       Margin="0,2,0,0"/>
                            </VerticalStackLayout>

                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Bottom gradient fade � matchar topp-gradienten spegelv�nt -->
        <BoxView Grid.RowSpan="2" InputTransparent="True" VerticalOptions="End" HeightRequest="150" ZIndex="22">
            <BoxView.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#00141418" Offset="0.0"/>
                    <GradientStop Color="#38141418" Offset="0.35"/>
                    <GradientStop Color="#90141418" Offset="0.65"/>
                    <GradientStop Color="#141418" Offset="1.0"/>
                </LinearGradientBrush>
            </BoxView.Background>
        </BoxView>

    </Grid>
</ContentPage>
