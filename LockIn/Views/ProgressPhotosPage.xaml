<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:LockIn.ViewModels"
             xmlns:controls="clr-namespace:LockIn.Controls"
             xmlns:loc="clr-namespace:LockIn.Resources.Strings"
             x:Class="LockIn.Views.ProgressPhotosPage"
             x:DataType="vm:ProgressPhotosViewModel"
             xmlns:ios="clr-namespace:Microsoft.Maui.Controls.PlatformConfiguration.iOSSpecific;assembly=Microsoft.Maui.Controls"
             Shell.NavBarIsVisible="False"
             BackgroundColor="Transparent">

    <Grid RowDefinitions="Auto,*" SafeAreaEdges="None">

        <!-- Atmosf�risk bakgrund -->
        <controls:AtmosphericBackgroundView Grid.RowSpan="2" InputTransparent="True"/>

        <!-- Header -->
        <Grid Grid.Row="0" Padding="16,56,16,12">
            <Border WidthRequest="36" HeightRequest="36"
                    HorizontalOptions="Start" VerticalOptions="Center"
                    StrokeShape="Ellipse"
                    BackgroundColor="{AppThemeBinding Light=#1A000000, Dark=#17FFFFFF}"
                    Stroke="{AppThemeBinding Light=#0D000000, Dark=#29FFFFFF}"
                    StrokeThickness="0.5">
                <Path Style="{StaticResource BackChevron}"/>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding GoBackCommand}"/>
                </Border.GestureRecognizers>
            </Border>
            <Label Text="{loc:Localize ProgressPhotos_Title}"
                   FontFamily="BebasNeue" FontSize="28" CharacterSpacing="1"
                   TextColor="{AppThemeBinding Light={StaticResource LightText}, Dark={StaticResource ForgeText}}"
                   HorizontalOptions="Center" VerticalOptions="Center"/>
        </Grid>

        <ActivityIndicator Grid.Row="1"
                           IsRunning="{Binding IsLoading}"
                           IsVisible="{Binding IsLoading}"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"/>

        <CollectionView Grid.Row="1"
                        ItemsSource="{Binding PhotoGroups}"
                        IsGrouped="True"
                        IsVisible="{Binding IsLoading, Converter={x:Static vm:InverseBoolConverter.Instance}}"
                        Margin="16,4,16,48">

            <CollectionView.GroupHeaderTemplate>
                <DataTemplate x:DataType="vm:PhotoGroup">
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10"
                          Padding="0,14,0,8">
                        <Label Grid.Column="0"
                               Text="{Binding MonthKey}"
                               FontFamily="BebasNeue" FontSize="12" CharacterSpacing="2.5"
                               TextColor="{StaticResource ForgeAccentBlue}"
                               VerticalOptions="Center"/>
                        <BoxView Grid.Column="1"
                                 HeightRequest="1"
                                 BackgroundColor="{StaticResource ForgeBorder}"
                                 VerticalOptions="Center"/>
                    </Grid>
                </DataTemplate>
            </CollectionView.GroupHeaderTemplate>

            <CollectionView.EmptyView>
                <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center"
                                     Spacing="8" Margin="0,80,0,0">
                    <Label Text="{loc:Localize ProgressPhotos_Empty_Title}" Style="{StaticResource DisplayLabel}"
                           FontSize="22" TextColor="{StaticResource ForgeMuted}"
                           HorizontalOptions="Center"/>
                    <Label Text="{loc:Localize ProgressPhotos_Empty_Body}"
                           Style="{StaticResource MutedLabel}"
                           HorizontalOptions="Center" HorizontalTextAlignment="Center"/>
                </VerticalStackLayout>
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="vm:PhotoRow">
                    <Border Margin="0,0,0,14"
                            StrokeShape="RoundRectangle 20"
                            Stroke="{StaticResource ForgeBorder}"
                            StrokeThickness="1"
                            Padding="0">
                        <Grid RowDefinitions="Auto,Auto">
                            <Image Grid.Row="0"
                                   Source="{Binding Source}"
                                   Aspect="AspectFill"
                                   HeightRequest="220"/>
                            <Grid Grid.Row="1" ColumnDefinitions="*,Auto" Padding="16,12"
                                  BackgroundColor="{AppThemeBinding Light={StaticResource LightSurface}, Dark={StaticResource ForgeSurface}}">
                                <Label Grid.Column="0"
                                       Text="{Binding DateDisplay}"
                                       FontFamily="DMSansMedium" FontSize="14"
                                       TextColor="{AppThemeBinding Light={StaticResource LightText}, Dark={StaticResource ForgeText}}"
                                       VerticalOptions="Center"/>
                                <Label Grid.Column="1" Text="✕"
                                       TextColor="{StaticResource ForgeMuted}"
                                       FontSize="16" VerticalOptions="Center">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ProgressPhotosViewModel}}, Path=DeletePhotoCommand}"
                                            CommandParameter="{Binding .}"/>
                                    </Label.GestureRecognizers>
                                </Label>
                            </Grid>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>
</ContentPage>
