<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:LockIn.ViewModels"
             xmlns:data="clr-namespace:LockIn.Data"
             xmlns:views="clr-namespace:LockIn.Views"
             xmlns:controls="clr-namespace:LockIn.Controls"
             x:Class="LockIn.Views.ProgramDetailPage"
             x:DataType="vm:ProgramDetailViewModel"
             xmlns:ios="clr-namespace:Microsoft.Maui.Controls.PlatformConfiguration.iOSSpecific;assembly=Microsoft.Maui.Controls"
             Shell.NavBarIsVisible="False"
             BackgroundColor="Transparent"
             ios:Page.UseSafeArea="False">

    <ContentPage.Resources>
        <views:InvertedBoolConverter x:Key="InvertedBoolConverter"/>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*,Auto" SafeAreaEdges="None">

        <!-- Atmosfärisk bakgrund -->
        <controls:AtmosphericBackgroundView Grid.RowSpan="3" InputTransparent="True"/>

        <!-- Header -->
        <Grid Grid.Row="0" Padding="16,56,16,8" ColumnDefinitions="48,*">
            <Border Grid.Column="0"
                    WidthRequest="36" HeightRequest="36"
                    StrokeShape="Ellipse"
                    BackgroundColor="#17FFFFFF"
                    Stroke="#29FFFFFF"
                    StrokeThickness="0.5"
                    VerticalOptions="Center">
                <Label Text="‹" FontSize="22" FontFamily="DMSansMedium"
                       HorizontalOptions="Center" VerticalOptions="Center"
                       TextColor="{StaticResource ForgeText}"/>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnBackClicked"/>
                </Border.GestureRecognizers>
            </Border>
            <StackLayout Grid.Column="1" Spacing="1" VerticalOptions="Center" Margin="4,0,0,0">
                <Label Text="{Binding ProgramName}"
                       FontFamily="BebasNeue" FontSize="24" CharacterSpacing="1"/>
                <Label Text="{Binding DaysLabel}"
                       Style="{StaticResource MutedLabel}"/>
            </StackLayout>
        </Grid>

        <!-- Content -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="16,4,16,16" Spacing="10">

                <!-- Description -->
                <Border Style="{StaticResource CardFrame}" Padding="16,14">
                    <Label Text="{Binding Description}"
                           Style="{StaticResource MutedLabel}"
                           LineBreakMode="WordWrap"/>
                </Border>

                <!-- Days -->
                <Label Text="PASS I PROGRAMMET"
                       Style="{StaticResource SectionLabel}" Margin="4,4,0,0"/>

                <StackLayout BindableLayout.ItemsSource="{Binding Days}" Spacing="10">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="data:ProgramDay">
                            <Border Style="{StaticResource CardFrame}">
                                <VerticalStackLayout Spacing="0">

                                    <!-- Day header -->
                                    <Label Text="{Binding Label}"
                                           FontFamily="DMSansMedium" FontSize="15"
                                           Padding="16,12,16,8"/>

                                    <BoxView BackgroundColor="{StaticResource ForgeBorder}"
                                             HeightRequest="1" Margin="0"/>

                                    <!-- Exercises list -->
                                    <StackLayout BindableLayout.ItemsSource="{Binding Exercises}"
                                                 Padding="16,8,16,10" Spacing="6">
                                        <BindableLayout.ItemTemplate>
                                            <DataTemplate x:DataType="data:ProgramExercise">
                                                <Grid ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="10">
                                                    <Label Grid.Column="0"
                                                           Text="{Binding ExerciseName}"
                                                           FontFamily="DMSansRegular" FontSize="14"
                                                           VerticalOptions="Center"/>
                                                    <Label Grid.Column="1"
                                                           Text="{Binding Sets, StringFormat='{0}×'}"
                                                           Style="{StaticResource MutedLabel}"
                                                           FontFamily="BebasNeue" FontSize="15"
                                                           VerticalOptions="Center"/>
                                                    <Label Grid.Column="2"
                                                           Text="{Binding Reps}"
                                                           Style="{StaticResource MutedLabel}"
                                                           FontFamily="BebasNeue" FontSize="15"
                                                           VerticalOptions="Center"/>
                                                    <Label Grid.Column="3"
                                                           Text="{Binding RestSeconds, StringFormat='{0}s vila'}"
                                                           Style="{StaticResource MutedLabel}"
                                                           FontSize="12"
                                                           VerticalOptions="Center"/>
                                                </Grid>
                                            </DataTemplate>
                                        </BindableLayout.ItemTemplate>
                                    </StackLayout>

                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </StackLayout>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Activate button -->
        <Grid Grid.Row="2" Padding="16,8,16,32">
            <Button Text="AKTIVERA PROGRAM"
                    Style="{StaticResource PrimaryButton}"
                    IsEnabled="{Binding IsActivating, Converter={x:StaticResource InvertedBoolConverter}}"
                    Command="{Binding ActivateCommand}"/>
        </Grid>

    </Grid>

</ContentPage>
