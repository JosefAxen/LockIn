<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:LockIn.ViewModels"
             xmlns:data="clr-namespace:LockIn.Data"
             xmlns:views="clr-namespace:LockIn.Views"
             xmlns:controls="clr-namespace:LockIn.Controls"
             xmlns:loc="clr-namespace:LockIn.Resources.Strings"
             x:Class="LockIn.Views.ProgramDetailPage"
             x:DataType="vm:ProgramDetailViewModel"
             xmlns:ios="clr-namespace:Microsoft.Maui.Controls.PlatformConfiguration.iOSSpecific;assembly=Microsoft.Maui.Controls"
             Shell.NavBarIsVisible="False"
             BackgroundColor="Transparent"
             ios:Page.UseSafeArea="False">

    <ContentPage.Resources>
        <views:InvertedBoolConverter x:Key="InvertedBoolConverter"/>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*,Auto" SafeAreaEdges="None">

        <!-- Atmosfärisk bakgrund -->
        <controls:AtmosphericBackgroundView Grid.RowSpan="3" InputTransparent="True"/>

        <!-- Permanent status bar gradient -->
        <BoxView Grid.RowSpan="3" VerticalOptions="Start" HeightRequest="90" InputTransparent="True" ZIndex="19">
            <BoxView.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#28141418" Offset="0.0"/>
                    <GradientStop Color="#00141418" Offset="1.0"/>
                </LinearGradientBrush>
            </BoxView.Background>
        </BoxView>

        <!-- Sticky header gradient (fades in on scroll) -->
        <Grid x:Name="StickyHeader" Grid.RowSpan="3" VerticalOptions="Start" ZIndex="20" Opacity="0"
              HeightRequest="150" SafeAreaEdges="None" InputTransparent="True">
            <BoxView InputTransparent="True">
                <BoxView.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#D8141418" Offset="0.0"/>
                        <GradientStop Color="#90141418" Offset="0.35"/>
                        <GradientStop Color="#38141418" Offset="0.65"/>
                        <GradientStop Color="#00141418" Offset="1.0"/>
                    </LinearGradientBrush>
                </BoxView.Background>
            </BoxView>
        </Grid>

        <!-- Header -->
        <Grid Grid.Row="0" Padding="16,56,16,8" ColumnDefinitions="48,*" ZIndex="21">
            <Border Grid.Column="0"
                    WidthRequest="36" HeightRequest="36"
                    StrokeShape="Ellipse"
                    BackgroundColor="#17FFFFFF"
                    Stroke="#29FFFFFF"
                    StrokeThickness="0.5"
                    VerticalOptions="Center">
                <Path Style="{StaticResource BackChevron}"/>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnBackClicked"/>
                </Border.GestureRecognizers>
            </Border>
            <StackLayout Grid.Column="1" Spacing="1" VerticalOptions="Center" Margin="4,0,0,0">
                <Label Text="{Binding ProgramName}"
                       FontFamily="BebasNeue" FontSize="24" CharacterSpacing="1"/>
                <Label Text="{Binding DaysLabel}"
                       Style="{StaticResource MutedLabel}"/>
            </StackLayout>
        </Grid>

        <!-- Content -->
        <ScrollView Grid.Row="1" Scrolled="OnScrolled">
            <VerticalStackLayout Padding="16,4,16,16" Spacing="10">

                <!-- Description -->
                <Border Style="{StaticResource CardFrame}" Padding="16,14">
                    <Label Text="{Binding Description}"
                           Style="{StaticResource MutedLabel}"
                           LineBreakMode="WordWrap"/>
                </Border>

                <!-- Days -->
                <Label Text="{loc:Localize ProgramDetail_SectionDays}"
                       Style="{StaticResource SectionLabel}" Margin="0,4,0,0"/>

                <StackLayout BindableLayout.ItemsSource="{Binding Days}" Spacing="10">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="data:ProgramDay">
                            <Border Style="{StaticResource CardFrame}">
                                <VerticalStackLayout Spacing="0">

                                    <!-- Day header -->
                                    <Label Text="{Binding Label}"
                                           FontFamily="DMSansMedium" FontSize="15"
                                           Padding="16,12,16,8"/>

                                    <BoxView BackgroundColor="{StaticResource ForgeBorder}"
                                             HeightRequest="1" Margin="0"/>

                                    <!-- Exercises list -->
                                    <StackLayout BindableLayout.ItemsSource="{Binding Exercises}"
                                                 Padding="16,8,16,10" Spacing="6">
                                        <BindableLayout.ItemTemplate>
                                            <DataTemplate x:DataType="data:ProgramExercise">
                                                <Grid ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="10">
                                                    <Label Grid.Column="0"
                                                           Text="{Binding ExerciseName}"
                                                           FontFamily="DMSansRegular" FontSize="14"
                                                           VerticalOptions="Center"/>
                                                    <Label Grid.Column="1"
                                                           Text="{Binding Sets, StringFormat='{0}×'}"
                                                           Style="{StaticResource MutedLabel}"
                                                           FontFamily="BebasNeue" FontSize="15"
                                                           VerticalOptions="Center"/>
                                                    <Label Grid.Column="2"
                                                           Text="{Binding Reps}"
                                                           Style="{StaticResource MutedLabel}"
                                                           FontFamily="BebasNeue" FontSize="15"
                                                           VerticalOptions="Center"/>
                                                    <Label Grid.Column="3"
                                                           Text="{Binding RestLabel}"
                                                           Style="{StaticResource MutedLabel}"
                                                           FontSize="12"
                                                           VerticalOptions="Center"/>
                                                </Grid>
                                            </DataTemplate>
                                        </BindableLayout.ItemTemplate>
                                    </StackLayout>

                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </StackLayout>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Bottom gradient fade — matchar topp-gradienten spegelvänt -->
        <BoxView Grid.RowSpan="3" InputTransparent="True" VerticalOptions="End" HeightRequest="150" ZIndex="22">
            <BoxView.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#00141418" Offset="0.0"/>
                    <GradientStop Color="#38141418" Offset="0.35"/>
                    <GradientStop Color="#90141418" Offset="0.65"/>
                    <GradientStop Color="#141418" Offset="1.0"/>
                </LinearGradientBrush>
            </BoxView.Background>
        </BoxView>

        <!-- Activate button -->
        <Grid Grid.Row="2" Padding="16,8,16,32" ZIndex="23">
            <Button Text="{loc:Localize ProgramDetail_ActivateButton}"
                    Style="{StaticResource PrimaryButton}"
                    IsEnabled="{Binding IsActivating, Converter={x:StaticResource InvertedBoolConverter}}"
                    Command="{Binding ActivateCommand}"/>
        </Grid>

    </Grid>

</ContentPage>
