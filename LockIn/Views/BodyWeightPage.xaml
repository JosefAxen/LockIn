<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:LockIn.ViewModels"
             xmlns:models="clr-namespace:LockIn.Models"
             xmlns:views="clr-namespace:LockIn.Views"
             xmlns:controls="clr-namespace:LockIn.Controls"
             x:Class="LockIn.Views.BodyWeightPage"
             x:DataType="vm:BodyWeightViewModel"
             xmlns:ios="clr-namespace:Microsoft.Maui.Controls.PlatformConfiguration.iOSSpecific;assembly=Microsoft.Maui.Controls"
             Shell.NavBarIsVisible="False"
             BackgroundColor="Transparent"
             ios:Page.UseSafeArea="False">

    <ContentPage.Resources>
        <views:InvertedBoolConverter x:Key="InvertedBoolConverter"/>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*" SafeAreaEdges="None">

        <!-- Atmosfärisk bakgrund -->
        <controls:AtmosphericBackgroundView Grid.RowSpan="2" InputTransparent="True"/>

        <!-- Header -->
        <Grid Grid.Row="0" Padding="16,56,16,8" ColumnDefinitions="Auto,*">
            <Border Grid.Column="0"
                    WidthRequest="36" HeightRequest="36"
                    StrokeShape="Ellipse"
                    BackgroundColor="{AppThemeBinding Light=#1A000000, Dark=#17FFFFFF}"
                    Stroke="{AppThemeBinding Light=#0D000000, Dark=#29FFFFFF}"
                    StrokeThickness="0.5"
                    VerticalOptions="Center">
                <Path Style="{StaticResource BackChevron}"/>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding GoBackCommand}"/>
                </Border.GestureRecognizers>
            </Border>
            <Label Grid.Column="1"
                   Text="KROPPSVIKT"
                   Style="{StaticResource DisplayLabel}"
                   FontSize="28"
                   HorizontalOptions="Center" VerticalOptions="Center"/>
        </Grid>

        <ScrollView Grid.Row="1" VerticalScrollBarVisibility="Never">
            <VerticalStackLayout Padding="16,4,16,48" Spacing="12">

                <!-- Latest weight hero -->
                <Border Style="{StaticResource CardFrame}" Padding="24,20">
                    <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                        <Label Text="{Binding LatestWeight}"
                               FontSize="56" FontAttributes="Bold"
                               CharacterSpacing="-1"
                               TextColor="{AppThemeBinding Light={StaticResource LightAccent}, Dark={StaticResource ForgeAccent}}"
                               HorizontalOptions="Center"/>
                        <Label Text="{Binding LatestDate}"
                               Style="{StaticResource MutedLabel}"
                               HorizontalOptions="Center"/>
                        <Label Text="Ingen data ännu – logga din första vikt nedan"
                               Style="{StaticResource MutedLabel}"
                               HorizontalOptions="Center"
                               HorizontalTextAlignment="Center"
                               IsVisible="{Binding HasData, Converter={x:StaticResource InvertedBoolConverter}}"/>
                    </VerticalStackLayout>
                </Border>

                <!-- Chart -->
                <Border Style="{StaticResource CardFrame}" Padding="12,14,12,10"
                        IsVisible="{Binding HasData}">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="VIKTUTVECKLING"
                               Style="{StaticResource SectionLabel}"
                               Margin="4,0,0,0"/>
                        <controls:LineChartView Points="{Binding ChartPoints}" StrokeColor="#6EA8DC" HeightRequest="180" BackgroundColor="Transparent"/>
                    </VerticalStackLayout>
                </Border>

                <!-- Log button -->
                <Border BackgroundColor="{StaticResource ForgePrimary}"
                        StrokeShape="RoundRectangle 26"
                        StrokeThickness="0"
                        HeightRequest="56"
                        HorizontalOptions="Fill">
                    <HorizontalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="10">
                        <views:AppIcon Source="ic_plus.png"
                                       WidthRequest="18" HeightRequest="18"
                                       ForceTint="{StaticResource ForgePrimaryForeground}"
                                       VerticalOptions="Center"/>
                        <Label Text="LOGGA VIKT"
                               TextColor="{StaticResource ForgePrimaryForeground}"
                               FontFamily="BebasNeue"
                               FontSize="20"
                               CharacterSpacing="3"
                               VerticalOptions="Center"/>
                    </HorizontalStackLayout>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding LogWeightCommand}" Tapped="OnLoggaViktTapped"/>
                    </Border.GestureRecognizers>
                </Border>

                <!-- Recent entries -->
                <Label Text="SENASTE LOGGNINGAR"
                       Style="{StaticResource SectionLabel}"
                       IsVisible="{Binding HasData}"/>
                <Border Style="{StaticResource CardFrame}" Padding="0,4"
                        IsVisible="{Binding HasData}">
                    <StackLayout BindableLayout.ItemsSource="{Binding RecentEntries}" Spacing="0">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="models:BodyWeightEntry">
                                <Grid ColumnDefinitions="*,Auto,Auto" Padding="16,10,12,10">
                                    <Label Grid.Column="0"
                                           Text="{Binding LoggedAt, StringFormat='{0:d MMM yyyy  HH:mm}'}"
                                           Style="{StaticResource MutedLabel}"
                                           VerticalOptions="Center"/>
                                    <Label Grid.Column="1"
                                           Text="{Binding WeightKg, StringFormat='{0:F1} kg'}"
                                           FontFamily="DMSansMedium" FontSize="15"
                                           TextColor="{AppThemeBinding Light={StaticResource LightAccent}, Dark={StaticResource ForgeAccent}}"
                                           VerticalOptions="Center"
                                           Margin="0,0,12,0"/>
                                    <Border Grid.Column="2"
                                            WidthRequest="36" HeightRequest="36"
                                            BackgroundColor="{AppThemeBinding Light={StaticResource LightSurface2}, Dark={StaticResource ForgeSurface2}}"
                                            StrokeShape="Ellipse" StrokeThickness="0">
                                        <views:AppIcon Source="ic_trash.png"
                                                       WidthRequest="16" HeightRequest="16"
                                                       HorizontalOptions="Center" VerticalOptions="Center"/>
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:BodyWeightViewModel}}, Path=DeleteEntryCommand}"
                                                CommandParameter="{Binding .}"/>
                                        </Border.GestureRecognizers>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </StackLayout>
                </Border>

                <!-- Visa fler -->
                <Border Style="{StaticResource CardFrame}"
                        Padding="0,4"
                        IsVisible="{Binding HasMore}">
                    <Label Text="VISA FLER"
                           FontFamily="BebasNeue" FontSize="15" CharacterSpacing="2"
                           TextColor="{AppThemeBinding Light={StaticResource LightMuted}, Dark={StaticResource ForgeMuted}}"
                           HorizontalOptions="Center"
                           Padding="0,10"/>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding LoadMoreCommand}"/>
                    </Border.GestureRecognizers>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</ContentPage>
