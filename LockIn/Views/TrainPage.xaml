<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:LockIn.ViewModels"
             xmlns:models="clr-namespace:LockIn.Models"
             x:Class="LockIn.Views.TrainPage"
             x:DataType="vm:TrainViewModel"
             Title="Träna">

    <Grid RowDefinitions="Auto,*">

        <!-- Header -->
        <Grid Grid.Row="0" Padding="20,20,20,4">
            <Label Text="TRÄNA" Style="{StaticResource DisplayLabel}" FontSize="40"/>
        </Grid>

        <!-- Content -->
        <ScrollView Grid.Row="1">
            <StackLayout Padding="16,8,16,120" Spacing="0">

                <!-- Stats row -->
                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8" Margin="0,0,0,16">
                    <Border Grid.Column="0" Style="{StaticResource CardFrame}" Padding="14,12">
                        <StackLayout Spacing="2">
                            <Image Source="ic_calendar.png" WidthRequest="16" HeightRequest="16"
                                   HorizontalOptions="Start" Margin="0,0,0,2"/>
                            <Label Text="{Binding WeekCount}"
                                   FontFamily="BebasNeue" FontSize="28"
                                   TextColor="{StaticResource ForgeAccent}"/>
                            <Label Text="DENNA VECKA" Style="{StaticResource SectionLabel}" FontSize="9"/>
                        </StackLayout>
                    </Border>
                    <Border Grid.Column="1" Style="{StaticResource CardFrame}" Padding="14,12">
                        <StackLayout Spacing="2">
                            <Image Source="ic_flame.png" WidthRequest="16" HeightRequest="16"
                                   HorizontalOptions="Start" Margin="0,0,0,2"/>
                            <Label Text="{Binding Streak}"
                                   FontFamily="BebasNeue" FontSize="28"
                                   TextColor="{AppThemeBinding Light={StaticResource LightText}, Dark={StaticResource ForgeText}}"/>
                            <Label Text="DAGAR STREAK" Style="{StaticResource SectionLabel}" FontSize="9"/>
                        </StackLayout>
                    </Border>
                    <Border Grid.Column="2" Style="{StaticResource CardFrame}" Padding="14,12">
                        <StackLayout Spacing="2">
                            <Image Source="ic_barbell.png" WidthRequest="16" HeightRequest="16"
                                   HorizontalOptions="Start" Margin="0,0,0,2"/>
                            <Label Text="{Binding TotalCount}"
                                   FontFamily="BebasNeue" FontSize="28"
                                   TextColor="{AppThemeBinding Light={StaticResource LightText}, Dark={StaticResource ForgeText}}"/>
                            <Label Text="TOTALT PASS" Style="{StaticResource SectionLabel}" FontSize="9"/>
                        </StackLayout>
                    </Border>
                </Grid>

                <!-- Deload banner -->
                <Border IsVisible="{Binding ShowDeloadBanner}"
                        BackgroundColor="{StaticResource ForgeAccentDim}"
                        StrokeShape="RoundRectangle 12"
                        StrokeThickness="1"
                        Stroke="{StaticResource ForgeAccent}"
                        Padding="14,12" Margin="0,0,0,4">
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                        <Label Grid.Column="0" Text="📉" FontSize="20" VerticalOptions="Center"/>
                        <StackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                            <Label Text="DAGS FÖR DELOAD?"
                                   FontFamily="BebasNeue" FontSize="15"
                                   CharacterSpacing="0.5"
                                   TextColor="{StaticResource ForgeAccent}"/>
                            <Label Text="Din volym har minskat 3 veckor i rad. Minska vikterna med 40–50% i veckan."
                                   Style="{StaticResource MutedLabel}"
                                   FontSize="12"
                                   LineBreakMode="WordWrap"/>
                        </StackLayout>
                        <Label Grid.Column="2" Text="✕"
                               FontSize="16"
                               TextColor="{StaticResource ForgeMuted}"
                               VerticalOptions="Center">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding DismissDeloadCommand}"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </Grid>
                </Border>

                <!-- Muskelpoäng: Senaste 7 dagarna -->
                <Border Style="{StaticResource CardFrame}" Padding="16,14" Margin="0,0,0,4">
                    <VerticalStackLayout Spacing="0">
                        <Label Text="SENASTE 7 DAGARNA"
                               Style="{StaticResource SectionLabel}"
                               Margin="0,0,0,14"/>
                        <StackLayout BindableLayout.ItemsSource="{Binding MuscleScores}" Spacing="13">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="vm:MuscleScoreRow">
                                    <Grid ColumnDefinitions="72,*,36" ColumnSpacing="10">
                                        <Label Grid.Column="0"
                                               Text="{Binding Name}"
                                               FontFamily="BebasNeue" FontSize="14"
                                               CharacterSpacing="0.5"
                                               TextColor="{StaticResource ForgeText}"
                                               VerticalOptions="Center"/>
                                        <Grid Grid.Column="1" HeightRequest="4" VerticalOptions="Center">
                                            <BoxView BackgroundColor="{AppThemeBinding Light={StaticResource LightSurface2}, Dark={StaticResource ForgeSurface3}}" CornerRadius="2"
                                                     HorizontalOptions="Fill" VerticalOptions="Fill"/>
                                            <BoxView BackgroundColor="{StaticResource ForgeAccent}"
                                                     CornerRadius="2"
                                                     HorizontalOptions="Fill" VerticalOptions="Fill"
                                                     AnchorX="0" ScaleX="{Binding ScaleFraction}"/>
                                        </Grid>
                                        <Label Grid.Column="2"
                                               Text="{Binding ScoreText}"
                                               TextColor="{Binding ScoreColor}"
                                               FontFamily="BebasNeue" FontSize="15"
                                               HorizontalOptions="End"
                                               VerticalOptions="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </StackLayout>
                    </VerticalStackLayout>
                </Border>

                <ActivityIndicator IsRunning="{Binding IsLoading}"
                                   IsVisible="{Binding IsLoading}"
                                   HorizontalOptions="Center" Margin="20"/>

                <!-- Empty state -->
                <StackLayout IsVisible="{Binding HasNoTemplates}"
                             HorizontalOptions="Center" Spacing="10" Margin="0,80,0,0">
                    <Label Text="INGA MALLAR"
                           Style="{StaticResource DisplayLabel}" FontSize="22"
                           HorizontalOptions="Center" TextColor="{StaticResource ForgeMuted}"/>
                    <Label Text="Skapa mallar under Bibliotek → Mallar"
                           Style="{StaticResource MutedLabel}"
                           HorizontalOptions="Center" HorizontalTextAlignment="Center"/>
                </StackLayout>

                <!-- Program groups -->
                <Label Text="PROGRAM" Style="{StaticResource SectionLabel}"
                       IsVisible="{Binding HasProgramGroups}" Margin="4,0,4,8"/>

                <StackLayout BindableLayout.ItemsSource="{Binding ProgramGroups}"
                             Spacing="10" Margin="0,0,0,16"
                             IsVisible="{Binding HasProgramGroups}">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="vm:ProgramGroup">
                            <Border Style="{StaticResource CardFrame}">
                                <StackLayout Spacing="0">
                                    <!-- Program header -->
                                    <Grid ColumnDefinitions="4,*">
                                        <BoxView Grid.Column="0"
                                                 BackgroundColor="{StaticResource ForgeAccent}"
                                                 CornerRadius="16,0,0,16"/>
                                        <Grid Grid.Column="1" ColumnDefinitions="*,Auto"
                                              Padding="14,14,16,14">
                                            <StackLayout Grid.Column="0" Spacing="2" VerticalOptions="Center">
                                                <Label Text="{Binding ProgramName}"
                                                       FontFamily="BebasNeue" FontSize="20" CharacterSpacing="1"/>
                                                <Label Text="{Binding TemplateCount, StringFormat='{0} PASS'}"
                                                       Style="{StaticResource SectionLabel}" FontSize="10"/>
                                            </StackLayout>
                                            <Label Grid.Column="1" Text="{Binding ChevronIcon}"
                                                   FontSize="20" TextColor="{StaticResource ForgeMuted}"
                                                   VerticalOptions="Center"/>
                                        </Grid>
                                    </Grid>
                                    <!-- Template list (expandable) -->
                                    <StackLayout IsVisible="{Binding IsExpanded}" Spacing="0">
                                        <BoxView BackgroundColor="{StaticResource ForgeBorder}" HeightRequest="1"/>
                                        <StackLayout BindableLayout.ItemsSource="{Binding Templates}" Spacing="0">
                                            <BindableLayout.ItemTemplate>
                                                <DataTemplate x:DataType="models:WorkoutTemplate">
                                                    <Grid ColumnDefinitions="*,Auto"
                                                          Padding="14,10,12,10">
                                                        <Label Grid.Column="0" Text="{Binding Name}"
                                                               FontFamily="DMSansMedium" FontSize="14"
                                                               VerticalOptions="Center"/>
                                                        <Button Grid.Column="1"
                                                                ImageSource="ic_play.png" Text=""
                                                                Style="{StaticResource PrimaryButton}"
                                                                HeightRequest="36" WidthRequest="44" Padding="9"
                                                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:TrainViewModel}}, Path=StartWorkoutCommand}"
                                                                CommandParameter="{Binding .}"/>
                                                    </Grid>
                                                </DataTemplate>
                                            </BindableLayout.ItemTemplate>
                                        </StackLayout>
                                    </StackLayout>
                                </StackLayout>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:TrainViewModel}}, Path=ToggleProgramGroupCommand}"
                                        CommandParameter="{Binding .}"/>
                                </Border.GestureRecognizers>
                            </Border>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </StackLayout>

                <!-- Free templates -->
                <Label Text="MINA MALLAR" Style="{StaticResource SectionLabel}" Margin="4,0,4,8"/>

                <StackLayout BindableLayout.ItemsSource="{Binding FreeTemplates}" Spacing="10">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="models:WorkoutTemplate">
                            <SwipeView>
                                <SwipeView.RightItems>
                                    <SwipeItems>
                                        <SwipeItem Text="Ta bort"
                                                   BackgroundColor="{StaticResource ForgeDestructive}"
                                                   Command="{Binding Source={RelativeSource AncestorType={x:Type vm:TrainViewModel}}, Path=DeleteTemplateCommand}"
                                                   CommandParameter="{Binding .}"/>
                                    </SwipeItems>
                                </SwipeView.RightItems>
                                <Border Style="{StaticResource CardFrame}">
                                    <Grid ColumnDefinitions="4,*">
                                        <BoxView Grid.Column="0"
                                                 BackgroundColor="{StaticResource ForgeAccent}"
                                                 CornerRadius="16,0,0,16"/>
                                        <Grid Grid.Column="1" ColumnDefinitions="*,Auto"
                                              Padding="14,16,16,16">
                                            <StackLayout Grid.Column="0" Spacing="3" VerticalOptions="Center">
                                                <Label Text="{Binding Name}"
                                                       FontFamily="BebasNeue" FontSize="22" CharacterSpacing="1"/>
                                                <Label Text="TRYCK FÖR ATT STARTA"
                                                       Style="{StaticResource SectionLabel}" FontSize="10"/>
                                            </StackLayout>
                                            <Image Grid.Column="1"
                                                   Source="ic_play.png"
                                                   WidthRequest="18" HeightRequest="18"
                                                   VerticalOptions="Center"/>
                                        </Grid>
                                    </Grid>
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Tapped="OnTemplateTapped"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:TrainViewModel}}, Path=StartWorkoutCommand}"
                                            CommandParameter="{Binding .}"/>
                                    </Border.GestureRecognizers>
                                </Border>
                            </SwipeView>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </StackLayout>

            </StackLayout>
        </ScrollView>

        <!-- Floating FAB: starta fritt pass -->
        <Button Grid.Row="1"
                Text="FRITT PASS"
                ImageSource="ic_play.png"
                ContentLayout="Left, 8"
                Style="{StaticResource PrimaryButton}"
                HorizontalOptions="End"
                VerticalOptions="End"
                Margin="0,0,20,44"
                HeightRequest="48"
                WidthRequest="162"
                CornerRadius="24"
                Command="{Binding StartFreeWorkoutCommand}"/>

    </Grid>
</ContentPage>
