<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:LockIn.ViewModels"
             xmlns:models="clr-namespace:LockIn.Models"
             xmlns:views="clr-namespace:LockIn.Views"
             xmlns:controls="clr-namespace:LockIn.Controls"
             xmlns:loc="clr-namespace:LockIn.Resources.Strings"
             xmlns:ios="clr-namespace:Microsoft.Maui.Controls.PlatformConfiguration.iOSSpecific;assembly=Microsoft.Maui.Controls"
             x:Class="LockIn.Views.TrainPage"
             x:DataType="vm:TrainViewModel"
             Title="{loc:Localize Train_PageTitle}"
             Shell.NavBarIsVisible="False"
             BackgroundColor="Transparent">

    <Grid SafeAreaEdges="None">

        <!-- Atmosf�risk bakgrund � renderas under allt annat -->
        <controls:AtmosphericBackgroundView InputTransparent="True"/>

        <!-- Permanent status bar gradient (alltid synlig, fyller Dynamic Island-zonen) -->
        <BoxView VerticalOptions="Start" HeightRequest="90" InputTransparent="True" ZIndex="19">
            <BoxView.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="{AppThemeBinding Light=#28FCFCFC, Dark=#28141418}" Offset="0.0"/>
                    <GradientStop Color="{AppThemeBinding Light=#00FCFCFC, Dark=#00141418}" Offset="1.0"/>
                </LinearGradientBrush>
            </BoxView.Background>
        </BoxView>

        <!-- Sticky header (fades in on scroll) -->
        <Grid x:Name="StickyHeader" VerticalOptions="Start" ZIndex="20" Opacity="0"
              HeightRequest="150" SafeAreaEdges="None">
            <BoxView InputTransparent="True">
                <BoxView.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="{AppThemeBinding Light=#D8FCFCFC, Dark=#D8141418}" Offset="0.0"/>
                        <GradientStop Color="{AppThemeBinding Light=#90FCFCFC, Dark=#90141418}" Offset="0.35"/>
                        <GradientStop Color="{AppThemeBinding Light=#38FCFCFC, Dark=#38141418}" Offset="0.65"/>
                        <GradientStop Color="{AppThemeBinding Light=#00FCFCFC, Dark=#00141418}" Offset="1.0"/>
                    </LinearGradientBrush>
                </BoxView.Background>
            </BoxView>
            <Label Text="{loc:Localize Train_PageTitle}"
                   Padding="20,14,20,12"
                   Style="{StaticResource DisplayLabel}" FontSize="18"
                   HorizontalOptions="Fill" HorizontalTextAlignment="Center"
                   VerticalOptions="Start"/>
        </Grid>

        <!-- Content -->
        <ScrollView VerticalScrollBarVisibility="Never" Scrolled="OnScrolled">
            <StackLayout Padding="16,56,16,120" Spacing="0">

                <!-- Page title (visible at top, scrolls away before sticky header appears) -->
                <Label Text="{loc:Localize Train_PageTitle}"
                       FontFamily="BebasNeue" FontSize="34" CharacterSpacing="1"
                       TextColor="{AppThemeBinding Light={StaticResource LightText}, Dark={StaticResource ForgeText}}"
                       Margin="4,0,0,8"/>

                <!-- Stats row -->
                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8" Margin="0,0,0,16">
                    <Border Grid.Column="0" Style="{StaticResource CardFrame}" Padding="14,12">
                        <StackLayout Spacing="2">
                            <views:AppIcon Source="ic_calendar.png" WidthRequest="16" HeightRequest="16"
                                          HorizontalOptions="Start" Margin="0,0,0,2"
                                          ForceTint="{StaticResource ForgeAccentBlue}"/>
                            <Label Text="{Binding WeekCount}"
                                   FontSize="28" FontAttributes="Bold"
                                   TextColor="{StaticResource ForgeAccentBlue}"/>
                            <Label Text="{loc:Localize Train_ThisWeek}" Style="{StaticResource SectionLabel}" FontSize="9"/>
                        </StackLayout>
                    </Border>
                    <Border Grid.Column="1" Style="{StaticResource CardFrame}" Padding="14,12">
                        <StackLayout Spacing="2">
                            <views:AppIcon Source="ic_flame.png" WidthRequest="16" HeightRequest="16"
                                          HorizontalOptions="Start" Margin="0,0,0,2"
                                          ForceTint="{StaticResource ForgeAccentAmber}"/>
                            <Label Text="{Binding Streak}"
                                   FontSize="28" FontAttributes="Bold"
                                   TextColor="{StaticResource ForgeAccentAmber}"/>
                            <Label Text="{loc:Localize Train_DaysStreak}" Style="{StaticResource SectionLabel}" FontSize="9"/>
                        </StackLayout>
                    </Border>
                    <Border Grid.Column="2" Style="{StaticResource CardFrame}" Padding="14,12">
                        <StackLayout Spacing="2">
                            <views:AppIcon Source="ic_barbell.png" WidthRequest="16" HeightRequest="16"
                                          HorizontalOptions="Start" Margin="0,0,0,2"
                                          ForceTint="{StaticResource ForgeAccentPurple}"/>
                            <Label Text="{Binding TotalCount}"
                                   FontSize="28" FontAttributes="Bold"
                                   TextColor="{StaticResource ForgeAccentPurple}"/>
                            <Label Text="{loc:Localize Train_TotalSessions}" Style="{StaticResource SectionLabel}" FontSize="9"/>
                        </StackLayout>
                    </Border>
                </Grid>

                <!-- Deload banner -->
                <Border IsVisible="{Binding ShowDeloadBanner}"
                        BackgroundColor="{StaticResource ForgeAccentDim}"
                        StrokeShape="RoundRectangle 12"
                        StrokeThickness="1"
                        Stroke="{StaticResource ForgeAccent}"
                        Padding="14,12" Margin="0,0,0,4">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                        <StackLayout Grid.Column="0" Spacing="2" VerticalOptions="Center">
                            <Label Text="{loc:Localize Train_Deload_Title}"
                                   FontFamily="BebasNeue" FontSize="15"
                                   CharacterSpacing="0.5"
                                   TextColor="{StaticResource ForgeAccent}"/>
                            <Label Text="{loc:Localize Train_Deload_Body}"
                                   Style="{StaticResource MutedLabel}"
                                   FontSize="12"
                                   LineBreakMode="WordWrap"/>
                        </StackLayout>
                        <Label Grid.Column="1" Text="?"
                               FontSize="16"
                               TextColor="{StaticResource ForgeMuted}"
                               VerticalOptions="Center">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding DismissDeloadCommand}"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </Grid>
                </Border>

                <!-- Muskelpo�ng: Senaste 7 dagarna -->
                <Border Style="{StaticResource CardFrame}" Padding="16,14" Margin="0,0,0,4">
                    <VerticalStackLayout Spacing="0">
                        <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,14">
                            <Label Text="{loc:Localize Train_Volume_Title}"
                                   Style="{StaticResource SectionLabel}"/>
                            <Label Grid.Column="1" Text="{loc:Localize Train_Volume_Max}"
                                   Style="{StaticResource SectionLabel}"
                                   TextColor="{StaticResource ForgeMuted}"/>
                        </Grid>
                        <StackLayout BindableLayout.ItemsSource="{Binding MuscleScores}" Spacing="13">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="vm:MuscleScoreRow">
                                    <Grid ColumnDefinitions="72,*,36" ColumnSpacing="10">
                                        <Label Grid.Column="0"
                                               Text="{Binding Name}"
                                               FontFamily="BebasNeue" FontSize="14"
                                               CharacterSpacing="0.5"
                                               TextColor="{StaticResource ForgeText}"
                                               VerticalOptions="Center"/>
                                        <Grid Grid.Column="1" HeightRequest="4" VerticalOptions="Center">
                                            <BoxView BackgroundColor="{AppThemeBinding Light={StaticResource LightSurface2}, Dark={StaticResource ForgeSurface3}}" CornerRadius="2"
                                                     HorizontalOptions="Fill" VerticalOptions="Fill"/>
                                            <BoxView BackgroundColor="{StaticResource ForgeAccent}"
                                                     CornerRadius="2"
                                                     HorizontalOptions="Fill" VerticalOptions="Fill"
                                                     AnchorX="0" ScaleX="{Binding ScaleFraction}"
                                                     Loaded="OnMuscleBarLoaded"/>
                                        </Grid>
                                        <Label Grid.Column="2"
                                               Text="{Binding ScoreText}"
                                               TextColor="{Binding ScoreColor}"
                                               FontFamily="BebasNeue" FontSize="15"
                                               HorizontalOptions="End"
                                               VerticalOptions="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </StackLayout>
                    </VerticalStackLayout>
                </Border>

                <ActivityIndicator IsRunning="{Binding IsLoading}"
                                   IsVisible="{Binding IsLoading}"
                                   HorizontalOptions="Center" Margin="20"/>

                <!-- Empty state -->
                <StackLayout IsVisible="{Binding HasNoTemplates}"
                             HorizontalOptions="Center" Spacing="10" Margin="0,80,0,0">
                    <Label Text="{loc:Localize Train_NoTemplates_Title}"
                           Style="{StaticResource DisplayLabel}" FontSize="22"
                           HorizontalOptions="Center" TextColor="{StaticResource ForgeMuted}"/>
                    <Label Text="{loc:Localize Train_NoTemplates_Body}"
                           Style="{StaticResource MutedLabel}"
                           HorizontalOptions="Center" HorizontalTextAlignment="Center"/>
                </StackLayout>

                <!-- Program groups -->
                <Label Text="{loc:Localize Train_Programs_Section}" Style="{StaticResource SectionLabel}"
                       IsVisible="{Binding HasProgramGroups}" Margin="4,0,4,8"/>

                <StackLayout BindableLayout.ItemsSource="{Binding ProgramGroups}"
                             Spacing="10" Margin="0,0,0,16"
                             IsVisible="{Binding HasProgramGroups}">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="vm:ProgramGroup">
                            <Border BackgroundColor="{AppThemeBinding Light={StaticResource LightSurface}, Dark={StaticResource ForgeSurface}}"
                                    StrokeShape="RoundRectangle 18"
                                    StrokeThickness="0"
                                    Padding="0">
                                <Border.Shadow>
                                    <Shadow Brush="Black" Offset="0,2" Radius="10" Opacity="0.18"/>
                                </Border.Shadow>
                                <StackLayout Spacing="0">
                                    <!-- Program header -->
                                    <Grid ColumnDefinitions="12,*,Auto" ColumnSpacing="12"
                                          Padding="18,14">
                                        <Ellipse Grid.Column="0"
                                                 WidthRequest="10" HeightRequest="10"
                                                 Fill="{StaticResource ForgeAccentPurple}"
                                                 VerticalOptions="Center"/>
                                        <StackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                            <Label Text="{Binding ProgramName}"
                                                   FontFamily="BebasNeue" FontSize="20" CharacterSpacing="1"/>
                                            <Label Text="{Binding TemplateCountText}"
                                                   Style="{StaticResource SectionLabel}" FontSize="10"/>
                                        </StackLayout>
                                        <Label Grid.Column="2" Text="{Binding ChevronIcon}"
                                               FontSize="20" TextColor="{StaticResource ForgeMuted}"
                                               VerticalOptions="Center"/>
                                    </Grid>
                                    <!-- Template list (expandable) -->
                                    <StackLayout IsVisible="{Binding IsExpanded}" Spacing="0">
                                        <BoxView BackgroundColor="{StaticResource ForgeBorder}" HeightRequest="1"/>
                                        <StackLayout BindableLayout.ItemsSource="{Binding Templates}" Spacing="0">
                                            <BindableLayout.ItemTemplate>
                                                <DataTemplate x:DataType="models:WorkoutTemplate">
                                                    <Grid ColumnDefinitions="*,Auto"
                                                          Padding="14,10,12,10">
                                                        <Grid.GestureRecognizers>
                                                            <TapGestureRecognizer
                                                                Tapped="OnTemplateTapped"
                                                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:TrainViewModel}}, Path=StartWorkoutCommand}"
                                                                CommandParameter="{Binding .}"/>
                                                        </Grid.GestureRecognizers>
                                                        <StackLayout Grid.Column="0" Spacing="2" VerticalOptions="Center">
                                                            <Label Text="{Binding Name}"
                                                                   FontFamily="DMSansMedium" FontSize="14"/>
                                                            <Label Text="{Binding LastUsedText}"
                                                                   Style="{StaticResource SectionLabel}" FontSize="9"/>
                                                        </StackLayout>
                                                        <Border Grid.Column="2"
                                                                WidthRequest="44" HeightRequest="44"
                                                                BackgroundColor="Transparent"
                                                                StrokeShape="Ellipse" StrokeThickness="0"
                                                                VerticalOptions="Center"
                                                                HorizontalOptions="Center">
                                                            <Border WidthRequest="36" HeightRequest="36"
                                                                    BackgroundColor="{StaticResource ForgeAccentPurple}"
                                                                    StrokeShape="Ellipse" StrokeThickness="0"
                                                                    HorizontalOptions="Center"
                                                                    VerticalOptions="Center">
                                                                <views:AppIcon Source="ic_play.png"
                                                                               WidthRequest="18" HeightRequest="18"
                                                                               ForceTint="White"
                                                                               HorizontalOptions="Center"
                                                                               VerticalOptions="Center"/>
                                                            </Border>
                                                        </Border>
                                                    </Grid>
                                                </DataTemplate>
                                            </BindableLayout.ItemTemplate>
                                        </StackLayout>
                                    </StackLayout>
                                </StackLayout>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Tapped="OnProgramTapped"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:TrainViewModel}}, Path=ToggleProgramGroupCommand}"
                                        CommandParameter="{Binding .}"/>
                                </Border.GestureRecognizers>
                            </Border>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </StackLayout>

                <!-- Free templates -->
                <Label Text="{loc:Localize Train_MyTemplates}"
                       Style="{StaticResource SectionLabel}"
                       Margin="4,0,4,8"
                       IsVisible="{Binding FreeTemplates.Count, Converter={x:Static vm:GreaterThanZeroConverter.Instance}}"/>

                <StackLayout BindableLayout.ItemsSource="{Binding FreeTemplates}" Spacing="10">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="models:WorkoutTemplate">
                            <SwipeView>
                                <SwipeView.RightItems>
                                    <SwipeItems>
                                        <SwipeItem Text="{loc:Localize Common_Delete}"
                                                   BackgroundColor="{StaticResource ForgeDestructive}"
                                                   Command="{Binding Source={RelativeSource AncestorType={x:Type vm:TrainViewModel}}, Path=DeleteTemplateCommand}"
                                                   CommandParameter="{Binding .}"/>
                                    </SwipeItems>
                                </SwipeView.RightItems>
                                <Border BackgroundColor="{AppThemeBinding Light={StaticResource LightSurface}, Dark={StaticResource ForgeSurface}}"
                                        StrokeShape="RoundRectangle 18"
                                        StrokeThickness="0"
                                        Padding="18,14,12,14">
                                    <Border.Shadow>
                                        <Shadow Brush="Black" Offset="0,2" Radius="10" Opacity="0.18"/>
                                    </Border.Shadow>
                                    <Grid ColumnDefinitions="12,*,Auto" ColumnSpacing="12">
                                        <Ellipse Grid.Column="0"
                                                 WidthRequest="10" HeightRequest="10"
                                                 Fill="{StaticResource ForgeAccentCoral}"
                                                 VerticalOptions="Center"/>
                                        <StackLayout Grid.Column="1" Spacing="3" VerticalOptions="Center">
                                            <Label Text="{Binding Name}"
                                                   FontFamily="BebasNeue" FontSize="22" CharacterSpacing="1"/>
                                            <Label Text="{Binding LastUsedText}"
                                                   Style="{StaticResource SectionLabel}" FontSize="10"/>
                                        </StackLayout>
                                        <Border Grid.Column="2"
                                                WidthRequest="36" HeightRequest="36"
                                                BackgroundColor="{StaticResource ForgeAccentCoral}"
                                                StrokeShape="Ellipse" StrokeThickness="0"
                                                VerticalOptions="Center">
                                            <views:AppIcon Source="ic_play.png"
                                                           WidthRequest="18" HeightRequest="18"
                                                           ForceTint="White"
                                                           HorizontalOptions="Center"
                                                           VerticalOptions="Center"/>
                                        </Border>
                                    </Grid>
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Tapped="OnTemplateTapped"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:TrainViewModel}}, Path=StartWorkoutCommand}"
                                            CommandParameter="{Binding .}"/>
                                    </Border.GestureRecognizers>
                                </Border>
                            </SwipeView>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </StackLayout>

            </StackLayout>
        </ScrollView>

        <!-- Cardio-shortcut -->
        <Border StrokeShape="RoundRectangle 28" StrokeThickness="1"
                Stroke="{StaticResource ForgeBorder}"
                BackgroundColor="{StaticResource ForgeSurface}"
                HorizontalOptions="Start" VerticalOptions="End"
                Margin="18,0,0,100"
                HeightRequest="56" Padding="20,0"
                ZIndex="30">
            <HorizontalStackLayout Spacing="8" HorizontalOptions="Center" VerticalOptions="Center">
                <Label Text="?" FontSize="16" TextColor="{StaticResource ForgeAccentCoral}"
                       VerticalOptions="Center"/>
                <Label Text="{loc:Localize TrainPage_Cardio_Button}"
                       FontFamily="BebasNeue" FontSize="17" CharacterSpacing="2"
                       TextColor="{StaticResource ForgeText}" VerticalOptions="Center"/>
            </HorizontalStackLayout>
            <Border.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding OpenCardioCommand}"/>
            </Border.GestureRecognizers>
        </Border>

        <!-- Floating FAB: starta fritt pass � premium pill -->
        <!-- ZIndex 30 = ovanf�r bottom-gradient (22) s� den inte m�rkas -->
        <!-- Metallisk silver-gradient direkt p� Border.Background (klipps av StrokeShape) -->
        <!-- ist�llet f�r en separat highlight-BoxView som syns som fyrkant igenom rundningen. -->
        <Border x:Name="FrittPassButton"
                StrokeShape="RoundRectangle 28" StrokeThickness="0"
                HorizontalOptions="End" VerticalOptions="End"
                Margin="0,0,18,100"
                HeightRequest="56" WidthRequest="180"
                Padding="20,0"
                ZIndex="30">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#FAFAFA" Offset="0.0"/>
                    <GradientStop Color="#E5E5E8" Offset="0.25"/>
                    <GradientStop Color="#B8B8BC" Offset="0.60"/>
                    <GradientStop Color="#7A7A80" Offset="1.0"/>
                </LinearGradientBrush>
            </Border.Background>
            <Border.Shadow>
                <Shadow Brush="#B8B8BC" Offset="0,6" Radius="28" Opacity="0.45"/>
            </Border.Shadow>
            <HorizontalStackLayout Spacing="10" HorizontalOptions="Center" VerticalOptions="Center">
                <views:AppIcon Source="ic_play.png"
                               WidthRequest="18" HeightRequest="18"
                               ForceTint="{StaticResource ForgeFabForeground}"
                               VerticalOptions="Center"/>
                <Label Text="{loc:Localize Train_FreeWorkout}"
                       FontFamily="BebasNeue" FontSize="17" CharacterSpacing="2"
                       TextColor="{StaticResource ForgeFabForeground}" VerticalOptions="Center"/>
            </HorizontalStackLayout>
            <Border.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding StartFreeWorkoutCommand}" Tapped="OnFabTapped"/>
            </Border.GestureRecognizers>
        </Border>
        <!-- = WORKOUT BANNER � Live Forge Capsule = -->
        <Grid x:Name="WorkoutBanner"
              IsVisible="False"
              VerticalOptions="End"
              HorizontalOptions="Center"
              Margin="0,0,0,96"
              ZIndex="10">
            <Border StrokeThickness="0"
                    StrokeShape="RoundRectangle 36"
                    BackgroundColor="{StaticResource ForgeAccentGlow}"
                    Margin="-18,-14"
                    InputTransparent="True"/>
            <Border StrokeThickness="1"
                    Stroke="#55B8B8BC"
                    StrokeShape="RoundRectangle 22"
                    Padding="16,9,18,10">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#26262E" Offset="0"/>
                        <GradientStop Color="#18181C" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,6" Radius="22" Opacity="0.55"/>
                </Border.Shadow>
                <HorizontalStackLayout Spacing="11" VerticalOptions="Center">
                    <controls:ForgeLiveDotView x:Name="BannerPulseRing"
                                               VerticalOptions="Center"/>
                    <Label Text="{loc:Localize Hem_WorkoutBanner_Label}"
                           FontFamily="BebasNeue" FontSize="13" CharacterSpacing="3"
                           TextColor="{StaticResource ForgeText}"
                           VerticalOptions="Center"/>
                    <Path Style="{StaticResource ForwardChevron}"
                          Stroke="{StaticResource ForgeAccent}"/>
                </HorizontalStackLayout>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnWorkoutBannerTapped"/>
                </Border.GestureRecognizers>
            </Border>
        </Grid>

    <!-- Bottom gradient fade behind floating tab bar � matchar topp-gradienten spegelv�nt -->
    <BoxView Grid.RowSpan="99" InputTransparent="True" VerticalOptions="End" HeightRequest="150">
        <BoxView.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="{AppThemeBinding Light=#00FCFCFC, Dark=#00141418}" Offset="0.0"/>
                <GradientStop Color="{AppThemeBinding Light=#38FCFCFC, Dark=#38141418}" Offset="0.35"/>
                <GradientStop Color="{AppThemeBinding Light=#90FCFCFC, Dark=#90141418}" Offset="0.65"/>
                <GradientStop Color="{AppThemeBinding Light=#FCFCFC, Dark=#141418}" Offset="1.0"/>
            </LinearGradientBrush>
        </BoxView.Background>
    </BoxView>

    </Grid>
</ContentPage>