<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:LockIn.ViewModels"
             xmlns:controls="clr-namespace:LockIn.Controls"
             xmlns:loc="clr-namespace:LockIn.Resources.Strings"
             x:Class="LockIn.Views.PlateCalculatorPage"
             x:DataType="vm:PlateCalculatorViewModel"
             xmlns:ios="clr-namespace:Microsoft.Maui.Controls.PlatformConfiguration.iOSSpecific;assembly=Microsoft.Maui.Controls"
             Shell.NavBarIsVisible="False"
             Shell.TabBarIsVisible="False"
             BackgroundColor="Transparent"
             ios:Page.UseSafeArea="False">

    <Grid RowDefinitions="Auto,*" SafeAreaEdges="None">

        <!-- Atmosfärisk bakgrund -->
        <controls:AtmosphericBackgroundView Grid.RowSpan="2" InputTransparent="True"/>

        <!-- Header -->
        <Grid Grid.Row="0" Padding="16,56,16,8" ColumnDefinitions="Auto,*">
            <Border Grid.Column="0"
                    WidthRequest="36" HeightRequest="36"
                    StrokeShape="Ellipse"
                    BackgroundColor="{AppThemeBinding Light=#1A000000, Dark=#17FFFFFF}"
                    Stroke="{AppThemeBinding Light=#0D000000, Dark=#29FFFFFF}"
                    StrokeThickness="0.5"
                    VerticalOptions="Center">
                <Path Style="{StaticResource BackChevron}"/>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding GoBackCommand}"/>
                </Border.GestureRecognizers>
            </Border>
            <Label Grid.Column="1" Text="{loc:Localize PlateCalculator_Title}"
                   Style="{StaticResource DisplayLabel}"
                   FontSize="22"
                   HorizontalOptions="Center" VerticalOptions="Center"/>
        </Grid>

        <!-- Content -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="16,8,16,40" Spacing="14">

                <!-- Input card -->
                <Border Style="{StaticResource CardFrame}" Padding="16,14">
                    <VerticalStackLayout Spacing="16">

                        <!-- Målvikt -->
                        <VerticalStackLayout Spacing="6">
                            <Label Text="{loc:Localize PlateCalculator_TargetWeight}" Style="{StaticResource SectionLabel}"/>
                            <Border BackgroundColor="{StaticResource ForgeSurface2}"
                                    StrokeShape="RoundRectangle 10"
                                    StrokeThickness="0">
                                <Grid ColumnDefinitions="*,Auto" Padding="16,0,14,0">
                                    <Entry Grid.Column="0"
                                           Text="{Binding TargetWeightText}"
                                           Keyboard="Numeric"
                                           Placeholder="0"
                                           PlaceholderColor="{StaticResource ForgeTextSecondary}"
                                           FontSize="34" FontAttributes="Bold"
                                           BackgroundColor="Transparent"
                                           TextColor="{StaticResource ForgeText}"
                                           HeightRequest="62"/>
                                    <Label Grid.Column="1" Text="KG"
                                           FontFamily="BebasNeue" FontSize="18"
                                           TextColor="{StaticResource ForgeMuted}"
                                           VerticalOptions="Center"/>
                                </Grid>
                            </Border>
                        </VerticalStackLayout>

                        <!-- Separator -->
                        <BoxView BackgroundColor="{StaticResource ForgeBorder}"
                                 HeightRequest="1" Margin="0"/>

                        <!-- Stångvikt -->
                        <VerticalStackLayout Spacing="6">
                            <Label Text="{loc:Localize PlateCalculator_BarWeight}" Style="{StaticResource SectionLabel}"/>
                            <Border BackgroundColor="{StaticResource ForgeSurface2}"
                                    StrokeShape="RoundRectangle 10"
                                    StrokeThickness="0">
                                <Grid ColumnDefinitions="*,Auto" Padding="16,0,14,0">
                                    <Entry Grid.Column="0"
                                           Text="{Binding BarWeightText}"
                                           Keyboard="Numeric"
                                           FontSize="34" FontAttributes="Bold"
                                           BackgroundColor="Transparent"
                                           TextColor="{StaticResource ForgeText}"
                                           HeightRequest="62"/>
                                    <Label Grid.Column="1" Text="KG"
                                           FontFamily="BebasNeue" FontSize="18"
                                           TextColor="{StaticResource ForgeMuted}"
                                           VerticalOptions="Center"/>
                                </Grid>
                            </Border>
                        </VerticalStackLayout>

                    </VerticalStackLayout>
                </Border>

                <!-- Calculate button -->
                <Button Text="{loc:Localize PlateCalculator_Calculate}"
                        Style="{StaticResource PrimaryButton}"
                        HeightRequest="52"
                        Command="{Binding CalculateCommand}"/>

                <!-- Result: barbell view -->
                <Border IsVisible="{Binding HasResult}"
                        BackgroundColor="{StaticResource ForgeSurface2}"
                        StrokeShape="RoundRectangle 16"
                        StrokeThickness="0"
                        Padding="0,16">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="{loc:Localize PlateCalculator_PerSide}"
                               Style="{StaticResource SectionLabel}"
                               TextColor="{StaticResource ForgeAccent}"
                               Margin="20,0"/>
                        <GraphicsView x:Name="BarbellView"
                                      HeightRequest="160"/>
                        <Label x:Name="ResultLabel"
                               Text="{Binding ResultText}"
                               FontFamily="BebasNeue" FontSize="18"
                               TextColor="{StaticResource ForgeTextSecondary}"
                               HorizontalTextAlignment="Center"
                               Margin="20,0"/>
                    </VerticalStackLayout>
                </Border>

                <!-- Plate reference chips -->
                <Border Style="{StaticResource CardFrame}" Padding="16,14">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="{loc:Localize PlateCalculator_AvailablePlates}" Style="{StaticResource SectionLabel}"/>
                        <Grid ColumnDefinitions="*,*,*,*" RowDefinitions="Auto,Auto"
                              ColumnSpacing="8" RowSpacing="8">
                            <Border Grid.Row="0" Grid.Column="0"
                                    BackgroundColor="{StaticResource ForgeSurface2}"
                                    StrokeShape="RoundRectangle 8" StrokeThickness="0" Padding="0,10">
                                <Label Text="25 kg" FontFamily="BebasNeue" FontSize="17"
                                       TextColor="{StaticResource ForgeAccent}"
                                       HorizontalOptions="Center"/>
                            </Border>
                            <Border Grid.Row="0" Grid.Column="1"
                                    BackgroundColor="{StaticResource ForgeSurface2}"
                                    StrokeShape="RoundRectangle 8" StrokeThickness="0" Padding="0,10">
                                <Label Text="20 kg" FontFamily="BebasNeue" FontSize="17"
                                       TextColor="{StaticResource ForgeAccent}"
                                       HorizontalOptions="Center"/>
                            </Border>
                            <Border Grid.Row="0" Grid.Column="2"
                                    BackgroundColor="{StaticResource ForgeSurface2}"
                                    StrokeShape="RoundRectangle 8" StrokeThickness="0" Padding="0,10">
                                <Label Text="15 kg" FontFamily="BebasNeue" FontSize="17"
                                       TextColor="{StaticResource ForgeAccent}"
                                       HorizontalOptions="Center"/>
                            </Border>
                            <Border Grid.Row="0" Grid.Column="3"
                                    BackgroundColor="{StaticResource ForgeSurface2}"
                                    StrokeShape="RoundRectangle 8" StrokeThickness="0" Padding="0,10">
                                <Label Text="10 kg" FontFamily="BebasNeue" FontSize="17"
                                       TextColor="{StaticResource ForgeAccent}"
                                       HorizontalOptions="Center"/>
                            </Border>
                            <Border Grid.Row="1" Grid.Column="0"
                                    BackgroundColor="{StaticResource ForgeSurface2}"
                                    StrokeShape="RoundRectangle 8" StrokeThickness="0" Padding="0,10">
                                <Label Text="5 kg" FontFamily="BebasNeue" FontSize="17"
                                       TextColor="{StaticResource ForgeMuted}"
                                       HorizontalOptions="Center"/>
                            </Border>
                            <Border Grid.Row="1" Grid.Column="1"
                                    BackgroundColor="{StaticResource ForgeSurface2}"
                                    StrokeShape="RoundRectangle 8" StrokeThickness="0" Padding="0,10">
                                <Label Text="2.5 kg" FontFamily="BebasNeue" FontSize="17"
                                       TextColor="{StaticResource ForgeMuted}"
                                       HorizontalOptions="Center"/>
                            </Border>
                            <Border Grid.Row="1" Grid.Column="2"
                                    BackgroundColor="{StaticResource ForgeSurface2}"
                                    StrokeShape="RoundRectangle 8" StrokeThickness="0" Padding="0,10">
                                <Label Text="1.25 kg" FontFamily="BebasNeue" FontSize="17"
                                       TextColor="{StaticResource ForgeMuted}"
                                       HorizontalOptions="Center"/>
                            </Border>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>

</ContentPage>
