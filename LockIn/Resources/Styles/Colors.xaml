<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Forge dark palette — pure black foundation -->
    <Color x:Key="ForgeBackground">#080808</Color>
    <Color x:Key="ForgeSurface">#111111</Color>
    <Color x:Key="ForgeSurface2">#1A1A1A</Color>
    <Color x:Key="ForgeSurface3">#222222</Color>
    <Color x:Key="ForgeAccent">#FF5A1F</Color>
    <Color x:Key="ForgeAccentDim">#1FFF5A1F</Color>
    <Color x:Key="ForgeAccentGlow">#0FFF5A1F</Color>
    <Color x:Key="ForgeText">#F0F0F0</Color>
    <Color x:Key="ForgeTextSecondary">#A0A0A8</Color>
    <Color x:Key="ForgeMuted">#484850</Color>
    <Color x:Key="ForgeBorder">#222224</Color>
    <Color x:Key="ForgeBorderLight">#303035</Color>
    <Color x:Key="ForgeSuccess">#4ADE80</Color>
    <Color x:Key="ForgeSuccessDim">#1F4ADE80</Color>
    <Color x:Key="ForgeDestructive">#FF3B30</Color>

    <!-- Light mode -->
    <Color x:Key="LightBackground">#F2F2F7</Color>
    <Color x:Key="LightSurface">#FFFFFF</Color>
    <Color x:Key="LightSurface2">#EBEBF0</Color>
    <Color x:Key="LightText">#0D0D0D</Color>
    <Color x:Key="LightMuted">#8E8E93</Color>
    <Color x:Key="LightBorder">#DCDCE0</Color>

    <SolidColorBrush x:Key="ForgeAccentBrush" Color="{StaticResource ForgeAccent}" />
    <SolidColorBrush x:Key="ForgeSurfaceBrush" Color="{StaticResource ForgeSurface}" />
    <SolidColorBrush x:Key="ForgeBorderBrush" Color="{StaticResource ForgeBorder}" />

</ResourceDictionary>
