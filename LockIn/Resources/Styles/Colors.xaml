<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- ═══ Dark palette ═══ -->
    <Color x:Key="ForgeBackground">#0E0E10</Color>
    <Color x:Key="ForgeSurface">#161618</Color>
    <Color x:Key="ForgeSurface2">#222228</Color>
    <Color x:Key="ForgeSurface3">#2E2E36</Color>

    <!-- Accent: ring / highlight color — silver, matchar logo -->
    <Color x:Key="ForgeAccent">#B8B8BC</Color>
    <!-- Primary: button background in dark mode (dark silver) -->
    <Color x:Key="ForgePrimary">#3E3E44</Color>
    <!-- Text on primary buttons in dark mode -->
    <Color x:Key="ForgePrimaryForeground">#FAFAFA</Color>

    <!-- Tinted accent surfaces -->
    <Color x:Key="ForgeAccentDim">#1FB8B8BC</Color>
    <Color x:Key="ForgeAccentGlow">#0FB8B8BC</Color>

    <Color x:Key="ForgeText">#E2E8F0</Color>
    <Color x:Key="ForgeTextSecondary">#A2A2A2</Color>
    <Color x:Key="ForgeMuted">#A2A2A2</Color>    <!-- intentional alias of ForgeTextSecondary -->
    <Color x:Key="ForgeBorder">#252530</Color>
    <Color x:Key="ForgeBorderLight">#323240</Color>

    <!-- Icon tinting — apply as TintColor on PNG icons -->
    <Color x:Key="ForgeIconTint">#C8C8D2</Color>
    <Color x:Key="LightIconTint">#3A3A44</Color>

    <!-- Multi-accent palette for data cards -->
    <Color x:Key="ForgeAccentCoral">#FB7185</Color>
    <Color x:Key="ForgeAccentBlue">#38BDF8</Color>
    <Color x:Key="ForgeAccentPurple">#A78BFA</Color>
    <Color x:Key="ForgeAccentAmber">#FBBF24</Color>
    <Color x:Key="ForgeAccentAmberDim">#1FFBBF24</Color>
    <Color x:Key="ForgeAccentOrange">#FB923C</Color>
    <Color x:Key="ForgeAccentOrangeDim">#1FFB923C</Color>

    <!-- Dim versions for card backgrounds / fills -->
    <Color x:Key="ForgeAccentCoralDim">#1FFB7185</Color>
    <Color x:Key="ForgeAccentBlueDim">#1F38BDF8</Color>
    <Color x:Key="ForgeAccentPurpleDim">#1FA78BFA</Color>

    <!-- Semantic alias of ForgeAccent — intentional, use when meaning is "success" not "brand" -->
    <Color x:Key="ForgeSuccess">#4ADE80</Color>
    <Color x:Key="ForgeSuccessDim">#1F4ADE80</Color>

    <Color x:Key="ForgeDestructive">#CA3214</Color>

    <!-- ═══ Light palette ═══ -->
    <Color x:Key="LightBackground">#FCFCFC</Color>
    <Color x:Key="LightSurface">#FFFFFF</Color>
    <Color x:Key="LightSurface2">#EDEDED</Color>
    <Color x:Key="LightText">#171717</Color>
    <Color x:Key="LightMuted">#606060</Color>
    <Color x:Key="LightBorder">#DFDFDF</Color>

    <!-- Accent / primary for light mode -->
    <Color x:Key="LightAccent">#9E9EA6</Color>
    <!-- Button background in light mode — mirrors ForgePrimary in dark -->
    <Color x:Key="LightPrimary">#3E3E44</Color>
    <!-- Text on primary buttons in light mode -->
    <Color x:Key="LightPrimaryForeground">#1E1E22</Color>

    <!-- Light multi-accent -->
    <Color x:Key="LightAccentCoral">#E11D48</Color>
    <Color x:Key="LightAccentBlue">#0284C7</Color>
    <Color x:Key="LightAccentPurple">#7C3AED</Color>

    <SolidColorBrush x:Key="ForgeAccentBrush" Color="{StaticResource ForgeAccent}" />
    <SolidColorBrush x:Key="ForgeSurfaceBrush" Color="{StaticResource ForgeSurface}" />
    <SolidColorBrush x:Key="ForgeBorderBrush" Color="{StaticResource ForgeBorder}" />

</ResourceDictionary>
