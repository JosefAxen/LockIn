<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Style TargetType="Page" ApplyToDerivedTypes="True">
        <Setter Property="Padding" Value="0"/>
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource LightBackground}, Dark={StaticResource ForgeBackground}}" />
    </Style>

    <Style TargetType="Shell" ApplyToDerivedTypes="True">
        <Setter Property="Shell.BackgroundColor" Value="{AppThemeBinding Light={StaticResource LightSurface}, Dark={StaticResource ForgeBackground}}" />
        <Setter Property="Shell.ForegroundColor" Value="{AppThemeBinding Light={StaticResource LightText}, Dark={StaticResource ForgeText}}" />
        <Setter Property="Shell.TitleColor" Value="{AppThemeBinding Light={StaticResource LightText}, Dark={StaticResource ForgeText}}" />
        <Setter Property="Shell.DisabledColor" Value="{AppThemeBinding Light={StaticResource LightMuted}, Dark={StaticResource ForgeMuted}}" />
        <Setter Property="Shell.UnselectedColor" Value="{AppThemeBinding Light={StaticResource LightMuted}, Dark={StaticResource ForgeTextSecondary}}" />
        <Setter Property="Shell.NavBarHasShadow" Value="False" />
        <Setter Property="Shell.TabBarBackgroundColor" Value="{AppThemeBinding Light={StaticResource LightSurface}, Dark={StaticResource ForgeSurface}}" />
        <Setter Property="Shell.TabBarForegroundColor" Value="{AppThemeBinding Light={StaticResource ForgeAccent}, Dark={StaticResource ForgeAccent}}" />
        <Setter Property="Shell.TabBarTitleColor" Value="{AppThemeBinding Light={StaticResource ForgeAccent}, Dark={StaticResource ForgeAccent}}" />
        <Setter Property="Shell.TabBarUnselectedColor" Value="{AppThemeBinding Light={StaticResource LightMuted}, Dark={StaticResource ForgeTextSecondary}}" />
    </Style>

    <!-- Base label -->
    <Style TargetType="Label">
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource LightText}, Dark={StaticResource ForgeText}}" />
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="FontFamily" Value="DMSansRegular" />
        <Setter Property="FontSize" Value="14" />
    </Style>

    <!-- Display: big Bebas titles -->
    <Style x:Key="DisplayLabel" TargetType="Label">
        <Setter Property="FontFamily" Value="BebasNeue" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource LightText}, Dark={StaticResource ForgeText}}" />
        <Setter Property="CharacterSpacing" Value="2" />
    </Style>

    <!-- Hero number: giant stat display -->
    <Style x:Key="HeroNumber" TargetType="Label">
        <Setter Property="FontFamily" Value="BebasNeue" />
        <Setter Property="FontSize" Value="44" />
        <Setter Property="CharacterSpacing" Value="1" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource LightText}, Dark={StaticResource ForgeText}}" />
        <Setter Property="LineHeight" Value="1" />
    </Style>

    <!-- Accent hero number: orange stat -->
    <Style x:Key="AccentHeroNumber" TargetType="Label" BasedOn="{StaticResource HeroNumber}">
        <Setter Property="TextColor" Value="{StaticResource ForgeAccent}" />
    </Style>

    <!-- Section header above content groups -->
    <Style x:Key="SectionLabel" TargetType="Label">
        <Setter Property="FontFamily" Value="BebasNeue" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="CharacterSpacing" Value="3" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource LightMuted}, Dark={StaticResource ForgeMuted}}" />
    </Style>

    <Style x:Key="MutedLabel" TargetType="Label">
        <Setter Property="FontFamily" Value="DMSansRegular" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource LightMuted}, Dark={StaticResource ForgeTextSecondary}}" />
    </Style>

    <Style x:Key="AccentLabel" TargetType="Label">
        <Setter Property="FontFamily" Value="DMSansMedium" />
        <Setter Property="TextColor" Value="{StaticResource ForgeAccent}" />
    </Style>

    <!-- Primary CTA button: pill shape, orange -->
    <Style x:Key="PrimaryButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource ForgeAccent}" />
        <Setter Property="TextColor" Value="White" />
        <Setter Property="FontFamily" Value="BebasNeue" />
        <Setter Property="FontSize" Value="20" />
        <Setter Property="CharacterSpacing" Value="3" />
        <Setter Property="CornerRadius" Value="26" />
        <Setter Property="HeightRequest" Value="56" />
        <Setter Property="BorderWidth" Value="0" />
        <Setter Property="Shadow">
            <Setter.Value>
                <Shadow Brush="#FF5A1F" Offset="0,4" Radius="20" Opacity="0.35" />
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SecondaryButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource LightSurface2}, Dark={StaticResource ForgeSurface2}}" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource LightText}, Dark={StaticResource ForgeText}}" />
        <Setter Property="FontFamily" Value="DMSansMedium" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="CornerRadius" Value="14" />
        <Setter Property="HeightRequest" Value="44" />
        <Setter Property="BorderWidth" Value="0" />
    </Style>

    <Style x:Key="DestructiveButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="TextColor" Value="{StaticResource ForgeDestructive}" />
        <Setter Property="FontFamily" Value="DMSansMedium" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="BorderWidth" Value="0" />
    </Style>

    <!-- Card with depth -->
    <Style x:Key="CardFrame" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource LightSurface}, Dark={StaticResource ForgeSurface}}" />
        <Setter Property="StrokeShape" Value="RoundRectangle 16" />
        <Setter Property="Stroke" Value="{AppThemeBinding Light={StaticResource LightBorder}, Dark={StaticResource ForgeBorderLight}}" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Shadow">
            <Setter.Value>
                <Shadow Brush="Black" Offset="0,3" Radius="12" Opacity="0.12" />
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Always-dark card — used for contexts that are always dark (active workout) -->
    <Style x:Key="DarkCardFrame" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource ForgeSurface}" />
        <Setter Property="StrokeShape" Value="RoundRectangle 16" />
        <Setter Property="Stroke" Value="{StaticResource ForgeBorder}" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="Padding" Value="0" />
    </Style>

    <!-- Elevated card with orange border glow -->
    <Style x:Key="AccentCard" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource LightSurface}, Dark={StaticResource ForgeSurface}}" />
        <Setter Property="StrokeShape" Value="RoundRectangle 16" />
        <Setter Property="Stroke" Value="{StaticResource ForgeAccent}" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Shadow">
            <Setter.Value>
                <Shadow Brush="#FF5A1F" Offset="0,4" Radius="20" Opacity="0.15" />
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="InputField" TargetType="Entry">
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource LightSurface2}, Dark={StaticResource ForgeSurface2}}" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource LightText}, Dark={StaticResource ForgeText}}" />
        <Setter Property="PlaceholderColor" Value="{AppThemeBinding Light={StaticResource LightMuted}, Dark={StaticResource ForgeMuted}}" />
        <Setter Property="FontFamily" Value="DMSansRegular" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="MinimumHeightRequest" Value="44" />
    </Style>

    <Style TargetType="ActivityIndicator">
        <Setter Property="Color" Value="{StaticResource ForgeAccent}" />
    </Style>

    <Style TargetType="ProgressBar">
        <Setter Property="ProgressColor" Value="{StaticResource ForgeAccent}" />
    </Style>

    <Style TargetType="Switch">
        <Setter Property="OnColor" Value="{StaticResource ForgeAccent}" />
        <Setter Property="ThumbColor" Value="White" />
    </Style>

    <Style TargetType="SearchBar">
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource LightText}, Dark={StaticResource ForgeText}}" />
        <Setter Property="PlaceholderColor" Value="{AppThemeBinding Light={StaticResource LightMuted}, Dark={StaticResource ForgeMuted}}" />
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource LightSurface2}, Dark={StaticResource ForgeSurface}}" />
        <Setter Property="FontFamily" Value="DMSansRegular" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="CancelButtonColor" Value="{StaticResource ForgeAccent}" />
    </Style>

    <Style TargetType="RefreshView">
        <Setter Property="RefreshColor" Value="{StaticResource ForgeAccent}" />
    </Style>

</ResourceDictionary>
